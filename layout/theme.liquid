<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#ffffff">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {{ content_for_header }}

  {%- comment -%}
    ── STYLESHEETS ─────────────────────────────────────────────────────────────
    Loaded in dependency order. Each file is co-located with its subsystem.

    critical.css              Resets, .page-width, .visually-hidden, :focus-visible.
                              Preloaded to eliminate layout shift on first paint.

    theme.css                 Site chrome, compare bar, shared utilities.

    header.css                Header layout: rows, logo, account, cart, nav.

    header-account.css        Account trigger link. Scoped to .header__account.

    header-search.css         Search shell styles: form, input, submit button.
                              Owned by the header-search subsystem.

    predictive-search.css     Results panel styles: list, cards, footer, empty state.
                              Owned by the predictive-search subsystem.
                              Loaded here (not inside header-search.liquid) so all
                              asset loading is declared in one place.

    quickview-modal.css       Modal shell. Separate so it is styled from first paint
                              even though it is injected into <body> at runtime.

    cart-drawer.css           Cart drawer shell and content. Same reasoning as above.

    product-card.css is NOT loaded here — loaded by sections that use cards.
  {%- endcomment -%}

  <link rel="preload" href="{{ 'critical.css' | asset_url }}" as="style">
  {{ 'critical.css'             | asset_url | stylesheet_tag }}
  {{ 'theme.css'                | asset_url | stylesheet_tag }}
  {{ 'header.css'               | asset_url | stylesheet_tag }}
  {{ 'header-cart.css'          | asset_url | stylesheet_tag }}
  {{ 'header-account.css'       | asset_url | stylesheet_tag }}
  {{ 'header-search.css'        | asset_url | stylesheet_tag }}
  {{ 'predictive-search.css'    | asset_url | stylesheet_tag }}
  {{ 'quickview-modal.css'      | asset_url | stylesheet_tag }}
  {{ 'cart-drawer.css'          | asset_url | stylesheet_tag }}
  {{ 'cart-page.css' | asset_url | stylesheet_tag }}
  {%- comment -%}
    ── SCRIPTS ─────────────────────────────────────────────────────────────────
    All deferred. Each file is co-located with its subsystem.
    Do NOT re-load any of these inside a section or snippet.

    product-card.js           ATC, Wishlist, Compare, Quick View.
    cart-drawer.js            Cart drawer; listens for cart:open and cart:updated.
    header.js                 Mobile menu toggle, sticky behaviour, cart count badge sync.
    header-account.js         Account trigger → drawer open/close. Loaded after
                              header.js so the header DOM is fully initialised.
    header-search.js          Search shell: typewriter placeholder animation.
    predictive-search.js      Debounced fetch, results injection, panel open/close.
                              Loaded after header-search.js — both share the
                              data-search-* contract but neither calls the other.
  {%- endcomment -%}
  <script src="{{ 'cart-page.js' | asset_url }}" defer></script>
  <script src="{{ 'product-card.js'         | asset_url }}" defer></script>
  <script src="{{ 'cart-drawer.js'          | asset_url }}" defer></script>
  <script src="{{ 'header.js'               | asset_url }}" defer></script>
  <script src="{{ 'header-account.js'       | asset_url }}" defer></script>
  <script src="{{ 'header-cart.js' | asset_url }}" defer></script>
  <script src="{{ 'header-search.js'        | asset_url }}" defer></script>
  <script src="{{ 'predictive-search.js'    | asset_url }}" defer></script>

</head>

<body class="template-{{ template.name }}{% if template.suffix != blank %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  {%- comment -%} ── HEADER ── {%- endcomment -%}
  {% section 'header' %}

  {%- comment -%} ── MAIN CONTENT ── {%- endcomment -%}
  <main id="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% render 'compare-bar' %}

  {%- comment -%} ── FOOTER ── {%- endcomment -%}
  <footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
      <p class="site-footer__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        {{ powered_by_link }}
      </p>
    </div>
  </footer>

</body>
</html>