<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#ffffff">

  <title>
    {{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
    {% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {{ content_for_header }}

  {%- comment -%}
    Global stylesheets, in dependency order:
      1. critical.css        — resets, .page-width, .visually-hidden, :focus-visible.
                               Preloaded to prevent layout shift on first paint.
      2. theme.css           — site chrome + Compare bar + shared utilities.
      3. header.css          — three-row header (top bar / middle bar / bottom nav),
                               mobile menu, sticky state. Kept separate from theme.css
                               so header styles are co-located with header.liquid and
                               header.js.
      4. quickview-modal.css — modal shell. Separate so it's styled from first paint
                               even though it's injected into <body> at runtime.
      5. cart-drawer.css     — cart drawer shell + content. Same reasoning as above.
    product-card.css is NOT loaded here — loaded by sections that use cards.
  {%- endcomment -%}
  <link rel="preload" href="{{ 'critical.css' | asset_url }}" as="style">
  {{ 'critical.css'        | asset_url | stylesheet_tag }}
  {{ 'theme.css'           | asset_url | stylesheet_tag }}
  {{ 'header.css'          | asset_url | stylesheet_tag }}
  {{ 'quickview-modal.css' | asset_url | stylesheet_tag }}
  {{ 'cart-drawer.css'     | asset_url | stylesheet_tag }}

  {%- comment -%}
    Global JS.
    product-card.js — owns ATC, Wishlist, Compare, Quick View.
    cart-drawer.js  — owns the cart drawer; listens for cart:open / cart:updated.
    header.js       — mobile menu toggle, sticky behaviour, cart count badge sync.
    All three loaded once here. Do NOT re-load inside any section or snippet.
  {%- endcomment -%}
  <script src="{{ 'product-card.js' | asset_url }}" defer></script>
  <script src="{{ 'cart-drawer.js'  | asset_url }}" defer></script>
  <script src="{{ 'header.js'       | asset_url }}" defer></script>
</head>

<body class="template-{{ template.name }}{% if template.suffix != blank %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  {%- comment -%} ── HEADER (rendered via section) ── {%- endcomment -%}
  {% section 'header' %}

  {%- comment -%} ── MAIN CONTENT ── {%- endcomment -%}
  <main id="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% render 'compare-bar' %}

  {%- comment -%} ── FOOTER ── {%- endcomment -%}
  <footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
      <p class="site-footer__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        {{ powered_by_link }}
      </p>
    </div>
  </footer>

</body>
</html>