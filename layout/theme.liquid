<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {{ 'base.css'                  | asset_url | stylesheet_tag }}
    {{ 'theme.css'                 | asset_url | stylesheet_tag }}


    {{ 'quick-view.css'            | asset_url | stylesheet_tag }}
    {{ 'cart-drawer.css'           | asset_url | stylesheet_tag }}
    {{ 'cart-recommendations.css'  | asset_url | stylesheet_tag }}
    {{ 'article-card.css'          | asset_url | stylesheet_tag }}
    {{ 'product-card.css'          | asset_url | stylesheet_tag }}
    {{ 'collection-layout.css'     | asset_url | stylesheet_tag }}
    {{ 'header.css'                | asset_url | stylesheet_tag }}
    {{ 'compare-bar.css'           | asset_url | stylesheet_tag }}
    {{ 'section-accordion.css'     | asset_url | stylesheet_tag }}
    {{ 'related-products.css'      | asset_url | stylesheet_tag }}

    {%- comment -%}
      header-search.css and header-search.js are intentionally NOT loaded here.
      They are loaded by sections/main-header.liquid so they are scoped to the
      header section and only included when the section is present on the page.
    {%- endcomment -%}

    {% render 'css-variables' %}

    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% render 'meta-tags' %}

    {% if settings.favicon != blank %}
      <link rel="icon" type="image/png"
            href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {% endif %}

    {{ content_for_header }}
  </head>

  <body class="{{ settings.theme_preset }}" data-header-layout="{{ settings.header_layout }}">

    {% sections 'header-group' %}

    <main role="main">
      <div class="page-width">
        {{ content_for_layout }}
      </div>
    </main>

    <footer role="contentinfo">
      <div class="page-width--footer">
        {% sections 'footer-group' %}
      </div>
    </footer>

    {{- 'base.js'               | asset_url | script_tag }}
    {{- 'theme.js'              | asset_url | script_tag }}
    {{- 'countdown-timer.js'    | asset_url | script_tag }}
    {{- 'copy-to-clipboard.js'  | asset_url | script_tag }}
    {{- 'collection-filters.js' | asset_url | script_tag }}
    {{- 'product-card.js'       | asset_url | script_tag }}

    {% render 'compare-bar' %}
    {% section 'cart-drawer' %}
    {% section 'quick-view' %}

    {%- comment -%}
      Load order: cart-drawer.js MUST precede cart-recommendations.js and
      quick-view.js because both dispatch events that cart-drawer.js listens for.
      header-cart.js is loaded by sections/main-header.liquid with defer and is
      NOT duplicated here — Shopify CDN would deduplicate same-URL scripts anyway,
      but keeping it out of theme.liquid keeps this file clean.
    {%- endcomment -%}
    <script src="{{ 'cart-drawer.js'          | asset_url }}" defer></script>
    <script src="{{ 'cart-recommendations.js' | asset_url }}" defer></script>
    <script src="{{ 'quick-view.js'           | asset_url }}" defer></script>

  </body>
</html>