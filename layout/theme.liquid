<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head> 
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ 'compare-bar.css' | asset_url | stylesheet_tag }}
    {{ 'quickview-modal.css' | asset_url | stylesheet_tag }}
    {{ 'section-accordion.css' | asset_url | stylesheet_tag }}
    {{ 'cart-drawer.css' | asset_url | stylesheet_tag }}
    {{ 'related-products.css' | asset_url | stylesheet_tag }}
    {{ 'header-mega-menu.css' | asset_url | stylesheet_tag }}
    {{ 'ecombio-search.css' | asset_url | stylesheet_tag }}
    {{ 'flyout-panel.css' | asset_url | stylesheet_tag }}
    {{ 'flyout-menu.css'  | asset_url | stylesheet_tag }}
    {{ 'flyout.css'       | asset_url | stylesheet_tag }}
    {% render 'css-variables' %}

    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
{% render 'meta-tags' %}

{% if settings.favicon != blank %}
  <link
    rel="icon"
    type="image/png"
    href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
  >
{% endif %}

{{ content_for_header }}
  </head>

  <body class="{{ settings.theme_preset }}" data-header-layout="{{ settings.header_layout }}">

    <div class="ecombio-sticky-header">
      <div class="page-width--header">
        {% section 'announcement-bar' %}
        {% section 'header' %}
      </div>
    </div>

    <main role="main">
      <div class="page-width">
        {{ content_for_layout }}
      </div>
    </main>

    <footer role="contentinfo">
      <div class="page-width--footer">
        {% sections 'footer-group' %}
      </div>
    </footer>

    {{ 'header.css' | asset_url | stylesheet_tag }}
    {{ 'base.js' | asset_url | script_tag }}
    {{ 'theme.js' | asset_url | script_tag }}
    {{ 'header.js' | asset_url | script_tag }}
    {{ 'countdown-timer.js' | asset_url | script_tag }}
    {{ 'copy-to-clipboard.js' | asset_url | script_tag }}
    {{ 'ecombio-search.js' | asset_url | script_tag }}
    {{ 'collection-filters.js' | asset_url | script_tag }}

    <style>
      /* ── Page Width Constraints ── */
      .page-width--header {
        max-width: var(--header-width);
        margin: 0 auto;
        padding: 0 var(--header-margin);
      }

      .page-width {
        max-width: var(--page-width);
        margin: 0 auto;
        padding: 0 var(--page-margin);
      }

      .page-width--footer {
        max-width: var(--footer-width);
        margin: 0 auto;
        padding: 0 var(--footer-margin);
      }

      /* Full-bleed escape hatch for hero banners etc. */
      .page-width--full {
        max-width: 100%;
        padding: 0;
      }

      /* ── Sticky Header Wrapper ── */
      .ecombio-sticky-header {
        position: sticky;
        top: 0;
        z-index: 200;
        background-color: var(--color-background);
      }

      /* ── Sticky Footer ── */
      html, body {
        height: 100%;
      }

      body {
        display: flex !important;
        flex-direction: column !important;
        min-height: 100vh !important;
      }

      main {
        flex: 1 0 auto !important;
      }
    </style>

    <script>
      window.Shopify = window.Shopify || {};
      window.Shopify.routes = window.Shopify.routes || {};
      window.Shopify.routes.root = '{{ routes.root_url }}';
    </script>
    
    {{ 'product-card.js' | asset_url | script_tag }}
    {{ 'card-product-features.js' | asset_url | script_tag }}
    {% render 'compare-bar' %}
    {% render 'cart-drawer' %}
    {{ 'cart-drawer.js' | asset_url | script_tag }}
    {{ 'theme.js' | asset_url | script_tag }}
  </body>
</html>