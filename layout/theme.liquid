<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#ffffff">

  <title>
    {{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
    {% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- comment -%} Canonical & hreflang {%- endcomment -%}
  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} Shopify-required head content (analytics, consent, etc.) {%- endcomment -%}
  {{ content_for_header }}

  {%- comment -%}
    Global stylesheets, in dependency order:
      1. critical.css      — resets, .page-width, .visually-hidden,
                              :focus-visible. Preloaded since it's
                              needed to prevent layout shift on first
                              paint, and main-product.liquid depends
                              on these classes without redeclaring them.
      2. theme.css          — site chrome (header/nav/footer) + the
                              Compare bar (rendered globally at runtime
                              by product-card.js) + shared utilities.
      3. quickview-modal.css — modal shell only. Kept separate (not
                              folded into theme.css) so the modal is
                              styled from first paint even though it's
                              injected into <body> at runtime — the
                              section content CSS (product-quickview.css)
                              still only loads on demand.
    product-card.css is NOT loaded here — it's loaded by individual
    sections that use cards (e.g. product-carousel.liquid) to keep it
    scoped to pages that need it.
  {%- endcomment -%}
  <link rel="preload" href="{{ 'critical.css' | asset_url }}" as="style">
  {{ 'critical.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ 'quickview-modal.css' | asset_url | stylesheet_tag }}

  {%- comment -%}
    Global JS — product-card.js owns ATC, Wishlist, Compare, Quick View.
    Loaded here once; do NOT re-load it inside any section or snippet.
    Loading it again double-registers all click handlers.
  {%- endcomment -%}
  <script src="{{ 'product-card.js' | asset_url }}" defer></script>
</head>

<body class="template-{{ template.name }}{% if template.suffix != blank %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  {%- comment -%}── HEADER ──{%- endcomment -%}
  <header class="site-header" role="banner">
    <div class="site-header__inner">
      <a class="site-header__logo" href="{{ routes.root_url }}">
        {%- if settings.logo != blank -%}
          {{
            settings.logo
            | image_url: width: 200
            | image_tag:
              class: 'site-header__logo-img',
              alt: shop.name,
              widths: '100, 150, 200',
              sizes: '150px'
          }}
        {%- else -%}
          <span class="site-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <nav class="site-header__nav" aria-label="Main navigation">
        {%- for link in linklists.main-menu.links -%}
          <a
            class="site-header__nav-link{% if link.active %} is-active{% endif %}"
            href="{{ link.url }}"
            {% if link.active %}aria-current="page"{% endif %}
          >
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>

      <div class="site-header__icons">
        <a href="{{ routes.account_url }}" class="site-header__icon-btn" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 17c0-3.314 3.134-6 7-6s7 2.686 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
        <a href="{{ routes.cart_url }}" class="site-header__icon-btn" aria-label="Cart ({{ cart.item_count }})">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M2 2h2l2.5 10h9l2-7H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="8.5" cy="15.5" r="1" fill="currentColor"/>
            <circle cx="15.5" cy="15.5" r="1" fill="currentColor"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="site-header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>
    </div>
  </header>

  {%- comment -%}── MAIN CONTENT ──{%- endcomment -%}
  <main id="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>
{% render 'compare-bar' %}
  {%- comment -%}── FOOTER ──{%- endcomment -%}
  <footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
      <p class="site-footer__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        {{ powered_by_link }}
      </p>
    </div>
  </footer>

</body>
</html>
