[
  {
  "name": "Predictive Search",
  "settings": [
    {
      "type": "header",
      "content": "Behaviour"
    },
    {
      "type": "range",
      "id": "search_debounce_ms",
      "label": "Debounce delay (ms)",
      "info": "How long to wait after the user stops typing before firing the search. Lower = faster but more API calls.",
      "min": 100,
      "max": 600,
      "step": 50,
      "default": 200,
      "unit": "ms"
    },
    {
      "type": "range",
      "id": "search_min_chars",
      "label": "Minimum characters to trigger search",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Result Limits"
    },
    {
      "type": "range",
      "id": "search_max_products",
      "label": "Max product results",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "search_max_collections",
      "label": "Max collection results",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "search_max_queries",
      "label": "Max query suggestions",
      "min": 0,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Recent Searches"
    },
    {
      "type": "range",
      "id": "search_recent_limit",
      "label": "Recent searches to remember",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "header",
      "content": "Trending Searches"
    },
    {
      "type": "text",
      "id": "search_trending_1",
      "label": "Trending search 1",
      "default": "sofa"
    },
    {
      "type": "text",
      "id": "search_trending_2",
      "label": "Trending search 2",
      "default": "dining table"
    },
    {
      "type": "text",
      "id": "search_trending_3",
      "label": "Trending search 3",
      "default": "accent chair"
    },
    {
      "type": "text",
      "id": "search_trending_4",
      "label": "Trending search 4",
      "default": "floor lamp"
    },
    {
      "type": "text",
      "id": "search_trending_5",
      "label": "Trending search 5",
      "default": "bookshelf"
    },
    {
      "type": "header",
      "content": "Search Input"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Input placeholder text",
      "default": "What are you looking for?"
    },
    {
      "type": "header",
      "content": "Category Filter"
    },
    {
      "type": "checkbox",
      "id": "search_show_category",
      "label": "Show category filter pill",
      "default": true
    },
    {
      "type": "text",
      "id": "search_category_1_label",
      "label": "Category 1 label",
      "default": "Furniture"
    },
    {
      "type": "text",
      "id": "search_category_1_value",
      "label": "Category 1 tag (must match product tag in Shopify)",
      "default": "furniture"
    },
    {
      "type": "text",
      "id": "search_category_2_label",
      "label": "Category 2 label",
      "default": "Lighting"
    },
    {
      "type": "text",
      "id": "search_category_2_value",
      "label": "Category 2 tag",
      "default": "lighting"
    },
    {
      "type": "text",
      "id": "search_category_3_label",
      "label": "Category 3 label",
      "default": "Storage"
    },
    {
      "type": "text",
      "id": "search_category_3_value",
      "label": "Category 3 tag",
      "default": "storage"
    },
    {
      "type": "text",
      "id": "search_category_4_label",
      "label": "Category 4 label",
      "default": "Décor"
    },
    {
      "type": "text",
      "id": "search_category_4_value",
      "label": "Category 4 tag",
      "default": "decor"
    },
    {
      "type": "text",
      "id": "search_category_5_label",
      "label": "Category 5 label",
      "default": "Outdoor"
    },
    {
      "type": "text",
      "id": "search_category_5_value",
      "label": "Category 5 tag",
      "default": "outdoor"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "search_accent_color",
      "label": "Accent colour",
      "info": "Used for the active category pill and focus ring.",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "search_highlight_bg",
      "label": "Match highlight colour",
      "info": "Background of the matched text inside result titles.",
      "default": "#FFF3CD"
    },
    {
      "type": "color",
      "id": "search_hover_bg",
      "label": "Result row hover background",
      "default": "#F5F5F5"
    },
    {
      "type": "color",
      "id": "search_border_focus",
      "label": "Input focus border colour",
      "default": "#1a1a1a"
    }
  ]
},
  {
    "name": "theme_info",
    "theme_name": "ECOMBIO",
    "theme_version": "1.0.0",
    "theme_author": "ECOMBIO",
    "theme_documentation_url": "https://ecombio.com",
    "theme_support_url": "https://ecombio.com/support"
  },

  {
    "name": "t:general.theme_presets",
    "settings": [
      {
        "type": "select",
        "id": "theme_preset",
        "label": "t:labels.theme_style",
        "default": "hyper",
        "options": [
          {
            "value": "hyper",
            "label": "t:options.theme_style.hyper"
          },
          {
            "value": "focus",
            "label": "t:options.theme_style.focus"
          }
        ],
        "info": "Hyper = Marketplace density. Focus = Premium storefront experience."
      }
    ]
  },

  {
    "name": "t:general.density",
    "settings": [
      {
        "type": "header",
        "content": "t:general.density_and_spacing"
      },
      {
        "type": "range",
        "id": "section_spacing_scale",
        "label": "t:labels.section_spacing",
        "min": 0.5,
        "max": 2,
        "step": 0.1,
        "default": 1,
        "unit": "x",
        "info": "Controls vertical spacing between sections. Lower = tighter (Hyper). Higher = more breathing room (Focus)."
      },
      {
        "type": "range",
        "id": "card_padding",
        "label": "t:labels.card_padding",
        "min": 8,
        "max": 40,
        "step": 2,
        "default": 16,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "grid_gap",
        "label": "t:labels.grid_gap",
        "min": 8,
        "max": 40,
        "step": 2,
        "default": 16,
        "unit": "px"
      }
    ]
  },

  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },

  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          { "value": "90rem", "label": "t:options.page_width.narrow" },
          { "value": "110rem", "label": "t:options.page_width.wide" }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },

  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },

  {
    "name": "t:general.header",
    "settings": [
      {
        "type": "header",
        "content": "t:general.header_settings"
      },
      {
        "type": "checkbox",
        "id": "enable_sticky_header",
        "label": "t:labels.sticky_header",
        "default": true
      },
      {
        "type": "select",
        "id": "header_search_style",
        "label": "t:labels.search_style",
        "options": [
          { "value": "icon", "label": "t:options.search.icon_only" },
          { "value": "full", "label": "t:options.search.full_width" }
        ],
        "default": "icon"
      }
    ]
  },

  {
    "name": "t:general.product_cards",
    "settings": [
      {
        "type": "header",
        "content": "t:general.product_cards"
      },
      {
        "type": "select",
        "id": "product_card_style",
        "label": "t:labels.card_style",
        "options": [
          { "value": "minimal", "label": "t:options.card.minimal" },
          { "value": "bordered", "label": "t:options.card.bordered" },
          { "value": "shadow", "label": "t:options.card.shadow" }
        ],
        "default": "bordered"
      },
      {
        "type": "checkbox",
        "id": "show_quick_add",
        "label": "t:labels.show_quick_add",
        "default": true
      }
    ]
  }
]