{{ 'footer-body-nav.css' | asset_url | stylesheet_tag }}

<section class="footer-body-nav-section" {{ section.shopify_attributes }}>
  <div class="footer__body-nav">

    {%- if section.settings.heading != blank -%}
      <h3 class="footer__body-heading">
        {{ section.settings.heading }}
      </h3>
    {%- endif %}

    {% if section.settings.menu != blank %}
      {% render 'footer-mega-menu', 
          menu: linklists[section.settings.menu],
          show_section_titles: section.settings.show_section_titles %}
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Footer Body Nav",
  "class": "shopify-section--footer-body-nav",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Explore"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Mega Menu",
      "info": "Select a nested menu for the mega menu"
    },
    {
      "type": "checkbox",
      "id": "show_section_titles",
      "label": "Show section titles",
      "default": true,
      "info": "Display Level 2 titles inside the mega menu"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Footer Body Nav"
    }
  ]
}
{% endschema %}