{% comment %}
  ╔══════════════════════════════════════════════════════════╗
  ║  sections/product-recently-viewed.liquid                 ║
  ║  Mode: localStorage browser history                      ║
  ║  Cards: snippets/product-card.liquid (via sections API)  ║
  ╚══════════════════════════════════════════════════════════╝
{% endcomment %}

{% render 'pr-card-styles' %}

{%- liquid
  assign cols_d     = section.settings.columns_desktop
  assign cols_m     = section.settings.columns_mobile
  assign gap        = section.settings.card_gap
  assign pad_top    = section.settings.padding_top
  assign pad_bottom = section.settings.padding_bottom
  assign cs         = section.settings.color_scheme
  assign limit      = section.settings.products_to_show
-%}

<section
  class="pr-section cs-{{ cs }}"
  id="pr-rv-section-{{ section.id }}"
  style="
    --pr-cols: {{ cols_d }};
    --pr-cols-mob: {{ cols_m }};
    --pr-gap: {{ gap }}px;
    --pr-pad-top: {{ pad_top }}px;
    --pr-pad-bottom: {{ pad_bottom }}px;
  "
  aria-label="{{ section.settings.heading | escape }}"
  hidden
>
  <div class="pr-inner">
    <div class="pr-header">
      <h2 class="pr-heading">{{ section.settings.heading }}</h2>
    </div>
    <div class="pr-grid" id="pr-rv-grid-{{ section.id }}">
      {% comment %} Filled by JS via sections API {% endcomment %}
    </div>
  </div>
</section>

<script>
(function () {
  const STORAGE_KEY = 'pr_recently_viewed';
  const MAX_STORED  = 20;
  const section     = document.getElementById('pr-rv-section-{{ section.id }}');
  const grid        = document.getElementById('pr-rv-grid-{{ section.id }}');
  const currentId   = {{ product.id | json }};
  const currentHandle = {{ product.handle | json }};
  const limit       = {{ limit | json }};
  const hideIfEmpty = {{ section.settings.hide_if_empty | json }};

  /* ── Storage helpers ── */
  function load() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
    catch (e) { return []; }
  }

  function save(arr) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(arr)); }
    catch (e) {}
  }

  /* ── Track current product visit ── */
  (function track() {
    const list = load().filter(item => item.id !== currentId);
    list.unshift({ id: currentId, handle: currentHandle });
    save(list.slice(0, MAX_STORED));
  })();

  /* ── Build history list (exclude current product) ── */
  const history = load()
    .filter(item => item.id !== currentId)
    .slice(0, limit);

  if (history.length === 0) {
    if (!hideIfEmpty) {
      section.removeAttribute('hidden');
      grid.innerHTML = '<p class="pr-empty">No recently viewed products yet.</p>';
    }
    return;
  }

  /*
   * Fetch each product card HTML via the Shopify sections API.
   * /products/{handle}?sections=product-card-single returns a rendered
   * snippets/product-card.liquid wrapped in sections/product-card-single.liquid
   * so the markup + CSS classes are identical to every other product-card
   * on the page.
   */
  Promise.all(
    history.map(item =>
      fetch(`/products/${item.handle}?sections=product-card-single`, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      })
        .then(r => r.ok ? r.json() : null)
        .catch(() => null)
    )
  ).then(results => {
    const cards = results
      .filter(Boolean)
      .map(data => data['product-card-single'])
      .filter(Boolean);

    if (cards.length === 0) {
      if (!hideIfEmpty) {
        section.removeAttribute('hidden');
        grid.innerHTML = '<p class="pr-empty">No recently viewed products yet.</p>';
      }
      return;
    }

    grid.innerHTML = cards.join('');
    section.removeAttribute('hidden');

    /*
     * Re-sync wishlist buttons that were just injected into the DOM.
     * product-card.js exposes syncWishlistButtons via a custom event
     * if available; otherwise dispatch a lightweight signal.
     */
    document.dispatchEvent(new CustomEvent('productcard:injected', { bubbles: true }));
  });
})();
</script>

{% schema %}
{
  "name": "Recently Viewed",
  "tag": "section",
  "class": "section-pr-recently-viewed",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently Viewed"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "label": "Max products to show"
    },
    {
      "type": "checkbox",
      "id": "hide_if_empty",
      "label": "Hide section if no history",
      "default": true,
      "info": "Recommended — avoids showing an empty section to first-time visitors."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Columns (desktop)"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2,
      "label": "Columns (mobile)"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 16,
      "label": "Card gap (px)"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color Scheme",
      "options": [
        { "value": "light",  "label": "Light" },
        { "value": "gray",   "label": "Light Gray" },
        { "value": "dark",   "label": "Dark" },
        { "value": "accent", "label": "Accent" }
      ],
      "default": "light"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 52,
      "label": "Padding top (px)"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 52,
      "label": "Padding bottom (px)"
    }
  ],
  "presets": [
    {
      "name": "Recently Viewed",
      "settings": {
        "heading": "Recently Viewed",
        "products_to_show": 4,
        "hide_if_empty": true
      }
    }
  ]
}
{% endschema %}
