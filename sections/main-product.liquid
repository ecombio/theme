{% comment %}
  ============================================================
  sections/main-product.liquid
  Full product detail page (PDP) — orchestrator.

  Template entry-point: templates/product.liquid
    {% section 'main-product' %}

  Composition:
    snippets/product-media.liquid   ← left column  (gallery)
    snippets/product-detail.liquid  ← right column (info, form, accordions)

  Assets (split by column — see assets/ for each file's own header):
    assets/product-media.css   ← gallery, viewer, thumbs, zoom
    assets/product-detail.css  ← info panel, price, form, swatches, badges, accordions
    assets/product-media.js    ← thumbnail switching, switchMedia()
    assets/product-detail.js   ← variant resolution, ATC, qty stepper, wishlist, copy link
  Load order matters: product-media.js must load before
  product-detail.js, since product-detail.js calls
  window.mpMedia.switchMedia() on variant change.

  Design system alignment:
    • Tokens match product-card.css + theme.liquid
      (#111827 text · #E5E7EB borders · #4F46E5 accent)
    • ATC uses data-atc-btn / data-atc-label hooks from
      product-card.js (already loaded globally via theme.liquid)
    • Fires cart:updated + cart:open after successful add —
      same as product-card.js — so any cart drawer / bubble
      integration works identically on the PDP.
    • CSS scoped to .mp — stable, since main-product renders
      once per page. (No more per-instance .mp--{section.id}
      scoping — that only worked while CSS/JS were inline; the
      asset files are static and can't read Liquid variables.)
    • .page-width, .visually-hidden, :focus-visible come from
      critical.css and are NOT redeclared here.

  What is NOT here:
    • No reference to product-quickview.liquid or the QV modal.
    • No {% section 'product-quickview' %}.
    • product-card.js is NOT re-loaded (already global).
  ============================================================
{% endcomment %}

{%- liquid
  assign current_variant  = product.selected_or_first_available_variant
  assign product_form_id  = 'mp-form-' | append: section.id
  assign show_vendor      = section.settings.show_vendor
  assign show_rating      = section.settings.show_rating
  assign show_badges      = section.settings.show_trust_badges
  assign sticky_panel     = section.settings.enable_sticky_panel
  assign show_share       = section.settings.show_share_buttons
  assign show_eta         = section.settings.show_eta
  assign show_quantity    = section.settings.show_quantity

  assign eta_text         = product.metafields.custom.eta_text
  assign rating_value     = product.metafields.reviews.rating.value
  assign rating_count     = product.metafields.reviews.rating_count.value

  assign badge_blocks     = section.blocks | where: 'type', 'trust_badge'
  assign accordion_blocks = section.blocks | where: 'type', 'accordion'
-%}

<div class="mp mp--{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="main-product">
  <div class="mp__inner page-width">

    {%- comment -%}── Breadcrumb ──{%- endcomment -%}
    {%- if section.settings.show_breadcrumb -%}
      <nav class="mp__breadcrumb" aria-label="Breadcrumb">
        <ol class="mp__breadcrumb-list">
          <li><a href="{{ routes.root_url }}">Home</a></li>
          {%- if collection -%}
            <li aria-hidden="true" class="mp__breadcrumb-sep">›</li>
            <li><a href="{{ collection.url }}">{{ collection.title }}</a></li>
          {%- endif -%}
          <li aria-hidden="true" class="mp__breadcrumb-sep">›</li>
          <li aria-current="page">{{ product.title }}</li>
        </ol>
      </nav>
    {%- endif -%}

    <div class="mp__layout">

      {%- comment -%}── Left column: media gallery ──{%- endcomment -%}
      {%- render 'product-media',
        product:    product,
        section_id: section.id
      -%}

      {%- comment -%}── Right column: product info + form ──{%- endcomment -%}
      {%- render 'product-detail',
        product:          product,
        section_id:       section.id,
        current_variant:  current_variant,
        product_form_id:  product_form_id,
        sticky_panel:     sticky_panel,
        show_vendor:      show_vendor,
        show_rating:      show_rating,
        show_eta:         show_eta,
        show_badges:      show_badges,
        show_share:       show_share,
        show_quantity:    show_quantity,
        eta_text:         eta_text,
        rating_value:     rating_value,
        rating_count:     rating_count,
        badge_blocks:     badge_blocks,
        accordion_blocks: accordion_blocks
      -%}

    </div>
    {%- comment -%}/mp__layout{%- endcomment -%}
  </div>
  {%- comment -%}/mp__inner{%- endcomment -%}
</div>
{%- comment -%}/mp{%- endcomment -%}

{%- comment -%}── Variant JSON for JS ──{%- endcomment -%}
<script type="application/json" id="mp-variants-{{ section.id }}" data-mp-variants>
  {
    "variants": [
      {%- for v in product.variants -%}
        {
          "id":                {{ v.id }},
          "title":             {{ v.title | json }},
          "available":         {{ v.available }},
          "price":             {{ v.price }},
          "compare_at_price":  {{ v.compare_at_price | default: 'null' }},
          "option1":           {{ v.option1 | json }},
          "option2":           {{ v.option2 | json }},
          "option3":           {{ v.option3 | json }},
          "featured_media_id": {{ v.featured_media.id | default: 'null' }},
          "options":           {{ v.options | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    "options": {{ product.options | json }}
  }
</script>

{% comment %}
  ╔══════════════════════════════════════════════════════════╗
  ║  STYLES                                                  ║
  ╚══════════════════════════════════════════════════════════╝
{% endcomment %}
<style>
/* ─────────────────────────────────────────────
   Scope guard: all rules live under .mp
   No :root declarations — tokens are local.
   (Stable .mp scope — main-product renders once
   per page. Column-specific styles for the gallery
   and info panel live in their own asset files:
   assets/product-media.css / assets/product-detail.css)
───────────────────────────────────────────── */
.mp {
  /* Design tokens — aligned with product-card.css & theme.liquid */
  --mp-text:          #111827;
  --mp-text-muted:    #6B7280;
  --mp-border:        #E5E7EB;
  --mp-surface:       #F9FAFB;
  --mp-accent:        #4F46E5;
  --mp-accent-hover:  #4338CA;
  --mp-sale:          #DC2626;
  --mp-save:          #D97706;
  --mp-gold:          #C8991A;  /* matches QV + wishlist icon fill */
  --mp-radius:        8px;
  --mp-radius-sm:     4px;
  --mp-gap:           2rem;
  --mp-trans:         0.18s ease;
  --mp-font:          -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
}

/* ── Breadcrumb ── */
.mp .mp__breadcrumb {
  padding: 1rem 0 0.5rem;
}
.mp .mp__breadcrumb-list {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.25rem;
  list-style: none;
  margin: 0;
  padding: 0;
  font-size: 0.78rem;
  color: var(--mp-text-muted);
}
.mp .mp__breadcrumb-list a {
  color: var(--mp-text-muted);
  text-decoration: none;
  transition: color var(--mp-trans);
}
.mp .mp__breadcrumb-list a:hover { color: var(--mp-text); }
.mp .mp__breadcrumb-sep { margin-inline: 0.15rem; user-select: none; }

/* ── Main two-column grid ── */
.mp .mp__inner {
  padding-block: 1.5rem 3rem;
}
.mp .mp__layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--mp-gap);
  align-items: start;
}

/* ════════════════════════════
   TABLET  ≥ 768px
════════════════════════════ */
@media (min-width: 768px) {
  .mp .mp__layout {
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }
}

/* ════════════════════════════
   DESKTOP  ≥ 1024px
════════════════════════════ */
@media (min-width: 1024px) {
  .mp .mp__layout {
    grid-template-columns: 55fr 45fr;
    gap: 3.5rem;
  }
}

/* ════════════════════════════
   REDUCED MOTION
════════════════════════════ */
@media (prefers-reduced-motion: reduce) {
  .mp *,
  .mp *::before,
  .mp *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
</style>

