{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "main-product-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_panel",
      "label": "Sticky info panel on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show star rating",
      "info": "Requires reviews.rating metafield or Judge.me / Yotpo app.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_eta",
      "label": "Show estimated delivery",
      "info": "Reads custom.eta_text product metafield.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "label": "Show share buttons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or inline SVG)",
          "default": "🚚"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Free shipping over $75"
        }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Details"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product",
      "blocks": [
        {
          "type": "trust_badge",
          "settings": { "icon": "🚚", "label": "Free shipping over $75" }
        },
        {
          "type": "trust_badge",
          "settings": { "icon": "↩", "label": "30-day returns" }
        },
        {
          "type": "trust_badge",
          "settings": { "icon": "🔒", "label": "Secure checkout" }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Shipping & returns",
            "open_by_default": false
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Size guide",
            "open_by_default": false
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Materials & care",
            "open_by_default": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
