{{- 'article-card.css' | asset_url | stylesheet_tag -}}
{{- 'featured-article.css' | asset_url | stylesheet_tag -}}

{%- comment -%}
  sections/featured-article.liquid
  ─────────────────────────────────
  Displays featured articles from the collection metafield:
  custom.featured_articles (List of blog posts)
  Assign articles per collection via:
  Shopify Admin → Catalog → Collections → [collection] → Metafields → Featured Articles
{%- endcomment -%}

{%- assign featured_articles = collection.metafields.custom.featured_articles.value -%}

{%- if featured_articles != blank and featured_articles.size > 0 -%}

  <section class="featured-article" id="featured-article-{{ section.id }}">
    <div class="featured-article__inner">

      {%- comment -%} ── Section header: heading + prev/next controls + view all ── {%- endcomment -%}
      <div class="featured-article__header">
        <div class="featured-article__header-left">
          {%- if section.settings.heading != blank -%}
            <h2 class="featured-article__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
        <div class="featured-article__header-right">
          {%- if section.settings.show_view_all and section.settings.blog != blank -%}
            <a href="{{ section.settings.blog.url }}" class="featured-article__view-all">
              View all &rarr;
            </a>
          {%- endif -%}
          <div class="featured-article__controls">
            <button class="featured-article__btn featured-article__btn--prev" aria-label="Previous article">&#8592;</button>
            <button class="featured-article__btn featured-article__btn--next" aria-label="Next article">&#8594;</button>
          </div>
        </div>
      </div>

      {%- comment -%} ── Carousel track ── {%- endcomment -%}
      <div class="featured-article__track-wrapper">
        <ul class="featured-article__track" role="list">
          {%- for article in featured_articles -%}
            <li class="featured-article__slide">
              {%- render 'article-card', article: article -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} ── Dot indicators ── {%- endcomment -%}
      {%- if featured_articles.size > 1 -%}
        <div class="featured-article__dots" role="tablist" aria-label="Article slides">
          {%- for article in featured_articles -%}
            <button
              class="featured-article__dot{% if forloop.first %} featured-article__dot--active{% endif %}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="Go to slide {{ forloop.index }}"
            ></button>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </section>

{%- elsif request.design_mode -%}

  {%- comment -%} ── Editor-only empty state ── {%- endcomment -%}
  <section class="featured-article" id="featured-article-{{ section.id }}">
    <div class="featured-article__inner">
      <p class="featured-article__empty">
        No featured articles found. Assign articles to this collection via
        Admin &rarr; Catalog &rarr; Collections &rarr; [collection] &rarr; Metafields &rarr; Featured Articles.
      </p>
    </div>
  </section>

{%- endif -%}

<style>
  #featured-article-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

<script>
  (function () {
    const section = document.getElementById('featured-article-{{ section.id }}');
    if (!section) return;

    const track   = section.querySelector('.featured-article__track');
    const slides  = section.querySelectorAll('.featured-article__slide');
    const dots    = section.querySelectorAll('.featured-article__dot');
    const prevBtn = section.querySelector('.featured-article__btn--prev');
    const nextBtn = section.querySelector('.featured-article__btn--next');

    if (!track || slides.length < 2) return;

    let current = 0;

    function getSlidesPerView() {
      const w = window.innerWidth;
      if (w <= 768)  return 1;
      if (w <= 1024) return 2;
      return 3;
    }

    function getMaxIndex() {
      return Math.max(0, slides.length - getSlidesPerView());
    }

    function updateButtons() {
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current >= getMaxIndex();
    }

    function goTo(index) {
      const max = getMaxIndex();
      current = Math.max(0, Math.min(index, max));

      const slideWidth = slides[0].offsetWidth + 20; // 20px = gap
      track.style.transform = `translateX(-${current * slideWidth}px)`;

      dots.forEach((dot, i) => {
        const active = i === current;
        dot.classList.toggle('featured-article__dot--active', active);
        dot.setAttribute('aria-selected', String(active));
      });

      updateButtons();
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => goTo(current), 150);
    });

    goTo(0);
  })();
</script>

{% schema %}
{
  "name": "Featured Articles",
  "tag": "section",
  "class": "section-featured-article",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Articles"
    },
    {
      "type": "header",
      "content": "Footer"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show \"View all\" button",
      "default": true
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "\"View all\" blog link",
      "info": "Select the blog the View all button should link to"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Featured Articles"
    }
  ]
}
{% endschema %}