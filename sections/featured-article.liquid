{{- 'article-card.css' | asset_url | stylesheet_tag -}}

{%- comment -%}
  sections/featured-article.liquid
  ─────────────────────────────────
  Displays the latest articles from a merchant-selected blog.
  Uses the reusable `article-card` snippet for each article.
  No metafields or custom data — all configuration via the schema below.
{%- endcomment -%}

{%- liquid
  assign blog_source  = section.settings.blog
  assign article_limit = section.settings.article_count
-%}

{%- if blog_source != blank and blog_source.articles_count > 0 -%}

  <section class="featured-article" id="featured-article-{{ section.id }}">
    <div class="featured-article__inner">

      {%- comment -%} ── Section header ── {%- endcomment -%}
      <div class="featured-article__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="featured-article__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- comment -%} "View all" links to the blog index {%- endcomment -%}
        {%- if section.settings.show_view_all -%}
          <a href="{{ blog_source.url }}" class="featured-article__view-all">
            View all &rarr;
          </a>
        {%- endif -%}
      </div>

      {%- comment -%} ── Article grid ── {%- endcomment -%}
      <ul class="featured-article__grid" role="list">
        {%- for article in blog_source.articles limit: article_limit -%}
          <li class="featured-article__item">
            {%- render 'article-card',
              article: article,
              show_excerpt: section.settings.show_excerpt,
              show_author: section.settings.show_author,
              show_date: section.settings.show_date
            -%}
          </li>
        {%- endfor -%}
      </ul>

    </div>
  </section>

{%- elsif request.design_mode -%}

  {%- comment -%} ── Editor-only empty state ── {%- endcomment -%}
  <section class="featured-article">
    <div class="featured-article__inner">
      <p class="featured-article__empty">
        Select a blog in the section settings to display articles here.
      </p>
    </div>
  </section>

{%- endif -%}

<style>
  #featured-article-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

{% schema %}
{
  "name": "Featured Articles",
  "tag": "section",
  "class": "section-featured-article",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Latest Articles"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "article_count",
      "label": "Number of articles",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Card options"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "header",
      "content": "Footer"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show \"View all\" button",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Featured Articles"
    }
  ]
}
{% endschema %}
