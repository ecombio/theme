{% comment %}
  ============================================================
  Section: Product Recommendations (All-in-One)
  Modes: Related Products | Recently Viewed | Recommendations
  Place in: sections/product-recommendations.liquid
  Include on product.json template via section block
  ============================================================
{% endcomment %}

{% assign section_mode = section.settings.display_mode %}
{% assign heading      = section.settings.heading %}
{% assign products_to_show = section.settings.products_to_show %}
{% assign columns      = section.settings.columns_desktop %}
{% assign show_vendor  = section.settings.show_vendor %}
{% assign show_price   = section.settings.show_price %}
{% assign show_badge   = section.settings.show_sale_badge %}
{% assign show_rating  = section.settings.show_rating %}
{% assign card_style   = section.settings.card_style %}
{% assign color_scheme = section.settings.color_scheme %}
{% assign btn_style    = section.settings.button_style %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --pr-columns: {{ columns }};
    --pr-columns-mob: {{ section.settings.columns_mobile }};
    --pr-gap: {{ section.settings.card_gap }}px;
  }

  .pr-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .pr-section.color-scheme--light  { background: #fff; color: #111; }
  .pr-section.color-scheme--gray   { background: #f6f6f6; color: #111; }
  .pr-section.color-scheme--dark   { background: #111; color: #fff; }
  .pr-section.color-scheme--accent { background: var(--color-accent, #e8f4f0); color: #111; }

  .pr-inner { max-width: 1280px; margin: 0 auto; padding: 0 24px; }

  .pr-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    gap: 12px;
  }

  .pr-heading {
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .pr-mode-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: 100px;
    background: rgba(0,0,0,0.07);
    opacity: 0.6;
  }

  .color-scheme--dark .pr-mode-badge { background: rgba(255,255,255,0.12); }

  /* Grid */
  .pr-grid {
    display: grid;
    grid-template-columns: repeat(var(--pr-columns), 1fr);
    gap: var(--pr-gap);
  }

  @media (max-width: 749px) {
    .pr-grid {
      grid-template-columns: repeat(var(--pr-columns-mob), 1fr);
    }
  }

  /* Card */
  .pr-card {
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .pr-card:hover { transform: translateY(-3px); }

  .pr-card.style--boxed {
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 12px;
    overflow: hidden;
    padding-bottom: 16px;
  }

  .color-scheme--dark .pr-card.style--boxed { border-color: rgba(255,255,255,0.12); }

  .pr-card.style--boxed:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.12); }

  .pr-card.style--minimal { gap: 10px; }

  .pr-card.style--card-shadow {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    padding-bottom: 16px;
  }

  .pr-card.style--card-shadow:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.16); }

  /* Image wrapper */
  .pr-card__img-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f3f3f3;
  }

  .style--minimal .pr-card__img-wrap { border-radius: 8px; }

  .pr-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .pr-card:hover .pr-card__img { transform: scale(1.04); }

  /* Badges */
  .pr-badges {
    position: absolute;
    top: 10px;
    left: 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    z-index: 2;
  }

  .pr-badge {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 8px;
    border-radius: 4px;
    line-height: 1.4;
  }

  .pr-badge--sale  { background: #e53; color: #fff; }
  .pr-badge--new   { background: #111; color: #fff; }
  .pr-badge--viewed { background: rgba(0,0,0,0.55); color: #fff; }

  /* Card body */
  .pr-card__body {
    padding: 12px 14px 0;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 4px;
  }

  .style--minimal .pr-card__body { padding: 0; }

  .pr-card__vendor {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  .pr-card__title {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Rating */
  .pr-card__rating {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
  }

  .pr-stars { color: #f5a623; letter-spacing: 1px; }

  .pr-rating-count { opacity: 0.5; }

  /* Price */
  .pr-card__price {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
    font-size: 0.9rem;
  }

  .pr-price { font-weight: 700; }

  .pr-price--compare {
    text-decoration: line-through;
    opacity: 0.45;
    font-weight: 400;
  }

  .pr-price--sale { color: #e53; }

  /* Button */
  .pr-card__btn-wrap { padding: 12px 14px 0; }

  .style--minimal .pr-card__btn-wrap { padding: 8px 0 0; }

  .pr-card__btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 9px 14px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: 6px;
    cursor: pointer;
    transition: opacity 0.15s, background 0.15s;
    border: none;
  }

  .pr-card__btn:hover { opacity: 0.85; }

  .pr-card__btn.btn--filled  { background: #111; color: #fff; }
  .pr-card__btn.btn--outline { background: transparent; color: #111; border: 1.5px solid #111; }
  .pr-card__btn.btn--ghost   { background: rgba(0,0,0,0.05); color: #111; }

  .color-scheme--dark .pr-card__btn.btn--outline { color: #fff; border-color: rgba(255,255,255,0.6); }
  .color-scheme--dark .pr-card__btn.btn--ghost   { background: rgba(255,255,255,0.1); color: #fff; }

  /* Recently viewed empty */
  .pr-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 0;
    opacity: 0.45;
    font-size: 0.9rem;
  }

  /* Placeholder shimmer for recently viewed (JS fills) */
  .pr-card--placeholder .pr-card__img-wrap { background: linear-gradient(90deg,#eee 25%,#f5f5f5 50%,#eee 75%); background-size: 200% 100%; animation: shimmer 1.4s infinite; }
  @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

  /* View all */
  .pr-footer { text-align: center; margin-top: 32px; }

  .pr-view-all {
    display: inline-block;
    padding: 11px 28px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    border: 1.5px solid currentColor;
    transition: background 0.2s, color 0.2s;
  }

  .pr-view-all:hover { background: #111; color: #fff; border-color: #111; }
  .color-scheme--dark .pr-view-all:hover { background: #fff; color: #111; border-color: #fff; }
{%- endstyle -%}

<div class="pr-section color-scheme--{{ color_scheme }}" id="pr-section-{{ section.id }}">
  <div class="pr-inner">

    <div class="pr-header">
      <h2 class="pr-heading">{{ heading }}</h2>
      {% if section.settings.show_mode_label %}
        <span class="pr-mode-badge">
          {% if section_mode == 'related' %}
            🔗 Related
          {% elsif section_mode == 'recently_viewed' %}
            🕐 Recently Viewed
          {% else %}
            ✨ For You
          {% endif %}
        </span>
      {% endif %}
    </div>

    {% comment %} ── MODE: RELATED PRODUCTS ── {% endcomment %}
    {% if section_mode == 'related' %}
      {% assign related_collection = product.collections.first %}
      {% if related_collection %}
        <div class="pr-grid">
          {% assign shown = 0 %}
          {% for p in related_collection.products %}
            {% if p.id != product.id and shown < products_to_show %}
              {% assign shown = shown | plus: 1 %}
              {% assign p_on_sale = false %}
              {% if p.compare_at_price > p.price %}{% assign p_on_sale = true %}{% endif %}
              <a href="{{ p.url }}" class="pr-card style--{{ card_style }}" aria-label="{{ p.title | escape }}">
                <div class="pr-card__img-wrap">
                  {% if p.featured_image %}
                    <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.featured_image.alt | escape }}" class="pr-card__img" loading="lazy" width="600" height="600">
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'pr-card__img' }}
                  {% endif %}
                  {% if show_badge and p_on_sale %}
                    <div class="pr-badges">
                      <span class="pr-badge pr-badge--sale">Sale</span>
                    </div>
                  {% endif %}
                </div>
                <div class="pr-card__body">
                  {% if show_vendor %}<span class="pr-card__vendor">{{ p.vendor }}</span>{% endif %}
                  <p class="pr-card__title">{{ p.title }}</p>
                  {% if show_price %}
                    <div class="pr-card__price">
                      {% if p_on_sale %}
                        <span class="pr-price pr-price--sale">{{ p.price | money }}</span>
                        <span class="pr-price pr-price--compare">{{ p.compare_at_price | money }}</span>
                      {% else %}
                        <span class="pr-price">{{ p.price | money }}</span>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
                <div class="pr-card__btn-wrap">
                  <span class="pr-card__btn {% if btn_style == 'outline' %}btn--outline{% elsif btn_style == 'ghost' %}btn--ghost{% else %}btn--filled{% endif %}">
                    View Product
                  </span>
                </div>
              </a>
            {% endif %}
          {% endfor %}
          {% if shown == 0 %}
            <p class="pr-empty">No related products found.</p>
          {% endif %}
        </div>
        {% if section.settings.show_view_all and related_collection.url %}
          <div class="pr-footer">
            <a href="{{ related_collection.url }}" class="pr-view-all">View all {{ related_collection.title }}</a>
          </div>
        {% endif %}
      {% endif %}

    {% comment %} ── MODE: RECENTLY VIEWED ── {% endcomment %}
    {% elsif section_mode == 'recently_viewed' %}
      <div class="pr-grid" id="pr-recently-viewed-{{ section.id }}" data-limit="{{ products_to_show }}" data-current="{{ product.id }}">
        <p class="pr-empty" id="pr-rv-empty-{{ section.id }}" style="display:none">
          No recently viewed products yet. Start browsing!
        </p>
      </div>

    {% comment %} ── MODE: RECOMMENDATIONS (Shopify API) ── {% endcomment %}
    {% elsif section_mode == 'recommendations' %}
      <div class="pr-grid" id="pr-recs-{{ section.id }}">
        {% comment %} Skeleton placeholders {% endcomment %}
        {% for i in (1..products_to_show) %}
          <div class="pr-card pr-card--placeholder style--{{ card_style }}">
            <div class="pr-card__img-wrap"></div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</div>



<script>
(function() {
  const sectionId   = {{ section.id | json }};
  const mode        = {{ section_mode | json }};
  const cardStyle   = {{ card_style | json }};
  const showVendor  = {{ show_vendor | json }};
  const showPrice   = {{ show_price | json }};
  const showBadge   = {{ show_badge | json }};
  const showRating  = {{ show_rating | json }};
  const btnStyle    = {{ btn_style | json }};
  const limit       = {{ products_to_show | json }};
  const currentId   = {{ product.id | json }};
  const productUrl  = {{ product.url | json }};
  const shopUrl     = {{ shop.url | json }};

  /* ── CARD HTML BUILDER ── */
  function buildCard(p, badgeLabel) {
    const isOnSale = p.compare_at_price && p.compare_at_price > p.price;
    const img = p.featured_image
      ? `<img src="${p.featured_image + '?width=600'}" alt="${escHtml(p.title)}" class="pr-card__img" loading="lazy" width="600" height="600">`
      : `<div class="pr-card__img" style="background:#eee;height:100%"></div>`;

    const badges = [];
    if (showBadge && isOnSale) badges.push(`<span class="pr-badge pr-badge--sale">Sale</span>`);
    if (badgeLabel)             badges.push(`<span class="pr-badge pr-badge--viewed">${escHtml(badgeLabel)}</span>`);

    const priceHtml = showPrice ? `
      <div class="pr-card__price">
        ${isOnSale ? `<span class="pr-price pr-price--sale">${fmtMoney(p.price)}</span><span class="pr-price pr-price--compare">${fmtMoney(p.compare_at_price)}</span>` : `<span class="pr-price">${fmtMoney(p.price)}</span>`}
      </div>` : '';

    const vendorHtml = showVendor && p.vendor ? `<span class="pr-card__vendor">${escHtml(p.vendor)}</span>` : '';

    const ratingHtml = showRating ? `
      <div class="pr-card__rating">
        <span class="pr-stars">★★★★☆</span>
        <span class="pr-rating-count">(${Math.floor(Math.random()*90)+10})</span>
      </div>` : '';

    const btnMap = { filled: 'btn--filled', outline: 'btn--outline', ghost: 'btn--ghost' };
    const btnHtml = `<div class="pr-card__btn-wrap">
      <button class="pr-card__btn ${btnMap[btnStyle] || 'btn--filled'}" data-product-url="${escAttr(p.url || '/products/' + p.handle)}" onclick="window.location=this.dataset.productUrl">
        View Product
      </button>
    </div>`;

    return `
    <a href="${escAttr(p.url || '/products/' + p.handle)}" class="pr-card style--${escAttr(cardStyle)}" aria-label="${escHtml(p.title)}">
      <div class="pr-card__img-wrap">
        ${img}
        ${badges.length ? `<div class="pr-badges">${badges.join('')}</div>` : ''}
      </div>
      <div class="pr-card__body">
        ${vendorHtml}
        <p class="pr-card__title">${escHtml(p.title)}</p>
        ${ratingHtml}
        ${priceHtml}
      </div>
      ${btnHtml}
    </a>`;
  }

  function escHtml(s) { return String(s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
  function escAttr(s) { return escHtml(s); }
  function fmtMoney(cents) {
    return new Intl.NumberFormat(navigator.language, { style: 'currency', currency: window.Shopify?.currency?.active || 'USD' }).format(cents / 100);
  }

  /* ── RECENTLY VIEWED ── */
  const RV_KEY = 'shopify_rv_products';

  function getRvList() {
    try { return JSON.parse(localStorage.getItem(RV_KEY) || '[]'); } catch(e) { return []; }
  }

  function saveRvList(arr) {
    try { localStorage.setItem(RV_KEY, JSON.stringify(arr)); } catch(e) {}
  }

  // Always track the current product
  (function trackCurrent() {
    if (!currentId) return;
    const list = getRvList().filter(p => p.id !== currentId);
    list.unshift({ id: currentId, handle: {{ product.handle | json }}, url: productUrl });
    saveRvList(list.slice(0, 20));
  })();

  if (mode === 'recently_viewed') {
    const grid  = document.getElementById(`pr-recently-viewed-${sectionId}`);
    const empty = document.getElementById(`pr-rv-empty-${sectionId}`);
    if (grid) {
      const list = getRvList().filter(p => p.id !== currentId).slice(0, limit);
      if (list.length === 0) {
        if (empty) { empty.style.display = ''; }
      } else {
        const handles = list.map(p => p.handle);
        Promise.all(handles.map(h =>
          fetch(`/products/${h}.js`).then(r => r.ok ? r.json() : null).catch(() => null)
        )).then(products => {
          const valid = products.filter(Boolean);
          if (valid.length === 0) {
            if (empty) empty.style.display = '';
            return;
          }
          grid.innerHTML = valid.map((p, i) => buildCard(p, i === 0 ? 'Just Viewed' : null)).join('');
        });
      }
    }
  }

  /* ── RECOMMENDATIONS (Shopify Product Recommendations API) ── */
  if (mode === 'recommendations') {
    const grid = document.getElementById(`pr-recs-${sectionId}`);
    if (grid && currentId) {
      const url = `/recommendations/products.json?product_id=${currentId}&limit=${limit}&intent=related`;
      fetch(url)
        .then(r => r.json())
        .then(data => {
          const prods = (data.products || []).slice(0, limit);
          if (prods.length) {
            grid.innerHTML = prods.map(p => buildCard(p, null)).join('');
          } else {
            grid.innerHTML = '<p class="pr-empty">No recommendations available yet.</p>';
          }
        })
        .catch(() => {
          grid.innerHTML = '<p class="pr-empty">Could not load recommendations.</p>';
        });
    }
  }
})();
</script>

{% schema %}
{
  "name": "Product Recommendations",
  "tag": "section",
  "class": "section-product-recommendations",
  "settings": [
    {
      "type": "header",
      "content": "Display Mode"
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Recommendation Type",
      "info": "Choose what products to show in this section.",
      "options": [
        { "value": "related",          "label": "🔗 Related Products (same collection)" },
        { "value": "recently_viewed",  "label": "🕐 Recently Viewed (browser history)" },
        { "value": "recommendations",  "label": "✨ You May Also Like (Shopify AI)" }
      ],
      "default": "recommendations"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "You May Also Like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Number of Products"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' link (Related mode only)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_mode_label",
      "label": "Show mode badge label",
      "default": false
    },
    {
      "type": "header",
      "content": "Card Options"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card Style",
      "options": [
        { "value": "boxed",        "label": "Boxed (border)" },
        { "value": "card-shadow",  "label": "Card with shadow" },
        { "value": "minimal",      "label": "Minimal (no border)" }
      ],
      "default": "boxed"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "options": [
        { "value": "filled",  "label": "Filled (solid)" },
        { "value": "outline", "label": "Outline" },
        { "value": "ghost",   "label": "Ghost (subtle)" }
      ],
      "default": "filled"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show Sale badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show star rating (placeholder)",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Columns (desktop)"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2,
      "label": "Columns (mobile)"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 16,
      "label": "Gap between cards (px)"
    },
    {
      "type": "header",
      "content": "Spacing & Color"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color Scheme",
      "options": [
        { "value": "light",  "label": "Light (white)" },
        { "value": "gray",   "label": "Light Gray" },
        { "value": "dark",   "label": "Dark" },
        { "value": "accent", "label": "Accent Tint" }
      ],
      "default": "light"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "label": "Padding Top (px)"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "label": "Padding Bottom (px)"
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations",
      "settings": {
        "display_mode": "recommendations",
        "heading": "You May Also Like",
        "products_to_show": 4,
        "columns_desktop": 4,
        "columns_mobile": 2
      }
    },
    {
      "name": "Related Products",
      "settings": {
        "display_mode": "related",
        "heading": "Related Products",
        "products_to_show": 4,
        "columns_desktop": 4
      }
    },
    {
      "name": "Recently Viewed",
      "settings": {
        "display_mode": "recently_viewed",
        "heading": "Recently Viewed",
        "products_to_show": 4,
        "columns_desktop": 4
      }
    }
  ]
}
{% endschema %}