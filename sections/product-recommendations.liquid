{% comment %}
  ╔══════════════════════════════════════════════════════════╗
  ║  sections/product-recommendations.liquid                 ║
  ║  Mode: Shopify AI — recommendations object (server-side) ║
  ║  Cards: snippets/product-card.liquid                     ║
  ╚══════════════════════════════════════════════════════════╝
{% endcomment %}

{% render 'pr-card-styles' %}

{%- liquid
  assign cols_d     = section.settings.columns_desktop
  assign cols_m     = section.settings.columns_mobile
  assign gap        = section.settings.card_gap
  assign pad_top    = section.settings.padding_top
  assign pad_bottom = section.settings.padding_bottom
  assign cs         = section.settings.color_scheme
  assign limit      = section.settings.products_to_show
-%}

<section
  class="pr-section cs-{{ cs }}"
  id="pr-recs-section-{{ section.id }}"
  style="
    --pr-cols: {{ cols_d }};
    --pr-cols-mob: {{ cols_m }};
    --pr-gap: {{ gap }}px;
    --pr-pad-top: {{ pad_top }}px;
    --pr-pad-bottom: {{ pad_bottom }}px;
  "
  aria-label="{{ section.settings.heading | escape }}"
>
  <div class="pr-inner">
    <div class="pr-header">
      <h2 class="pr-heading">{{ section.settings.heading }}</h2>
    </div>

    {%- if recommendations.performed and recommendations.products_count > 0 -%}
      <div class="pr-grid">
        {%- for rec_product in recommendations.products limit: limit -%}
          {%- render 'product-card', product: rec_product -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "AI Recommendations",
  "tag": "section",
  "class": "section-pr-recommendations",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "label": "Number of Products"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Columns (desktop)"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2,
      "label": "Columns (mobile)"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 16,
      "label": "Card gap (px)"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color Scheme",
      "options": [
        { "value": "light",  "label": "Light" },
        { "value": "gray",   "label": "Light Gray" },
        { "value": "dark",   "label": "Dark" },
        { "value": "accent", "label": "Accent" }
      ],
      "default": "light"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "label": "Padding top (px)"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "label": "Padding bottom (px)"
    }
  ],
  "presets": [
    {
      "name": "AI Recommendations",
      "settings": {
        "heading": "You May Also Like",
        "products_to_show": 4
      }
    }
  ]
}
{% endschema %}
