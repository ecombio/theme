{% comment %}
  sections/collection.liquid
  [1] Root section for templates/collection.json.

  Children:
    [1.1] snippets/collection-filter.liquid  — sort + filter UI
    [1.2] snippets/collection-feed.liquid    — tabs + grid + in-feed injection

  Owns:
    - Layout mode (sidebar | full)
    - Breadcrumb
    - Collection header (title + description) or hero banner
    - Paginate wrapper — opened here so paginate flows into feed
    - Section schema + blocks (forwarded to collection-feed)

  Blocks defined here, forwarded to collection-feed → sponsored-ads:
    "sponsored-products" — single product or manual carousel
    "sponsored-brands"   — banner-left + product carousel

  Metafields:
    collection.metafields.custom.description  — rich-text override
    collection.metafields.custom.banner_image — hero image override

  CSS: collection.css
  JS:  product-card.js (global), collection-feed.js, filters.js
{% endcomment %}

{{ 'collection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign products_per_page = section.settings.products_per_page | default: 12
  assign columns_desktop   = section.settings.columns_desktop   | default: 4
  assign show_banner       = section.settings.show_banner
  assign show_description  = section.settings.show_description
  assign show_breadcrumb   = section.settings.show_breadcrumb
  assign layout            = section.settings.layout | default: 'sidebar'

  assign banner_image = collection.metafields.custom.banner_image.value
  if banner_image == blank
    assign banner_image = collection.image
  endif
-%}

<div class="collection-section collection-section--{{ layout }}">

  {%- comment -%} ── Breadcrumb ──────────────────────────────────────────── {%- endcomment -%}

  {%- if show_breadcrumb -%}
    <nav class="collection-section__breadcrumb" aria-label="Breadcrumb">
      <ol class="collection-section__breadcrumb-list">
        <li class="collection-section__breadcrumb-item">
          <a href="/" class="collection-section__breadcrumb-link">Home</a>
        </li>
        <li class="collection-section__breadcrumb-item" aria-hidden="true">
          <span class="collection-section__breadcrumb-sep">/</span>
        </li>
        <li class="collection-section__breadcrumb-item">
          <a href="/collections" class="collection-section__breadcrumb-link">Collections</a>
        </li>
        <li class="collection-section__breadcrumb-item" aria-hidden="true">
          <span class="collection-section__breadcrumb-sep">/</span>
        </li>
        <li
          class="collection-section__breadcrumb-item collection-section__breadcrumb-item--current"
          aria-current="page"
        >
          {{ collection.title }}
        </li>
      </ol>
    </nav>
  {%- endif -%}

  {%- comment -%} ── Hero banner ──────────────────────────────────────────── {%- endcomment -%}

  {%- if show_banner and banner_image -%}
    <div class="collection-section__banner">
      <img
        class="collection-section__banner-image"
        src="{{ banner_image | image_url: width: 1400 }}"
        alt="{{ banner_image.alt | escape | default: collection.title | escape }}"
        width="1400"
        height="{{ 1400 | divided_by: banner_image.aspect_ratio | round }}"
        loading="eager"
        fetchpriority="high"
      >
      <div class="collection-section__banner-overlay">
        <h1 class="collection-section__banner-title">{{ collection.title }}</h1>
      </div>
    </div>

  {%- else -%}

    <header class="collection-section__header">
      <h1 class="collection-section__title">{{ collection.title }}</h1>
      {%- if show_description -%}
        {%- liquid
          assign description_content = collection.metafields.custom.description.value
          if description_content == blank
            assign description_content = collection.description
          endif
        -%}
        {%- if description_content != blank -%}
          <div class="collection-section__description">{{ description_content }}</div>
        {%- endif -%}
      {%- endif -%}
    </header>

  {%- endif -%}

  {%- comment -%} ── Body ────────────────────────────────────────────────── {%- endcomment -%}

  <div class="collection-section__body">

    {%- if layout == 'sidebar' -%}
      <aside class="collection-section__sidebar" aria-label="Collection filters">
        {%- render 'collection-filter',
          collection: collection,
          context:    'sidebar'
        -%}
      </aside>
    {%- endif -%}

    <div class="collection-section__main">

      {%- if layout == 'full' -%}
        {%- render 'collection-filter',
          collection: collection,
          context:    'toolbar'
        -%}
      {%- endif -%}

      {%- paginate collection.products by products_per_page -%}
        {%- render 'collection-feed',
          collection: collection,
          blocks:     section.blocks,
          paginate:   paginate,
          columns:    columns_desktop
        -%}
      {%- endpaginate -%}

    </div>

  </div>

</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-collection",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "sidebar", "label": "Sidebar filters" },
        { "value": "full",    "label": "Full width + toolbar" }
      ],
      "default": "sidebar"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 6,
      "max": 48,
      "step": 6,
      "default": 12
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description",
      "default": true
    },
    {
      "type": "header",
      "content": "Banner"
    },
    {
      "type": "checkbox",
      "id": "show_banner",
      "label": "Show hero banner",
      "info": "Uses collection.metafields.custom.banner_image if set, otherwise falls back to the collection image.",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "sponsored-products",
      "name": "Sponsored Products",
      "settings": [
        {
          "type": "header",
          "content": "Placement"
        },
        {
          "type": "range",
          "id": "row",
          "label": "Insert after row",
          "info": "This unit appears after this product row in the grid.",
          "min": 1,
          "max": 20,
          "step": 1,
          "default": 2
        },
        {
          "type": "header",
          "content": "Products"
        },
        {
          "type": "product",
          "id": "product_1",
          "label": "Product 1"
        },
        {
          "type": "product",
          "id": "product_2",
          "label": "Product 2"
        },
        {
          "type": "product",
          "id": "product_3",
          "label": "Product 3"
        },
        {
          "type": "product",
          "id": "product_4",
          "label": "Product 4"
        },
        {
          "type": "product",
          "id": "product_5",
          "label": "Product 5"
        },
        {
          "type": "product",
          "id": "product_6",
          "label": "Product 6"
        },
        {
          "type": "product",
          "id": "product_7",
          "label": "Product 7"
        },
        {
          "type": "product",
          "id": "product_8",
          "label": "Product 8"
        }
      ]
    },
    {
      "type": "sponsored-brands",
      "name": "Sponsored Brands",
      "settings": [
        {
          "type": "header",
          "content": "Placement"
        },
        {
          "type": "range",
          "id": "row",
          "label": "Insert after row",
          "min": 1,
          "max": 20,
          "step": 1,
          "default": 1
        },
        {
          "type": "header",
          "content": "Brand banner"
        },
        {
          "type": "image_picker",
          "id": "banner_image",
          "label": "Banner image",
          "info": "Displays to the left of the product carousel. Portrait or square images work best."
        },
        {
          "type": "text",
          "id": "banner_heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "banner_subheading",
          "label": "Subheading"
        },
        {
          "type": "url",
          "id": "banner_link",
          "label": "Banner link"
        },
        {
          "type": "header",
          "content": "Products"
        },
        {
          "type": "select",
          "id": "source_mode",
          "label": "Product source",
          "options": [
            { "value": "manual",     "label": "Hand-picked products" },
            { "value": "collection", "label": "From a collection" }
          ],
          "default": "manual"
        },
        {
          "type": "collection",
          "id": "source_collection",
          "label": "Source collection",
          "info": "Used when source is set to 'From a collection'."
        },
        {
          "type": "product",
          "id": "product_1",
          "label": "Product 1"
        },
        {
          "type": "product",
          "id": "product_2",
          "label": "Product 2"
        },
        {
          "type": "product",
          "id": "product_3",
          "label": "Product 3"
        },
        {
          "type": "product",
          "id": "product_4",
          "label": "Product 4"
        },
        {
          "type": "product",
          "id": "product_5",
          "label": "Product 5"
        },
        {
          "type": "product",
          "id": "product_6",
          "label": "Product 6"
        },
        {
          "type": "product",
          "id": "product_7",
          "label": "Product 7"
        },
        {
          "type": "product",
          "id": "product_8",
          "label": "Product 8"
        },
        {
          "type": "header",
          "content": "Display"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Carousel heading"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Collection" }
  ]
}
{% endschema %}