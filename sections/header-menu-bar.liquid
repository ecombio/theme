        {
          "type": "link_list",
          "id": "menu",
          "label": "Dropdown menu"
        }
      ]
    },
    {
      "type": "mega",
      "name": "Mega Menu",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label (overrides menu title)",
          "info": "Leave blank to use the menu's title"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "", "label": "None" },
            { "value": "hamburger", "label": "Hamburger" },
            { "value": "home", "label": "Home" },
            { "value": "sale", "label": "Sale" },
            { "value": "category", "label": "Category" },
            { "value": "star", "label": "Star" }
