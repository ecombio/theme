{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}
{{ 'cart.css' | asset_url | stylesheet_tag }}
{{ 'cart.js' | asset_url | script_tag }}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">



<section class="cart-page" aria-label="{{ 'cart.title' | t }}">
  <div class="cart-page__inner">

    <header class="cart-page__header">
      <h1 class="cart-page__title">{{ 'cart.title' | t }}</h1>
      {% if cart.item_count > 0 %}
        <span class="cart-page__count">
          {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}
        </span>
      {% endif %}
    </header>

    {% if cart.item_count == 0 %}

      <div class="cart-empty">
        <svg class="cart-empty__icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 8h4.5l7.5 32h28l6-22H18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="28" cy="50" r="3" stroke="currentColor" stroke-width="2.5"/>
          <circle cx="44" cy="50" r="3" stroke="currentColor" stroke-width="2.5"/>
        </svg>
        <p class="cart-empty__heading">Your cart is empty</p>
        <p class="cart-empty__text">Add something you love and it will appear here.</p>
        <a href="{{ routes.all_products_collection_url }}" class="cart-empty__cta">
          Browse products
        </a>
      </div>

    {% else %}

      <form action="{{ routes.cart_url }}" method="post" class="cart-page__body" id="cart-form">

        <div>
          {%- comment -%} ── Items ── {%- endcomment -%}
          <div class="cart-items" role="table" aria-label="{{ 'cart.title' | t }}">

            <div class="cart-items__head" role="row" aria-hidden="true">
              <span>Product</span>
              <span class="cart-items__head-qty">Quantity</span>
              <span class="cart-items__head-price">Price</span>
              <span class="cart-items__head-remove"></span>
            </div>

            {% for item in cart.items %}
              <div class="cart-item" role="row">

                {%- comment -%} Product info {%- endcomment -%}
                <div class="cart-item__info" role="cell">
                  <div class="cart-item__img-wrap">
                    {% if item.image %}
                      <img
                        src="{{ item.image | image_url: width: 144 }}"
                        alt="{{ item.image.alt | escape }}"
                        width="72"
                        height="72"
                        loading="lazy"
                      >
                    {% else %}
                      <div class="cart-item__img-placeholder" aria-hidden="true">
                        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <rect x="4" y="4" width="20" height="20" rx="2" stroke="currentColor" stroke-width="1.5"/>
                          <circle cx="10.5" cy="10.5" r="2" stroke="currentColor" stroke-width="1.5"/>
                          <path d="M4 18l6-5 4 4 3-3 7 6" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                        </svg>
                      </div>
                    {% endif %}
                  </div>
                  <div class="cart-item__meta">
                    {% if item.vendor != blank %}
                      <p class="cart-item__vendor">{{ item.vendor }}</p>
                    {% endif %}
                    <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                    {% unless item.variant.title == 'Default Title' %}
                      <p class="cart-item__variant">{{ item.variant.title }}</p>
                    {% endunless %}
                    {% if item.line_level_discount_allocations.size > 0 %}
                      <ul style="margin-top:6px;list-style:none;display:flex;flex-wrap:wrap;gap:4px;">
                        {% for discount in item.line_level_discount_allocations %}
                          <li style="font-size:0.7rem;background:var(--danger-light);color:var(--danger);padding:2px 8px;border-radius:12px;font-weight:500;">
                            {{ discount.discount_application.title }}
                          </li>
                        {% endfor %}
                      </ul>
                    {% endif %}
                  </div>
                </div>

                {%- comment -%} Quantity {%- endcomment -%}
                <div class="cart-item__qty" role="cell">
                  <div class="qty-control" aria-label="Quantity for {{ item.product.title | escape }}">
                    <button
                      type="button"
                      class="qty-control__btn"
                      aria-label="Decrease quantity"
                      data-action="decrease"
                      data-index="{{ forloop.index0 }}"
                    >−</button>
                    <input
                      class="qty-control__input"
                      type="number"
                      name="updates[]"
                      id="updates_{{ item.key }}"
                      value="{{ item.quantity }}"
                      min="0"
                      aria-label="Quantity"
                    >
                    <button
                      type="button"
                      class="qty-control__btn"
                      aria-label="Increase quantity"
                      data-action="increase"
                      data-index="{{ forloop.index0 }}"
                    >+</button>
                  </div>
                </div>

                {%- comment -%} Price {%- endcomment -%}
                <div class="cart-item__price" role="cell">
                  {% if item.original_line_price != item.final_line_price %}
                    <span class="price price--original">{{ item.original_line_price | money }}</span>
                    <span class="price price--discounted">{{ item.final_line_price | money }}</span>
                  {% else %}
                    <span class="price">{{ item.final_line_price | money }}</span>
                  {% endif %}
                </div>

                {%- comment -%} Remove {%- endcomment -%}
                <div class="cart-item__remove" role="cell">
                  <a
                    href="{{ item.url_to_remove }}"
                    class="btn-remove"
                    aria-label="{{ 'cart.remove' | t }} {{ item.product.title | escape }}"
                  >
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M1.5 1.5l9 9M10.5 1.5l-9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    {{ 'cart.remove' | t }}
                  </a>
                </div>

              </div>
            {% endfor %}
          </div>

          <div class="cart-actions">
            <button type="submit" name="update" class="btn-update">
              {{ 'cart.update' | t }}
            </button>
          </div>
        </div>

        {%- comment -%} ── Summary sidebar ── {%- endcomment -%}
        <aside class="cart-summary" aria-label="Order summary">

          <div class="cart-summary__header">
            <p class="cart-summary__title">Order summary</p>
          </div>

          <div class="cart-summary__lines">
            <div class="summary-line">
              <span class="summary-line__label">Subtotal</span>
              <span class="summary-line__value">{{ cart.original_total_price | money }}</span>
            </div>

            {% if cart.cart_level_discount_applications.size > 0 %}
              {% for discount in cart.cart_level_discount_applications %}
                <div class="summary-line">
                  <span class="summary-line__label">{{ discount.title }}</span>
                  <span class="summary-line__value" style="color:var(--danger);">
                    −{{ discount.total_allocated_amount | money }}
                  </span>
                </div>
              {% endfor %}
            {% endif %}

            <div class="summary-line summary-line--shipping">
              <span class="summary-line__label">Shipping</span>
              <span class="summary-line__value">Calculated at checkout</span>
            </div>
          </div>

          <div class="cart-summary__divider"></div>

          <div class="cart-summary__total">
            <span class="cart-summary__total-label">Total</span>
            <span class="cart-summary__total-value">{{ cart.total_price | money_with_currency }}</span>
          </div>

          {% if cart.taxes_included %}
            <p class="cart-summary__tax-note">Tax included</p>
          {% else %}
            <p class="cart-summary__tax-note">Taxes and shipping at checkout</p>
          {% endif %}

          <div class="cart-summary__checkout">
            <button type="submit" name="checkout" class="btn-checkout">
              {{ 'cart.checkout' | t }} →
            </button>
          </div>

          <div class="cart-summary__continue">
            <a href="{{ routes.all_products_collection_url }}">Continue shopping</a>
          </div>

        </aside>

      </form>

    {% endif %}
  </div>
</section>

<script>

</script>

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}