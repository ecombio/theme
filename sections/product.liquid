{%- comment -%} ════════════════════════════════════════
  JAVASCRIPT
════════════════════════════════════════ {%- endcomment -%}
<script>
(function () {
  'use strict';

  const SECTION_ID = {{ section.id | json }};
  const SCOPE      = `.ps--${SECTION_ID}`;
  const root       = document.querySelector(SCOPE);
  if (!root) return;

  // ── Product data ──────────────────────────────────────────
  const productDataEl = document.getElementById(`ps-product-json-${SECTION_ID}`);
  const productData   = productDataEl ? JSON.parse(productDataEl.textContent) : { variants: [] };
  const variants      = productData.variants;

  // ── DOM refs ──────────────────────────────────────────────
  const variantIdInput = root.querySelector(`#ps-variant-id-${SECTION_ID}`);
  const priceBlock     = root.querySelector(`#ps-price-${SECTION_ID}`);
  const atcBtn         = root.querySelector(`#ps-atc-${SECTION_ID}`);
  const atcText        = atcBtn ? atcBtn.querySelector('.ps__btn-text')    : null;
  const atcSpinner     = atcBtn ? atcBtn.querySelector('.ps__btn-spinner') : null;
  const toast          = root.querySelector(`#ps-toast-${SECTION_ID}`);
  const qtyInput       = root.querySelector(`input[name="quantity"]`);
  const mainMedia      = root.querySelector(`#ps-main-media-${SECTION_ID}`);
  const thumbBtns      = root.querySelectorAll('.ps__thumb-btn');
  const optionGroups   = root.querySelectorAll('.ps__option-group');

  // ── Helpers ───────────────────────────────────────────────
  function formatMoney (cents) {
    return (cents / 100).toLocaleString('en-US', { style: 'currency', currency: window.Shopify?.currency?.active || 'USD' });
  }

  function showToast (msg, type = 'success') {
    if (!toast) return;
    toast.textContent = msg;
    toast.className   = `ps__toast ps__toast--${type}`;
    toast.hidden      = false;
    clearTimeout(toast._tid);
    toast._tid = setTimeout(() => { toast.hidden = true; }, 4000);
  }

  // ── Media switcher ────────────────────────────────────────
  function switchMedia (mediaId) {
    const items = mainMedia ? mainMedia.querySelectorAll('.ps__media-item') : [];
    items.forEach(el => {
      const active = String(el.dataset.mediaId) === String(mediaId);
      el.classList.toggle('is-active', active);
      el.setAttribute('aria-hidden', String(!active));
    });
    thumbBtns.forEach(btn => {
      const active = String(btn.dataset.mediaId) === String(mediaId);
      btn.classList.toggle('is-active', active);
      btn.setAttribute('aria-pressed', String(active));
    });
  }

  thumbBtns.forEach(btn => {
    btn.addEventListener('click', () => switchMedia(btn.dataset.mediaId));
  });

  // ── Variant resolution ────────────────────────────────────
  function getSelectedOptions () {
    const opts = [];
    optionGroups.forEach(group => {
      const checked = group.querySelector('input[type="radio"]:checked');
      if (checked) opts.push(checked.value);
    });
    return opts;
  }

  function findVariant (selectedOptions) {
    return variants.find(v => {
      const vOptions = [v.option1, v.option2, v.option3].filter(Boolean);
      return selectedOptions.every((opt, i) => opt === vOptions[i]);
    }) || null;
  }

  function updatePrice (variant) {
    if (!priceBlock || !variant) return;

    let html = '';
    if (variant.compare_at_price && variant.compare_at_price > variant.price) {
      html += `<span class="ps__badge ps__badge--sale">Sale</span>`;
      html += `<span class="ps__price ps__price--sale">${formatMoney(variant.price)}</span>`;
      html += `<s class="ps__price ps__price--compare">${formatMoney(variant.compare_at_price)}</s>`;
    } else {
      html += `<span class="ps__price">${formatMoney(variant.price)}</span>`;
    }
    priceBlock.innerHTML = html;
  }

  function updateAtcButton (variant) {
    if (!atcBtn || !atcText) return;
    const available = variant && variant.available;
    atcBtn.disabled = !available;
    atcBtn.setAttribute('aria-disabled', String(!available));
    atcText.textContent = available ? 'Add to Cart' : 'Sold Out';
  }

  function updateURL (variant) {
    if (!variant || !history.replaceState) return;
    const url = new URL(window.location.href);
    url.searchParams.set('variant', variant.id);
    history.replaceState({}, '', url.toString());
  }

  function onVariantChange () {
    const selected = getSelectedOptions();
    const variant  = findVariant(selected);

    if (variant) {
      variantIdInput.value = variant.id;
      updatePrice(variant);
      updateAtcButton(variant);
      updateURL(variant);
      if (variant.featured_media_id) switchMedia(variant.featured_media_id);
    } else {
      updateAtcButton(null);
    }
  }

  optionGroups.forEach(group => {
    group.addEventListener('change', onVariantChange);
  });

  // ── Quantity stepper ──────────────────────────────────────
  root.querySelectorAll('.ps__stepper-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!qtyInput) return;
      const current = parseInt(qtyInput.value, 10) || 1;
      const delta   = btn.dataset.action === 'increment' ? 1 : -1;
      qtyInput.value = Math.max(1, current + delta);
    });
  });

  // ── AJAX Add to Cart ──────────────────────────────────────
  const form = root.querySelector('.ps__form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!atcBtn || atcBtn.disabled) return;

      // Loading state
      atcBtn.disabled = true;
      if (atcText)    atcText.hidden    = true;
      if (atcSpinner) atcSpinner.hidden = false;

      const formData = new FormData(form);
      const body     = JSON.stringify({
        id:       formData.get('id'),
        quantity: parseInt(formData.get('quantity'), 10) || 1,
        sections: 'cart-icon-bubble'
      });

      try {
        const res  = await fetch('/cart/add.js', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body
        });
        const data = await res.json();

        if (!res.ok) throw new Error(data.description || 'Could not add to cart');

        showToast('Added to cart ✓', 'success');

        // Dispatch cart update event for header cart bubble / drawer
        document.dispatchEvent(new CustomEvent('cart:updated', { detail: data }));

        // Update cart count badge if theme uses [data-cart-count]
        const countEl = document.querySelector('[data-cart-count]');
        if (countEl && data.sections?.['cart-icon-bubble']) {
          const tmp = document.createElement('div');
          tmp.innerHTML = data.sections['cart-icon-bubble'];
          const newCount = tmp.querySelector('[data-cart-count]');
          if (newCount) countEl.textContent = newCount.textContent;
        }

      } catch (err) {
        showToast(err.message || 'Something went wrong. Please try again.', 'error');
      } finally {
        atcBtn.disabled = false;
        if (atcText)    atcText.hidden    = false;
        if (atcSpinner) atcSpinner.hidden = true;
      }
    });
  }

})();
</script>

