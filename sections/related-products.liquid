{% comment %}
  Section: related-products
  Renders a "You May Also Like" product recommendations grid.
  Uses the Shopify Product Recommendations API (algorithm-based).
  Falls back to a manual collection if no recommendations are returned.
{% endcomment %}

{%- liquid
  assign products_to_show = section.settings.products_to_show
  assign heading         = section.settings.heading
  assign columns_desktop = section.settings.columns_desktop
-%}

<div
  class="related-products page-width"
  id="related-products-{{ section.id }}"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ products_to_show }}"
>
  {%- if heading != blank -%}
    <div class="related-products__header">
      <h2 class="related-products__heading">{{ heading | escape }}</h2>
    </div>
  {%- endif -%}

  {%- if recommendations.performed and recommendations.products_count > 0 -%}
    <div class="related-products__grid related-products__grid--{{ columns_desktop }}-col">
      {%- for product in recommendations.products limit: products_to_show -%}
        {%- render 'product-card',
          product:            product,
          show_badge:         section.settings.show_badge,
          show_selling_fast:  section.settings.show_selling_fast,
          show_swatches:      section.settings.show_swatches,
          image_ratio:        section.settings.image_ratio
        -%}
      {%- endfor -%}
    </div>
  {%- elsif section.settings.fallback_collection != blank -%}
    {%- assign fallback = collections[section.settings.fallback_collection] -%}
    {%- if fallback.products_count > 0 -%}
      <div class="related-products__grid related-products__grid--{{ columns_desktop }}-col">
        {%- for product in fallback.products limit: products_to_show -%}
          {%- render 'product-card',
            product:            product,
            show_badge:         section.settings.show_badge,
            show_selling_fast:  section.settings.show_selling_fast,
            show_swatches:      section.settings.show_swatches,
            image_ratio:        section.settings.image_ratio
          -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Related Products",
  "tag": "section",
  "class": "section-related-products",
  "limit": 1,
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "You May Also Like",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5,
      "label": "Maximum products to show"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Number of columns on desktop",
      "default": "5",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" },
        { "value": "5", "label": "5 columns" }
      ]
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "portrait",
      "options": [
        { "value": "square",   "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "landscape","label": "Landscape (4:3)" }
      ]
    },
    {
      "type": "header",
      "content": "Product Card Options"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "default": true,
      "label": "Show product badges (Sale, Best Choice, etc.)"
    },
    {
      "type": "checkbox",
      "id": "show_selling_fast",
      "default": true,
      "label": "Show \"Selling Fast\" banner when low stock"
    },
    {
      "type": "number",
      "id": "selling_fast_threshold",
      "default": 5,
      "label": "\"Selling Fast\" inventory threshold"
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "default": true,
      "label": "Show color swatches"
    },
    {
      "type": "header",
      "content": "Fallback Collection"
    },
    {
      "type": "collection",
      "id": "fallback_collection",
      "label": "Fallback collection",
      "info": "Shown when no algorithmic recommendations are available."
    }
  ],
  "presets": [
    {
      "name": "Related Products"
    }
  ]
}
{% endschema %}
