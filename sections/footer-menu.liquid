{{ 'footer-menu.css' | asset_url | stylesheet_tag }}

<footer-menu class="footer-menu color-{{ section.settings.color_scheme }}" style="--footer-menu-padding-top: {{ section.settings.padding_top }}px; --footer-menu-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="footer-menu__inner page-width">

    {%- if section.settings.show_logo and section.settings.logo != blank -%}
      <div class="footer-menu__brand">
        <a href="{{ routes.root_url }}" class="footer-menu__logo-link">
          <img
            src="{{ section.settings.logo | image_url: width: 300 }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            width="{{ section.settings.logo_width }}"
            loading="lazy"
            class="footer-menu__logo"
          >
        </a>
        {%- if section.settings.brand_text != blank -%}
          <div class="footer-menu__brand-text rte">{{ section.settings.brand_text }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="footer-menu__columns">
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'menu' -%}
            <div class="footer-menu__column footer-menu__column--menu" {{ block.shopify_attributes }}>
              <div class="footer-menu__column-header" data-footer-menu-toggle>
                <h3 class="footer-menu__heading">{{ block.settings.heading }}</h3>
                <span class="footer-menu__toggle-icon" aria-hidden="true">
                  <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
              <div class="footer-menu__column-content">
                {%- if block.settings.menu != blank -%}
                  <ul class="footer-menu__list" role="list">
                    {%- for link in block.settings.menu.links -%}
                      <li class="footer-menu__list-item">
                        <a href="{{ link.url }}" class="footer-menu__link"{% if link.active %} aria-current="page"{% endif %}>
                          {{ link.title }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>
            </div>

          {%- when 'text' -%}
            <div class="footer-menu__column footer-menu__column--text" {{ block.shopify_attributes }}>
              <div class="footer-menu__column-header" data-footer-menu-toggle>
                <h3 class="footer-menu__heading">{{ block.settings.heading }}</h3>
                <span class="footer-menu__toggle-icon" aria-hidden="true">
                  <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
              <div class="footer-menu__column-content">
                <div class="footer-menu__text rte">{{ block.settings.text }}</div>
              </div>
            </div>

          {%- when 'newsletter' -%}
            <div class="footer-menu__column footer-menu__column--newsletter" {{ block.shopify_attributes }}>
              <div class="footer-menu__column-header" data-footer-menu-toggle>
                <h3 class="footer-menu__heading">{{ block.settings.heading }}</h3>
                <span class="footer-menu__toggle-icon" aria-hidden="true">
                  <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
              <div class="footer-menu__column-content">
                {%- if block.settings.text != blank -%}
                  <div class="footer-menu__text rte">{{ block.settings.text }}</div>
                {%- endif -%}
                {% form 'customer', id: 'FooterMenuNewsletterForm' %}
                  {%- if form.posted_successfully? -%}
                    <p class="footer-menu__newsletter-success">{{ 'newsletter.success' | t | default: 'Thanks for subscribing' }}</p>
                  {%- endif -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <div class="footer-menu__newsletter-field">
                    <label for="FooterMenuNewsletterEmail" class="visually-hidden">{{ 'newsletter.email' | t | default: 'Email' }}</label>
                    <input
                      type="email"
                      name="contact[email]"
                      id="FooterMenuNewsletterEmail"
                      class="footer-menu__newsletter-input"
                      value="{{ form.email }}"
                      placeholder="{{ 'newsletter.email_placeholder' | t | default: 'Email address' }}"
                      required
                    >
                    <button type="submit" class="footer-menu__newsletter-submit" aria-label="{{ 'newsletter.subscribe' | t | default: 'Subscribe' }}">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 8H15M15 8L8 1M15 8L8 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>
                  </div>
                {% endform %}
              </div>
            </div>

        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_social -%}
      <div class="footer-menu__social">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="footer-menu__social-link" aria-label="Instagram">Instagram</a>
        {%- endif -%}
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" class="footer-menu__social-link" aria-label="Facebook">Facebook</a>
        {%- endif -%}
        {%- if settings.social_twitter_link != blank -%}
          <a href="{{ settings.social_twitter_link }}" class="footer-menu__social-link" aria-label="Twitter">Twitter</a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" class="footer-menu__social-link" aria-label="TikTok">TikTok</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="footer-menu__bottom">
      <p class="footer-menu__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'footer.powered_by' | t | default: 'Powered by Shopify' }}
      </p>
      {%- if section.settings.show_payment_icons -%}
        <ul class="footer-menu__payment-icons" role="list">
          {%- for type in shop.enabled_payment_types -%}
            <li class="footer-menu__payment-icon">
              {{ type | payment_type_svg_tag: class: 'footer-menu__payment-icon-svg' }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

  </div>
</footer-menu>

<script src="{{ 'footer-menu.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Footer menu",
  "tag": "section",
  "class": "section-footer-menu",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show logo",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 140
    },
    {
      "type": "richtext",
      "id": "brand_text",
      "label": "Brand text",
      "default": "<p>Add a short description about your brand here.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social media icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text column",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "About us"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share store details, hours, or contact information.</p>"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Subscribe to our newsletter"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Be the first to know about new products and offers.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer menu",
      "blocks": [
        {
          "type": "menu",
          "settings": {
            "heading": "Quick links"
          }
        },
        {
          "type": "text",
          "settings": {
            "heading": "About us"
          }
        },
        {
          "type": "newsletter",
          "settings": {
            "heading": "Subscribe to our newsletter"
          }
        }
      ]
    }
  ]
}
{% endschema %}