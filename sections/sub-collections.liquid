{% comment %}
  Section: sub-collections
  Renders a horizontal slider of sub-collections sourced from the
  collection metafield  custom.sub_collections  (type: List › Collection).

  Drop into:  sections/sub-collections.liquid
  Add to collection template JSON under the "order" array.
{% endcomment %}

{%- liquid
  assign sub_cols = collection.metafields.custom.sub_collections.value
  assign has_items = false
  if sub_cols != blank and sub_cols.size > 0
    assign has_items = true
  endif
-%}

{%- if has_items or request.design_mode -%}

{{ 'sub-collections.css' | asset_url | stylesheet_tag }}

<section
  class="sub-collections"
  data-section-id="{{ section.id }}"
  style="
    --sc-pt: {{ section.settings.padding_top }}px;
    --sc-pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="sub-collections__inner page-width">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="sub-collections__header sub-collections__header--{{ section.settings.text_alignment }}">
        {%- if section.settings.subheading != blank -%}
          <p class="sub-collections__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="sub-collections__heading {{ section.settings.heading_size }}">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="sub-collections__track-wrap">
      <button
        class="sub-collections__arrow sub-collections__arrow--prev"
        aria-label="Previous"
        type="button"
        hidden
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <ul class="sub-collections__track" role="list" id="SubColTrack-{{ section.id }}">

        {%- if has_items -%}
          {%- for col in sub_cols -%}
            {%- if col == blank -%}{%- continue -%}{%- endif -%}
            <li class="sub-collections__item">
              <a
                href="{{ col.url }}"
                class="sub-collections__card{% if section.settings.rounded_image %} sub-collections__card--round{% endif %}"
              >
                <div class="sub-collections__img-wrap{% unless col.featured_image %} sub-collections__img-wrap--label-only{% endunless %}">
  {%- if col.featured_image -%}
    {{
      col.featured_image
      | image_url: width: 400
      | image_tag:
        loading: 'lazy',
        widths: '200, 300, 400',
        class: 'sub-collections__img',
        alt: col.title | escape
    }}
  {%- else -%}
    <span class="sub-collections__tile-label">{{ col.title | escape }}</span>
  {%- endif -%}
</div>
                <span class="sub-collections__name">{{ col.title | escape }}</span>
              </a>
            </li>
          {%- endfor -%}

        {%- elsif request.design_mode -%}
          {%- comment -%} Placeholder tiles visible only in Theme Editor {%- endcomment -%}
          {%- for i in (1..6) -%}
            <li class="sub-collections__item">
              <a href="#" class="sub-collections__card{% if section.settings.rounded_image %} sub-collections__card--round{% endif %}">
                <div class="sub-collections__img-wrap">
                  {{ 'collection-' | append: i | placeholder_svg_tag: 'sub-collections__img sub-collections__img--placeholder' }}
                </div>
                <span class="sub-collections__name">Sub-collection {{ i }}</span>
              </a>
            </li>
          {%- endfor -%}
        {%- endif -%}

      </ul>

      <button
        class="sub-collections__arrow sub-collections__arrow--next"
        aria-label="Next"
        type="button"
        hidden
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

  </div>
</section>

<script>
(function () {
  const section  = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;

  const track    = section.querySelector('.sub-collections__track');
  const btnPrev  = section.querySelector('.sub-collections__arrow--prev');
  const btnNext  = section.querySelector('.sub-collections__arrow--next');
  const items    = Array.from(track.querySelectorAll('.sub-collections__item'));

  if (!track || items.length === 0) return;

  let current = 0;

  function itemsVisible() {
    const trackW = track.parentElement.offsetWidth;
    const itemW  = items[0].offsetWidth + parseInt(getComputedStyle(track).gap || 16);
    return Math.max(1, Math.floor(trackW / itemW));
  }

  function maxIndex() {
    return Math.max(0, items.length - itemsVisible());
  }

  function scrollTo(idx) {
    current = Math.min(Math.max(idx, 0), maxIndex());
    const itemW = items[0].offsetWidth + parseInt(getComputedStyle(track).gap || 16);
    track.scrollTo({ left: current * itemW, behavior: 'smooth' });
    btnPrev.hidden = current === 0;
    btnNext.hidden = current >= maxIndex();
  }

  function init() {
    if (items.length > itemsVisible()) {
      btnPrev.hidden = true;
      btnNext.hidden = false;
    } else {
      btnPrev.hidden = true;
      btnNext.hidden = true;
    }
  }

  btnPrev.addEventListener('click', () => scrollTo(current - 1));
  btnNext.addEventListener('click', () => scrollTo(current + 1));

  // Sync arrow state on native scroll (touch / trackpad)
  track.addEventListener('scroll', () => {
    const itemW = items[0].offsetWidth + parseInt(getComputedStyle(track).gap || 16);
    current     = Math.round(track.scrollLeft / itemW);
    btnPrev.hidden = current === 0;
    btnNext.hidden = current >= maxIndex();
  }, { passive: true });

  window.addEventListener('resize', init, { passive: true });
  init();
})();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Sub-collections",
  "tag": "section",
  "class": "section-sub-collections",
  "settings": [
    {
      "type": "paragraph",
      "content": "Collections are pulled from the **custom.sub_collections** metafield on the current collection. Add that metafield in Settings › Custom data › Collections."
    },
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "display_lg", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Card settings"
    },
    {
      "type": "checkbox",
      "id": "rounded_image",
      "label": "Show rounded image",
      "default": false
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Sub-collections"
    }
  ]
}
{% endschema %}
