{% doc %}
  Header Bottom - Level 1 as blocks, Mega Menu on hover with Level 2 columns + Level 3 links
{% enddoc %}

{%- liquid
  assign padding_top = section.settings.padding_top | default: 12
  assign padding_bottom = section.settings.padding_bottom | default: 12
-%}

<div class="header-bottom" data-theme-preset="{{ settings.theme_preset | default: 'hyper' }}" 
     style="--padding-top: {{ padding_top }}px; --padding-bottom: {{ padding_bottom }}px;"
     {{ section.shopify_attributes }}>
  
  <div class="header-bottom__inner">
    <nav class="header-bottom__nav" aria-label="Main navigation">
      <ul class="header-bottom__menu">

        {%- for block in section.blocks -%}

          {%- case block.type -%}

            {%- when 'menu_link' -%}
              <li class="header-bottom__menu-item" {{ block.shopify_attributes }}>
                <a href="{{ block.settings.link }}" class="header-bottom__link">
                  {{ block.settings.label }}
                </a>
              </li>

            {%- when 'mega_menu' -%}
              <li class="header-bottom__menu-item header-bottom__menu-item--mega" {{ block.shopify_attributes }}>
                <a href="{{ block.settings.link | default: '#' }}" class="header-bottom__link header-bottom__link--has-mega">
                  {{ block.settings.label }}
                  <span class="header-bottom__chevron">▾</span>
                </a>

                <div class="header-bottom__mega">
                  <div class="header-bottom__mega-inner">
                    
                    <!-- Mega Menu Content -->
                    {%- if block.settings.menu != blank -%}
                      {% render 'header-mega-menu', menu: block.settings.menu %}
                    {%- endif -%}

                    <!-- Optional Right Banner -->
                    {%- if block.settings.show_featured_content -%}
                      <div class="header-bottom__mega-featured">
                        {%- if block.settings.featured_image != blank -%}
                          <div class="header-bottom__mega-image">
                            {{ block.settings.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                          </div>
                        {%- endif -%}
                        {%- if block.settings.featured_heading != blank -%}
                          <h4>{{ block.settings.featured_heading }}</h4>
                        {%- endif -%}
                        {%- if block.settings.featured_text != blank -%}
                          <p>{{ block.settings.featured_text }}</p>
                        {%- endif -%}
                        {%- if block.settings.featured_button != blank -%}
                          <a href="{{ block.settings.featured_link }}" class="header-bottom__mega-button">
                            {{ block.settings.featured_button }}
                          </a>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                  </div>
                </div>
              </li>

          {%- endcase -%}

        {%- endfor -%}

      </ul>
    </nav>
  </div>
</div>

{% stylesheet %}
  .header-bottom {
    background: #1a1a1a;
    color: #fff;
    border-bottom: 1px solid #222;
  }

  .header-bottom__inner {
    max-width: 1480px;
    margin: 0 auto;
    padding: var(--padding-top) 24px var(--padding-bottom);
  }

  .header-bottom__menu {
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header-bottom__link {
    color: inherit;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .header-bottom__chevron {
    font-size: 11px;
    transition: transform 0.2s;
  }

  .header-bottom__menu-item--mega:hover .header-bottom__chevron {
    transform: rotate(180deg);
  }

  /* Mega Menu */
  .header-bottom__mega {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: #111;
    padding: 40px 60px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.7);
    z-index: 999;
  }

  .header-bottom__menu-item--mega:hover .header-bottom__mega {
    display: block;
  }

  .header-bottom__mega-inner {
    display: flex;
    gap: 60px;
    max-width: 1480px;
    margin: 0 auto;
  }

  /* Columns from snippet */
  .header-bottom__mega-columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 50px 40px;
    flex: 1;
  }

  .header-bottom__mega-column h4 {
    color: #fff;
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 16px;
    border-bottom: 1px solid #333;
    padding-bottom: 10px;
  }

  .header-bottom__mega-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .header-bottom__mega-link {
    color: #ccc;
    display: block;
    padding: 6px 0;
    text-decoration: none;
  }

  .header-bottom__mega-link:hover {
    color: #00ff9d;
  }

  /* Banner */
  .header-bottom__mega-featured {
    width: 280px;
    flex-shrink: 0;
  }

  .header-bottom__mega-button {
    background: #00ff9d;
    color: #111;
    padding: 10px 24px;
    font-weight: 700;
    border-radius: 4px;
    display: inline-block;
    margin-top: 12px;
  }

  @media (max-width: 990px) {
    .header-bottom__mega { display: none !important; }
  }
  .header-bottom__mega-subheading {
  font-size: 13px;
  font-weight: 700;
  color: #00ff9d;
  margin: 16px 0 6px;
  text-transform: uppercase;
}

.header-bottom__mega-columns {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 40px 32px;
  flex: 1;
}

.header-bottom__mega-column {
  min-width: 0;
}

.header-bottom__mega-heading {
  color: #fff;
  font-size: 15px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  margin-bottom: 16px;
  padding-bottom: 10px;
  border-bottom: 1px solid #333;
}

.header-bottom__mega-list {
  list-style: none;
  padding: 0;
  margin: 0 0 12px 0;
}

.header-bottom__mega-link {
  color: #ccc;
  display: block;
  padding: 5px 0;
  text-decoration: none;
  font-size: 14px;
}

.header-bottom__mega-link:hover {
  color: #00ff9d;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Header Bottom",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "menu_link",
      "name": "Simple Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Shop All" },
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    },
    {
      "type": "mega_menu",
      "name": "Mega Menu",
      "settings": [
        { "type": "text", "id": "label", "label": "Level 1 Label", "default": "Electric Scooters" },
        { "type": "url", "id": "link", "label": "Level 1 Link (optional)" },
        { "type": "link_list", "id": "menu", "label": "Mega Menu Content (Level 2 = columns, Level 3 = links)" },
        { "type": "checkbox", "id": "show_featured_content", "label": "Show Right Banner", "default": true },
        { "type": "image_picker", "id": "featured_image", "label": "Banner Image" },
        { "type": "text", "id": "featured_heading", "label": "Banner Heading" },
        { "type": "textarea", "id": "featured_text", "label": "Banner Text" },
        { "type": "text", "id": "featured_button", "label": "Button Text", "default": "Shop Now" },
        { "type": "url", "id": "featured_link", "label": "Button Link" }
      ]
    }
  ],
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 4, "max": 24, "default": 12 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 4, "max": 24, "default": 12 }
  ],
  "presets": [
    {
      "name": "Header Bottom",
      "blocks": [
        { "type": "mega_menu", "settings": { "label": "Electric Scooters" } },
        { "type": "mega_menu", "settings": { "label": "Electric Bikes" } }
      ]
    }
  ]
}
{% endschema %}