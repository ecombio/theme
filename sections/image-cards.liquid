{% comment %}
  ECOMBIO – Image Cards Carousel Section
  File: sections/image-cards.liquid
  Version: 1.0.0
{% endcomment %}

{%- liquid
  assign section_id = 'image-cards-' | append: section.id
  assign card_count  = section.blocks.size
-%}

<section
  id="{{ section_id }}"
  class="image-cards-section"
  data-section-id="{{ section.id }}"
  style="
    --ic-bg:              {{ section.settings.bg_color }};
    --ic-accent:          {{ section.settings.accent_color }};
    --ic-btn-bg:          {{ section.settings.btn_bg_color }};
    --ic-btn-text:        {{ section.settings.btn_text_color }};
    --ic-badge-bg:        {{ section.settings.badge_bg_color }};
    --ic-badge-text:      {{ section.settings.badge_text_color }};
    --ic-ratio:           {{ section.settings.card_ratio }};
    --ic-cols-desktop:    {{ section.settings.cols_desktop }};
    --ic-cols-mobile:     {{ section.settings.cols_mobile }};
    --ic-gap:             {{ section.settings.card_gap }}px;
    --ic-peek:            {{ section.settings.overflow_peek }}px;
    --ic-section-pt:      {{ section.settings.padding_top }}px;
    --ic-section-pb:      {{ section.settings.padding_bottom }}px;
  "
>

  {%- comment -%} ─── SECTION HEADER ─────────────────────────────────────── {%- endcomment -%}
  {%- if section.settings.show_header -%}
    <div class="ic-header">
      {%- if section.settings.subheading != blank -%}
        <p class="ic-subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="ic-heading">
          {%- liquid
            assign raw_heading = section.settings.heading
            assign highlighted  = section.settings.highlighted_words
          -%}
          {%- if highlighted != blank -%}
            {%- assign hl_words = highlighted | split: ',' -%}
            {%- assign output   = raw_heading -%}
            {%- for word in hl_words -%}
              {%- assign trimmed  = word | strip -%}
              {%- assign wrapped  = '<mark class="ic-highlight">' | append: trimmed | append: '</mark>' -%}
              {%- assign output   = output | replace: trimmed, wrapped -%}
            {%- endfor -%}
            {{ output }}
          {%- else -%}
            {{ raw_heading }}
          {%- endif -%}
        </h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ─── CAROUSEL WRAPPER ────────────────────────────────────── {%- endcomment -%}
  <div class="ic-carousel-outer" role="region" aria-label="{{ section.settings.heading | escape | default: 'Product cards' }}">

    <div
      class="ic-track"
      id="{{ section_id }}-track"
      aria-live="polite"
    >
      {%- for block in section.blocks -%}
        {%- render 'card-image',
          block:          block,
          section:        section,
          forloop_index:  forloop.index0
        -%}
      {%- else -%}
        {%- comment -%} Placeholder cards for theme editor empty state {%- endcomment -%}
        {%- for i in (1..4) -%}
          <article class="ic-card ic-card--placeholder">
            <div class="ic-card__image-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'ic-card__placeholder-svg' }}
            </div>
            <div class="ic-card__content">
              <span class="ic-card__badge">CATEGORY</span>
              <p class="ic-card__title">Product Name</p>
              <button class="ic-card__btn" disabled>Shop Now</button>
            </div>
          </article>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ─── NAV ARROWS ──────────────────────────────────────── {%- endcomment -%}
    {%- if section.settings.show_arrows and card_count > 1 -%}
      <div class="ic-nav" aria-label="Carousel navigation">
        <button
          class="ic-nav__btn ic-nav__btn--prev"
          aria-label="Previous cards"
          aria-controls="{{ section_id }}-track"
          data-dir="prev"
        >
          {%- render 'icon-arrow-left' -%}
        </button>
        <button
          class="ic-nav__btn ic-nav__btn--next"
          aria-label="Next cards"
          aria-controls="{{ section_id }}-track"
          data-dir="next"
        >
          {%- render 'icon-arrow-right' -%}
        </button>
      </div>
    {%- endif -%}

  </div><!-- /.ic-carousel-outer -->

  {%- comment -%} ─── SCROLL PROGRESS BAR ────────────────────────────────── {%- endcomment -%}
  {%- if section.settings.show_progress_bar -%}
    <div class="ic-progress-wrap" aria-hidden="true">
      <div class="ic-progress-bar" id="{{ section_id }}-progress"></div>
    </div>
  {%- endif -%}

</section>


{%- comment -%} ════════════════════════════════════════════════════════════
  STYLES
════════════════════════════════════════════════════════════════════════════ {%- endcomment -%}
<style>
/* ── Reset & custom properties ─────────────────────────────────────────── */
#{{ section_id }} *,
#{{ section_id }} *::before,
#{{ section_id }} *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── Section shell ──────────────────────────────────────────────────────── */
.image-cards-section {
  background: var(--ic-bg, #f0f2f8);
  padding: var(--ic-section-pt, 72px) 0 var(--ic-section-pb, 72px);
  overflow: hidden;
  position: relative;
}

/* ── Header ─────────────────────────────────────────────────────────────── */
.ic-header {
  text-align: center;
  padding: 0 clamp(1.25rem, 5vw, 4rem);
  margin-bottom: clamp(2rem, 4vw, 3.5rem);
}

.ic-subheading {
  font-family: 'Barlow', 'DIN Alternate', 'Arial Narrow', sans-serif;
  font-size: clamp(0.65rem, 1vw, 0.75rem);
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #888;
  margin-bottom: 0.75rem;
}

.ic-heading {
  font-family: 'Barlow Condensed', 'DIN Alternate', 'Arial Narrow', Impact, sans-serif;
  font-size: clamp(2rem, 4.5vw, 3.25rem);
  font-weight: 800;
  line-height: 1.12;
  color: #111;
  max-width: 780px;
  margin: 0 auto;
  text-wrap: balance;
}

/* Highlighted text – yellow underline marker style */
.ic-highlight {
  background: none;
  position: relative;
  display: inline;
  white-space: nowrap;
}
.ic-highlight::after {
  content: '';
  position: absolute;
  left: -2px; right: -2px;
  bottom: 2px;
  height: 0.42em;
  background: {{ section.settings.accent_color | default: '#f5c842' }};
  opacity: 0.55;
  z-index: -1;
  border-radius: 2px;
}

/* ── Carousel outer ──────────────────────────────────────────────────────── */
.ic-carousel-outer {
  position: relative;
  padding: 0 clamp(1rem, 3vw, 3rem);
}

/* ── Track (the scrolling row) ───────────────────────────────────────────── */
.ic-track {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: calc(
    (100% - (var(--ic-cols-desktop, 4) - 1) * var(--ic-gap, 16px) - var(--ic-peek, 40px))
    / var(--ic-cols-desktop, 4)
  );
  gap: var(--ic-gap, 16px);
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-right: var(--ic-peek, 40px); /* reveal the next card edge */
  cursor: grab;
}
.ic-track::-webkit-scrollbar { display: none; }
.ic-track.is-grabbing { cursor: grabbing; }

/* ── Card ────────────────────────────────────────────────────────────────── */
.ic-card {
  scroll-snap-align: start;
  border-radius: {{ section.settings.card_radius }}px;
  overflow: hidden;
  position: relative;
  background: #1a1a1a;
  display: flex;
  flex-direction: column;
  transition: transform 0.28s cubic-bezier(.22,.68,0,1.2);
  will-change: transform;
}
.ic-card:hover { transform: translateY(-4px); }

/* ── Card image ──────────────────────────────────────────────────────────── */
.ic-card__image-wrap {
  position: relative;
  aspect-ratio: var(--ic-ratio, 0.78);
  overflow: hidden;
}
.ic-card__image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.55s cubic-bezier(.25,.46,.45,.94);
}
.ic-card:hover .ic-card__image-wrap img { transform: scale(1.04); }

/* Placeholder SVG */
.ic-card__placeholder-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Image overlay */
.ic-card__image-wrap::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    transparent 40%,
    rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }}) 100%
  );
  pointer-events: none;
}

/* ── Category badge (top-left) ───────────────────────────────────────────── */
.ic-card__badge {
  position: absolute;
  top: 14px;
  left: 14px;
  z-index: 2;
  display: inline-block;
  padding: 5px 13px;
  font-family: 'Barlow', 'Arial Narrow', sans-serif;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #fff;
  background: rgba(255,255,255,0.18);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.35);
  border-radius: 999px;
  white-space: nowrap;
}

/* ── Save / promo badge (top-right, circular) ───────────────────────────── */
.ic-card__promo-badge {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 2;
  width: 68px;
  height: 68px;
  border-radius: 50%;
  background: var(--ic-badge-bg, #fff);
  color: var(--ic-badge-text, #111);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.15;
  box-shadow: 0 4px 18px rgba(0,0,0,0.18);
  animation: ic-badge-pop 0.6s cubic-bezier(.34,1.56,.64,1) both;
}
.ic-card__promo-badge .badge-label {
  font-family: 'Barlow', sans-serif;
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.ic-card__promo-badge .badge-value {
  font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: -0.02em;
}
@keyframes ic-badge-pop {
  from { transform: scale(0); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}

/* ── Card content (title + button) ──────────────────────────────────────── */
.ic-card__content {
  padding: {{ section.settings.card_padding }}px;
  background: {{ section.settings.card_content_bg | default: '#fff' }};
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex: 1;
}

/* ── When content is overlaid on image ─────────────────────────────────── */
.ic-card--overlay .ic-card__content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: transparent;
  padding: 20px 18px 20px;
}
.ic-card--overlay .ic-card__title { color: #fff; }

.ic-card__title {
  font-family: 'Barlow Condensed', 'DIN Alternate', Impact, sans-serif;
  font-size: clamp(1.1rem, 1.6vw, 1.35rem);
  font-weight: 800;
  letter-spacing: 0.01em;
  line-height: 1.15;
  color: #111;
  text-transform: uppercase;
}

/* ── Shop Now button ─────────────────────────────────────────────────────── */
.ic-card__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 11px 24px;
  border-radius: 999px;
  background: var(--ic-btn-bg, #fff);
  color: var(--ic-btn-text, #111);
  font-family: 'Barlow', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  text-decoration: none;
  border: 2px solid transparent;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, transform 0.15s, box-shadow 0.2s;
  align-self: flex-start;
  white-space: nowrap;
}
.ic-card__btn:hover {
  transform: scale(1.03);
  box-shadow: 0 6px 20px rgba(0,0,0,0.15);
}
.ic-card__btn:focus-visible {
  outline: 3px solid var(--ic-accent, #f5c842);
  outline-offset: 2px;
}

/* ── Nav arrows ──────────────────────────────────────────────────────────── */
.ic-nav {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 24px;
  padding-right: clamp(1rem, 3vw, 3rem);
}

.ic-nav__btn {
  width: 46px; height: 46px;
  border-radius: 50%;
  border: 2px solid rgba(0,0,0,0.14);
  background: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, border-color 0.2s, transform 0.15s;
  flex-shrink: 0;
}
.ic-nav__btn:hover {
  background: var(--ic-accent, #f5c842);
  border-color: var(--ic-accent, #f5c842);
  transform: scale(1.06);
}
.ic-nav__btn:focus-visible {
  outline: 3px solid var(--ic-accent, #f5c842);
  outline-offset: 2px;
}
.ic-nav__btn svg { width: 18px; height: 18px; stroke: #111; fill: none; }
.ic-nav__btn:disabled { opacity: 0.3; pointer-events: none; }

/* ── Progress bar ────────────────────────────────────────────────────────── */
.ic-progress-wrap {
  margin: 20px clamp(1rem, 3vw, 3rem) 0;
  height: 3px;
  background: rgba(0,0,0,0.1);
  border-radius: 999px;
  overflow: hidden;
}
.ic-progress-bar {
  height: 100%;
  width: 0%;
  background: var(--ic-accent, #f5c842);
  border-radius: 999px;
  transition: width 0.2s;
}

/* ── Mobile overrides ────────────────────────────────────────────────────── */
@media (max-width: 767px) {
  .ic-track {
    grid-auto-columns: calc(
      (100% - (var(--ic-cols-mobile, 1) - 1) * var(--ic-gap, 12px) - var(--ic-peek, 32px))
      / var(--ic-cols-mobile, 1)
    );
  }
  .ic-nav { display: none; } /* arrows hidden on mobile – use swipe */
}

/* ── Load Barlow font from Google (fallback) ─────────────────────────────── */
@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@400;600;700&display=swap');
</style>


{%- comment -%} ════════════════════════════════════════════════════════════
  JAVASCRIPT
════════════════════════════════════════════════════════════════════════════ {%- endcomment -%}
<script>
(function () {
  'use strict';

  function initCarousel(sectionId) {
    var section   = document.getElementById(sectionId);
    if (!section) return;

    var track     = document.getElementById(sectionId + '-track');
    var progressEl= document.getElementById(sectionId + '-progress');
    var prevBtn   = section.querySelector('.ic-nav__btn--prev');
    var nextBtn   = section.querySelector('.ic-nav__btn--next');

    if (!track) return;

    /* ── Scroll helpers ── */
    function getScrollStep() {
      var card = track.querySelector('.ic-card');
      if (!card) return track.clientWidth / 2;
      return card.offsetWidth + parseInt(getComputedStyle(track).columnGap || 16);
    }

    function scrollBy(dir) {
      track.scrollBy({ left: dir * getScrollStep(), behavior: 'smooth' });
    }

    /* ── Update nav state ── */
    function updateNav() {
      var atStart = track.scrollLeft <= 4;
      var atEnd   = track.scrollLeft >= track.scrollWidth - track.clientWidth - 4;
      if (prevBtn) prevBtn.disabled = atStart;
      if (nextBtn) nextBtn.disabled = atEnd;
    }

    /* ── Progress bar ── */
    function updateProgress() {
      if (!progressEl) return;
      var pct = track.scrollWidth <= track.clientWidth
        ? 100
        : (track.scrollLeft / (track.scrollWidth - track.clientWidth)) * 100;
      progressEl.style.width = pct + '%';
    }

    /* ── Arrow clicks ── */
    if (prevBtn) prevBtn.addEventListener('click', function () { scrollBy(-1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { scrollBy(1); });

    /* ── Scroll events ── */
    track.addEventListener('scroll', function () {
      updateNav();
      updateProgress();
    }, { passive: true });

    /* ── Drag to scroll (desktop) ── */
    var isDragging  = false;
    var startX      = 0;
    var scrollStart = 0;

    track.addEventListener('mousedown', function (e) {
      isDragging  = true;
      startX      = e.clientX;
      scrollStart = track.scrollLeft;
      track.classList.add('is-grabbing');
      e.preventDefault();
    });
    document.addEventListener('mousemove', function (e) {
      if (!isDragging) return;
      track.scrollLeft = scrollStart - (e.clientX - startX);
    });
    document.addEventListener('mouseup', function () {
      isDragging = false;
      track.classList.remove('is-grabbing');
    });

    /* ── Init ── */
    updateNav();
    updateProgress();
  }

  /* Run after DOM is ready */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('.image-cards-section').forEach(function (el) {
        initCarousel(el.id);
      });
    });
  } else {
    document.querySelectorAll('.image-cards-section').forEach(function (el) {
      initCarousel(el.id);
    });
  }

  /* Re-init on Shopify theme editor section load/re-render */
  document.addEventListener('shopify:section:load', function (e) {
    var section = e.target.querySelector('.image-cards-section');
    if (section) initCarousel(section.id);
  });

})();
</script>


