  SECTION SCHEMA
════════════════════════════════════════════════════════════════════════════ {%- endcomment -%}
{% schema %}
{
  "name": "Image Cards",
  "tag": "section",
  "class": "section-image-cards",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header",
      "default": true
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (small uppercase)",
      "default": "EFFORTLESS ELEGANCE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore our collection of shoes & bags from chic boots to loafers"
    },
    {
      "type": "text",
      "id": "highlighted_words",
      "label": "Highlighted word(s)",
      "info": "Comma-separated. E.g. shoes & bags, boots",
      "default": "shoes & bags, boots"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Highlight / accent color",
      "default": "#f5c842"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#edf0f8"
    },
    {
      "type": "color",
      "id": "card_content_bg",
      "label": "Card content area background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Promo badge background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Promo badge text color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Card Layout"
    },
    {
      "type": "range",
      "id": "cols_desktop",
      "label": "Cards visible – desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "cols_mobile",
      "label": "Cards visible – mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "overflow_peek",
      "label": "Overflow peek (px) – next card preview",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards (px)",
      "min": 4,
      "max": 48,
      "step": 2,
      "default": 14
    },
    {
      "type": "select",
      "id": "card_ratio",
      "label": "Card image ratio",
      "options": [
        { "value": "0.65", "label": "Wide (3:2)" },
        { "value": "0.78", "label": "Portrait (4:5) – default" },
        { "value": "1",    "label": "Square (1:1)" },
        { "value": "1.33", "label": "Tall (3:4)" }
      ],
      "default": "0.78"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card border radius (px)",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card content padding (px)",
      "min": 8,
      "max": 32,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay darkness (%)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 35
    },
    {
      "type": "header",
      "content": "Navigation & Controls"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show prev/next arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_progress_bar",
      "label": "Show scroll progress bar",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Image Card",
      "settings": [
        {
          "type": "header",
          "content": "Card Image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Product lifestyle image"
