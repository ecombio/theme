{{ 'footer-newsletter.css' | asset_url | stylesheet_tag }}

<div class="footer-newsletter footer-newsletter--{{ section.settings.style }}"
     style="--padding-top: {{ section.settings.padding_top }}px; 
            --padding-bottom: {{ section.settings.padding_bottom }}px;">
  
  <div class="footer-newsletter__text">
    {%- if section.settings.heading != blank -%}
      <p class="footer-newsletter__heading">{{ section.settings.heading | escape }}</p>
    {%- endif -%}
    
    {%- if section.settings.subtext != blank -%}
      <p class="footer-newsletter__subtext">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}
  </div>

  <div class="footer-newsletter__right">
    {%- form 'customer', id: 'footer-newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      <div class="footer-newsletter__form-content" aria-live="polite">
        {%- if form.posted_successfully? -%}
          <div class="footer-newsletter__success-state">
            <p class="footer-newsletter__success">
              {{- 'general.newsletter.confirmation' | t -}}
            </p>
            <p class="footer-newsletter__success-sub">
              {{- section.settings.success_message | default: "You're all set. Check your inbox for confirmation." -}}
            </p>
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <p class="footer-newsletter__error" role="alert">
              {{- form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] -}}
            </p>
          {%- endif -%}

          <div class="footer-newsletter__input-wrap">
            <div class="footer-newsletter__input-inner">
              <input
                type="email"
                name="contact[email]"
                id="footer-newsletter-email"
                placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
                value="{{ form.email }}"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                aria-label="{{ 'general.newsletter.email_placeholder' | t }}"
                required
              >
            </div>

            <button type="submit" class="footer-newsletter__btn">
              {{- section.settings.button_label | default: 'Subscribe' -}}
              <span class="footer-newsletter__btn-arrow">→</span>
            </button>
          </div>

          {%- if section.settings.privacy_note != blank -%}
            <p class="footer-newsletter__privacy">{{ section.settings.privacy_note | escape }}</p>
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Footer newsletter",
  "tag": "section",
  "class": "footer-newsletter-section",
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "options": [
        { "value": "clean", "label": "Clean (Recommended)" },
        { "value": "elevated", "label": "Elevated" }
      ],
      "default": "clean"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay in the loop"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Be the first to know about new drops, exclusive deals, and tech that actually matters."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "name@email.com"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're all set. Check your inbox for confirmation."
    },
    {
      "type": "text",
      "id": "privacy_note",
      "label": "Privacy note",
      "default": "We respect your inbox. Unsubscribe anytime."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Footer newsletter"
    }
  ]
}
{% endschema %}