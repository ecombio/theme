{{ 'footer-newsletter.css' | asset_url | stylesheet_tag }}

<section
  class="footer-newsletter color-{{ section.settings.color_scheme }}"
  style="--fn-padding-top: {{ section.settings.padding_top }}px; --fn-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
  data-section-type="footer-newsletter"
>
  <div class="footer-newsletter__inner page-width">
    <div class="footer-newsletter__content footer-newsletter__content--{{ section.settings.layout }}">

      <div class="footer-newsletter__text">
        {% if section.settings.heading != blank %}
          <h2 class="footer-newsletter__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <div class="footer-newsletter__subheading">{{ section.settings.subheading }}</div>
        {% endif %}
      </div>

      <div class="footer-newsletter__form-wrap">
        {% form 'customer', id: 'FooterNewsletterForm', class: 'footer-newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">

          {% if form.posted_successfully? %}
            <div class="footer-newsletter__message footer-newsletter__message--success" role="status" tabindex="-1" data-fn-success>
              {{ section.settings.success_message | default: 'Thanks for subscribing!' }}
            </div>
          {% else %}

            {% if form.errors %}
              <div class="footer-newsletter__message footer-newsletter__message--error" role="alert" data-fn-error>
                {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
              </div>
            {% endif %}

            <div class="footer-newsletter__fields">
              <div class="footer-newsletter__field">
                <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">
                  {{ section.settings.placeholder | default: 'Email address' }}
                </label>
                <input
                  type="email"
                  id="NewsletterEmail-{{ section.id }}"
                  name="contact[email]"
                  class="footer-newsletter__input"
                  value="{{ form.email }}"
                  placeholder="{{ section.settings.placeholder | default: 'Email address' }}"
                  autocomplete="email"
                  autocorrect="off"
                  autocapitalize="off"
                  required
                  data-fn-email-input
                >
              </div>

              <button
                type="submit"
                class="footer-newsletter__submit button"
                name="commit"
                data-fn-submit
              >
                <span data-fn-submit-text>{{ section.settings.button_label | default: 'Subscribe' }}</span>
              </button>
            </div>

            <div class="footer-newsletter__inline-error" data-fn-inline-error hidden>
              {{ section.settings.invalid_email_message | default: 'Please enter a valid email address.' }}
            </div>

          {% endif %}
        {% endform %}
      </div>

    </div>
  </div>
</section>

<script src="{{ 'footer-newsletter.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Footer Newsletter",
  "class": "shopify-section--footer-newsletter",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "stacked", "label": "Stacked" },
        { "value": "side-by-side", "label": "Side by side" }
      ],
      "default": "side-by-side"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe to our newsletter"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Get the latest news, updates and offers straight to your inbox.</p>"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder text",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for subscribing!"
    },
    {
      "type": "text",
      "id": "invalid_email_message",
      "label": "Invalid email message",
      "default": "Please enter a valid email address."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Footer Newsletter"
    }
  ]
}
{% endschema %}