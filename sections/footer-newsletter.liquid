{{ 'footer-newsletter.css' | asset_url | stylesheet_tag }}

<div class="footer-newsletter" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="footer-newsletter__text">
    {%- if section.settings.heading != blank -%}
      <p class="footer-newsletter__heading">{{ section.settings.heading }}</p>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="footer-newsletter__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
  </div>

  <div class="footer-newsletter__right">
    {%- form 'customer', id: 'footer-newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <p class="footer-newsletter__success">
          {{- 'general.newsletter.confirmation' | t -}}
        </p>
      {%- elsif form.errors -%}
        <p class="footer-newsletter__error">
          {{- form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] -}}
        </p>
      {%- endif -%}

      <div class="footer-newsletter__input-wrap">
        <div class="footer-newsletter__input-inner">
          <input
            type="email"
            name="contact[email]"
            id="footer-newsletter-email"
            placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
            value="{{ form.email }}"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            aria-label="{{ 'general.newsletter.email_placeholder' | t }}"
            {% if form.posted_successfully? %}disabled{% endif %}
          >
          <svg class="footer-newsletter__mail-icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m2 7 10 7 10-7"/>
          </svg>
        </div>

        <button type="submit" class="footer-newsletter__btn">
          {{- section.settings.button_label | default: 'Sign up' -}}
        </button>
      </div>
    {%- endform -%}

    {%- if section.settings.show_learn_more and section.settings.learn_more_url != blank -%}
      <a href="{{ section.settings.learn_more_url }}" class="footer-newsletter__learn-more">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6"/>
        </svg>
        {{- 'general.newsletter.learn_more' | t | default: 'Learn more' -}}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Footer newsletter",
  "tag": "section",
  "class": "footer-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay in the loop with hot drops"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Be the first to know about new arrivals, exclusive deals, and tech news that matters."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Sign up"
    },
    {
      "type": "header",
      "content": "Learn more link"
    },
    {
      "type": "checkbox",
      "id": "show_learn_more",
      "label": "Show learn more link",
      "default": true
    },
    {
      "type": "url",
      "id": "learn_more_url",
      "label": "Learn more URL"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Footer newsletter"
    }
  ]
}
{% endschema %}