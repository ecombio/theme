{%- comment -%}
  sections/product-carousel.liquid
  A horizontally-scrolling product carousel.
  Reuses card-product.liquid snippet — ATC button is intentionally excluded
  via enable_atc: false (the section setting is never surfaced in schema).
{%- endcomment -%}

{%- liquid
  assign heading      = section.settings.heading
  assign subheading   = section.settings.subheading
  assign show_vendor  = section.settings.show_vendor
  assign show_compare = section.settings.show_compare_at_price
  assign cards_desk   = section.settings.cards_per_row_desktop
  assign cards_mob    = section.settings.cards_per_row_mobile
  assign show_arrows  = section.settings.show_arrows
  assign show_dots    = section.settings.show_dots
  assign autoplay     = section.settings.autoplay
  assign autoplay_ms  = section.settings.autoplay_interval | times: 1000
-%}

{{ 'product-carousel.css' | asset_url | stylesheet_tag }}

<section
  class="product-carousel"
  id="product-carousel-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-cards-desktop="{{ cards_desk }}"
  data-cards-mobile="{{ cards_mob }}"
  data-autoplay="{{ autoplay }}"
  data-autoplay-interval="{{ autoplay_ms }}"
>

  {%- if heading != blank or subheading != blank -%}
    <div class="product-carousel__header">
      {%- if heading != blank -%}
        <h2 class="product-carousel__heading">{{ heading }}</h2>
      {%- endif -%}
      {%- if subheading != blank -%}
        <p class="product-carousel__subheading">{{ subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="product-carousel__stage">

    {%- if show_arrows -%}
      <button
        class="product-carousel__arrow product-carousel__arrow--prev"
        type="button"
        aria-label="Previous products"
        data-carousel-prev
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    {%- endif -%}

    <div class="product-carousel__track-wrapper" data-carousel-wrapper>
      <ul
        class="product-carousel__track"
        data-carousel-track
        role="list"
        aria-label="{{ heading | default: 'Products' | escape }}"
      >
        {%- for block in section.blocks -%}
          {%- assign p = block.settings.product -%}
          {%- if p != blank -%}
            <li
              class="product-carousel__slide"
              data-carousel-slide
              {{ block.shopify_attributes }}
            >
              {%- render 'card-product',
                product:               p,
                show_vendor:           show_vendor,
                show_compare_at_price: show_compare,
                section: section
              -%}
            </li>
          {%- else -%}
            {%- comment -%} Placeholder in the editor when no product is picked yet {%- endcomment -%}
            <li class="product-carousel__slide product-carousel__slide--placeholder" {{ block.shopify_attributes }}>
              <div class="card-product card-product--placeholder">
                <div class="card-product__img-zone">
                  <div class="card-product__image-placeholder" aria-hidden="true">
                    {{ 'product-1' | placeholder_svg_tag: 'card-product__placeholder-svg' }}
                  </div>
                </div>
                <div class="card-product__content">
                  <span class="card-product__vendor">Brand</span>
                  <span class="card-product__title">Sample product title</span>
                  <div class="card-product__pricing">
                    <span class="card-product__price">$00.00</span>
                  </div>
                </div>
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    {%- if show_arrows -%}
      <button
        class="product-carousel__arrow product-carousel__arrow--next"
        type="button"
        aria-label="Next products"
        data-carousel-next
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    {%- endif -%}

  </div><!-- /.product-carousel__stage -->

  {%- if show_dots -%}
    <div class="product-carousel__dots" data-carousel-dots aria-hidden="true"></div>
  {%- endif -%}

</section>

<script src="{{ 'product-carousel.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "class": "section-product-carousel",
  "max_blocks": 24,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Card options"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_compare_at_price",
      "label": "Show compare-at price",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "cards_per_row_desktop",
      "label": "Cards visible — desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "cards_per_row_mobile",
      "label": "Cards visible — mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Controls"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show prev / next arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dot indicators",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Autoplay interval (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Feature flags (shared with card)"
    },
    {
      "type": "checkbox",
      "id": "enable_quickview",
      "label": "Enable quick view",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_compare",
      "label": "Enable compare",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_wishlist",
      "label": "Enable wishlist",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_eta",
      "label": "Show estimated arrival",
      "default": false
    },
    {
      "type": "number",
      "id": "eta_days_min",
      "label": "ETA min days",
      "default": 3
    },
    {
      "type": "number",
      "id": "eta_days_max",
      "label": "ETA max days",
      "default": 7
    },
    {
      "type": "text",
      "id": "eta_label",
      "label": "ETA label",
      "default": "Est. arrival:"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Carousel",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}