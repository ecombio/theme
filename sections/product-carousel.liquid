{%- comment -%}
  sections/product-carousel.liquid
  Uses card-product.liquid — enable_atc is intentionally false.
  All card feature flags are driven by this section's own settings.
{%- endcomment -%}

{%- liquid
  assign heading       = section.settings.heading
  assign subheading    = section.settings.subheading
  assign show_vendor   = section.settings.show_vendor
  assign show_compare  = section.settings.show_compare_at_price
  assign cards_desk    = section.settings.cards_per_row_desktop | default: 3
  assign cards_mob     = section.settings.cards_per_row_mobile  | default: 1
  assign show_arrows   = section.settings.show_arrows
  assign show_dots     = section.settings.show_dots
  assign autoplay      = section.settings.autoplay
  assign autoplay_ms   = section.settings.autoplay_interval | default: 4 | times: 1000
  assign banner_show   = section.settings.show_banner
  assign banner_image  = section.settings.banner_image
  assign banner_link   = section.settings.banner_link
  assign placeholder_count = 4
-%}

{{ 'product-carousel.css' | asset_url | stylesheet_tag }}

<section
  class="product-carousel"
  id="pc-section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-cards-desktop="{{ cards_desk }}"
  data-cards-mobile="{{ cards_mob }}"
  data-autoplay="{{ autoplay }}"
  data-autoplay-interval="{{ autoplay_ms }}"
>

  <div class="product-carousel__layout{% if banner_show %} product-carousel__layout--has-banner{% endif %}">

    {%- comment -%}── BANNER ──{%- endcomment -%}
    {%- if banner_show -%}
      <div class="product-carousel__banner">
        {%- if banner_link != blank -%}<a href="{{ banner_link }}" class="product-carousel__banner-link">{%- endif -%}
        {%- if banner_image != blank -%}
          {{
            banner_image
            | image_url: width: 800
            | image_tag:
              class: 'product-carousel__banner-img',
              loading: 'lazy',
              widths: '200, 300, 400, 600',
              sizes: '(max-width: 767px) 100vw, 260px',
              alt: banner_image.alt | default: heading | escape
          }}
        {%- else -%}
          <div class="product-carousel__banner-placeholder" aria-hidden="true">
            {{ 'collection-1' | placeholder_svg_tag: 'product-carousel__banner-placeholder-svg' }}
          </div>
        {%- endif -%}
        {%- if banner_link != blank -%}</a>{%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%}── CAROUSEL COLUMN ──{%- endcomment -%}
    <div class="product-carousel__carousel-col">

      {%- if heading != blank or subheading != blank -%}
        <div class="product-carousel__header">
          {%- if heading != blank -%}<h2 class="product-carousel__heading">{{ heading }}</h2>{%- endif -%}
          {%- if subheading != blank -%}<p class="product-carousel__subheading">{{ subheading }}</p>{%- endif -%}
        </div>
      {%- endif -%}

      <div class="product-carousel__stage">

        {%- if show_arrows -%}
          <button class="product-carousel__arrow product-carousel__arrow--prev" type="button" aria-label="Previous products" data-carousel-prev>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M11 14L6 9L11 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}

        <div class="product-carousel__track-wrapper" data-carousel-wrapper>
          <ul class="product-carousel__track" data-carousel-track role="list" aria-label="{{ heading | default: 'Products' | escape }}">

            {%- if section.blocks.size > 0 -%}
              {%- for block in section.blocks -%}
                {%- assign p = block.settings.product -%}
                <li class="product-carousel__slide" data-carousel-slide {{ block.shopify_attributes }}>
                  {%- if p != blank -%}
                    {%- render 'card-product',
                      product:               p,
                      show_vendor:           show_vendor,
                      show_compare_at_price: show_compare,
                      section:               section
                    -%}
                  {%- else -%}
                    <div class="pc-placeholder-card">
                      <div class="pc-placeholder-card__image">
                        {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'pc-placeholder-card__svg' }}
                      </div>
                      <div class="pc-placeholder-card__body">
                        <div class="pc-placeholder-card__line pc-placeholder-card__line--vendor"></div>
                        <div class="pc-placeholder-card__line pc-placeholder-card__line--title"></div>
                        <div class="pc-placeholder-card__line pc-placeholder-card__line--title pc-placeholder-card__line--title-short"></div>
                        <div class="pc-placeholder-card__line pc-placeholder-card__line--price"></div>
                      </div>
                    </div>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            {%- else -%}
              {%- for i in (1..placeholder_count) -%}
                <li class="product-carousel__slide" data-carousel-slide>
                  <div class="pc-placeholder-card">
                    <div class="pc-placeholder-card__image">
                      {{ 'product-' | append: i | placeholder_svg_tag: 'pc-placeholder-card__svg' }}
                    </div>
                    <div class="pc-placeholder-card__body">
                      <div class="pc-placeholder-card__line pc-placeholder-card__line--vendor"></div>
                      <div class="pc-placeholder-card__line pc-placeholder-card__line--title"></div>
                      <div class="pc-placeholder-card__line pc-placeholder-card__line--title pc-placeholder-card__line--title-short"></div>
                      <div class="pc-placeholder-card__line pc-placeholder-card__line--price"></div>
                    </div>
                  </div>
                </li>
              {%- endfor -%}
            {%- endif -%}

          </ul>
        </div>

        {%- if show_arrows -%}
          <button class="product-carousel__arrow product-carousel__arrow--next" type="button" aria-label="Next products" data-carousel-next>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M7 4L12 9L7 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}

      </div><!-- /.product-carousel__stage -->

      {%- if show_dots -%}
        <div class="product-carousel__dots" data-carousel-dots aria-hidden="true"></div>
      {%- endif -%}

    </div><!-- /.product-carousel__carousel-col -->
  </div><!-- /.product-carousel__layout -->

</section>

<script src="{{ 'product-carousel.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "class": "section-product-carousel",
  "max_blocks": 24,
  "settings": [
    {
      "type": "header",
      "content": "Banner"
    },
    {
      "type": "checkbox",
      "id": "show_banner",
      "label": "Show banner",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Card options"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_compare_at_price",
      "label": "Show compare-at price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_quickview",
      "label": "Enable quick view",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_wishlist",
      "label": "Enable wishlist",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_atc",
      "label": "Show Add to cart button",
      "default": false,
      "info": "Disabled by default for browse-focused carousels"
    },
    {
      "type": "checkbox",
      "id": "enable_compare",
      "label": "Enable compare",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_eta",
      "label": "Show estimated arrival",
      "default": false
    },
    {
      "type": "number",
      "id": "eta_days_min",
      "label": "ETA min days",
      "default": 3
    },
    {
      "type": "number",
      "id": "eta_days_max",
      "label": "ETA max days",
      "default": 7
    },
    {
      "type": "text",
      "id": "eta_label",
      "label": "ETA label",
      "default": "Est. arrival:"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "cards_per_row_desktop",
      "label": "Cards visible — desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "cards_per_row_mobile",
      "label": "Cards visible — mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "header",
      "content": "Controls"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show prev / next arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dot indicators",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Autoplay interval (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Carousel",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}