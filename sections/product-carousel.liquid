{{ 'product-carousel.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign products   = section.settings.collection.products
  assign has_banner = false
  if section.settings.banner_image != blank
    assign has_banner = true
  endif
-%}

<div
  class="product-carousel-section"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  "
>
  <div class="product-carousel-section__inner{% if has_banner %} product-carousel-section__inner--with-banner{% endif %} page-width">

    {%- if has_banner -%}
      <div class="product-carousel-banner">
        <a
          href="{{ section.settings.banner_link | default: '#' }}"
          class="product-carousel-banner__link"
          {%- if section.settings.banner_link == blank %} tabindex="-1" aria-disabled="true"{% endif %}
        >
          <img
            class="product-carousel-banner__image"
            src="{{ section.settings.banner_image | image_url: width: 800 }}"
            srcset="
              {{ section.settings.banner_image | image_url: width: 400 }} 400w,
              {{ section.settings.banner_image | image_url: width: 800 }} 800w,
              {{ section.settings.banner_image | image_url: width: 1200 }} 1200w
            "
            sizes="(min-width: 990px) 320px, (min-width: 750px) 45vw, 100vw"
            alt="{{ section.settings.banner_image.alt | default: section.settings.heading | escape }}"
            loading="lazy"
            width="{{ section.settings.banner_image.width }}"
            height="{{ section.settings.banner_image.height }}"
          >
          {%- if section.settings.banner_heading != blank or section.settings.banner_subheading != blank -%}
            <span class="product-carousel-banner__overlay">
              {%- if section.settings.banner_heading != blank -%}
                <span class="product-carousel-banner__heading">{{ section.settings.banner_heading }}</span>
              {%- endif -%}
              {%- if section.settings.banner_subheading != blank -%}
                <span class="product-carousel-banner__subheading">{{ section.settings.banner_subheading }}</span>
              {%- endif -%}
            </span>
          {%- endif -%}
        </a>
      </div>
    {%- endif -%}

    <div class="product-carousel-content">

      {%- if section.settings.heading != blank -%}
        <div class="product-carousel-section__header">
          <div class="product-carousel-section__header-top">
            <h2 class="product-carousel-section__heading">{{ section.settings.heading }}</h2>
            {%- if section.settings.show_view_all and section.settings.collection != blank -%}
              <a href="{{ section.settings.collection.url }}" class="product-carousel-section__view-all">
                {{ section.settings.view_all_label | default: 'View all' }}
              </a>
            {%- endif -%}
          </div>
          {%- if section.settings.subheading != blank -%}
            <p class="product-carousel-section__subheading">{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="product-carousel" data-product-carousel>
        <div class="product-carousel__track" data-product-carousel-track>
          {%- if products.size > 0 -%}
            {%- for product in products limit: section.settings.products_to_show -%}
              <div class="product-carousel__slide">
                {%- render 'card-product',
                  product: product,
                  show_vendor: section.settings.show_vendor,
                  show_compare_at_price: section.settings.show_compare_at_price,
                  enable_atc: section.settings.enable_atc,
                  enable_quickview: section.settings.enable_quickview,
                  enable_wishlist: section.settings.enable_wishlist,
                  enable_compare: section.settings.enable_compare,
                  show_eta: section.settings.show_eta,
                  eta_days_max: section.settings.eta_days_max,
                  eta_label: section.settings.eta_label
                -%}
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..4) -%}
              <div class="product-carousel__slide">
                {%- render 'card-product', product: null -%}
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>

        <button type="button" class="product-carousel__btn product-carousel__btn--prev" data-product-carousel-prev aria-label="Previous">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button type="button" class="product-carousel__btn product-carousel__btn--next" data-product-carousel-next aria-label="Next">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>

    </div>
  </div>
</div>

<script src="{{ 'product-carousel.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Product carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Number of products",
      "default": 8
    },
    {
      "type": "header",
      "content": "Card features"
    },
    {
      "type": "checkbox",
      "id": "enable_atc",
      "label": "Show Add to Cart button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_quickview",
      "label": "Show Quick View button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_wishlist",
      "label": "Show Wishlist button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_compare",
      "label": "Show Compare checkbox",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_compare_at_price",
      "label": "Show compare-at price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_eta",
      "label": "Show estimated delivery",
      "default": true
    },
    {
      "type": "header",
      "content": "View all"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "'View all' label",
      "default": "View all"
    },
    {
      "type": "header",
      "content": "Banner"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image",
      "info": "Optional. Displays beside the carousel."
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    },
    {
      "type": "text",
      "id": "banner_heading",
      "label": "Banner heading"
    },
    {
      "type": "text",
      "id": "banner_subheading",
      "label": "Banner subheading"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Product carousel"
    }
  ]
}
{% endschema %}