{% comment %}
  sections/product-feed.liquid

  Standalone product grid section.
  Derived from snippets/collection-products.liquid (collection-feed [1.2.1]).

  Intentionally dropped from the original:
    - Tab bar (was collection-feed.liquid's job, not this grid's)
    - Sponsored-ad row injection (was block-driven ad placement —
      pull this back in later as its own concern if/when needed)

  Works on the collection template (uses the page's `collection` object).
  If placed elsewhere, falls back to a collection chosen in the section settings.

  CSS: collection-products.css, product-card.css
{% endcomment %}

{{ 'product-feed.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign columns = section.settings.columns | default: 4

  if collection != blank
    assign feed_collection = collection
  elsif section.settings.collection != blank
    assign feed_collection = section.settings.collection
  endif
-%}

<div
  class="product-feed"
  style="--product-feed-columns: {{ columns }};"
  data-product-feed
>

  {%- if feed_collection.products != blank -%}

    {%- paginate feed_collection.products by section.settings.products_per_page -%}

      <div class="product-feed__grid">
        {%- assign row_index = 0 -%}
        {%- for product in feed_collection.products -%}

          {%- render 'product-card', product: product -%}

          {%- assign position_mod = forloop.index | modulo: columns -%}
          {%- if position_mod == 0 and forloop.last == false -%}
            {%- assign row_index = row_index | plus: 1 -%}
            </div>
            {%- for block in section.blocks -%}
              {%- if block.type == 'in_feed_unit' and block.settings.row == row_index -%}
                {%- render 'in-feed-unit', block: block -%}
              {%- endif -%}
            {%- endfor -%}
            <div class="product-feed__grid">
          {%- elsif forloop.last -%}
            {%- assign row_index = row_index | plus: 1 -%}
          {%- endif -%}

        {%- endfor -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'in_feed_unit' and block.settings.row == row_index -%}
          {%- render 'in-feed-unit', block: block -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if paginate.pages > 1 -%}
        <nav
          class="product-feed__pagination"
          aria-label="{{ 'general.pagination.label' | t }}"
        >
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="product-feed__page-link">
              &larr; {{ 'general.pagination.previous' | t }}
            </a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="product-feed__page-link">
                {{ part.title }}
              </a>
            {%- else -%}
              <span class="product-feed__page-link product-feed__page-link--current" aria-current="page">
                {{ part.title }}
              </span>
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="product-feed__page-link">
              {{ 'general.pagination.next' | t }} &rarr;
            </a>
          {%- endif -%}
        </nav>
      {%- endif -%}

    {%- endpaginate -%}

  {%- else -%}

    <p class="product-feed__empty">
      {{ 'collections.general.no_matches' | t }}
    </p>

  {%- endif -%}

</div>

{% schema %}
{
  "name": "Product feed",
  "tag": "section",
  "class": "section-product-feed",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used only if this section is placed outside the collection template."
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "in_feed_unit",
      "name": "In-feed unit",
      "settings": [
        {
          "type": "number",
          "id": "row",
          "label": "Insert after row",
          "info": "1 = after the first row of products, 2 = after the second row, etc."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product feed"
    }
  ]
}
{% endschema %}