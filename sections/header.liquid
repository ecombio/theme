<!--
  ============================================================================
  sections/header.liquid
  ============================================================================

  4 ROWS, TOP TO BOTTOM:
    1. .header__promo   — navy bar, live countdown (hidden when toggled off)
    2. .header__utility — page links + Shopify localization form
    3. .header__main    — logo, search, account, cart
    4. .header__menu    — block-driven nav (link / linklist / mega / promo)

  NAV BLOCKS:
    Each block in section.blocks becomes one item in the menu bar.
    Merchants add, remove, and reorder blocks in the theme editor.
    Types: link | linklist | mega | promo
  ============================================================================
-->

<header class="header" data-header>

  <!-- ROW 1: PROMO BAR ───────────────────────────────────────────────────── -->
  {% if section.settings.show_promo %}
    {% render 'header-promo',
       promo_text:    section.settings.promo_text,
       sale_end_time: section.settings.sale_end_time
    %}
  {% endif %}

  <!-- ROW 2: UTILITY BAR ─────────────────────────────────────────────────── -->
  {% render 'header-utility' %}

  <!-- ROW 3: MAIN BAR ────────────────────────────────────────────────────── -->
  <div class="header__main">
    <div class="header__main-inner page-width">

      {% render 'header-logo',
         logo:               settings.logo,
         logo_width_desktop: settings.logo_width_desktop,
         logo_width_tablet:  settings.logo_width_tablet,
         logo_width_mobile:  settings.logo_width_mobile
      %}

      {% render 'header-search',
         placeholder: section.settings.search_placeholder
      %}

      <div class="header__main-right">
        {% render 'header-account' %}
        {% render 'header-cart' %}
      </div>

    </div>
  </div>

  <!-- ROW 4: MENU BAR ────────────────────────────────────────────────────── -->
  {% render 'header-menu', blocks: section.blocks %}

</header>


{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [

    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder text",
      "default": "What are you looking for?"
    },

    {
      "type": "header",
      "content": "Promo bar"
    },
    {
      "type": "checkbox",
      "id": "show_promo",
      "label": "Show promo bar",
      "default": true
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Promo message",
      "default": "🛎️ Hurry! Sale ends in..."
    },
    {
      "type": "text",
      "id": "sale_end_time",
      "label": "Sale end date/time",
      "info": "ISO 8601 format, e.g. 2025-12-31T23:59:59",
      "default": "2027-12-31T23:59:59"
    }

  ],

  "blocks": [

    {
      "type": "link",
      "name": "Single link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight (deals styling)",
          "default": false
        }
      ]
    },

    {
      "type": "linklist",
      "name": "Link list",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu source"
        }
      ]
    },

    {
      "type": "mega",
      "name": "Mega menu",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Mega menu source",
          "info": "3 levels: column → subheading → links"
        },
        {
          "type": "checkbox",
          "id": "show_products",
          "label": "Show product grid",
          "default": false
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Products collection",
          "info": "Shown when 'Show product grid' is enabled"
        },
        {
          "type": "range",
          "id": "product_limit",
          "label": "Number of products",
          "min": 2,
          "max": 6,
          "step": 1,
          "default": 4
        }
      ]
    },

    {
      "type": "promo",
      "name": "In-menu promo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Button link"
        }
      ]
    }

  ],

  "presets": [
    {
      "name": "Header",
      "blocks": [
        { "type": "link" },
        { "type": "linklist" }
      ]
    }
  ]
}
{% endschema %}
