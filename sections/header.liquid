<header class="header" data-header>

  {%- comment -%} ── TOP BAR: promo text + account ── {%- endcomment -%}
  <div class="header__top">
    <div class="header__top-inner page-width">
      {%- if section.settings.promo_text != blank -%}
        <p class="header__promo">{{ section.settings.promo_text }}</p>
      {%- endif -%}

      <div class="header__top-icons">
        {%- if shop.customer_accounts_enabled -%}
          <shopify-account menu="{{ section.settings.customer_account_menu }}">
            {{ 'icon-account.svg' | inline_asset_content }}
          </shopify-account>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} ── MIDDLE BAR: logo + cart ── {%- endcomment -%}
  <div class="header__middle">
    <div class="header__middle-inner page-width">
      <h2 class="header__title">
        {{ shop.name | link_to: routes.root_url }}
      </h2>

      <div class="header__middle-icons">
        <a
          href="{{ routes.cart_url }}"
          class="header__cart"
          aria-label="Cart ({{ cart.item_count }})"
          data-cart-icon-btn
        >
          {%- if cart.item_count > 0 -%}
            <span class="header__cart-count" aria-hidden="true" data-cart-count>{{ cart.item_count }}</span>
          {%- else -%}
            <span class="header__cart-count header__cart-count--hidden" aria-hidden="true" data-cart-count></span>
          {%- endif -%}
          {{ 'icon-cart.svg' | inline_asset_content }}
        </a>

        {%- comment -%} Mobile menu toggle — visible on small screens only {%- endcomment -%}
        <button
          class="header__menu-toggle"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="header-nav"
          data-menu-toggle
        >
          <span class="header__menu-toggle-bar"></span>
          <span class="header__menu-toggle-bar"></span>
          <span class="header__menu-toggle-bar"></span>
        </button>
      </div>
    </div>
  </div>

  {%- comment -%} ── BOTTOM BAR: primary nav ── {%- endcomment -%}
  <nav
    id="header-nav"
    class="header__bottom"
    aria-label="Main navigation"
    data-nav
  >
    <div class="header__bottom-inner page-width">
      {%- for link in section.settings.menu.links -%}
        <a
          class="header__nav-link{% if link.active %} is-active{% endif %}"
          href="{{ link.url }}"
          {%- if link.active %} aria-current="page"{% endif %}
        >
          {{ link.title }}
        </a>
      {%- endfor -%}
    </div>
  </nav>

</header>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "text",
      "id": "promo_text",
      "label": "Top bar promo text",
      "placeholder": "Free shipping on orders over $50"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
