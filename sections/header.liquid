<!--
  ============================================================================
  sections/header.liquid
  ============================================================================

  4 ROWS, TOP TO BOTTOM:
    1. .header__promo   — navy bar, live countdown (hidden when toggled off)
    2. .header__utility — page links + Shopify localization form
    3. .header__main    — logo, search, account, cart
    4. .header__menu    — block-driven nav (link / linklist / mega)

  NAV BLOCKS:
    link      — single anchor
    linklist  — dropdown from a Shopify menu
    mega      — full-width panel with 3-level link columns
  ============================================================================
-->

<header class="header" data-header>

  <!-- ROW 1: PROMO BAR ───────────────────────────────────────────────────── -->
  {% if section.settings.show_promo %}
    {% render 'header-promo',
       promo_text:    section.settings.promo_text,
       sale_end_time: section.settings.sale_end_time
    %}
  {% endif %}

  <!-- ROW 2: UTILITY BAR ─────────────────────────────────────────────────── -->
  {% render 'header-utility',
     header_style:  section.settings.utility_style,
     links:         section.settings.utility_links,
     show_currency: section.settings.show_currency,
     show_locale:   section.settings.show_locale
  %}

  <!-- ROW 3: MAIN BAR ────────────────────────────────────────────────────── -->
  <div class="header__main">
    <div class="header__main-inner page-width">

      {% render 'header-logo',
         logo:               settings.logo,
         logo_width_desktop: settings.logo_width_desktop,
         logo_width_tablet:  settings.logo_width_tablet,
         logo_width_mobile:  settings.logo_width_mobile
      %}

      {% render 'header-search',
         placeholder: section.settings.search_placeholder
      %}

      <div class="header__main-right">
        {% render 'header-account' %}
        {% render 'header-cart' %}
      </div>

    </div>
  </div>

  <!-- ROW 4: MENU BAR ────────────────────────────────────────────────────── -->
  {% render 'header-menu', blocks: section.blocks %}

</header>


{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [

    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder text",
      "default": "What are you looking for?"
    },

    {
      "type": "header",
      "content": "Promo bar"
    },
    {
      "type": "checkbox",
      "id": "show_promo",
      "label": "Show promo bar",
      "default": true
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Promo message",
      "default": "🛎️ Hurry! Sale ends in..."
    },
    {
      "type": "text",
      "id": "sale_end_time",
      "label": "Sale end date/time",
      "info": "ISO 8601 format, e.g. 2025-12-31T23:59:59",
      "default": "2027-12-31T23:59:59"
    },

    {
      "type": "header",
      "content": "Utility bar"
    },
    {
      "type": "select",
      "id": "utility_style",
      "label": "Style",
      "options": [
        { "value": "hyper", "label": "Hyper (white background)" },
        { "value": "focus", "label": "Focus (muted background)" }
      ],
      "default": "hyper"
    },
    {
      "type": "textarea",
      "id": "utility_links",
      "label": "Utility links",
      "info": "One per line or comma-separated. Format: Label|/url",
      "default": "Track My Order|/pages/track-my-order, Store Finder|/pages/store-finder, Help Centre|/pages/help-centre"
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "label": "Show currency selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_locale",
      "label": "Show language selector",
      "default": true
    }

  ],

  "blocks": [

    {
      "type": "link",
      "name": "Single link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight",
          "info": "Renders the link in accent colour",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "fancy_highlight",
          "label": "Fancy highlight",
          "info": "Pill + animated sparkle stars. Requires Highlight to also be enabled.",
          "default": false
        }
      ]
    },

    {
      "type": "linklist",
      "name": "Link list",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu source"
        }
      ]
    },

    {
      "type": "mega",
      "name": "Mega menu",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu source",
          "info": "3 levels: column heading → subheading → links"
        }
      ]
    }

  ],

  "presets": [
    {
      "name": "Header",
      "blocks": [
        { "type": "link" },
        { "type": "linklist" }
      ]
    }
  ]
}
{% endschema %}