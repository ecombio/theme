{{ 'mw-image-grid.css' | asset_url | stylesheet_tag }}

<div class="mw-grid-wrap" style="background-color: {{ section.settings.bg_color }};">
  {% if section.settings.heading != blank %}
    <h2 class="mw-grid-heading">{{ section.settings.heading | escape }}</h2>
  {% endif %}

  <div class="mw-grid-cards">
    {% for block in section.blocks %}
      {% if block.type == 'card' %}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="mw-grid-card"
          style="background-color: {{ block.settings.card_color }};"
          {{ block.shopify_attributes }}
        >
          <div class="mw-grid-card__media">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
                  widths: '150, 300, 450, 600',
                  class: 'mw-grid-card__img'
              }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'mw-grid-card__img mw-grid-card__placeholder' }}
            {% endif %}
          </div>
          {% if block.settings.label != blank %}
            <p class="mw-grid-card__label">{{ block.settings.label | escape }}</p>
          {% endif %}
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "MW Image Grid",
  "tag": "section",
  "class": "mw-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop our most wanted"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#F5F6F7"
    },
    {
      "type": "range",
      "id": "cards_desktop",
      "label": "Cards per row — desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "cards_tablet",
      "label": "Cards per row — tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "cards_mobile",
      "label": "Cards per row — mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards (px)",
      "min": 4,
      "max": 32,
      "step": 2,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "color",
          "id": "card_color",
          "label": "Card background color",
          "default": "#E9F687"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MW Image Grid",
      "blocks": [
        { "type": "card", "settings": { "label": "Great deals" } },
        { "type": "card", "settings": { "label": "iPhone" } },
        { "type": "card", "settings": { "label": "MacBook" } },
        { "type": "card", "settings": { "label": "iPad" } },
        { "type": "card", "settings": { "label": "Video game consoles" } },
        { "type": "card", "settings": { "label": "Android" } },
        { "type": "card", "settings": { "label": "Windows Laptops" } },
        { "type": "card", "settings": { "label": "Airpods" } }
      ]
    }
  ]
}
{% endschema %}
