{{ 'blog.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign show_image       = section.settings.show_image
  assign columns          = section.settings.columns | default: 3
  assign per_page         = section.settings.per_page | default: 6
  assign pagination_style = section.settings.pagination_style | default: 'numbered'

  if current_tags.size > 0
    assign raw_tag     = current_tags | join: ' & '
    assign tag_words   = raw_tag | replace: '-', ' ' | split: ' '
    assign display_tag = ''
    for word in tag_words
      assign cap_word    = word | capitalize
      assign display_tag = display_tag | append: cap_word | append: ' '
    endfor
    assign display_tag = display_tag | strip
    assign page_title  = display_tag
  else
    assign page_title = blog.title | escape
  endif
-%}

{%- paginate blog.articles by per_page -%}

<div class="blog-feed">

  <h1 class="blog-feed__title">{{ page_title }}</h1>

  <div class="blog-feed__grid" style="--columns: {{ columns }};">
    {%- for article in blog.articles -%}

      <a href="{{ article.url }}" class="blog-feed__card">
        {%- if show_image -%}
          {%- if article.image -%}
            {{ article.image | image_url: width: 600 | image_tag: class: 'blog-feed__image', loading: 'lazy', alt: article.title }}
          {%- else -%}
            <div class="blog-feed__image blog-feed__image--placeholder" aria-hidden="true"></div>
          {%- endif -%}
        {%- endif -%}

        <div class="blog-feed__content">
          {%- if article.tags.size > 0 -%}
            <div class="blog-feed__card-tags">
              {%- for tag in article.tags -%}
                {%- assign tag_words_card = tag | replace: '-', ' ' | split: ' ' -%}
                {%- assign tag_label = '' -%}
                {%- for w in tag_words_card -%}
                  {%- assign tag_label = tag_label | append: w | capitalize | append: ' ' -%}
                {%- endfor -%}
                {%- assign tag_label = tag_label | strip -%}
                <a href="{{ blog.url }}/tagged/{{ tag | handle }}"
                   class="blog-feed__card-tag"
                   onclick="event.stopPropagation()">
                  {{ tag_label }}
                </a>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <h2 class="blog-feed__heading">{{ article.title | escape }}</h2>

          {%- if article.excerpt != blank -%}
            <p class="blog-feed__excerpt">
              {{ article.excerpt | strip_html | truncate: 110 }}
            </p>
          {%- endif -%}

          <div class="blog-feed__meta">
            <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
              {{ article.published_at | date: "%b %d, %Y" }}
            </time>
            {%- if section.settings.show_author -%}
              <span class="blog-feed__author">{{ article.author }}</span>
            {%- endif -%}
          </div>
        </div>
      </a>

    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    {%- render 'article-feed-pagination', paginate: paginate, style: pagination_style -%}
  {%- endif -%}

</div>

{%- endpaginate -%}

{{ 'blog.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "t:general.blog",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Columns on desktop"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "Show featured images"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": false,
      "label": "Show author"
    },
    {
      "type": "header",
      "content": "Pagination"
    },
    {
      "type": "range",
      "id": "per_page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 6,
      "label": "Articles per page"
    },
    {
      "type": "select",
      "id": "pagination_style",
      "label": "Pagination style",
      "default": "numbered",
      "options": [
        { "value": "numbered", "label": "Numbered pages" },
        { "value": "prevnext", "label": "Prev / Next only" },
        { "value": "loadmore", "label": "Load More button" },
        { "value": "infinite", "label": "Infinite scroll" }
      ]
    }
  ]
}
{% endschema %}