{% comment %}
  Main Header
  File: sections/main-header.liquid

  Isolated section — renders ONLY the header bar itself:
    Hamburger · Logo · Search (inline + mobile row) · Icons (store / account / cart)

  This section does NOT render the utility bar or the menu bar/mobile drawer.
  Those live in their own sections and are composed together via the
  header-group.json manifest:

    sections/header-group.json
      1. utility-bar    (sections/utility-bar.liquid)
      2. main-header     (sections/main-header.liquid)   <- this file
      3. header-menu      (sections/header-menu.liquid)

  The hamburger button below only needs aria-controls="mobile-nav" to work —
  it doesn't need to know anything about header-menu.liquid's markup or
  schema, since that's a DOM id, not a render dependency.

  Snippet tree (this section is the orchestrator — it reads section.settings
  and forwards values down by name; each snippet only knows the params it
  declares, nothing leaks in implicitly):
    header-logo            (logo, logo_width)
    header-search          (show_category, id_suffix — desktop + mobile instances)
    header-icons           (show_store, show_account, show_cart)
      ├── header-icon-store    (no params — leaf)
      ├── header-icon-account  (no params — leaf, uses global `customer`)
      └── header-icon-cart     (no params — leaf, uses global `cart`)

  Assets loaded here (this section's own CSS/behaviour only):
    header-search.css / header-search.js
    main-header.css / main-header.js
{% endcomment %}

{{ 'header-search.css' | asset_url | stylesheet_tag }}
{{ 'main-header.css'   | asset_url | stylesheet_tag }}

{%- liquid
  assign logo       = section.settings.logo
  assign logo_width = section.settings.logo_width | default: 140
  assign show_cat    = section.settings.show_category_filter
  assign show_store  = section.settings.show_icon_store
  assign show_acct   = section.settings.show_icon_account
  assign show_cart   = section.settings.show_icon_cart
-%}

<header class="main-header" id="main-header" role="banner">

  {%- comment -%} ═══════════════════════════════════════
      TOP BAR — Hamburger · Logo · Search · Icons
  ═══════════════════════════════════════ {%- endcomment -%}
  <div class="main-header__bar">
    <div class="main-header__inner">

      {%- comment -%} ── Hamburger (mobile + tablet) — opens the mobile nav drawer rendered by sections/header-menu.liquid ── {%- endcomment -%}
      <button class="main-header__hamburger"
              id="main-header-nav-toggle"
              type="button"
              aria-label="Open navigation"
              aria-expanded="false"
              aria-controls="mobile-nav">
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
      </button>

      {%- comment -%} ── Logo ── {%- endcomment -%}
      {%- render 'header-logo', logo: logo, logo_width: logo_width -%}

      {%- comment -%} ── Search (inline — desktop only) ── {%- endcomment -%}
      <div class="main-header__search main-header__search--inline">
        {%- render 'header-search', show_category: show_cat, id_suffix: 'desktop' -%}
      </div>

      {%- comment -%} ── Right icons ── {%- endcomment -%}
      {%- render 'header-icons',
            show_store:   show_store,
            show_account: show_acct,
            show_cart:    show_cart
      -%}

    </div>{%- comment -%} /.main-header__inner {%- endcomment -%}
  </div>{%- comment -%} /.main-header__bar {%- endcomment -%}

  {%- comment -%} ═══════════════════════════════════════
      SEARCH ROW — tablet + mobile only
  ═══════════════════════════════════════ {%- endcomment -%}
  <div class="main-header__search-row">
    <div class="main-header__search-row-inner">
      {%- render 'header-search', show_category: show_cat, id_suffix: 'mobile' -%}
    </div>
  </div>

</header>

<script src="{{ 'main-header.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Main Header",
  "tag": "div",
  "class": "main-header-section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 140,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "checkbox",
      "id": "show_category_filter",
      "label": "Show category filter in search",
      "default": true
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "checkbox",
      "id": "show_icon_store",
      "label": "Show store locator icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_cart",
      "label": "Show cart icon",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Main Header",
      "settings": {}
    }
  ]
}
{% endschema %}
