{% comment %}
  Main Header
  File: sections/main-header.liquid

  Merged section — combines what used to be sections/main-header.liquid
  with the desktop menu bar + mobile nav drawer markup that used to live in
  snippets/header-menu.liquid. That snippet is now rendered from here
  (see snippets/header-menu.liquid), and this section's schema is the one
  source of truth for the blocks (single/highlight/dropdown/mega/flyout)
  and the mobile navigation link list that drive it — snippets don't have
  their own schema, so those settings have to live on the section that
  renders the snippet.

  Renders:
    1. snippets/header-utility.liquid — slim top bar (links, switchers, region picker)
    2. Header bar                     — hamburger · logo · search · icons
    3. Search row                     — tablet + mobile only
    4. snippets/header-menu.liquid    — desktop menu bar + mobile nav drawer

  Block types (defined here, passed into snippets/header-menu.liquid as `blocks`):
    single, highlight, dropdown, mega, flyout — desktop menu bar items

  Assets loaded here:
    utility-bar.css / utility-bar.js   — utility bar styles + behaviour
    search-form.css                    — search form styles
    main-header.css / main-header.js   — header bar styles + behaviour
    header-menu.css                    — desktop menu bar + mobile drawer styles
                                          (used by snippets/header-menu.liquid)
    header-mega-menu.js / flyout-panel.js / flyout-menu.js / flyout.js
                                        — desktop mega menu + flyout behaviour
                                          (used by snippets/header-menu.liquid)

  layout/theme.liquid usage:
    {%- section 'main-header' -%}
    (the old {%- section 'header-menu' -%} call should be removed — that
    file is now a snippet, rendered automatically from this section)
{% endcomment %}

{{ 'utility-bar.css'    | asset_url | stylesheet_tag }}
{{ 'search-form.css'    | asset_url | stylesheet_tag }}
{{ 'main-header.css'    | asset_url | stylesheet_tag }}
{{ 'header-menu.css'    | asset_url | stylesheet_tag }}

{%- liquid
  assign logo       = section.settings.logo
  assign logo_width = section.settings.logo_width | default: 140
  assign logo_2x     = logo_width | times: 2
  assign show_cat    = section.settings.show_category_filter
  assign show_store  = section.settings.show_icon_store
  assign show_acct   = section.settings.show_icon_account
  assign show_cart   = section.settings.show_icon_cart
  assign bar_style   = section.settings.bar_style | default: 'hyper'
  assign show_curr   = section.settings.show_currency
  assign show_loc    = section.settings.show_locale
  assign nav_menu     = linklists[section.settings.mobile_menu] | default: linklists['main-menu']
-%}

{%- comment -%} ═══════════════════════════════════════
    UTILITY BAR
═══════════════════════════════════════ {%- endcomment -%}
{%- render 'header-utility',
  bar_style:  bar_style,
  show_curr:  show_curr,
  show_loc:   show_loc,
  section:    section
-%}

<header class="main-header" id="main-header" role="banner">

  {%- comment -%} ═══════════════════════════════════════
      TOP BAR — Hamburger · Logo · Search · Icons
  ═══════════════════════════════════════ {%- endcomment -%}
  <div class="main-header__bar">
    <div class="main-header__inner">

      {%- comment -%} ── Hamburger (mobile + tablet) — opens the mobile nav drawer below ── {%- endcomment -%}
      <button class="main-header__hamburger"
              id="main-header-nav-toggle"
              type="button"
              aria-label="Open navigation"
              aria-expanded="false"
              aria-controls="mobile-nav">
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
      </button>

      {%- comment -%} ── Logo ── {%- endcomment -%}
      <a href="{{ routes.root_url }}"
         class="main-header__logo-link"
         aria-label="{{ shop.name }} — home">
        {%- if logo != blank -%}
          <img class="main-header__logo-img"
               src="{{ logo | image_url: width: logo_width }}"
               srcset="{{ logo | image_url: width: logo_width }} 1x,
                       {{ logo | image_url: width: logo_2x }} 2x"
               alt="{{ logo.alt | default: shop.name | escape }}"
               width="{{ logo_width }}"
               height="{{ logo_width | divided_by: logo.aspect_ratio | round }}"
               loading="eager"
               fetchpriority="high">
        {%- else -%}
          <span class="main-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- comment -%} ── Search (inline — desktop only) ── {%- endcomment -%}
      <div class="main-header__search main-header__search--inline">
        {%- render 'search-form', show_category: show_cat, id_suffix: 'desktop' -%}
      </div>

      {%- comment -%} ── Right icons ── {%- endcomment -%}
      <ul class="main-header__icons" role="list" aria-label="Header actions">

        {%- if show_store -%}
          <li>
            <a href="{{ routes.root_url }}pages/stores"
               class="main-header__icon-btn"
               aria-label="Store locator">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="1.75"
                   stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
              <span class="main-header__icon-label">Stores</span>
            </a>
          </li>
        {%- endif -%}

        {%- comment -%} ── Account icon ── {%- endcomment -%}
        {%- if show_acct -%}
          <li>
            {%- if customer -%}
              <a href="{{ routes.account_url }}"
                 class="main-header__icon-btn"
                 aria-label="My account">
            {%- else -%}
              <a href="{{ routes.account_login_url }}"
                 class="main-header__icon-btn"
                 aria-label="Sign in or register">
            {%- endif -%}
              <svg class="main-header__icon" width="22" height="22" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="1.75"
                   stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              <span class="main-header__icon-label" aria-hidden="true">
                {%- if customer -%}Account{%- else -%}Sign in / Register{%- endif -%}
              </span>
            </a>
          </li>
        {%- endif -%}

        {%- comment -%} ── Cart icon ── {%- endcomment -%}
        {%- if show_cart -%}
          <li>
            <button type="button"
                    class="main-header__icon-btn main-header__cart-btn"
                    aria-label="Open cart, {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}"
                    aria-haspopup="dialog"
                    id="main-header-cart-toggle"
                    aria-controls="cart-drawer"
                    aria-expanded="false">
              <span class="main-header__cart-wrap">
                <svg class="main-header__icon" width="22" height="22" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.75"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                  <line x1="3" y1="6" x2="21" y2="6"/>
                  <path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
                <span
                  class="main-header__cart-badge{% unless cart.item_count > 0 %} main-header__cart-badge--hidden{% endunless %}"
                  data-cart-count
                  aria-live="polite"
                  aria-atomic="true">
                  {{ cart.item_count }}
                </span>
              </span>
              <span class="main-header__icon-label" aria-hidden="true">Cart</span>
            </button>
          </li>
        {%- endif -%}

      </ul>{%- comment -%} /.main-header__icons {%- endcomment -%}

    </div>{%- comment -%} /.main-header__inner {%- endcomment -%}
  </div>{%- comment -%} /.main-header__bar {%- endcomment -%}

  {%- comment -%} ═══════════════════════════════════════
      SEARCH ROW — tablet + mobile only
  ═══════════════════════════════════════ {%- endcomment -%}
  <div class="main-header__search-row">
    <div class="main-header__search-row-inner">
      {%- render 'search-form', show_category: show_cat, id_suffix: 'mobile' -%}
    </div>
  </div>

</header>

{%- comment -%} ═══════════════════════════════════════
    DESKTOP MENU BAR + MOBILE NAV DRAWER
    (snippets/header-menu.liquid — blocks/settings defined in this section's schema)
═══════════════════════════════════════ {%- endcomment -%}
{%- render 'header-menu', blocks: section.blocks, nav_menu: nav_menu -%}

<script src="{{ 'utility-bar.js' | asset_url }}" defer></script>
<script src="{{ 'main-header.js' | asset_url }}" defer></script>
{{- 'header-mega-menu.js' | asset_url | script_tag }}
{{- 'flyout-panel.js'     | asset_url | script_tag }}
{{- 'flyout-menu.js'      | asset_url | script_tag }}
{{- 'flyout.js'           | asset_url | script_tag }}

{% schema %}
{
  "name": "Main Header",
  "tag": "div",
  "class": "main-header-section",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 140,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "checkbox",
      "id": "show_category_filter",
      "label": "Show category filter in search",
      "default": true
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "checkbox",
      "id": "show_icon_store",
      "label": "Show store locator icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_cart",
      "label": "Show cart icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Mobile navigation"
    },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Mobile navigation menu",
      "default": "main-menu",
      "info": "Used for the mobile drawer (up to 3 levels). Desktop menu bar items are configured via blocks below."
    },
    {
      "type": "header",
      "content": "Utility Bar"
    },
    {
      "type": "select",
      "id": "bar_style",
      "label": "Bar style",
      "default": "hyper",
      "options": [
        { "value": "hyper", "label": "Hyper (white)" },
        { "value": "focus", "label": "Focus (warm grey)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "label": "Show currency selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_locale",
      "label": "Show language selector",
      "default": true
    },
    {
      "type": "header",
      "content": "Utility link 1"
    },
    {
      "type": "checkbox",
      "id": "utility_link_1_enabled",
      "label": "Show link",
      "default": true
    },
    {
      "type": "text",
      "id": "utility_link_1_label",
      "label": "Label",
      "default": "Track Order"
    },
    {
      "type": "url",
      "id": "utility_link_1_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Utility link 2"
    },
    {
      "type": "checkbox",
      "id": "utility_link_2_enabled",
      "label": "Show link",
      "default": true
    },
    {
      "type": "text",
      "id": "utility_link_2_label",
      "label": "Label",
      "default": "Store Locator"
    },
    {
      "type": "url",
      "id": "utility_link_2_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Utility link 3"
    },
    {
      "type": "checkbox",
      "id": "utility_link_3_enabled",
      "label": "Show link",
      "default": false
    },
    {
      "type": "text",
      "id": "utility_link_3_label",
      "label": "Label"
    },
    {
      "type": "url",
      "id": "utility_link_3_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Utility link 4"
    },
    {
      "type": "checkbox",
      "id": "utility_link_4_enabled",
      "label": "Show link",
      "default": false
    },
    {
      "type": "text",
      "id": "utility_link_4_label",
      "label": "Label"
    },
    {
      "type": "url",
      "id": "utility_link_4_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Utility link 5"
    },
    {
      "type": "checkbox",
      "id": "utility_link_5_enabled",
      "label": "Show link",
      "default": false
    },
    {
      "type": "text",
      "id": "utility_link_5_label",
      "label": "Label"
    },
    {
      "type": "url",
      "id": "utility_link_5_url",
      "label": "URL"
    }
  ],
  "blocks": [
    {
      "type": "single",
      "name": "Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name",
          "info": "Optional. Rendered via snippets/menu-icon.liquid."
        }
      ]
    },
    {
      "type": "highlight",
      "name": "Highlight link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "On Sale"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        }
      ]
    },
    {
      "type": "dropdown",
      "name": "Dropdown menu",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Top-level URL (optional)"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Dropdown menu"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        }
      ]
    },
    {
      "type": "mega",
      "name": "Mega menu",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Top-level URL (optional)"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Mega menu"
        },
        {
          "type": "checkbox",
          "id": "show_products",
          "label": "Show featured products",
          "default": true
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        }
      ]
    },
    {
      "type": "flyout",
      "name": "Flyout panel",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Browse all categories"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Top-level URL (optional)"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Flyout menu"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main Header",
      "settings": {
        "mobile_menu": "main-menu",
        "utility_link_1_enabled": true,
        "utility_link_1_label": "Track Order",
        "utility_link_1_url": "/apps/track",
        "utility_link_2_enabled": true,
        "utility_link_2_label": "Store Locator",
        "utility_link_2_url": "/pages/stores"
      },
      "blocks": [
        { "type": "single", "settings": { "label": "Shop",    "link": "/collections/all" } },
        { "type": "single", "settings": { "label": "About",   "link": "/pages/about" } },
        { "type": "single", "settings": { "label": "Contact", "link": "/pages/contact" } }
      ]
    }
  ]
}
{% endschema %}