{% comment %}
  Main Header Section
  File: sections/main-header.liquid
{% endcomment %}

{{ 'header-search.css'   | asset_url | stylesheet_tag }}
{{ 'main-header.css'     | asset_url | stylesheet_tag }}
{{ 'header-cart.css'     | asset_url | stylesheet_tag }}
{{ 'header-account.css'  | asset_url | stylesheet_tag }}

{%- liquid
  assign logo               = section.settings.logo
  assign logo_width         = section.settings.logo_width | default: 140
  assign show_cat            = section.settings.show_category_filter
  assign show_store          = section.settings.show_icon_store
  assign show_acct           = section.settings.show_icon_account
  assign show_cart           = section.settings.show_icon_cart
  assign enable_predictive   = section.settings.enable_predictive_search
-%}

<header class="main-header" id="main-header" role="banner">

  <div class="main-header__bar">
    <div class="main-header__inner">

      <button class="main-header__hamburger"
              id="main-header-nav-toggle"
              type="button"
              aria-label="Open navigation"
              aria-expanded="false"
              aria-controls="main-header-mobile-nav">
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
      </button>

      {%- render 'header-logo', logo: logo, logo_width: logo_width -%}

      {%- comment -%} ── Desktop search (hidden via CSS below 1024 px) ── {%- endcomment -%}
      <div class="main-header__search main-header__search--inline">
        {%- render 'header-search',
              id_suffix:           'desktop',
              show_category:       show_cat,
              trending_1:          section.settings.search_trending_1,
              trending_2:          section.settings.search_trending_2,
              trending_3:          section.settings.search_trending_3,
              trending_4:          section.settings.search_trending_4,
              trending_5:          section.settings.search_trending_5,
              cat_1_label:         section.settings.search_category_1_label,
              cat_1_value:         section.settings.search_category_1_value,
              cat_2_label:         section.settings.search_category_2_label,
              cat_2_value:         section.settings.search_category_2_value,
              cat_3_label:         section.settings.search_category_3_label,
              cat_3_value:         section.settings.search_category_3_value,
              accent_color:        section.settings.search_accent_color,
              highlight_bg:        section.settings.search_highlight_bg,
              hover_bg:            section.settings.search_hover_bg,
              border_focus:        section.settings.search_border_focus,
              voice_enabled:       true,
              placeholder_animate: true,
              enable_predictive:   enable_predictive
        -%}
      </div>

      <ul class="main-header__icons" role="list" aria-label="Header actions">
        {%- if show_acct != false -%}
          <li>{%- render 'header-account' -%}</li>
        {%- endif -%}
        {%- if show_cart != false -%}
          <li>{%- render 'header-cart' -%}</li>
        {%- endif -%}
      </ul>

    </div>
  </div>

  {%- comment -%} ── Tablet / mobile search row (hidden via CSS above 1024 px) ── {%- endcomment -%}
  <div class="main-header__search-row">
    <div class="main-header__search-row-inner">
      {%- render 'header-search',
            id_suffix:           'mobile',
            show_category:       show_cat,
            trending_1:          section.settings.search_trending_1,
            trending_2:          section.settings.search_trending_2,
            trending_3:          section.settings.search_trending_3,
            trending_4:          section.settings.search_trending_4,
            trending_5:          section.settings.search_trending_5,
            cat_1_label:         section.settings.search_category_1_label,
            cat_1_value:         section.settings.search_category_1_value,
            cat_2_label:         section.settings.search_category_2_label,
            cat_2_value:         section.settings.search_category_2_value,
            cat_3_label:         section.settings.search_category_3_label,
            cat_3_value:         section.settings.search_category_3_value,
            accent_color:        section.settings.search_accent_color,
            highlight_bg:        section.settings.search_highlight_bg,
            hover_bg:            section.settings.search_hover_bg,
            border_focus:        section.settings.search_border_focus,
            voice_enabled:       true,
            placeholder_animate: true,
            enable_predictive:   enable_predictive
      -%}
    </div>
  </div>

  <nav class="main-header__mobile-nav"
       id="main-header-mobile-nav"
       aria-label="Mobile navigation"
       aria-hidden="true"
       hidden>
    <ul class="main-header__mobile-nav-list">
      {%- for link in section.settings.mobile_menu.links -%}
        <li>
          <a class="main-header__mobile-nav-link" href="{{ link.url }}">
            {{ link.title }}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>

</header>

<script src="{{ 'header-search.js'  | asset_url }}" defer></script>
<script src="{{ 'main-header.js'    | asset_url }}" defer></script>
<script src="{{ 'header-cart.js'    | asset_url }}" defer></script>
<script src="{{ 'header-account.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Main Header",
  "tag": "div",
  "class": "main-header-section",
  "settings": [
    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 140,
      "unit": "px"
    },
    { "type": "header", "content": "Navigation" },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Mobile menu",
      "default": "main-menu"
    },
    { "type": "header", "content": "Search" },
    {
      "type": "checkbox",
      "id": "enable_predictive_search",
      "label": "Enable predictive search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_category_filter",
      "label": "Show category filter pill",
      "default": true
    },
    { "type": "text", "id": "search_trending_1", "label": "Trending search 1" },
    { "type": "text", "id": "search_trending_2", "label": "Trending search 2" },
    { "type": "text", "id": "search_trending_3", "label": "Trending search 3" },
    { "type": "text", "id": "search_trending_4", "label": "Trending search 4" },
    { "type": "text", "id": "search_trending_5", "label": "Trending search 5" },
    { "type": "text", "id": "search_category_1_label", "label": "Category 1 label" },
    { "type": "text", "id": "search_category_1_value", "label": "Category 1 tag value" },
    { "type": "text", "id": "search_category_2_label", "label": "Category 2 label" },
    { "type": "text", "id": "search_category_2_value", "label": "Category 2 tag value" },
    { "type": "text", "id": "search_category_3_label", "label": "Category 3 label" },
    { "type": "text", "id": "search_category_3_value", "label": "Category 3 tag value" },
    { "type": "header", "content": "Icons" },
    {
      "type": "checkbox",
      "id": "show_icon_store",
      "label": "Show store locator icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_cart",
      "label": "Show cart icon",
      "default": true
    },
    { "type": "header", "content": "Search colours" },
    {
      "type": "color",
      "id": "search_accent_color",
      "label": "Accent colour",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "search_highlight_bg",
      "label": "Match highlight colour",
      "default": "#FFF3CD"
    },
    {
      "type": "color",
      "id": "search_hover_bg",
      "label": "Row hover colour",
      "default": "#F5F5F5"
    },
    {
      "type": "color",
      "id": "search_border_focus",
      "label": "Focus border colour",
      "default": "#1a1a1a"
    }
  ],
  "presets": [
    { "name": "Main Header" }
  ]
}
{% endschema %}
