{% comment %}
  Main Header Section
  File: sections/main-header.liquid

  PIVOT: header-search moved off the official predictive-search
  pipeline (Section Rendering API), so this section no longer needs to
  pass trending terms, category labels/values, or colour settings
  through to the snippet — that whole rendering path now lives in
  Liquid inside sections/predictive-search.liquid. The only thing
  header-search.liquid actually needs to make its decision is whether
  predictive search is on at all.

  search-form.css / search-form.js are no longer loaded here —
  snippets/header-search.liquid now owns and loads its own assets
  (header-search.css always, header-search.js only when predictive
  search is enabled), the same way header-logo etc. are self-contained.

  Composition stays a flat, explicit sequence:
    main-header
      └─ header-logo
      └─ header-search   (single param: enable_predictive_search)
      └─ header-account
      └─ header-cart
{% endcomment %}

{{ 'main-header.css'    | asset_url | stylesheet_tag }}
{{ 'header-cart.css'    | asset_url | stylesheet_tag }}
{{ 'header-account.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign logo       = section.settings.logo
  assign logo_width = section.settings.logo_width | default: 140
  assign show_acct  = section.settings.show_icon_account
  assign show_cart  = section.settings.show_icon_cart
-%}

<header class="main-header" id="main-header" role="banner">

  <div class="main-header__bar">
    <div class="main-header__inner">

      <button class="main-header__hamburger"
              id="main-header-nav-toggle"
              type="button"
              aria-label="Open navigation"
              aria-expanded="false"
              aria-controls="main-header-mobile-nav">
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
      </button>

      {%- render 'header-logo', logo: logo, logo_width: logo_width -%}

      {%- render 'header-search', enable_predictive_search: section.settings.enable_predictive_search -%}

      <ul class="main-header__icons" role="list" aria-label="Header actions">
        {%- if show_acct != false -%}
          <li>{%- render 'header-account' -%}</li>
        {%- endif -%}
        {%- if show_cart != false -%}
          <li>{%- render 'header-cart' -%}</li>
        {%- endif -%}
      </ul>

    </div>
  </div>

  <nav class="main-header__mobile-nav"
       id="main-header-mobile-nav"
       aria-label="Mobile navigation"
       aria-hidden="true"
       hidden>
    <ul class="main-header__mobile-nav-list">
      {%- for link in section.settings.mobile_menu.links -%}
        <li>
          <a class="main-header__mobile-nav-link" href="{{ link.url }}">
            {{ link.title }}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>

</header>

<script src="{{ 'main-header.js'    | asset_url }}" defer></script>
<script src="{{ 'header-cart.js'    | asset_url }}" defer></script>
<script src="{{ 'header-account.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Main Header",
  "tag": "div",
  "class": "main-header-section",
  "settings": [
    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 140,
      "unit": "px"
    },
    { "type": "header", "content": "Navigation" },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Mobile menu",
      "default": "main-menu"
    },
    { "type": "header", "content": "Search" },
    {
      "type": "checkbox",
      "id": "enable_predictive_search",
      "label": "Enable predictive search",
      "info": "Shows product, collection and query suggestions as the customer types.",
      "default": true
    },
    { "type": "header", "content": "Icons" },
    {
      "type": "checkbox",
      "id": "show_icon_store",
      "label": "Show store locator icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_cart",
      "label": "Show cart icon",
      "default": true
    }
  ],
  "presets": [
    { "name": "Main Header" }
  ]
}
{% endschema %}
