{% comment %}
  Main Header Section
  File: sections/main-header.liquid

  we just removed our header-icons and would like to utilize a wrapper instead, comprised of the following; 

  <ul class="main-header__icons" role="list" aria-label="Header actions">
  {%- if show_store != false -%}
    <li>{%- render 'header-store' -%}</li>
  {%- endif -%}

  {%- if show_account != false -%}
    <li>{%- render 'header-account' -%}</li>
  {%- endif -%}

  {%- if show_cart != false -%}
    <li>{%- render 'header-cart' -%}</li>
  {%- endif -%}
</ul>

{% endcomment %}

{{ 'header-search.css'  | asset_url | stylesheet_tag }}
{{ 'main-header.css'   | asset_url | stylesheet_tag }}
{{ 'header-cart.css'   | asset_url | stylesheet_tag }}
{{ 'header-account.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign logo       = section.settings.logo
  assign logo_width = section.settings.logo_width | default: 140
  assign show_cat   = section.settings.show_category_filter
  assign show_store = section.settings.show_icon_store
  assign show_acct  = section.settings.show_icon_account
  assign show_cart  = section.settings.show_icon_cart
-%}

<header class="main-header" id="main-header" role="banner">

  {%- comment -%} ═══════════════════════════════════════
      TOP BAR — Hamburger · Logo · Search (desktop) · Icons
  ═══════════════════════════════════════ {%- endcomment -%}
  <div class="main-header__bar">
    <div class="main-header__inner">

      {%- comment -%} ── Hamburger — controls #main-header-mobile-nav below ── {%- endcomment -%}
      <button class="main-header__hamburger"
              id="main-header-nav-toggle"
              type="button"
              aria-label="Open navigation"
              aria-expanded="false"
              aria-controls="main-header-mobile-nav">
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
      </button>

      {%- comment -%} ── Logo ── {%- endcomment -%}
      {%- render 'header-logo', logo: logo, logo_width: logo_width -%}

      {%- comment -%} ── Inline search — desktop only (hidden via CSS below 1024px) ── {%- endcomment -%}
      <div class="main-header__search main-header__search--inline">
        {%- render 'header-search', show_category: show_cat, id_suffix: 'desktop' -%}
      </div>

      {%- comment -%} ── Right icon cluster ── 

<ul class="main-header__icons" role="list" aria-label="Header actions">
  {%- if show_store != false -%}
    <li>{%- render 'header-store' -%}</li>
  {%- endif -%}

  {%- if show_account != false -%}
    <li>{%- render 'header-account' -%}</li>
  {%- endif -%}

  {%- if show_cart != false -%}
    <li>{%- render 'header-cart' -%}</li>
  {%- endif -%}
</ul>

{%- endcomment -%}
    </div>
  </div>

  <ul class="main-header__icons" role="list" aria-label="Header actions">
  {%- if show_store != false -%}
    <li>{%- render 'header-store' -%}</li>
  {%- endif -%}

  {%- if show_account != false -%}
    <li>
      {%- if customer -%}
  <a
    href="{{ routes.account_url }}"
    class="main-header__icon-btn main-header__account-btn"
    aria-label="My account"
    data-account-link
  >
{%- else -%}
  <a
    href="{{ routes.account_login_url }}"
    class="main-header__icon-btn main-header__account-btn"
    aria-label="Sign in or register"
    data-account-link
  >
{%- endif -%}

  <svg
    class="main-header__icon main-header__account-icon"
    width="22"
    height="22"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    focusable="false"
  >
    <circle cx="12" cy="8" r="4"/>
    <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
  </svg>

  <span class="main-header__icon-label" aria-hidden="true">
    {%- if customer -%}Account{%- else -%}Sign in{%- endif -%}
  </span>

</a>
    </li>
  {%- endif -%}

  {%- if show_cart != false -%}
    <li>
      <button type="button"
        class="main-header__icon-btn main-header__cart-btn"
        aria-label="Open cart, {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}"
        aria-haspopup="dialog"
        id="main-header-cart-toggle"
        aria-controls="ecombio-cart-drawer"
        aria-expanded="false">
  <span class="main-header__cart-wrap">
    <svg class="main-header__icon" width="22" height="22" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="1.75"
         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
      <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
      <line x1="3" y1="6" x2="21" y2="6"/>
      <path d="M16 10a4 4 0 0 1-8 0"/>
    </svg>
    <span
      class="main-header__cart-badge{% unless cart.item_count > 0 %} main-header__cart-badge--hidden{% endunless %}"
      data-cart-count
      aria-live="polite"
      aria-atomic="true">({{ cart.item_count }})</span>
  </span>
  <span class="main-header__icon-label" aria-hidden="true">Cart</span>
</button>
</li>
  {%- endif -%}
</ul>

  {%- comment -%} ═══════════════════════════════════════
      SEARCH ROW — tablet + mobile (hidden via CSS above 1024px)
  ═══════════════════════════════════════ {%- endcomment -%}
  <div class="main-header__search-row">
    <div class="main-header__search-row-inner">
      {%- render 'header-search', show_category: show_cat, id_suffix: 'mobile' -%}
    </div>
  </div>

  {%- comment -%} ═══════════════════════════════════════
      MOBILE NAV DRAWER
      ID must match aria-controls on the hamburger button above.
      Content (links) is managed by the theme's menu settings.
  ═══════════════════════════════════════ {%- endcomment -%}
  <nav class="main-header__mobile-nav"
       id="main-header-mobile-nav"
       aria-label="Mobile navigation"
       aria-hidden="true"
       hidden>
    <ul class="main-header__mobile-nav-list">
      {%- for link in section.settings.mobile_menu.links -%}
        <li>
          <a class="main-header__mobile-nav-link" href="{{ link.url }}">
            {{ link.title }}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>

</header>

{%- comment -%}
  JS: defer all files so they execute after DOM is parsed.
  header-search.js must appear before main-header.js because both listen on
  DOMContentLoaded — order in source determines execution order after defer.
  header-cart.js depends on cart-drawer.js (loaded in theme.liquid) already
  being registered to listen for 'cart:open'.
  header-account.js is optional — remove if no flyout/intercept is needed.
{%- endcomment -%}
<script src="{{ 'header-search.js'  | asset_url }}" defer></script>
<script src="{{ 'main-header.js'    | asset_url }}" defer></script>
<script src="{{ 'header-cart.js'    | asset_url }}" defer></script>
<script src="{{ 'header-account.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Main Header",
  "tag": "div",
  "class": "main-header-section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 140,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Mobile menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "checkbox",
      "id": "show_category_filter",
      "label": "Show category filter pill",
      "default": true
    },
    {
      "type": "text",
      "id": "search_trending_1",
      "label": "Trending search 1"
    },
    {
      "type": "text",
      "id": "search_trending_2",
      "label": "Trending search 2"
    },
    {
      "type": "text",
      "id": "search_trending_3",
      "label": "Trending search 3"
    },
    {
      "type": "text",
      "id": "search_trending_4",
      "label": "Trending search 4"
    },
    {
      "type": "text",
      "id": "search_trending_5",
      "label": "Trending search 5"
    },
    {
      "type": "text",
      "id": "search_category_1_label",
      "label": "Category 1 label"
    },
    {
      "type": "text",
      "id": "search_category_1_value",
      "label": "Category 1 tag value"
    },
    {
      "type": "text",
      "id": "search_category_2_label",
      "label": "Category 2 label"
    },
    {
      "type": "text",
      "id": "search_category_2_value",
      "label": "Category 2 tag value"
    },
    {
      "type": "text",
      "id": "search_category_3_label",
      "label": "Category 3 label"
    },
    {
      "type": "text",
      "id": "search_category_3_value",
      "label": "Category 3 tag value"
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "checkbox",
      "id": "show_icon_store",
      "label": "Show store locator icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_cart",
      "label": "Show cart icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Search colours"
    },
    {
      "type": "color",
      "id": "search_accent_color",
      "label": "Accent colour",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "search_highlight_bg",
      "label": "Match highlight colour",
      "default": "#FFF3CD"
    },
    {
      "type": "color",
      "id": "search_hover_bg",
      "label": "Row hover colour",
      "default": "#F5F5F5"
    },
    {
      "type": "color",
      "id": "search_border_focus",
      "label": "Focus border colour",
      "default": "#1a1a1a"
    }
  ],
  "presets": [
    {
      "name": "Main Header"
    }
  ]
}
{% endschema %}
