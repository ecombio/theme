<div class="main-header">
  <div class="main-header__inner page-width">

    <div class="main-header__logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: section.settings.logo_width
            | image_tag:
              width: section.settings.logo_width,
              alt: shop.name,
              loading: 'eager',
              fetchpriority: 'high'
          }}
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>
    </div>

    <div class="main-header__search">
      <form action="{{ routes.search_url }}" method="get" role="search">
        <input type="hidden" name="type" value="product">
        <input type="hidden" name="options[prefix]" value="last">
        <input
          type="search"
          name="q"
          placeholder="{{ section.settings.search_placeholder }}"
          autocomplete="off"
          aria-label="{{ section.settings.search_placeholder }}"
        >
        <button type="submit" aria-label="Submit search">
          {%- render 'icon-search' -%}
        </button>
      </form>
    </div>

    <div class="main-header__icons">
      <a href="{{ routes.cart_url }}" aria-label="Cart">
        {%- render 'icon-shopping-bag' -%}
        <span>{{ cart.item_count }}</span>
      </a>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Main header",
  "tag": "header",
  "class": "section-main-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 80,
      "max": 280,
      "step": 4,
      "unit": "px",
      "default": 160
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search"
    }
  ],
  "presets": [
    {
      "name": "Main header"
    }
  ]
}
{% endschema %}
