{% comment %}
  Main Header Section
  File: sections/main-header.liquid

  POST-PIVOT: header-search is back to being a snippet, not a block.
  All search-related settings now live directly on this section's
  schema (Search header group below) and are passed explicitly into
  {%- render 'header-search' -%}, the same way logo/logo_width are
  already passed into {%- render 'header-logo' -%}.

  This removes the old block-loop machinery entirely: header-search is
  no longer addable/removable/reorderable by merchants in the theme
  editor — it is a fixed, always-present part of the header, alongside
  header-logo, header-account, and header-cart. Composition is now a
  flat, explicit sequence:

    main-header
      └─ header-logo
      └─ header-search   (snippet: search-modal once + search-form × 2)
      └─ header-account
      └─ header-cart

  Asset ownership:
    search-form.css / search-form.js — loaded here; own all .hs__*
      styles and the HeaderSearch class (form, dropdown, voice, etc.)
    search-modal.liquid             — emits window.HS_SETTINGS only;
      no CSS or JS of its own
    header-search.liquid            — coordinator snippet; no assets
{% endcomment %}

{{ 'search-form.css'   | asset_url | stylesheet_tag }}
{{ 'main-header.css'   | asset_url | stylesheet_tag }}
{{ 'header-cart.css'   | asset_url | stylesheet_tag }}
{{ 'header-account.css'| asset_url | stylesheet_tag }}

{%- liquid
  assign logo       = section.settings.logo
  assign logo_width = section.settings.logo_width | default: 140
  assign show_acct  = section.settings.show_icon_account
  assign show_cart  = section.settings.show_icon_cart
-%}

<header class="main-header" id="main-header" role="banner">

  <div class="main-header__bar">
    <div class="main-header__inner">

      <button class="main-header__hamburger"
              id="main-header-nav-toggle"
              type="button"
              aria-label="Open navigation"
              aria-expanded="false"
              aria-controls="main-header-mobile-nav">
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
        <span class="main-header__hamburger-line"></span>
      </button>

      {%- render 'header-logo', logo: logo, logo_width: logo_width -%}

      {%- render 'header-search',
            enable_predictive_search: section.settings.enable_predictive_search,
            show_category_filter:     section.settings.show_category_filter,
            search_trending_1:        section.settings.search_trending_1,
            search_trending_2:        section.settings.search_trending_2,
            search_trending_3:        section.settings.search_trending_3,
            search_trending_4:        section.settings.search_trending_4,
            search_trending_5:        section.settings.search_trending_5,
            search_category_1_label:  section.settings.search_category_1_label,
            search_category_1_value:  section.settings.search_category_1_value,
            search_category_2_label:  section.settings.search_category_2_label,
            search_category_2_value:  section.settings.search_category_2_value,
            search_category_3_label:  section.settings.search_category_3_label,
            search_category_3_value:  section.settings.search_category_3_value,
            search_accent_color:      section.settings.search_accent_color,
            search_highlight_bg:      section.settings.search_highlight_bg,
            search_hover_bg:          section.settings.search_hover_bg,
            search_border_focus:      section.settings.search_border_focus
      -%}

      <ul class="main-header__icons" role="list" aria-label="Header actions">
        {%- if show_acct != false -%}
          <li>{%- render 'header-account' -%}</li>
        {%- endif -%}
        {%- if show_cart != false -%}
          <li>{%- render 'header-cart' -%}</li>
        {%- endif -%}
      </ul>

    </div>
  </div>

  <nav class="main-header__mobile-nav"
       id="main-header-mobile-nav"
       aria-label="Mobile navigation"
       aria-hidden="true"
       hidden>
    <ul class="main-header__mobile-nav-list">
      {%- for link in section.settings.mobile_menu.links -%}
        <li>
          <a class="main-header__mobile-nav-link" href="{{ link.url }}">
            {{ link.title }}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>

</header>

<script src="{{ 'search-form.js'   | asset_url }}" defer></script>
<script src="{{ 'main-header.js'   | asset_url }}" defer></script>
<script src="{{ 'header-cart.js'   | asset_url }}" defer></script>
<script src="{{ 'header-account.js'| asset_url }}" defer></script>

{% schema %}
{
  "name": "Main Header",
  "tag": "div",
  "class": "main-header-section",
  "settings": [
    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 140,
      "unit": "px"
    },
    { "type": "header", "content": "Navigation" },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Mobile menu",
      "default": "main-menu"
    },
    { "type": "header", "content": "Search" },
    {
      "type": "checkbox",
      "id": "enable_predictive_search",
      "label": "Enable predictive search",
      "info": "Suggestions, recent searches, trending terms, voice input.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_category_filter",
      "label": "Show category filter pill",
      "default": true
    },
    { "type": "header", "content": "Search — trending searches" },
    { "type": "text", "id": "search_trending_1", "label": "Trending search 1" },
    { "type": "text", "id": "search_trending_2", "label": "Trending search 2" },
    { "type": "text", "id": "search_trending_3", "label": "Trending search 3" },
    { "type": "text", "id": "search_trending_4", "label": "Trending search 4" },
    { "type": "text", "id": "search_trending_5", "label": "Trending search 5" },
    { "type": "header", "content": "Search — category pills" },
    { "type": "text", "id": "search_category_1_label", "label": "Category 1 label" },
    { "type": "text", "id": "search_category_1_value", "label": "Category 1 tag value" },
    { "type": "text", "id": "search_category_2_label", "label": "Category 2 label" },
    { "type": "text", "id": "search_category_2_value", "label": "Category 2 tag value" },
    { "type": "text", "id": "search_category_3_label", "label": "Category 3 label" },
    { "type": "text", "id": "search_category_3_value", "label": "Category 3 tag value" },
    { "type": "header", "content": "Search — colours" },
    {
      "type": "color",
      "id": "search_accent_color",
      "label": "Accent colour",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "search_highlight_bg",
      "label": "Match highlight colour",
      "default": "#FFF3CD"
    },
    {
      "type": "color",
      "id": "search_hover_bg",
      "label": "Row hover colour",
      "default": "#F5F5F5"
    },
    {
      "type": "color",
      "id": "search_border_focus",
      "label": "Focus border colour",
      "default": "#1a1a1a"
    },
    { "type": "header", "content": "Icons" },
    {
      "type": "checkbox",
      "id": "show_icon_store",
      "label": "Show store locator icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_cart",
      "label": "Show cart icon",
      "default": true
    }
  ],
  "presets": [
    { "name": "Main Header" }
  ]
}
{% endschema %}
