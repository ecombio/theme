{% comment %}
  Trust Signals Section — Back Market style
  Responsive: mobile (stacked list) → tablet/desktop (inline row)
{% endcomment %}

<section
  class="trust-signals"
  id="shopify-section-{{ section.id }}"
  style="
    --ts-bg: {{ section.settings.background_color }};
    --ts-heading-color: {{ section.settings.heading_color }};
    --ts-body-color: {{ section.settings.body_color }};
    --ts-link-color: {{ section.settings.link_color }};
    --ts-badge-bg: {{ section.settings.badge_background }};
    --ts-badge-color: {{ section.settings.badge_text_color }};
  "
>
  <div class="trust-signals__inner">

    {% if section.settings.heading != blank %}
      <h2 class="trust-signals__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="trust-signals__subheading">
        {{ section.settings.subheading }}
        {% if section.settings.link_text != blank and section.settings.link_url != blank %}
          <a
            class="trust-signals__link"
            href="{{ section.settings.link_url }}"
          >{{ section.settings.link_text }}</a>
        {% endif %}
      </p>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <ul class="trust-signals__badges" role="list">
        {% for block in section.blocks %}
          <li class="trust-signals__badge" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <span class="trust-signals__icon" aria-hidden="true">
                {{ block.settings.icon }}
              </span>
            {% elsif block.settings.svg_icon != blank %}
              <span class="trust-signals__icon" aria-hidden="true">
                {{ block.settings.svg_icon }}
              </span>
            {% endif %}
            <span class="trust-signals__badge-text">{{ block.settings.label }}</span>
          </li>
        {% endfor %}
      </ul>
    {% endif %}

  </div>
</section>

<style>
  /* ── Reset & base ── */
  .trust-signals *,
  .trust-signals *::before,
  .trust-signals *::after {
    box-sizing: border-box;
  }

  /* ── Section wrapper ── */
  .trust-signals {
    background-color: var(--ts-bg, #f0f0f5);
    padding: 48px 20px 40px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  .trust-signals__inner {
    max-width: 1080px;
    margin: 0 auto;
    text-align: center;
  }

  /* ── Heading ── */
  .trust-signals__heading {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ts-heading-color, #0d0d0d);
    margin: 0 0 16px;
  }

  /* ── Subheading ── */
  .trust-signals__subheading {
    font-size: clamp(0.9rem, 2vw, 1rem);
    color: var(--ts-body-color, #1a1a1a);
    margin: 0 0 36px;
    line-height: 1.5;
  }

  /* ── Inline link ── */
  .trust-signals__link {
    color: var(--ts-link-color, #0d0d0d);
    text-decoration: underline;
    text-underline-offset: 2px;
    white-space: nowrap;
  }
  .trust-signals__link:hover {
    opacity: 0.7;
  }

  /* ── Badge list ── */
  .trust-signals__badges {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  /* ── Individual badge ── */
  .trust-signals__badge {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--ts-badge-bg, #e8e8f0);
    color: var(--ts-badge-color, #0d0d0d);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.3;
    min-width: 0;
    text-align: left;
  }

  /* ── Icon wrapper ── */
  .trust-signals__icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    line-height: 1;
  }

  .trust-signals__icon svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
  }

  /* ── MOBILE: stacked, full-width badges ── */
  @media (max-width: 599px) {
    .trust-signals {
      padding: 36px 16px 32px;
    }

    .trust-signals__badges {
      flex-direction: column;
      align-items: stretch;
      gap: 10px;
    }

    .trust-signals__badge {
      width: 100%;
      font-size: 0.9rem;
      padding: 12px 14px;
    }
  }

  /* ── TABLET: 2-column grid ── */
  @media (min-width: 600px) and (max-width: 899px) {
    .trust-signals__badges {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .trust-signals__badge {
      width: 100%;
    }
  }

  /* ── DESKTOP: single row ── */
  @media (min-width: 900px) {
    .trust-signals {
      padding: 56px 40px 48px;
    }

    .trust-signals__badges {
      flex-wrap: nowrap;
      justify-content: center;
      gap: 12px;
    }

    .trust-signals__badge {
      flex: 0 1 auto;
      white-space: nowrap;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .trust-signals__link {
      transition: none;
    }
  }
</style>

{% schema %}
{
  "name": "Trust Signals",
  "tag": "section",
  "class": "section-trust-signals",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Where the world shops refurbished tech."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you love about new, for less."
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Guaranteed by the Back Market Promise."
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#eeeef5"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#0d0d0d"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#0d0d0d"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Badge background",
      "default": "#e0e0ea"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#0d0d0d"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Badge label",
          "default": "Best-in-class refurbishment"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon emoji (optional)",
          "info": "Use an emoji, e.g. ⭐ ↩ 🏅. Leave blank if using SVG icon below.",
          "default": "☆"
        },
        {
          "type": "html",
          "id": "svg_icon",
          "label": "SVG icon (optional)",
          "info": "Paste an <svg> snippet. Used when Icon emoji is blank."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Signals",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "label": "Best-in-class refurbishment",
            "icon": "☆"
          }
        },
        {
          "type": "badge",
          "settings": {
            "label": "Up to 100-point quality inspection",
            "icon": "≡"
          }
        },
        {
          "type": "badge",
          "settings": {
            "label": "Free 30-day returns",
            "icon": "⇄"
          }
        },
        {
          "type": "badge",
          "settings": {
            "label": "1-year warranty",
            "icon": "🏅"
          }
        }
      ]
    }
  ]
}
{% endschema %}