{% comment %}
  CATEGORY PILLS - With short arrows (hover to show)
{% endcomment %}

<div class="category-pills-section" 
     style="padding-top: {{ section.settings.padding_top }}px; 
            padding-bottom: {{ section.settings.padding_bottom }}px; 
            background: #ffffff; position: relative;">

  {% if section.settings.heading != blank %}
    <div style="max-width: 1200px; margin: 0 auto 24px; padding: 0 50px;">
      <h2 style="font-size: 28px; font-weight: 700; margin: 0;">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  <div style="max-width: 1200px; margin: 0 auto; padding: 0 50px; position: relative;"
       class="cat-arrows-wrapper">

    <!-- LEFT ARROW -->
    <button class="cat-arrow cat-arrow-left" 
            onclick="document.getElementById('cat-scroll-{{ section.id }}').scrollBy({left: -220, behavior: 'smooth'})"
            aria-label="Scroll left">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M12 8a.5.5 0 0 1-.5.5H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5a.5.5 0 0 1 .5.5"/>
      </svg>
    </button>

    <!-- RIGHT ARROW -->
    <button class="cat-arrow cat-arrow-right" 
            onclick="document.getElementById('cat-scroll-{{ section.id }}').scrollBy({left: 220, behavior: 'smooth'})"
            aria-label="Scroll right">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8"/>
      </svg>
    </button>

    <!-- SCROLL AREA -->
    <div class="cat-scroll" id="cat-scroll-{{ section.id }}">
      {% for block in section.blocks %}
        {% render 'category-pill', 
             title: block.settings.title, 
             url: block.settings.url, 
             icon: block.settings.icon, 
             image: block.settings.image %}
      {% endfor %}
    </div>

  </div>
</div>

<style>
  .cat-arrows-wrapper:hover .cat-arrow {
    opacity: 1;
    pointer-events: auto;
  }

  .cat-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 999px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    color: #111111;
  }

  .cat-arrow:hover {
    background: #f8f9fa;
    transform: translateY(-50%) scale(1.05);
  }

  .cat-arrow-left  { left: 12px; }
  .cat-arrow-right { right: 12px; }

  .cat-scroll {
    display: flex;
    align-items: center;
    height: 66px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 12px;
    padding-right: 80px;
    cursor: grab;
    user-select: none;
  }

  .cat-scroll:active { cursor: grabbing; }
  .cat-scroll::-webkit-scrollbar { display: none; }
  .cat-scroll .single-pill { scroll-snap-align: start; flex-shrink: 0; }
</style>

<script>
  // Mouse drag scrolling
  (function() {
    const slider = document.getElementById('cat-scroll-{{ section.id }}');
    if (!slider) return;

    let isDown = false;
    let startX, scrollLeft;

    slider.addEventListener('mousedown', e => {
      isDown = true;
      slider.classList.add('active');
      startX = e.pageX - slider.offsetLeft;
      scrollLeft = slider.scrollLeft;
    });

    slider.addEventListener('mouseleave', () => { isDown = false; slider.classList.remove('active'); });
    slider.addEventListener('mouseup',   () => { isDown = false; slider.classList.remove('active'); });

    slider.addEventListener('mousemove', e => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - slider.offsetLeft;
      const walk = (x - startX) * 1.6;
      slider.scrollLeft = scrollLeft - walk;
    });
  })();
</script>

{% schema %}
{
  "name": "Category Pills",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Pill",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Electric Scooters"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (optional)"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon (if no image)",
          "options": [
            { "value": "scooter", "label": "Scooter" },
            { "value": "bike", "label": "Bike" },
            { "value": "skateboard", "label": "Skateboard" },
            { "value": "accessories", "label": "Accessories" },
            { "value": "default", "label": "Default" }
          ],
          "default": "scooter"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Pills"
    }
  ]
}
{% endschema %}