{% comment %}
  Section: Video Carousel
  - Horizontal scrollable carousel of video cards
  - Hover to autoplay (muted, inline)
  - Click to open video in modal/lightbox
  - Prev / Next arrow navigation
  - Fully configurable via theme editor
{% endcomment %}

{%- liquid
  assign section_id    = 'vc-' | append: section.id
  assign heading       = section.settings.heading
  assign subheading    = section.settings.subheading
  assign cards_per_row = section.settings.cards_per_row | default: 4
  assign card_aspect   = section.settings.card_aspect   | default: 'portrait'
  assign show_title    = section.settings.show_card_title
  assign show_caption  = section.settings.show_card_caption
  assign autoplay_delay = section.settings.autoplay_delay | default: 300
-%}

<section
  id="{{ section_id }}"
  class="vc-section"
  data-section-id="{{ section.id }}"
  data-section-type="video-carousel"
>

  {%- if heading != blank or subheading != blank -%}
    <div class="vc-header">
      <div class="vc-header__text">
        {%- if heading != blank -%}
          <h2 class="vc-heading">{{ heading }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="vc-subheading">{{ subheading }}</p>
        {%- endif -%}
      </div>

      <div class="vc-controls" aria-label="{{ 'general.accessibility.carousel_controls' | t | default: 'Carousel controls' }}">
        <button class="vc-btn vc-btn--prev" data-target="{{ section_id }}" aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="vc-btn vc-btn--next" data-target="{{ section_id }}" aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  {%- endif -%}

  <div class="vc-track-wrapper">
    <ul
      id="{{ section_id }}-track"
      class="vc-track vc-track--{{ card_aspect }}"
      role="list"
    >
      {%- for block in section.blocks -%}
        {%- liquid
          assign video_url   = block.settings.video_url
          assign hosted_video = block.settings.video
          assign thumbnail   = block.settings.thumbnail
          assign card_title  = block.settings.title
          assign caption     = block.settings.caption
          assign video_type  = 'hosted'
          if hosted_video == blank
            assign video_type = 'external'
          endif
        -%}

        <li
          class="vc-card"
          {{ block.shopify_attributes }}
          data-video-type="{{ video_type }}"
          {%- if video_type == 'hosted' and hosted_video != blank -%}
            data-video-id="{{ hosted_video.id }}"
          {%- elsif video_url != blank -%}
            data-video-url="{{ video_url }}"
          {%- endif -%}
          data-autoplay-delay="{{ autoplay_delay }}"
        >
          <div class="vc-card__inner">

            {%- comment %} Thumbnail / poster image {%- endcomment %}
            <div class="vc-card__media">
              {%- if thumbnail != blank -%}
                {{
                  thumbnail
                  | image_url: width: 800
                  | image_tag:
                    class: 'vc-card__thumbnail',
                    loading: 'lazy',
                    alt: card_title | default: 'Video thumbnail'
                }}
              {%- elsif hosted_video != blank -%}
                <img
                  src="{{ hosted_video | video_tag: image_size: '800x' | extract: 'poster' }}"
                  class="vc-card__thumbnail"
                  loading="lazy"
                  alt="{{ card_title | default: 'Video thumbnail' }}"
                />
              {%- else -%}
                <div class="vc-card__thumbnail vc-card__thumbnail--placeholder"></div>
              {%- endif -%}

              {%- comment %} Inline video element (populated by JS on hover) {%- endcomment %}
              <video
                class="vc-card__video"
                muted
                playsinline
                loop
                preload="none"
                tabindex="-1"
                aria-hidden="true"
                {%- if video_type == 'hosted' and hosted_video != blank -%}
                  {%- for source in hosted_video.sources -%}
                    {%- if source.format == 'mp4' -%}
                  {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              >
                {%- if video_type == 'hosted' and hosted_video != blank -%}
                  {%- for source in hosted_video.sources -%}
                    <source data-src="{{ source.url }}" type="video/{{ source.format }}">
                  {%- endfor -%}
                {%- endif -%}
              </video>

              {%- comment %} Play button overlay {%- endcomment %}
              <button class="vc-card__play-btn" aria-label="Play {{ card_title | default: 'video' }}">
                <svg class="vc-play-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="24" cy="24" r="24" fill="white" fill-opacity="0.92"/>
                  <path d="M19 15.5L34 24L19 32.5V15.5Z" fill="currentColor"/>
                </svg>
              </button>

              {%- if caption != blank and show_caption -%}
                <p class="vc-card__caption">{{ caption }}</p>
              {%- endif -%}
            </div>

            {%- if card_title != blank and show_title -%}
              <div class="vc-card__body">
                <p class="vc-card__title">{{ card_title }}</p>
              </div>
            {%- endif -%}

          </div>
        </li>
      {%- else -%}
        {%- comment %} Placeholder cards in theme editor {%- endcomment %}
        {%- for i in (1..4) -%}
          <li class="vc-card vc-card--placeholder">
            <div class="vc-card__inner">
              <div class="vc-card__media">
                <div class="vc-card__thumbnail vc-card__thumbnail--placeholder">
                  {{ 'collection-' | append: i | placeholder_svg_tag: 'vc-placeholder-svg' }}
                </div>
                <button class="vc-card__play-btn" aria-hidden="true" tabindex="-1">
                  <svg class="vc-play-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="24" cy="24" r="24" fill="white" fill-opacity="0.92"/>
                    <path d="M19 15.5L34 24L19 32.5V15.5Z" fill="currentColor"/>
                  </svg>
                </button>
              </div>
            </div>
          </li>
        {%- endfor -%}
      {%- endfor -%}
    </ul>
  </div>

  {%- comment %} Modal / Lightbox {%- endcomment %}
  <div
    id="{{ section_id }}-modal"
    class="vc-modal"
    role="dialog"
    aria-modal="true"
    aria-label="Video player"
    hidden
  >
    <div class="vc-modal__backdrop"></div>
    <div class="vc-modal__container">
      <button class="vc-modal__close" aria-label="Close video">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="vc-modal__player">
        <video class="vc-modal__video" controls playsinline></video>
        <div class="vc-modal__iframe-wrap">
          <iframe class="vc-modal__iframe" frameborder="0" allowfullscreen allow="autoplay; encrypted-media"></iframe>
        </div>
      </div>
    </div>
  </div>

</section>

{% comment %} =================== STYLES =================== {% endcomment %}
<style>
  #{{ section_id }} {
    --vc-gap:           {{ section.settings.card_gap | default: 16 }}px;
    --vc-radius:        {{ section.settings.card_radius | default: 16 }}px;
    --vc-heading-color: {{ section.settings.heading_color | default: 'currentColor' }};
    --vc-bg:            {{ section.settings.section_bg | default: 'transparent' }};
    --vc-card-bg:       {{ section.settings.card_bg | default: '#1a0a2e' }};
    --vc-btn-bg:        {{ section.settings.btn_bg | default: '#ffffff' }};
    --vc-btn-color:     {{ section.settings.btn_color | default: '#000000' }};
    --vc-cards-visible: {{ cards_per_row }};

    {%- case card_aspect -%}
      {%- when 'portrait' -%}
        --vc-card-aspect: 9 / 14;
      {%- when 'square' -%}
        --vc-card-aspect: 1 / 1;
      {%- when 'landscape' -%}
        --vc-card-aspect: 16 / 9;
      {%- else -%}
        --vc-card-aspect: 9 / 14;
    {%- endcase -%}
  }

  /* ---- Section shell ---- */
  .vc-section {
    background: var(--vc-bg);
    padding: {{ section.settings.section_padding_top | default: 60 }}px 0 {{ section.settings.section_padding_bottom | default: 60 }}px;
    overflow: hidden;
  }

  /* ---- Header ---- */
  .vc-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 0 {{ section.settings.section_padding_x | default: 40 }}px;
    margin-bottom: 28px;
  }

  .vc-heading {
    margin: 0 0 4px;
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    font-weight: 600;
    color: var(--vc-heading-color);
    line-height: 1.2;
  }

  .vc-subheading {
    margin: 0;
    font-size: 0.95rem;
    opacity: 0.65;
    color: var(--vc-heading-color);
  }

  /* ---- Prev / Next buttons ---- */
  .vc-controls {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .vc-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid rgba(0,0,0,0.15);
    background: var(--vc-btn-bg);
    color: var(--vc-btn-color);
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
  }

  .vc-btn:hover  { opacity: 0.8; transform: scale(1.05); }
  .vc-btn:active { transform: scale(0.97); }
  .vc-btn:disabled { opacity: 0.3; pointer-events: none; }

  /* ---- Track ---- */
  .vc-track-wrapper {
    padding: 0 {{ section.settings.section_padding_x | default: 40 }}px;
  }

  .vc-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc(
      (100% - (var(--vc-cards-visible) - 1) * var(--vc-gap)) / var(--vc-cards-visible)
    );
    gap: var(--vc-gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    list-style: none;
    margin: 0;
    padding: 8px 0 16px; /* room for box-shadow */
  }
  .vc-track::-webkit-scrollbar { display: none; }

  /* ---- Card ---- */
  .vc-card {
    scroll-snap-align: start;
    border-radius: var(--vc-radius);
    overflow: hidden;
    background: var(--vc-card-bg);
    position: relative;
  }

  .vc-card__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .vc-card__media {
    position: relative;
    aspect-ratio: var(--vc-card-aspect);
    overflow: hidden;
    cursor: pointer;
  }

  /* ---- Thumbnail ---- */
  .vc-card__thumbnail {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  .vc-card__thumbnail--placeholder {
    background: #2a1a3e;
  }

  .vc-card__thumbnail--placeholder .vc-placeholder-svg {
    width: 100%;
    height: 100%;
    opacity: 0.15;
  }

  /* ---- Inline preview video ---- */
  .vc-card__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  /* Hover state — show video, fade thumbnail */
  .vc-card.is-hovered .vc-card__video   { opacity: 1; }
  .vc-card.is-hovered .vc-card__thumbnail { opacity: 0; }

  /* ---- Play button ---- */
  .vc-card__play-btn {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 3;
    padding: 0;
  }

  .vc-play-icon {
    width: 52px;
    height: 52px;
    color: #111;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.25));
    transition: transform 0.2s ease, opacity 0.2s ease;
    flex-shrink: 0;
  }

  .vc-card__play-btn:hover .vc-play-icon  { transform: scale(1.1); }
  .vc-card.is-hovered .vc-play-icon        { opacity: 0.85; }

  /* ---- Caption overlay ---- */
  .vc-card__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 4;
    margin: 0;
    padding: 12px 14px;
    font-size: 0.85rem;
    line-height: 1.4;
    color: #fff;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 100%);
  }

  /* ---- Card body (title below media) ---- */
  .vc-card__body {
    padding: 10px 14px 14px;
  }

  .vc-card__title {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 500;
    color: #fff;
    line-height: 1.35;
  }

  /* ---- Modal ---- */
  .vc-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vc-modal[hidden] { display: none; }

  .vc-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.88);
    cursor: pointer;
  }

  .vc-modal__container {
    position: relative;
    z-index: 1;
    width: min(90vw, 960px);
    max-height: 90vh;
  }

  .vc-modal__close {
    position: absolute;
    top: -44px;
    right: 0;
    background: transparent;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 8px;
    display: flex;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .vc-modal__close:hover { opacity: 1; }

  .vc-modal__player {
    position: relative;
    width: 100%;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .vc-modal__video,
  .vc-modal__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .vc-modal__video[src=""],
  .vc-modal__video:not([src]) { display: none; }
  .vc-modal__iframe-wrap { position: absolute; inset: 0; }
  .vc-modal__iframe[src=""],
  .vc-modal__iframe:not([src]) { display: none; }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    #{{ section_id }} { --vc-cards-visible: 3; }
  }
  @media (max-width: 768px) {
    #{{ section_id }} { --vc-cards-visible: 2; }
    .vc-header { padding: 0 20px; }
    .vc-track-wrapper { padding: 0 20px; }
  }
  @media (max-width: 480px) {
    #{{ section_id }} { --vc-cards-visible: 1.2; }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .vc-card__video,
    .vc-card__thumbnail,
    .vc-play-icon { transition: none; }
  }
</style>

{% comment %} =================== JAVASCRIPT =================== {% endcomment %}
<script>
(function () {
  'use strict';

  function initVideoCarousel(sectionEl) {
    const sectionId   = sectionEl.id;
    const track       = document.getElementById(sectionId + '-track');
    const modal       = document.getElementById(sectionId + '-modal');
    const modalVideo  = modal.querySelector('.vc-modal__video');
    const modalIframe = modal.querySelector('.vc-modal__iframe');
    const modalClose  = modal.querySelector('.vc-modal__close');
    const modalBg     = modal.querySelector('.vc-modal__backdrop');
    const btnPrev     = sectionEl.querySelector('.vc-btn--prev');
    const btnNext     = sectionEl.querySelector('.vc-btn--next');

    if (!track) return;

    const cards = Array.from(track.querySelectorAll('.vc-card'));

    // ── Arrow navigation ──────────────────────────────────────────────
    function scrollByCard(dir) {
      const card    = cards[0];
      if (!card) return;
      const width   = card.offsetWidth;
      const gap     = parseInt(getComputedStyle(track).gap) || 0;
      track.scrollBy({ left: dir * (width + gap), behavior: 'smooth' });
    }

    if (btnPrev) btnPrev.addEventListener('click', () => scrollByCard(-1));
    if (btnNext) btnNext.addEventListener('click', () => scrollByCard(1));

    // Update button disabled state
    function syncButtons() {
      if (!btnPrev || !btnNext) return;
      btnPrev.disabled = track.scrollLeft <= 2;
      btnNext.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
    }
    track.addEventListener('scroll', syncButtons, { passive: true });
    syncButtons();

    // ── Hover-to-autoplay ─────────────────────────────────────────────
    cards.forEach(function (card) {
      const videoEl  = card.querySelector('.vc-card__video');
      const sources  = videoEl ? videoEl.querySelectorAll('source[data-src]') : [];
      let hoverTimer = null;
      let loaded     = false;
      const delay    = parseInt(card.dataset.autoplayDelay) || 300;

      function loadSources() {
        if (loaded || !sources.length) return;
        sources.forEach(function (s) {
          s.src = s.dataset.src;
        });
        videoEl.load();
        loaded = true;
      }

      function startPreview() {
        if (!videoEl || card.dataset.videoType === 'external') return;
        hoverTimer = setTimeout(function () {
          loadSources();
          card.classList.add('is-hovered');
          videoEl.play().catch(function () {}); // autoplay policy guard
        }, delay);
      }

      function stopPreview() {
        clearTimeout(hoverTimer);
        card.classList.remove('is-hovered');
        if (videoEl) {
          videoEl.pause();
          videoEl.currentTime = 0;
        }
      }

      card.addEventListener('mouseenter', startPreview);
      card.addEventListener('mouseleave', stopPreview);
      card.addEventListener('focusin',    startPreview);
      card.addEventListener('focusout',   stopPreview);
    });

    // ── Click-to-open modal ───────────────────────────────────────────
    cards.forEach(function (card) {
      const playBtn   = card.querySelector('.vc-card__play-btn');
      if (!playBtn) return;

      playBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        openModal(card);
      });
    });

    function openModal(card) {
      const type     = card.dataset.videoType;
      const videoId  = card.dataset.videoId;
      const videoUrl = card.dataset.videoUrl;

      // Reset
      modalVideo.removeAttribute('src');
      modalIframe.removeAttribute('src');

      if (type === 'hosted' && videoId) {
        // Shopify-hosted video — need to read real source URLs
        const videoEl   = card.querySelector('.vc-card__video');
        const firstSrc  = videoEl ? videoEl.querySelector('source') : null;
        if (firstSrc && firstSrc.src) {
          modalVideo.src = firstSrc.src;
        } else if (firstSrc && firstSrc.dataset.src) {
          modalVideo.src = firstSrc.dataset.src;
        }
      } else if (type === 'external' && videoUrl) {
        modalIframe.src = embedUrl(videoUrl);
      }

      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      modalClose.focus();

      if (type === 'hosted') {
        modalVideo.play().catch(function () {});
      }
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
      modalVideo.pause();
      modalVideo.removeAttribute('src');
      modalIframe.removeAttribute('src');
    }

    modalClose.addEventListener('click', closeModal);
    modalBg.addEventListener('click', closeModal);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });

    // ── Embed URL helper ──────────────────────────────────────────────
    function embedUrl(url) {
      try {
        const u = new URL(url);
        // YouTube
        if (u.hostname.includes('youtu')) {
          const id = u.searchParams.get('v') || u.pathname.split('/').pop();
          return 'https://www.youtube.com/embed/' + id + '?autoplay=1&rel=0';
        }
        // Vimeo
        if (u.hostname.includes('vimeo')) {
          const id = u.pathname.split('/').filter(Boolean).pop();
          return 'https://player.vimeo.com/video/' + id + '?autoplay=1';
        }
      } catch (err) {}
      return url;
    }
  }

  // Boot on DOMContentLoaded (and Shopify section re-render)
  function boot() {
    document.querySelectorAll('[data-section-type="video-carousel"]').forEach(initVideoCarousel);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  // Shopify theme editor live reload
  document.addEventListener('shopify:section:load', function (e) {
    const s = e.target.querySelector('[data-section-type="video-carousel"]');
    if (s) initVideoCarousel(s);
  });
})();
</script>

{% comment %} =================== SCHEMA =================== {% endcomment %}
{% schema %}
{
  "name": "Video Carousel",
  "tag": "section",
  "class": "section-video-carousel",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured videos"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Cards visible (desktop)",
      "default": 4
    },
    {
      "type": "select",
      "id": "card_aspect",
      "label": "Card aspect ratio",
      "default": "portrait",
      "options": [
        { "value": "portrait",   "label": "Portrait (9:14)" },
        { "value": "square",     "label": "Square (1:1)" },
        { "value": "landscape",  "label": "Landscape (16:9)" }
      ]
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Card corner radius",
      "default": 16
    },
    {
      "type": "header",
      "content": "Card content"
    },
    {
      "type": "checkbox",
      "id": "show_card_title",
      "label": "Show card title below video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_card_caption",
      "label": "Show caption overlay on video",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
