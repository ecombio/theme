{%- comment -%}
  sections/quick-view.liquid
  ==========================
  Modal shell for the Quick View feature.

  Flow:
    1. product-card.js fires 'quickview:open' with { handle, trigger }
    2. quick-view.js listens, fetches:
         /products/${handle}?sections=quick-view
       and injects the returned HTML into .quick-view-modal__body
    3. snippets/quick-view-media.liquid + snippets/quick-view-detail.liquid
       produce that inner HTML on demand.
    4. snippets/quick-view-description.liquid renders the tab strip
       (Description / Shipping Policy / Returns & Refunds) as a full-width
       row beneath the two-column layout.

  This section renders once in theme.liquid and is reused for every open.
  When fetched via /products/${handle}?sections=quick-view, Shopify passes
  the product object automatically — section.settings.preview_product is
  only used as a fallback in the theme editor.
{%- endcomment -%}

{%- liquid
  assign product       = product | default: section.settings.preview_product
  assign featured      = product.featured_image
  assign images        = product.images
  assign variants      = product.variants
  assign options       = product.options_with_values
  assign first_variant = product.first_available_variant | default: product.variants.first
  assign eta_text      = product.metafields.custom.eta_text

  assign has_single_var = false
  if product.has_only_default_variant
    assign has_single_var = true
  endif

  assign on_sale  = false
  assign save_pct = 0
  if first_variant.compare_at_price > first_variant.price
    assign on_sale  = true
    assign save_pct = first_variant.compare_at_price | minus: first_variant.price | times: 100 | divided_by: first_variant.compare_at_price
  endif
-%}

<div
  id="quick-view-modal"
  class="quick-view-modal"
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'products.quick_view.title' | t | default: 'Quick view' }}"
  aria-hidden="true"
>
  <div class="quick-view-modal__backdrop" data-quick-view-close></div>

  <div class="quick-view-modal__panel">
    <button
      type="button"
      class="quick-view-modal__close"
      aria-label="{{ 'accessibility.close' | t | default: 'Close' }}"
      data-quick-view-close
    >
      <svg class="quick-view-modal__close-icon" aria-hidden="true" focusable="false"
           viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="quick-view-modal__body">
      {%- comment -%}
        Populated by quick-view.js on open via sections fetch.
        On the first server render the body is intentionally empty —
        the Liquid below only runs when the section is fetched via
        the sections API or viewed in the theme editor.
      {%- endcomment -%}
      {%- if product != blank -%}
        <div class="quick-view"
          data-product-id="{{ product.id }}"
          data-product-handle="{{ product.handle }}"
        >
          {%- comment -%}── Two-column row: media + detail ──{%- endcomment -%}
          {%- render 'quick-view-media',
            product:  product,
            featured: featured,
            images:   images
          -%}
          {%- render 'quick-view-detail',
            product:        product,
            variants:       variants,
            first_variant:  first_variant,
            options:        options,
            has_single_var: has_single_var,
            on_sale:        on_sale,
            save_pct:       save_pct,
            eta_text:       eta_text
          -%}

          {%- comment -%}── Full-width row: description / policy tabs ──{%- endcomment -%}
          {%- render 'quick-view-description',
            product: product
          -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Quick View",
  "settings": [
    {
      "type": "product",
      "id": "preview_product",
      "label": "Preview product",
      "info": "Only used in the theme editor to preview the modal. Not shown on storefront."
    }
  ]
}
{% endschema %}