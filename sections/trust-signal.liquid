{%- comment -%}
  Trust Signals Section
  --------------------------------------------------
  Displays a row/grid of trust badges (Free Shipping,
  Warranty, Secure Checkout, etc.) configured via blocks.
  Each block = one badge with icon, heading, and subtext.
{%- endcomment -%}

<section class="trust-signals" data-section-id="{{ section.id }}" data-section-type="trust-signals">
  <div class="trust-signals__container page-width">

    {%- if section.settings.heading != blank -%}
      <h2 class="trust-signals__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div
        class="trust-signals__grid"
        style="--trust-signals-columns: {{ section.blocks.size }};"
      >
        {%- for block in section.blocks -%}
          <div class="trust-signals__item" {{ block.shopify_attributes }}>

            {%- if block.settings.icon != blank -%}
              <div class="trust-signals__icon-wrap">
                <img
                  class="trust-signals__icon"
                  src="{{ block.settings.icon | image_url: width: 100 }}"
                  alt="{{ block.settings.heading | escape }}"
                  loading="lazy"
                  width="48"
                  height="48"
                >
              </div>
            {%- endif -%}

            {%- if block.settings.heading != blank -%}
              <h3 class="trust-signals__item-heading">{{ block.settings.heading | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.subtext != blank -%}
              <p class="trust-signals__item-subtext">{{ block.settings.subtext | escape }}</p>
            {%- endif -%}

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{%- style -%}
  .trust-signals {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }

  .trust-signals__heading {
    text-align: center;
    margin: 0 0 30px;
    font-size: 1.6rem;
  }

  .trust-signals__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media screen and (min-width: 750px) {
    .trust-signals__grid {
      grid-template-columns: repeat(var(--trust-signals-columns, 4), 1fr);
    }
  }

  .trust-signals__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
  }

  .trust-signals__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }

  .trust-signals__icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .trust-signals__item-heading {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }

  .trust-signals__item-subtext {
    font-size: 0.85rem;
    color: rgba(0, 0, 0, 0.6);
    margin: 0;
    line-height: 1.4;
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Trust Signals",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Shop With Us"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "On all orders over $100"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Trust Signals",
      "blocks": [
        {
          "type": "trust_badge",
          "settings": {
            "heading": "Free Shipping",
            "subtext": "On all orders, no minimum"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "heading": "Lifetime Warranty",
            "subtext": "We stand behind every product"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "heading": "Secure Checkout",
            "subtext": "256-bit SSL encrypted payments"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "heading": "30-Day Returns",
            "subtext": "Hassle-free return policy"
          }
        }
      ]
    }
  ]
}
{% endschema %}