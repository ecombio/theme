{% comment %}
sections/main-footer.liquid
Main footer section for ScooterBio

Structure:
- Payment icons + Social icons
- Copyright + Policies
{% endcomment %}

{{ 'main-footer.css' | asset_url | stylesheet_tag }}

<footer class="main-footer" data-section-id="{{ section.id }}" data-section-type="main-footer">
  <div class="page-width">
    <div class="main-footer__content">
      <p>Main footer placeholder</p>
    </div>
  </div>

  <div class="main-footer__bottom">
    <div class="page-width">

      <!-- Payment + Social Icons -->
      <div class="main-footer__icons">
        <!-- Payment icons (static for trust) -->
        <div class="main-footer__payments">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/visa.svg" alt="Visa">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/mastercard.svg" alt="Mastercard">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/paypal.svg" alt="PayPal">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/applepay.svg" alt="Apple Pay">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/afterpay.svg" alt="Afterpay">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/klarna.svg" alt="Klarna">
        </div>

        <!-- Social icons (editable in theme editor) -->
        <div class="main-footer__socials">
          {% if section.settings.social_x != blank %}
            <a href="{{ section.settings.social_x }}" target="_blank">
              <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/x.svg" alt="X">
            </a>
          {% endif %}

          {% if section.settings.social_tiktok != blank %}
            <a href="{{ section.settings.social_tiktok }}" target="_blank">
              <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/tiktok.svg" alt="TikTok">
            </a>
          {% endif %}

          {% if section.settings.social_youtube != blank %}
            <a href="{{ section.settings.social_youtube }}" target="_blank">
              <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/youtube.svg" alt="YouTube">
            </a>
          {% endif %}

          {% if section.settings.social_instagram != blank %}
            <a href="{{ section.settings.social_instagram }}" target="_blank">
              <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/instagram.svg" alt="Instagram">
            </a>
          {% endif %}

          {% if section.settings.social_facebook != blank %}
            <a href="{{ section.settings.social_facebook }}" target="_blank">
              <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/facebook.svg" alt="Facebook">
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Copyright + Policies -->
      <div class="main-footer__bottom-inner">
        <div class="main-footer__copyright">
          <p>{{ section.settings.copyright_text }}</p>
        </div>

        <ul class="main-footer__policies">
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/terms-of-service">Terms of Service</a></li>
          <li><a href="/policies/refund-policy">Refund Policy</a></li>
          <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
        </ul>
      </div>

    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Main footer",
  "settings": [
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© {{ 'now' | date: '%Y' }} ScooterBio. All rights reserved."
    },
    {
      "type": "header",
      "content": "Social Media Links"
    },
    {
      "type": "url",
      "id": "social_x",
      "label": "X (Twitter)"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook"
    }
  ],
  "presets": [
    {
      "name": "Main footer"
    }
  ]
}
{% endschema %}