{% comment %}
sections/main-footer.liquid
Main footer section for ScooterBio

Structure:
- Payment icons + Social icons
- Copyright + Policies
{% endcomment %}

{{ 'main-footer.css' | asset_url | stylesheet_tag }}

<footer class="main-footer" data-section-id="{{ section.id }}" data-section-type="main-footer">
  <div class="page-width">
    <div class="main-footer__content">
      <!-- Upper footer content goes here -->
      <p>Main footer placeholder</p>
    </div>
  </div>

  <div class="main-footer__bottom">
    <div class="page-width">

      <!-- Payment Icons + Social Icons -->
      <div class="main-footer__icons">
        <div class="main-footer__payments">
          <!-- Drop your payment SVGs here (from simpleicons.org) -->
          <img src="{{ 'visa.svg' | asset_url }}" alt="Visa">
          <img src="{{ 'mastercard.svg' | asset_url }}" alt="Mastercard">
          <img src="{{ 'paypal.svg' | asset_url }}" alt="PayPal">
          <img src="{{ 'apple-pay.svg' | asset_url }}" alt="Apple Pay">
          <!-- Add Affirm, Afterpay etc. -->
        </div>

        <div class="main-footer__socials">
          <a href="https://x.com/scooterbio" target="_blank"><img src="{{ 'x.svg' | asset_url }}" alt="X"></a>
          <a href="https://tiktok.com/@scooterbio" target="_blank"><img src="{{ 'tiktok.svg' | asset_url }}" alt="TikTok"></a>
          <a href="https://youtube.com/@scooterbio" target="_blank"><img src="{{ 'youtube.svg' | asset_url }}" alt="YouTube"></a>
          <a href="https://instagram.com/scooterbio" target="_blank"><img src="{{ 'instagram.svg' | asset_url }}" alt="Instagram"></a>
          <a href="https://facebook.com/scooterbio" target="_blank"><img src="{{ 'facebook.svg' | asset_url }}" alt="Facebook"></a>
        </div>
      </div>

      <!-- Copyright + Policies -->
      <div class="main-footer__bottom-inner">
        <div class="main-footer__copyright">
          <p>&copy; {{ 'now' | date: '%Y' }} ScooterBio. All rights reserved.</p>
        </div>

        <ul class="main-footer__policies">
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/terms-of-service">Terms of Service</a></li>
          <li><a href="/policies/refund-policy">Refund Policy</a></li>
          <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
        </ul>
      </div>

    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Main footer",
  "settings": [],
  "presets": [
    {
      "name": "Main footer"
    }
  ]
}
{% endschema %}