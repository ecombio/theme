{% comment %}
sections/main-footer.liquid
Main footer section for ScooterBio
{% endcomment %}

<style>
/* Main Footer Styles */
.main-footer {
  background-color: #111111;
  color: #ffffff;
  padding-top: 40px;
}

.main-footer__content {
  padding-bottom: 40px;
}

/* Horizontal Footer Bottom - Desktop default */
.main-footer__bottom {
  background-color: #000000;
  padding: 20px 0;
  font-size: 14px;
}

.main-footer__bottom-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 16px;
}

.main-footer__copyright p {
  margin: 0;
}

.main-footer__policies {
  display: flex;
  gap: 24px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.main-footer__policies a {
  color: #ffffff;
  text-decoration: none;
  transition: opacity 0.2s ease;
}

.main-footer__policies a:hover {
  opacity: 0.7;
}

/* Mobile: max-width 767px */
@media screen and (max-width: 767px) {
  .main-footer__bottom-inner {
    flex-direction: column;
    text-align: center;
    gap: 12px;
  }

  .main-footer__policies {
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
  }
}

/* Tablet: 768px–1023px */
@media screen and (min-width: 768px) and (max-width: 1023px) {
  .main-footer__bottom-inner {
    gap: 20px;
  }
}
</style>

<footer class="main-footer" data-section-id="{{ section.id }}" data-section-type="main-footer">
  <div class="page-width">
    <div class="main-footer__content">
      <!-- Upper footer content goes here -->
      <p>Main footer placeholder</p>
    </div>
  </div>

  <div class="main-footer__bottom">
    <div class="page-width">
      <div class="main-footer__bottom-inner">
        <div class="main-footer__copyright">
          <p>&copy; {{ 'now' | date: '%Y' }} ScooterBio. All rights reserved.</p>
        </div>

        <ul class="main-footer__policies">
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/terms-of-service">Terms of Service</a></li>
          <li><a href="/policies/refund-policy">Refund Policy</a></li>
          <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Main footer",
  "settings": [],
  "presets": [
    {
      "name": "Main footer"
    }
  ]
}
{% endschema %}