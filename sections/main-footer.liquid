{% comment %}
sections/main-footer.liquid
Main footer section for ScooterBio

Structure:
- Payment icons + Social icons (Simple Icons CDN)
- Copyright + Policies
{% endcomment %}

{{ 'main-footer.css' | asset_url | stylesheet_tag }}

<footer class="main-footer" data-section-id="{{ section.id }}" data-section-type="main-footer">
  <div class="page-width">
    <div class="main-footer__content">
      <p>Main footer placeholder</p>
    </div>
  </div>

  <div class="main-footer__bottom">
    <div class="page-width">

      <!-- Payment + Social Icons -->
      <div class="main-footer__icons">
        <div class="main-footer__payments">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/visa.svg" alt="Visa" class="icon-visa">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/mastercard.svg" alt="Mastercard" class="icon-mastercard">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/paypal.svg" alt="PayPal" class="icon-paypal">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/applepay.svg" alt="Apple Pay" class="icon-applepay">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/afterpay.svg" alt="Afterpay" class="icon-afterpay">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/klarna.svg" alt="Klarna" class="icon-klarna">
        </div>

        <div class="main-footer__socials">
          <a href="https://x.com/scooterbio" target="_blank"><img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/x.svg" alt="X" class="icon-x"></a>
          <a href="https://tiktok.com/@scooterbio" target="_blank"><img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/tiktok.svg" alt="TikTok" class="icon-tiktok"></a>
          <a href="https://youtube.com/@scooterbio" target="_blank"><img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/youtube.svg" alt="YouTube" class="icon-youtube"></a>
          <a href="https://instagram.com/scooterbio" target="_blank"><img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/instagram.svg" alt="Instagram" class="icon-instagram"></a>
          <a href="https://facebook.com/scooterbio" target="_blank"><img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/facebook.svg" alt="Facebook" class="icon-facebook"></a>
        </div>
      </div>

      <!-- Copyright + Policies -->
      <div class="main-footer__bottom-inner">
        <div class="main-footer__copyright">
          <p>&copy; {{ 'now' | date: '%Y' }} ScooterBio. All rights reserved.</p>
        </div>

        <ul class="main-footer__policies">
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/terms-of-service">Terms of Service</a></li>
          <li><a href="/policies/refund-policy">Refund Policy</a></li>
          <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
        </ul>
      </div>

    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Main footer",
  "settings": [],
  "presets": [
    {
      "name": "Main footer"
    }
  ]
}
{% endschema %}