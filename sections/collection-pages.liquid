{%- if context == 'search' -%}
  {%- assign page_results = search.results | where: 'object_type', 'page' -%}
  {%- if page_results.size > 0 -%}
    <div class="collection-pages-grid">
      {%- for page in page_results -%}
        {% render 'card-page', page: page %}
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="collection-showcase__empty">No pages found for &ldquo;{{ search.terms | escape }}&rdquo;.</p>
  {%- endif -%}
{%- else -%}
  {%- if meta_pages != blank and meta_pages.size > 0 -%}
    <div class="collection-pages-grid">
      {%- for page in meta_pages -%}
        {% render 'card-page', page: page %}
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="collection-showcase__empty">No pages have been added to this collection yet.</p>
  {%- endif -%}
{%- endif -%}