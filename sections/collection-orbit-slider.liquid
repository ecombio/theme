{% comment %}
  Section: collection-orbit-slider
  Description: A horizontal scrolling collection category slider with circular
               image thumbnails, smooth drag-scroll, and animated hover states.
  Usage: Add to your Shopify theme's /sections/ folder.
         Configurable via Theme Customizer.
{% endcomment %}

{{ 'collection-orbit-slider.css' | asset_url | stylesheet_tag }}

<section
  class="orbit-slider"
  id="orbit-slider-{{ section.id }}"
  data-section-id="{{ section.id }}"
  style="
    --orbit-bg: {{ section.settings.background_color }};
    --orbit-text: {{ section.settings.text_color }};
    --orbit-accent: {{ section.settings.accent_color }};
    --orbit-padding-top: {{ section.settings.padding_top }}px;
    --orbit-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="orbit-slider__container">

    {% if section.settings.heading != blank %}
      <h2 class="orbit-slider__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="orbit-slider__track-wrapper">
      {%- comment -%} Fade edges {%- endcomment -%}
      <div class="orbit-slider__fade orbit-slider__fade--left" aria-hidden="true"></div>
      <div class="orbit-slider__fade orbit-slider__fade--right" aria-hidden="true"></div>

      {%- comment -%} Prev / Next nav buttons {%- endcomment -%}
      <button
        class="orbit-slider__nav orbit-slider__nav--prev"
        aria-label="Scroll left"
        data-dir="-1"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M12.5 16.25L6.25 10L12.5 3.75" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button
        class="orbit-slider__nav orbit-slider__nav--next"
        aria-label="Scroll right"
        data-dir="1"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7.5 3.75L13.75 10L7.5 16.25" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <ul class="orbit-slider__track" role="list" aria-label="{{ section.settings.heading | escape }}">
        {% for block in section.blocks %}
          {% assign collection = collections[block.settings.collection] %}
          {% assign label = block.settings.label | default: collection.title %}

          <li
            class="orbit-slider__item"
            {{ block.shopify_attributes }}
            style="--item-index: {{ forloop.index0 }}"
          >
            <a
              href="{% if collection != blank %}{{ collection.url }}{% else %}{{ block.settings.url }}{% endif %}"
              class="orbit-slider__link"
              aria-label="{{ label | escape }}"
            >
              <div class="orbit-slider__circle">
                {% if block.settings.image != blank %}
                  {{ block.settings.image
                    | image_url: width: 400
                    | image_tag:
                      loading: 'lazy',
                      class: 'orbit-slider__img',
                      alt: label,
                      widths: '80, 120, 160, 200, 400'
                  }}
                {% elsif collection != blank and collection.featured_image != blank %}
                  {{ collection.featured_image
                    | image_url: width: 400
                    | image_tag:
                      loading: 'lazy',
                      class: 'orbit-slider__img',
                      alt: label,
                      widths: '80, 120, 160, 200, 400'
                  }}
                {% else %}
                  {%- comment -%} Placeholder when no image is set {%- endcomment -%}
                  <div class="orbit-slider__placeholder" aria-hidden="true">
                    {{ 'collection-1' | placeholder_svg_tag: 'orbit-slider__placeholder-svg' }}
                  </div>
                {% endif %}

                {% if block.settings.badge != blank %}
                  <span class="orbit-slider__badge">{{ block.settings.badge }}</span>
                {% endif %}
              </div>

              <span class="orbit-slider__label">{{ label }}</span>
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>

  </div>
</section>

<style>
  #orbit-slider-{{ section.id }} {
    padding-top: var(--orbit-padding-top, 20px);
    padding-bottom: var(--orbit-padding-bottom, 20px);
    background-color: var(--orbit-bg, #ffffff);
  }

  #orbit-slider-{{ section.id }} .orbit-slider__item {
    animation-delay: calc(var(--item-index) * 60ms);
  }
</style>

<script src="{{ 'collection-orbit-slider.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Collection Orbit Slider",
  "tag": "section",
  "class": "section-orbit-slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by Category"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Label text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (badge / hover ring)",
      "default": "#c0392b"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection item",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Override label"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Override URL (if no collection)"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text (e.g. Sale)",
          "info": "Appears as a coloured pill over the circle."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Orbit Slider",
      "blocks": [
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ],
  "max_blocks": 20
}
{% endschema %}
