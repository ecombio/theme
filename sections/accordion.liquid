{% comment %}
  ECOMBIO Accordion Section
  File: sections/accordion.liquid

  Drop into blog post templates or any page template.
  Editors can add, reorder, and edit accordion items in the Shopify customizer.
  Zero blocks = section renders nothing.
{% endcomment %}

{%- if section.blocks.size > 0 -%}

{%- assign heading      = section.settings.heading -%}
{%- assign subheading   = section.settings.subheading -%}
{%- assign open_first   = section.settings.open_first -%}

<div class="ecombio-accordion" id="accordion-{{ section.id }}">

  {%- if heading != blank or subheading != blank -%}
    <div class="ecombio-accordion__header">
      {%- if heading != blank -%}
        <h2 class="ecombio-accordion__heading">{{ heading }}</h2>
      {%- endif -%}
      {%- if subheading != blank -%}
        <p class="ecombio-accordion__subheading">{{ subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="ecombio-accordion__list">
    {%- for block in section.blocks -%}
      {%- assign is_first = false -%}
      {%- if forloop.first and open_first -%}
        {%- assign is_first = true -%}
      {%- endif -%}

      <details class="ecombio-accordion__item" {% if is_first %}open{% endif %} {{ block.shopify_attributes }}>
        <summary class="ecombio-accordion__summary">
          {%- if block.settings.icon != blank -%}
            <span class="ecombio-accordion__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'info' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                {%- when 'lock' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                  </svg>
                {%- when 'bell' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                  </svg>
                {%- when 'star' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                  </svg>
                {%- when 'question' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                {%- when 'check' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
              {%- endcase -%}
            </span>
          {%- endif -%}

          <span class="ecombio-accordion__title">{{ block.settings.title | default: 'Accordion item' }}</span>

          <svg class="ecombio-accordion__chevron" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>

        <div class="ecombio-accordion__body">
          {{ block.settings.content }}
        </div>
      </details>
    {%- endfor -%}
  </div>

</div>

<style>
  #accordion-{{ section.id }} {
    --acc-gap:          {{ section.settings.spacing | default: 0 }}px;
    --acc-radius:       {{ section.settings.border_radius | default: 8 }}px;
    --acc-accent:       {{ section.settings.accent_color | default: '#111827' }};
    max-width: {{ section.settings.max_width | default: 720 }}px;
    margin-inline: auto;
    padding-block: {{ section.settings.section_padding | default: 40 }}px;
  }
</style>

{%- endif -%}

{% schema %}
{
  "name": "Accordion",
  "tag": "section",
  "class": "ecombio-section-accordion",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Behaviour"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first item by default",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width (px)",
      "min": 400,
      "max": 1200,
      "step": 40,
      "default": 720
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Item corner radius (px)",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent colour",
      "default": "#111827",
      "info": "Used for the open item's border and title."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Accordion item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "",         "label": "None" },
            { "value": "info",     "label": "Info" },
            { "value": "lock",     "label": "Lock / Privacy" },
            { "value": "bell",     "label": "Bell / Notifications" },
            { "value": "star",     "label": "Star" },
            { "value": "question", "label": "Question mark" },
            { "value": "check",    "label": "Check / Verified" }
          ],
          "default": ""
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Question or section title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Add your answer or content here. Rich text is supported — you can include <strong>bold text</strong>, <a href=\"#\">links</a>, and lists.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Accordion",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "info",
            "title": "Account Settings",
            "content": "<p>Manage your name, email, password, and billing details from your account dashboard.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "lock",
            "title": "Privacy & Permissions",
            "content": "<p>Control who sees your data and what third-party apps can access.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "bell",
            "title": "Notifications & Alerts",
            "content": "<p>Choose how and when you receive updates — email, SMS, or push.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}