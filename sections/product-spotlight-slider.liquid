          "info": "Use money format, e.g. $600.00 — leave blank if not on sale"
        },
        {
          "type": "checkbox",
          "id": "force_sale_badge",
          "label": "Show Sale badge",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "selling_fast",
          "label": "Show Selling Fast badge",
          "default": false
        },
        {
          "type": "text",
          "id": "swatch_colors",
          "label": "Swatch colors (comma-separated CSS colors)",
