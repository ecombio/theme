{% comment %}
  Section: product-spotlight-slider
  Description: A two-column layout with a sticky promotional banner on the left
               and a horizontally scrolling product card slider on the right.
               Features sale badges, color swatches, compare-at pricing, and
               a "Selling Fast" label. No Swiper dependency — pure vanilla JS.
  Files needed:
    /sections/product-spotlight-slider.liquid  ← this file
    /assets/product-spotlight-slider.css
    /assets/product-spotlight-slider.js
{% endcomment %}

{{ 'product-spotlight-slider.css' | asset_url | stylesheet_tag }}

<section
  class="pss"
  id="pss-{{ section.id }}"
  data-section-id="{{ section.id }}"
  style="
    --pss-accent: {{ section.settings.accent_color }};
    --pss-banner-bg: {{ section.settings.banner_bg_color }};
    --pss-banner-text: {{ section.settings.banner_text_color }};
    --pss-padding-top: {{ section.settings.padding_top }}px;
    --pss-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="pss__wrapper page-width page-width--fixed">

    {%- comment -%}────── Left: Promo Banner ──────{%- endcomment -%}
    <div class="pss__banner">
      {%- if section.settings.banner_image != blank -%}
        <div class="pss__banner-image">
          {{ section.settings.banner_image
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              class: 'pss__banner-img',
              alt: section.settings.banner_heading,
              widths: '200,300,400,600'
          }}
        </div>
      {%- else -%}
        <div class="pss__banner-image pss__banner-image--placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'pss__banner-placeholder-svg' }}
        </div>
      {%- endif -%}

      <div class="pss__banner-content">
        {%- if section.settings.banner_label != blank -%}
          <p class="pss__banner-label">{{ section.settings.banner_label | escape }}</p>
        {%- endif -%}
        {%- if section.settings.banner_heading != blank -%}
          <h2 class="pss__banner-heading">{{ section.settings.banner_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.banner_button_label != blank -%}
          <a
            class="pss__banner-btn"
            href="{{ section.settings.banner_button_url }}"
          >{{ section.settings.banner_button_label | escape }}</a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%}────── Right: Product Slider ──────{%- endcomment -%}
    <div class="pss__slider-wrap">
      <div class="pss__track" id="pss-track-{{ section.id }}">

        {%- for block in section.blocks -%}
          {%- liquid
            assign product = block.settings.product
            assign is_sale = false
            if product != blank and product.compare_at_price > product.price
              assign is_sale = true
            endif
            if block.settings.force_sale_badge
              assign is_sale = true
            endif
          -%}
          <div
            class="pss__card"
            data-index="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            {%- comment -%} Image area {%- endcomment -%}
            <div class="pss__card-image-wrap">
              {%- if is_sale -%}
                <span class="pss__badge pss__badge--sale">Sale</span>
              {%- endif -%}
              {%- if block.settings.selling_fast -%}
                <span class="pss__badge pss__badge--fast">⚡ Selling Fast</span>
              {%- endif -%}

              <a
                href="{% if product != blank %}{{ product.url }}{% else %}{{ block.settings.product_url }}{% endif %}"
                class="pss__card-link"
                aria-label="{{ block.settings.product_name | default: product.title | escape }}"
              >
                <div class="pss__card-image">
                  {%- if block.settings.product_image != blank -%}
                    {{ block.settings.product_image
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        class: 'pss__card-img',
                        alt: block.settings.product_name | default: product.title,
                        widths: '200,300,400,500,600'
                    }}
                  {%- elsif product != blank and product.featured_image != blank -%}
                    {{ product.featured_image
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        class: 'pss__card-img',
                        alt: product.title,
                        widths: '200,300,400,500,600'
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'pss__card-img pss__card-img--placeholder' }}
                  {%- endif -%}
                </div>
              </a>
            </div>

            {%- comment -%} Card info {%- endcomment -%}
            <div class="pss__card-info">
              {%- assign card_type = block.settings.product_type | default: product.type -%}
              {%- if card_type != blank -%}
                <p class="pss__card-type">{{ card_type | upcase }}</p>
              {%- endif -%}

              <h3 class="pss__card-title">
                <a href="{% if product != blank %}{{ product.url }}{% else %}{{ block.settings.product_url }}{% endif %}">
                  {{ block.settings.product_name | default: product.title }}
                </a>
              </h3>

              <div class="pss__card-price">
                {%- if is_sale -%}
                  <span class="pss__price pss__price--sale">
                    {{ block.settings.sale_price | default: product.price | money }}
                  </span>
                  <span class="pss__price pss__price--compare">
                    {{ block.settings.compare_price | default: product.compare_at_price | money }}
                  </span>
                {%- else -%}
                  <span class="pss__price">
                    {{ block.settings.sale_price | default: product.price | money }}
                  </span>
                {%- endif -%}
              </div>

              {%- comment -%} Color swatches {%- endcomment -%}
              {%- if block.settings.swatch_colors != blank -%}
                <div class="pss__swatches" aria-label="Available colours">
                  {%- assign swatches = block.settings.swatch_colors | split: ',' -%}
                  {%- for swatch in swatches -%}
                    <span
                      class="pss__swatch"
                      style="background: {{ swatch | strip }};"
                      title="{{ swatch | strip }}"
                    ></span>
                  {%- endfor -%}
                </div>
              {%- elsif product != blank -%}
                {%- assign color_option = product.options_by_name['Color'] | default: product.options_by_name['Colour'] -%}
                {%- if color_option != blank -%}
                  <div class="pss__swatches" aria-label="Available colours">
                    {%- for val in color_option.values limit: 4 -%}
                      <span class="pss__swatch pss__swatch--label" title="{{ val }}">
                        {{ val | slice: 0, 1 }}
                      </span>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Nav buttons {%- endcomment -%}
      {%- if section.blocks.size > 1 -%}
        <div class="pss__nav">
          <button class="pss__nav-btn pss__nav-btn--prev" aria-label="Previous products" data-track="pss-track-{{ section.id }}">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M12.5 16.25L6.25 10L12.5 3.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="pss__nav-btn pss__nav-btn--next" aria-label="Next products" data-track="pss-track-{{ section.id }}">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M7.5 3.75L13.75 10L7.5 16.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

<script src="{{ 'product-spotlight-slider.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product Spotlight Slider",
  "tag": "section",
  "class": "section-product-spotlight-slider",
  "settings": [
    {
      "type": "header",
      "content": "Promotional banner"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "text",
      "id": "banner_label",
      "label": "Banner label",
      "default": "Promotion"
    },
    {
      "type": "richtext",
      "id": "banner_heading",
      "label": "Banner heading",
      "default": "<p>Soft Stools Design</p>"
    },
    {
      "type": "text",
      "id": "banner_button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "banner_button_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "banner_bg_color",
      "label": "Banner background",
      "default": "#e8e5de"
    },
    {
      "type": "color",
      "id": "banner_text_color",
      "label": "Banner text",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / sale colour",
      "default": "#c0392b"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product (auto-fills details)"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Override image"
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Override product name"
        },
        {
          "type": "text",
          "id": "product_type",
          "label": "Product type label",
          "default": "CHAIRS",
          "info": "Shown above the product name (e.g. CHAIRS, SOFAS)"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Override product URL"
        },
        {
          "type": "text",
          "id": "sale_price",
          "label": "Sale price (override)",
