{% comment %}
  ╔══════════════════════════════════════════════════════════╗
  ║  sections/product-related.liquid                         ║
  ║  Mode: Same-collection products (pure Liquid, no JS)     ║
  ║  Best placed: middle of product page                     ║
  ╚══════════════════════════════════════════════════════════╝
{% endcomment %}

{% render 'pr-card-styles' %}

{%- liquid
  assign card_style   = section.settings.card_style
  assign btn_style    = section.settings.button_style
  assign cols_d       = section.settings.columns_desktop
  assign cols_m       = section.settings.columns_mobile
  assign gap          = section.settings.card_gap
  assign pad_top      = section.settings.padding_top
  assign pad_bottom   = section.settings.padding_bottom
  assign cs           = section.settings.color_scheme
  assign limit        = section.settings.products_to_show
  assign show_vendor  = section.settings.show_vendor
  assign show_price   = section.settings.show_price
  assign show_badge   = section.settings.show_sale_badge

  assign source_collection = nil

  if section.settings.collection != blank
    assign source_collection = section.settings.collection
  elsif product.collections.size > 0
    assign source_collection = product.collections.first
  endif
-%}

{% if source_collection == nil %}
  {% comment %} No collection — hide section silently {% endcomment %}
{% else %}

  {%- assign related_products = source_collection.products
      | where: 'available', true -%}

  {%- comment -%} Count products excluding current {%- endcomment -%}
  {%- assign eligible_count = 0 -%}
  {%- for p in related_products -%}
    {%- if p.id != product.id -%}
      {%- assign eligible_count = eligible_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  {% if eligible_count == 0 and section.settings.hide_if_empty %}
    {% comment %} Nothing to show and merchant opted to hide {% endcomment %}
  {% else %}

<section
  class="pr-section cs-{{ cs }}"
  id="pr-related-section-{{ section.id }}"
  style="
    --pr-cols: {{ cols_d }};
    --pr-cols-mob: {{ cols_m }};
    --pr-gap: {{ gap }}px;
    --pr-pad-top: {{ pad_top }}px;
    --pr-pad-bottom: {{ pad_bottom }}px;
  "
  aria-label="{{ section.settings.heading | escape }}"
>
  <div class="pr-inner">
    <div class="pr-header">
      <h2 class="pr-heading">{{ section.settings.heading }}</h2>
      {% if section.settings.show_view_all %}
        <a href="{{ source_collection.url }}" class="pr-view-all-link" aria-label="View all {{ source_collection.title | escape }}">
          View all →
        </a>
      {% endif %}
    </div>

    <div class="pr-grid">
      {%- assign shown = 0 -%}
      {%- for p in related_products -%}
        {%- if p.id != product.id and shown < limit -%}
          {%- assign shown = shown | plus: 1 -%}
          {%- assign on_sale = false -%}
          {%- if p.compare_at_price > p.price -%}{%- assign on_sale = true -%}{%- endif -%}

          <a href="{{ p.url }}" class="pr-card s-{{ card_style }}" aria-label="{{ p.title | escape }}">

            <div class="pr-card__media">
              {%- if p.featured_image -%}
                <img
                  src="{{ p.featured_image | image_url: width: 600 }}"
                  srcset="{{ p.featured_image | image_url: width: 300 }} 300w,
                          {{ p.featured_image | image_url: width: 600 }} 600w,
                          {{ p.featured_image | image_url: width: 900 }} 900w"
                  sizes="(max-width: 749px) 50vw, 25vw"
                  alt="{{ p.featured_image.alt | escape }}"
                  class="pr-card__img"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'pr-card__img' }}
              {%- endif -%}

              {%- if show_badge and on_sale -%}
                <div class="pr-badges">
                  <span class="pr-badge pr-badge--sale">Sale</span>
                </div>
              {%- endif -%}
            </div>

            <div class="pr-card__body">
              {%- if show_vendor -%}
                <span class="pr-card__vendor">{{ p.vendor }}</span>
              {%- endif -%}
              <p class="pr-card__title">{{ p.title }}</p>
              {%- if show_price -%}
                <div class="pr-card__price">
                  {%- if on_sale -%}
                    <span class="pr-price pr-price--sale">{{ p.price | money }}</span>
                    <span class="pr-price pr-price--was">{{ p.compare_at_price | money }}</span>
                  {%- else -%}
                    <span class="pr-price">{{ p.price | money }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>

            <div class="pr-card__foot">
              <span class="pr-btn
                {%- if btn_style == 'outline' %} pr-btn--outline
                {%- elsif btn_style == 'ghost' %} pr-btn--ghost
                {%- else %} pr-btn--filled{%- endif -%}">
                View Product
              </span>
            </div>

          </a>
        {%- endif -%}
      {%- endfor -%}

      {%- if shown == 0 -%}
        <p class="pr-empty">No related products found in this collection.</p>
      {%- endif -%}
    </div>
  </div>
</section>

  {% endif %}
{% endif %}

{% schema %}
{
  "name": "Related Products",
  "tag": "section",
  "class": "section-pr-related",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More From This Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to pull from",
      "info": "Leave blank to auto-use the product's first collection."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Number of products"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_if_empty",
      "label": "Hide section if no related products",
      "default": true
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card Style",
      "options": [
        { "value": "boxed",   "label": "Boxed" },
        { "value": "shadow",  "label": "Shadow" },
        { "value": "minimal", "label": "Minimal" }
      ],
      "default": "boxed"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "options": [
        { "value": "filled",  "label": "Filled" },
        { "value": "outline", "label": "Outline" },
        { "value": "ghost",   "label": "Ghost" }
      ],
      "default": "filled"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2, "max": 6, "step": 1, "default": 4,
      "label": "Columns (desktop)"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1, "max": 3, "step": 1, "default": 2,
      "label": "Columns (mobile)"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8, "max": 40, "step": 2, "default": 16,
      "label": "Card gap (px)"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color Scheme",
      "options": [
        { "value": "light",  "label": "Light" },
        { "value": "gray",   "label": "Light Gray" },
        { "value": "dark",   "label": "Dark" },
        { "value": "accent", "label": "Accent" }
      ],
      "default": "gray"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 120, "step": 4, "default": 52,
      "label": "Padding top (px)"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 120, "step": 4, "default": 52,
      "label": "Padding bottom (px)"
    }
  ],
  "presets": [
    {
      "name": "Related Products",
      "settings": {
        "heading": "More From This Collection",
        "products_to_show": 4
      }
    }
  ]
}
{% endschema %}
