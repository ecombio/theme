{% comment %}
  ╔══════════════════════════════════════════════════════════╗
  ║  sections/product-related.liquid                         ║
  ║  Mode: Same-collection products — pure Liquid, no JS     ║
  ║  Cards: snippets/card-product.liquid                     ║
  ║  Place: middle of product page                           ║
  ╚══════════════════════════════════════════════════════════╝
{% endcomment %}

{%- liquid
  assign cols_d     = section.settings.columns_desktop
  assign cols_m     = section.settings.columns_mobile
  assign gap        = section.settings.card_gap
  assign pad_top    = section.settings.padding_top
  assign pad_bottom = section.settings.padding_bottom
  assign cs         = section.settings.color_scheme
  assign limit      = section.settings.products_to_show

  assign source_col = nil
  if section.settings.collection != blank
    assign source_col = section.settings.collection
  elsif product.collections.size > 0
    assign source_col = product.collections.first
  endif
-%}

{% if source_col == nil %}
  {% comment %} No collection available — hide silently {% endcomment %}
{% else %}

  {%- assign eligible = 0 -%}
  {%- for p in source_col.products -%}
    {%- if p.id != product.id -%}{%- assign eligible = eligible | plus: 1 -%}{%- endif -%}
  {%- endfor -%}

  {%- if eligible == 0 and section.settings.hide_if_empty -%}
    {% comment %} Nothing to show {% endcomment %}
  {%- else -%}

<style>
  #pr-related-{{ section.id }} {
    background: var(--pr-bg);
    padding: {{ pad_top }}px 0 {{ pad_bottom }}px;
  }
  #pr-related-{{ section.id }} .pr-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  #pr-related-{{ section.id }} .pr-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 28px;
    gap: 16px;
  }
  #pr-related-{{ section.id }} .pr-heading {
    font-size: clamp(1.15rem, 2.2vw, 1.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }
  #pr-related-{{ section.id }} .pr-view-all {
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
    opacity: 0.55;
    transition: opacity 0.15s;
  }
  #pr-related-{{ section.id }} .pr-view-all:hover { opacity: 1; }
  #pr-related-{{ section.id }} .pr-grid {
    display: grid;
    grid-template-columns: repeat({{ cols_d }}, 1fr);
    gap: {{ gap }}px;
  }
  @media (max-width: 749px) {
    #pr-related-{{ section.id }} .pr-grid {
      grid-template-columns: repeat({{ cols_m }}, 1fr);
    }
  }
  #pr-related-{{ section.id }} .pr-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 32px 0;
    opacity: 0.4;
    font-size: 0.875rem;
  }

  {% case cs %}
  {% when 'gray'   %}#pr-related-{{ section.id }} { --pr-bg: #f6f6f6; }
  {% when 'dark'   %}#pr-related-{{ section.id }} { --pr-bg: #111; color: #fff; }
  {% when 'accent' %}#pr-related-{{ section.id }} { --pr-bg: var(--color-background-2, #f0f0f0); }
  {% else           %}#pr-related-{{ section.id }} { --pr-bg: #fff; }
  {% endcase %}
</style>

<section id="pr-related-{{ section.id }}" aria-label="{{ section.settings.heading | escape }}">
  <div class="pr-inner">
    <div class="pr-header">
      <h2 class="pr-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.show_view_all -%}
        <a href="{{ source_col.url }}" class="pr-view-all">View all →</a>
      {%- endif -%}
    </div>

    <div class="pr-grid">
      {%- assign shown = 0 -%}
      {%- for p in source_col.products -%}
        {%- if p.id != product.id and shown < limit -%}
          {%- assign shown = shown | plus: 1 -%}
          {%- render 'card-product',
            product: p,
            show_vendor: section.settings.show_vendor,
            show_compare_at_price: section.settings.show_compare_at_price
          -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if shown == 0 -%}
        <p class="pr-empty">No related products found.</p>
      {%- endif -%}
    </div>
  </div>
</section>

  {%- endif -%}
{% endif %}

{% schema %}
{
  "name": "Related Products",
  "tag": "section",
  "class": "section-pr-related",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "More From This Collection" },
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Leave blank to auto-use the product's first collection." },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "default": 4, "label": "Number of products" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'View all' link", "default": true },
    { "type": "checkbox", "id": "hide_if_empty", "label": "Hide if no related products", "default": true },

    { "type": "header", "content": "Card features" },
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": false },
    { "type": "checkbox", "id": "show_compare_at_price", "label": "Show compare-at price", "default": true },
    { "type": "checkbox", "id": "enable_atc", "label": "Add to cart button", "default": true },
    { "type": "checkbox", "id": "enable_quickview", "label": "Quick view button", "default": false },
    { "type": "checkbox", "id": "enable_wishlist", "label": "Wishlist button", "default": false },
    { "type": "checkbox", "id": "enable_compare", "label": "Compare checkbox", "default": false },

    { "type": "header", "content": "Estimated delivery" },
    { "type": "checkbox", "id": "show_eta", "label": "Show ETA", "default": false },
    { "type": "range", "id": "eta_days_min", "min": 1, "max": 14, "step": 1, "default": 3, "label": "ETA min days" },
    { "type": "range", "id": "eta_days_max", "min": 1, "max": 21, "step": 1, "default": 7, "label": "ETA max days" },
    { "type": "text", "id": "eta_label", "label": "ETA label", "default": "Est. arrival:" },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns_desktop", "min": 2, "max": 6, "step": 1, "default": 4, "label": "Columns (desktop)" },
    { "type": "range", "id": "columns_mobile", "min": 1, "max": 3, "step": 1, "default": 2, "label": "Columns (mobile)" },
    { "type": "range", "id": "card_gap", "min": 8, "max": 48, "step": 2, "default": 20, "label": "Card gap (px)" },

    { "type": "header", "content": "Style" },
    {
      "type": "select", "id": "color_scheme", "label": "Color scheme",
      "options": [
        { "value": "light",  "label": "Light" },
        { "value": "gray",   "label": "Light Gray" },
        { "value": "dark",   "label": "Dark" },
        { "value": "accent", "label": "Accent" }
      ],
      "default": "gray"
    },
    { "type": "range", "id": "padding_top",    "min": 0, "max": 120, "step": 4, "default": 52, "label": "Padding top (px)" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "default": 52, "label": "Padding bottom (px)" }
  ],
  "presets": [{ "name": "Related Products", "settings": { "heading": "More From This Collection" } }]
}
{% endschema %}