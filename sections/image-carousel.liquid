{% comment %}
  =========================================================
  IMAGE CAROUSEL SECTION — Shopify 2.0 Compatible
  Supports: Collection, Product, Blog, Page, URL links
  Placeholder-friendly: uses placeholder_svg_tag when no
  image is set, swaps to real image when one is uploaded.
  =========================================================
{% endcomment %}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

{% style %}
  .carousel-section-{{ section.id }} {
    --slide-height: {{ section.settings.slide_height }}px;
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --text-color: {{ section.settings.text_color }};
    --accent-color: {{ section.settings.accent_color }};
    --dot-color: {{ section.settings.dot_color }};
    --nav-bg: {{ section.settings.nav_bg_color }};
    --nav-icon: {{ section.settings.nav_icon_color }};
    position: relative;
    overflow: hidden;
  }

  /* ── Swiper wrapper ── */
  .carousel-section-{{ section.id }} .swiper {
    width: 100%;
    height: var(--slide-height);
  }

  .carousel-section-{{ section.id }} .swiper-slide {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
  }

  /* ── Image / placeholder ── */
  .carousel-section-{{ section.id }} .slide-img,
  .carousel-section-{{ section.id }} .slide-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .carousel-section-{{ section.id }} .slide-placeholder {
    background: #e8e8e8;
  }

  .carousel-section-{{ section.id }} .slide-placeholder svg {
    width: 100%;
    height: 100%;
  }

  .carousel-section-{{ section.id }} .swiper-slide:hover .slide-img,
  .carousel-section-{{ section.id }} .swiper-slide:hover .slide-placeholder {
    transform: scale(1.03);
  }

  /* ── Overlay ── */
  .carousel-section-{{ section.id }} .slide-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,var(--overlay-opacity));
    pointer-events: none;
  }

  /* ── Text content ── */
  .carousel-section-{{ section.id }} .slide-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2.5rem 3rem;
    color: var(--text-color);
    pointer-events: none;
  }

  .carousel-section-{{ section.id }} .slide-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.75;
    margin-bottom: 0.4rem;
  }

  .carousel-section-{{ section.id }} .slide-heading {
    font-size: clamp(1.4rem, 3vw, 2.4rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 0.6rem;
  }

  .carousel-section-{{ section.id }} .slide-subtext {
    font-size: 0.95rem;
    opacity: 0.85;
    max-width: 480px;
  }

  .carousel-section-{{ section.id }} .slide-cta {
    display: inline-block;
    margin-top: 1.2rem;
    padding: 0.55rem 1.4rem;
    background: var(--accent-color);
    color: var(--text-color);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 3px;
    pointer-events: auto;
    transition: opacity 0.2s;
  }

  .carousel-section-{{ section.id }} .slide-cta:hover {
    opacity: 0.85;
  }

  /* ── Navigation arrows ── */
  .carousel-section-{{ section.id }} .swiper-button-prev,
  .carousel-section-{{ section.id }} .swiper-button-next {
    width: 44px;
    height: 44px;
    background: var(--nav-bg);
    border-radius: 50%;
    color: var(--nav-icon);
    transition: background 0.2s;
  }

  .carousel-section-{{ section.id }} .swiper-button-prev:hover,
  .carousel-section-{{ section.id }} .swiper-button-next:hover {
    background: var(--accent-color);
    color: var(--text-color);
  }

  .carousel-section-{{ section.id }} .swiper-button-prev::after,
  .carousel-section-{{ section.id }} .swiper-button-next::after {
    font-size: 1rem;
    font-weight: 700;
  }

  /* ── Pagination dots ── */
  .carousel-section-{{ section.id }} .swiper-pagination-bullet {
    background: var(--dot-color);
    opacity: 0.45;
    width: 8px;
    height: 8px;
  }

  .carousel-section-{{ section.id }} .swiper-pagination-bullet-active {
    opacity: 1;
    background: var(--accent-color);
    width: 24px;
    border-radius: 4px;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .carousel-section-{{ section.id }} .swiper {
      height: {{ section.settings.slide_height_mobile }}px;
    }
    .carousel-section-{{ section.id }} .slide-content {
      padding: 1.5rem;
    }
    .carousel-section-{{ section.id }} .swiper-button-prev,
    .carousel-section-{{ section.id }} .swiper-button-next {
      display: none;
    }
  }
{% endstyle %}

<section
  class="carousel-section-{{ section.id }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-speed="{{ section.settings.autoplay_speed }}"
  data-loop="{{ section.settings.loop }}"
  data-effect="{{ section.settings.transition_effect }}"
>
  <div
    class="swiper carousel-swiper-{{ section.id }}"
    aria-label="{{ section.settings.accessibility_label | escape }}"
  >
    <div class="swiper-wrapper">

      {% for block in section.blocks %}
        {% assign block_link = '' %}

        {%- case block.settings.link_type -%}
          {%- when 'collection' -%}
            {% if block.settings.link_collection != blank %}
              {% assign block_link = block.settings.link_collection.url %}
            {% endif %}
          {%- when 'product' -%}
            {% if block.settings.link_product != blank %}
              {% assign block_link = block.settings.link_product.url %}
            {% endif %}
          {%- when 'blog' -%}
            {% if block.settings.link_blog != blank %}
              {% assign block_link = block.settings.link_blog.url %}
            {% endif %}
          {%- when 'page' -%}
            {% if block.settings.link_page != blank %}
              {% assign block_link = block.settings.link_page.url %}
            {% endif %}
          {%- when 'url' -%}
            {% assign block_link = block.settings.link_url %}
        {%- endcase -%}

        {% if block_link != blank %}
          <a
            class="swiper-slide"
            href="{{ block_link }}"
            {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
            {{ block.shopify_attributes }}
            role="group"
            aria-label="Slide {{ forloop.index }}: {{ block.settings.heading | default: 'Image slide' }}"
          >
        {% else %}
          <div
            class="swiper-slide"
            {{ block.shopify_attributes }}
            role="group"
            aria-label="Slide {{ forloop.index }}: {{ block.settings.heading | default: 'Image slide' }}"
          >
        {% endif %}

          {% comment %} ── Image or placeholder ── {% endcomment %}
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1800
              | image_tag:
                loading: 'lazy',
                class: 'slide-img',
                widths: '480, 768, 1024, 1440, 1800',
                sizes: '100vw',
                alt: block.settings.image.alt | default: block.settings.heading
            }}
          {% else %}
            <div class="slide-placeholder" aria-hidden="true">
              {{ 'lifestyle-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% comment %} ── Overlay ── {% endcomment %}
          <div class="slide-overlay" aria-hidden="true"></div>

          {% comment %} ── Text ── {% endcomment %}
          {% if block.settings.eyebrow != blank
            or block.settings.heading != blank
            or block.settings.subtext != blank
            or block.settings.cta_label != blank
          %}
            <div class="slide-content">
              {% if block.settings.eyebrow != blank %}
                <p class="slide-eyebrow">{{ block.settings.eyebrow }}</p>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h2 class="slide-heading">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.subtext != blank %}
                <p class="slide-subtext">{{ block.settings.subtext }}</p>
              {% endif %}
              {% if block.settings.cta_label != blank and block_link != blank %}
                <span class="slide-cta" aria-hidden="true">{{ block.settings.cta_label }}</span>
              {% endif %}
            </div>
          {% endif %}

        {% if block_link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}

      {% else %}
        {% comment %} ── Fallback: no blocks added yet ── {% endcomment %}
        {% for i in (1..3) %}
          <div class="swiper-slide" role="group" aria-label="Placeholder slide {{ i }}">
            <div class="slide-placeholder" aria-hidden="true">
              {{ 'lifestyle-' | append: i | placeholder_svg_tag }}
            </div>
            <div class="slide-overlay" aria-hidden="true"></div>
            <div class="slide-content">
              <p class="slide-eyebrow">New collection</p>
              <h2 class="slide-heading">Add your slide heading</h2>
              <p class="slide-subtext">Update this slide in the theme editor to add an image, heading, and link.</p>
            </div>
          </div>
        {% endfor %}
      {% endfor %}

    </div><!-- /swiper-wrapper -->

    {% if section.settings.show_navigation %}
      <div class="swiper-button-prev" aria-label="Previous slide"></div>
      <div class="swiper-button-next" aria-label="Next slide"></div>
    {% endif %}

    {% if section.settings.show_pagination %}
      <div class="swiper-pagination" role="tablist" aria-label="Carousel slides"></div>
    {% endif %}
  </div><!-- /swiper -->
</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var el = document.querySelector('.carousel-section-{{ section.id }}');
    if (!el) return;

    new Swiper('.carousel-swiper-{{ section.id }}', {
      loop:            el.dataset.loop      === 'true',
      effect:          el.dataset.effect    || 'slide',
      speed:           600,
      autoplay: el.dataset.autoplay === 'true' ? {
        delay:            parseInt(el.dataset.speed, 10) || 4000,
        disableOnInteraction: false,
        pauseOnMouseEnter:    true
      } : false,
      navigation: {
        nextEl: '.carousel-section-{{ section.id }} .swiper-button-next',
        prevEl: '.carousel-section-{{ section.id }} .swiper-button-prev'
      },
      pagination: {
        el:        '.carousel-section-{{ section.id }} .swiper-pagination',
        clickable: true
      },
      a11y: {
        prevSlideMessage: 'Previous slide',
        nextSlideMessage: 'Next slide'
      },
      keyboard: { enabled: true },
    });
  });
</script>

{% schema %}
{
  "name": "Image Carousel",
  "tag": "section",
  "class": "image-carousel",
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "slide_height",
      "label": "Slide height (desktop)",
      "min": 300,
      "max": 900,
      "step": 20,
      "default": 600,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "slide_height_mobile",
      "label": "Slide height (mobile)",
      "min": 200,
      "max": 600,
      "step": 20,
      "default": 380,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay delay",
      "min": 2000,
      "max": 9000,
      "step": 500,
      "default": 5000,
      "unit": "ms"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop slides",
      "default": true
    },
    {
      "type": "select",
      "id": "transition_effect",
      "label": "Transition effect",
      "options": [
        { "value": "slide", "label": "Slide" },
        { "value": "fade",  "label": "Fade" }
      ],
      "default": "slide"
    },
    {
      "type": "header",
      "content": "Controls"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show prev/next arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 35,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / CTA color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Pagination dot color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "nav_bg_color",
      "label": "Arrow background",
      "default": "rgba(255,255,255,0.25)"
    },
    {
      "type": "color",
      "id": "nav_icon_color",
      "label": "Arrow icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Carousel aria-label",
      "default": "Featured content"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Recommended: 1800 × 900 px. Leave blank to use placeholder."
        },
        {
          "type": "header",
          "content": "Text overlay"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow (small label above heading)",
          "placeholder": "e.g. New arrivals"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "placeholder": "e.g. Summer Edit"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "placeholder": "Optional supporting sentence."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA button label",
          "placeholder": "e.g. Shop now"
        },
        {
          "type": "header",
          "content": "Link destination"
        },
        {
          "type": "select",
          "id": "link_type",
          "label": "Link type",
          "options": [
            { "value": "none",       "label": "No link" },
            { "value": "collection", "label": "Collection" },
            { "value": "product",    "label": "Product" },
            { "value": "blog",       "label": "Blog" },
            { "value": "page",       "label": "Page" },
            { "value": "url",        "label": "Custom URL" }
          ],
          "default": "none"
        },
        {
          "type": "collection",
          "id": "link_collection",
          "label": "Collection",
          "info": "Active when Link type = Collection"
        },
        {
          "type": "product",
          "id": "link_product",
          "label": "Product",
          "info": "Active when Link type = Product"
        },
        {
          "type": "blog",
          "id": "link_blog",
          "label": "Blog",
          "info": "Active when Link type = Blog"
        },
        {
          "type": "page",
          "id": "link_page",
          "label": "Page",
          "info": "Active when Link type = Page"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Custom URL",
          "info": "Active when Link type = Custom URL"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Carousel",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "New arrivals",
            "heading": "Summer Edit",
            "subtext": "Fresh styles just landed — explore the full collection.",
            "cta_label": "Shop now",
            "link_type": "collection"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Staff pick",
            "heading": "Featured Product",
            "cta_label": "View product",
            "link_type": "product"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "From the journal",
            "heading": "Style Notes",
            "cta_label": "Read more",
            "link_type": "blog"
          }
        }
      ]
    }
  ]
}
{% endschema %}
