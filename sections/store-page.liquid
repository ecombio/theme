{% comment %}
  sections/store-page.liquid

  Two divisions within one section:
    [1] product  — product-filter (sort + filter form), product-card, promo-product, promo-carousel
    [2] content  — article-card

  Tab bar toggles between divisions client-side (no page reload).

  Collection falls back to section settings if not on a collection template.
  Blog is always chosen in section settings.

  Filtering is server-rendered: the filter form submits as a GET, the page
  reloads with `filter.*` / `sort_by` query params, and `feed_collection.products`
  reflects the filtered/sorted set automatically. No AJAX re-render.

  CSS: store-page.css, product-card.css, article-card.css, promo-carousel.css,
       promo-product.css, product-filter.css
  JS:  product-filter.js
{% endcomment %}

{{ 'store-page.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}
{{ 'article-card.css' | asset_url | stylesheet_tag }}
{{ 'promo-carousel.css' | asset_url | stylesheet_tag }}
{{ 'promo-product.css' | asset_url | stylesheet_tag }}
{{ 'product-filter.css' | asset_url | stylesheet_tag }}

<style>
  .store-page__layout {
    display: flex;
    align-items: flex-start;
    gap: 2.5rem;
  }

  .store-page__sidebar {
    flex: 0 0 260px;
    width: 260px;
    position: sticky;
    top: 1.5rem;
  }

  .store-page__main {
    flex: 1 1 auto;
    min-width: 0;
  }

  @media (max-width: 989px) {
    .store-page__layout {
      flex-direction: column;
      gap: 1.5rem;
    }

    .store-page__sidebar {
      flex: 1 1 auto;
      width: 100%;
      position: static;
    }
  }
</style>

{%- liquid
  assign columns = section.settings.columns | default: 4

  if collection != blank
    assign feed_collection = collection
  elsif section.settings.collection != blank
    assign feed_collection = section.settings.collection
  endif

  assign feed_blog = section.settings.blog

  assign show_sort = section.settings.show_sort

  assign active_count = 0
  for filter in feed_collection.filters
    if filter.type == 'price_range'
      if filter.min_value.value or filter.max_value.value
        assign active_count = active_count | plus: 1
      endif
    else
      assign active_count = active_count | plus: filter.active_values.size
    endif
  endfor
-%}

<div
  class="store-page"
  style="--store-page-columns: {{ columns }};"
  data-store-page
>

  {%- comment -%} Tab bar {%- endcomment -%}
  <div class="store-page__tabs" role="tablist">
    <button
      class="store-page__tab store-page__tab--active"
      role="tab"
      aria-selected="true"
      aria-controls="store-page-product-{{ section.id }}"
      id="store-page-tab-product-{{ section.id }}"
      data-store-tab="product"
    >
      {{ 'sections.store_page.tab_product' | t | default: 'Product' }}
    </button>
    <button
      class="store-page__tab"
      role="tab"
      aria-selected="false"
      aria-controls="store-page-content-{{ section.id }}"
      id="store-page-tab-content-{{ section.id }}"
      data-store-tab="content"
      tabindex="-1"
    >
      {{ 'sections.store_page.tab_content' | t | default: 'Content' }}
    </button>
  </div>

  {%- comment -%} ── [1] PRODUCT division ── {%- endcomment -%}
  <div
    class="store-page__division"
    id="store-page-product-{{ section.id }}"
    role="tabpanel"
    aria-labelledby="store-page-tab-product-{{ section.id }}"
    data-store-division="product"
  >

    <div class="store-page__layout">

    {%- comment -%} ── Filter + sort (left sidebar) ───────────────────────── {%- endcomment -%}
    {%- if feed_collection != blank -%}
      <aside class="store-page__sidebar">
      <div class="product-filter" data-product-filter>

        <div class="product-filter__header">
          <h2 class="product-filter__heading">{{ section.settings.filter_heading | default: 'Filters' }}</h2>
          <span class="product-filter__count" aria-live="polite">
            {{ feed_collection.products_count }}
            {{- feed_collection.products_count | pluralize: 'result', 'results' }}
          </span>
        </div>

        <button
          class="product-filter__mobile-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="product-filter-drawer-{{ section.id }}"
          data-product-filter-mobile-toggle
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <line x1="1" y1="4"  x2="15" y2="4"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="3" y1="8"  x2="13" y2="8"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="5" y1="12" x2="11" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Filters &amp; sort
          {%- if active_count > 0 -%}
            <span class="product-filter__mobile-count" aria-label="{{ active_count }} active filters">
              {{ active_count }}
            </span>
          {%- endif -%}
        </button>

        <form
          id="product-filter-drawer-{{ section.id }}"
          class="product-filter__body"
          data-product-filter-form
          method="get"
          novalidate
        >

          {%- comment -%} Preserve non-filter params (q, page, etc.) {%- endcomment -%}
          {%- for param in request.query_parameters -%}
            {%- assign param_key = param | first -%}
            {%- unless param_key == 'sort_by' or param_key contains 'filter.' -%}
              <input type="hidden" name="{{ param_key }}" value="{{ param | last | escape }}">
            {%- endunless -%}
          {%- endfor -%}

          {%- comment -%} ── Sort ──────────────────────────────────────────────── {%- endcomment -%}
          {%- if show_sort and feed_collection.sort_options.size > 0 -%}
            <div class="product-filter__sort">
              <label class="product-filter__sort-label" for="product-filter-sort-{{ section.id }}">Sort by</label>
              <select
                id="product-filter-sort-{{ section.id }}"
                class="product-filter__sort-select"
                name="sort_by"
                data-product-filter-sort
              >
                {%- for option in feed_collection.sort_options -%}
                  <option value="{{ option.value }}"{% if option.value == feed_collection.sort_by %} selected{% endif %}>
                    {{ option.name }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endif -%}

          {%- comment -%} ── Active filter chips ───────────────────────────────── {%- endcomment -%}
          {%- if active_count > 0 -%}
            <div class="product-filter__active" aria-label="Active filters" data-product-filter-active>
              {%- for filter in feed_collection.filters -%}
                {%- if filter.type == 'price_range' -%}
                  {%- if filter.min_value.value or filter.max_value.value -%}
                    <a class="product-filter__chip" href="{{ filter.url_to_remove }}" aria-label="Remove price filter">
                      Price:
                      {%- if filter.min_value.value -%}
                        {{ filter.min_value.value | money_without_trailing_zeros }}
                      {%- else -%}0{%- endif -%}
                      &ndash;
                      {%- if filter.max_value.value -%}
                        {{ filter.max_value.value | money_without_trailing_zeros }}
                      {%- else -%}
                        {{ filter.range_max | money_without_trailing_zeros }}
                      {%- endif -%}
                      <span aria-hidden="true">&times;</span>
                    </a>
                  {%- endif -%}
                {%- else -%}
                  {%- for value in filter.active_values -%}
                    <a class="product-filter__chip" href="{{ value.url_to_remove }}" aria-label="Remove filter: {{ value.label | escape }}">
                      {{ value.label }}
                      <span aria-hidden="true">&times;</span>
                    </a>
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}

              <a class="product-filter__chip product-filter__chip--clear" href="{{ feed_collection.url }}{% if show_sort %}?sort_by={{ feed_collection.sort_by }}{% endif %}" data-product-filter-clear-all>
                Clear all
              </a>
            </div>
          {%- endif -%}

          {%- comment -%} ── Filter groups ──────────────────────────────────────── {%- endcomment -%}
          {%- if feed_collection.filters.size > 0 -%}
            <div class="product-filter__groups" data-product-filter-groups>
              {%- for filter in feed_collection.filters -%}
                <details
                  class="product-filter__group"
                  data-filter-type="{{ filter.type }}"
                  {%- if filter.type == 'price_range' -%}
                    {%- if filter.min_value.value or filter.max_value.value %} open{% endif -%}
                  {%- elsif filter.active_values.size > 0 %} open{%- endif -%}
                >
                  <summary class="product-filter__group-summary">
                    <span class="product-filter__group-label">{{ filter.label }}</span>
                    {%- if filter.type != 'price_range' and filter.active_values.size > 0 -%}
                      <span class="product-filter__group-count">{{ filter.active_values.size }}</span>
                    {%- endif -%}
                    <svg class="product-filter__group-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </summary>

                  <div class="product-filter__group-body">
                    {%- case filter.type -%}

                      {%- when 'boolean', 'list' -%}
                        <ul class="product-filter__list" role="group" aria-label="{{ filter.label }}">
                          {%- for value in filter.values -%}
                            {%- assign input_id = 'product-filter-' | append: section.id | append: '-' | append: filter.param_name | append: '-' | append: forloop.index -%}
                            <li class="product-filter__item{% if value.count == 0 and value.active == false %} product-filter__item--disabled{% endif %}">
                              <label class="product-filter__item-label" for="{{ input_id }}">
                                <input
                                  id="{{ input_id }}"
                                  class="product-filter__checkbox"
                                  type="checkbox"
                                  name="{{ value.param_name }}"
                                  value="{{ value.value | escape }}"
                                  {%- if value.active %} checked{% endif -%}
                                  {%- if value.count == 0 and value.active == false %} disabled{% endif -%}
                                  data-product-filter-checkbox
                                  data-url-add="{{ value.url_to_add }}"
                                  data-url-remove="{{ value.url_to_remove }}"
                                >
                                <span class="product-filter__item-text">{{ value.label }}</span>
                                <span class="product-filter__item-count">({{ value.count }})</span>
                              </label>
                            </li>
                          {%- endfor -%}
                        </ul>

                      {%- when 'price_range' -%}
                        {%- assign price_max = filter.range_max | divided_by: 100 -%}
                        {%- assign price_min_val = filter.min_value.value | divided_by: 100 -%}
                        {%- assign price_max_val = filter.max_value.value | divided_by: 100 -%}

                        <div class="product-filter__price" data-product-filter-price>
                          <div class="product-filter__price-field">
                            <label class="product-filter__price-label" for="product-filter-price-min-{{ section.id }}">Min</label>
                            <div class="product-filter__price-input-wrap">
                              <span class="product-filter__price-symbol">{{ cart.currency.symbol }}</span>
                              <input
                                id="product-filter-price-min-{{ section.id }}"
                                class="product-filter__price-input"
                                type="number"
                                name="{{ filter.min_value.param_name }}"
                                min="0"
                                max="{{ price_max }}"
                                value="{{ price_min_val }}"
                                placeholder="0"
                                data-product-filter-price-min
                              >
                            </div>
                          </div>
                          <span class="product-filter__price-sep" aria-hidden="true">&ndash;</span>
                          <div class="product-filter__price-field">
                            <label class="product-filter__price-label" for="product-filter-price-max-{{ section.id }}">Max</label>
                            <div class="product-filter__price-input-wrap">
                              <span class="product-filter__price-symbol">{{ cart.currency.symbol }}</span>
                              <input
                                id="product-filter-price-max-{{ section.id }}"
                                class="product-filter__price-input"
                                type="number"
                                name="{{ filter.max_value.param_name }}"
                                min="0"
                                max="{{ price_max }}"
                                value="{{ price_max_val }}"
                                placeholder="{{ price_max }}"
                                data-product-filter-price-max
                              >
                            </div>
                          </div>
                          <button class="product-filter__price-apply" type="button" data-product-filter-price-apply>
                            Apply
                          </button>
                        </div>

                    {%- endcase -%}
                  </div>
                </details>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <button class="product-filter__submit" type="submit" data-product-filter-submit>
            Apply filters
          </button>

        </form>

      </div>
      </aside>
    {%- endif -%}

    <div class="store-page__main">

    {%- if feed_collection.products != blank -%}

      {%- paginate feed_collection.products by section.settings.products_per_page -%}

        {%- assign row_index = 1 -%}

        <div class="store-page__grid">

          {%- for product in feed_collection.products -%}

            {%- render 'product-card', product: product -%}

            {%- assign position_mod = forloop.index | modulo: columns -%}

            {%- if position_mod == 0 and forloop.last == false -%}

              </div>{{- '' -}}

              {%- for block in section.blocks -%}
                {%- if block.settings.row == row_index -%}
                  {%- case block.type -%}
                    {%- when 'promo_product' -%}
                      {%- render 'promo-product', block: block -%}
                    {%- when 'promo_carousel' -%}
                      {%- render 'promo-carousel', block: block -%}
                  {%- endcase -%}
                {%- endif -%}
              {%- endfor -%}

              {%- assign row_index = row_index | plus: 1 -%}

              <div class="store-page__grid">

            {%- endif -%}

          {%- endfor -%}

        </div>

        {%- for block in section.blocks -%}
          {%- if block.settings.row == row_index -%}
            {%- case block.type -%}
              {%- when 'promo_product' -%}
                {%- render 'promo-product', block: block -%}
              {%- when 'promo_carousel' -%}
                {%- render 'promo-carousel', block: block -%}
            {%- endcase -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if paginate.pages > 1 -%}
          <nav class="store-page__pagination" aria-label="{{ 'general.pagination.label' | t }}">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="store-page__page-link">
                &larr; {{ 'general.pagination.previous' | t }}
              </a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="store-page__page-link">{{ part.title }}</a>
              {%- else -%}
                <span class="store-page__page-link store-page__page-link--current" aria-current="page">
                  {{ part.title }}
                </span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="store-page__page-link">
                {{ 'general.pagination.next' | t }} &rarr;
              </a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      {%- endpaginate -%}

    {%- else -%}
      <p class="store-page__empty">{{ 'collections.general.no_matches' | t }}</p>
    {%- endif -%}

    </div>
    </div>
  </div>

  {%- comment -%} ── [2] CONTENT division ── {%- endcomment -%}
  <div
    class="store-page__division"
    id="store-page-content-{{ section.id }}"
    role="tabpanel"
    aria-labelledby="store-page-tab-content-{{ section.id }}"
    data-store-division="content"
    hidden
  >
    {%- if feed_blog != blank and feed_blog.articles != blank -%}

      {%- paginate feed_blog.articles by section.settings.articles_per_page -%}

        <div class="store-page__grid">
          {%- for article in feed_blog.articles -%}
            {%- render 'article-card', article: article -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="store-page__pagination" aria-label="{{ 'general.pagination.label' | t }}">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="store-page__page-link">
                &larr; {{ 'general.pagination.previous' | t }}
              </a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="store-page__page-link">{{ part.title }}</a>
              {%- else -%}
                <span class="store-page__page-link store-page__page-link--current" aria-current="page">
                  {{ part.title }}
                </span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="store-page__page-link">
                {{ 'general.pagination.next' | t }} &rarr;
              </a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      {%- endpaginate -%}

    {%- else -%}
      <p class="store-page__empty">
        {{ 'sections.store_page.no_articles' | t | default: 'No articles found.' }}
      </p>
    {%- endif -%}
  </div>

</div>

<script src="{{ 'product-filter.js' | asset_url }}" defer></script>
<script>
  (function () {
    var page = document.querySelector('[data-store-page]');
    if (!page) return;

    var tabs      = page.querySelectorAll('[data-store-tab]');
    var divisions = page.querySelectorAll('[data-store-division]');

    tabs.forEach(function (tab, i) {
      tab.addEventListener('click', function () {
        var target = tab.dataset.storeTab;

        tabs.forEach(function (t) {
          var active = t.dataset.storeTab === target;
          t.classList.toggle('store-page__tab--active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
          t.setAttribute('tabindex', active ? '0' : '-1');
        });

        divisions.forEach(function (div) {
          if (div.dataset.storeDivision === target) {
            div.removeAttribute('hidden');
          } else {
            div.setAttribute('hidden', '');
          }
        });
      });

      tab.addEventListener('keydown', function (e) {
        var next;
        if (e.key === 'ArrowRight') next = tabs[i + 1] || tabs[0];
        if (e.key === 'ArrowLeft')  next = tabs[i - 1] || tabs[tabs.length - 1];
        if (next) { next.focus(); next.click(); }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Store page",
  "tag": "section",
  "class": "section-store-page",
  "settings": [
    {
      "type": "header",
      "content": "Product division"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used only if this section is placed outside the collection template."
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 16
    },
    {
      "type": "header",
      "content": "Filtering"
    },
    {
      "type": "text",
      "id": "filter_heading",
      "label": "Filter heading",
      "default": "Filters"
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sort control",
      "default": true
    },
    {
      "type": "header",
      "content": "Content division"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "promo_product",
      "name": "Sponsored Product",
      "settings": [
        {
          "type": "number",
          "id": "row",
          "label": "Insert after row",
          "info": "1 = after the first row of products, 2 = after the second row, etc."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "checkbox",
          "id": "sponsored",
          "label": "Show 'Sponsored' label",
          "default": true
        },
        {
          "type": "text",
          "id": "sponsor_name",
          "label": "Sponsor name (optional)",
          "info": "Defaults to \"Sponsored\" if left blank."
        }
      ]
    },
    {
      "type": "promo_carousel",
      "name": "Promo Carousel",
      "settings": [
        {
          "type": "number",
          "id": "row",
          "label": "Insert after row",
          "info": "1 = after the first row of products, 2 = after the second row, etc."
        },
        {
          "type": "select",
          "id": "content_type",
          "label": "Carousel content",
          "options": [
            { "value": "banner", "label": "Banners" },
            { "value": "product", "label": "Products" }
          ],
          "default": "product"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Carousel heading"
        },
        {
          "type": "collection",
          "id": "source_collection",
          "label": "Source collection (for products)"
        },
        {
          "type": "range",
          "id": "item_count",
          "label": "Items to show",
          "min": 2,
          "max": 12,
          "step": 1,
          "default": 6
        },
        {
          "type": "range",
          "id": "banner_count",
          "label": "Number of banners",
          "min": 1,
          "max": 3,
          "step": 1,
          "default": 3
        },
        {
          "type": "image_picker",
          "id": "banner_1_image",
          "label": "Banner 1 image"
        },
        {
          "type": "text",
          "id": "banner_1_heading",
          "label": "Banner 1 heading"
        },
        {
          "type": "url",
          "id": "banner_1_link",
          "label": "Banner 1 link"
        },
        {
          "type": "image_picker",
          "id": "banner_2_image",
          "label": "Banner 2 image"
        },
        {
          "type": "text",
          "id": "banner_2_heading",
          "label": "Banner 2 heading"
        },
        {
          "type": "url",
          "id": "banner_2_link",
          "label": "Banner 2 link"
        },
        {
          "type": "image_picker",
          "id": "banner_3_image",
          "label": "Banner 3 image"
        },
        {
          "type": "text",
          "id": "banner_3_heading",
          "label": "Banner 3 heading"
        },
        {
          "type": "url",
          "id": "banner_3_link",
          "label": "Banner 3 link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store page"
    }
  ]
}
{% endschema %}