{% comment %}
  sections/store-page.liquid

  Two divisions within one section:
    [1] product  — product-card, promo-product, promo-carousel
    [2] content  — article-card

  Tab bar toggles between divisions client-side (no page reload).

  Collection falls back to section settings if not on a collection template.
  Blog is always chosen in section settings.

  CSS: store-page.css
{% endcomment %}

{{ 'store-page.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}
{{ 'article-card.css' | asset_url | stylesheet_tag }}
{{ 'promo-carousel.css' | asset_url | stylesheet_tag }}
{{ 'promo-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign columns = section.settings.columns | default: 4

  if collection != blank
    assign feed_collection = collection
  elsif section.settings.collection != blank
    assign feed_collection = section.settings.collection
  endif

  assign feed_blog = section.settings.blog
-%}

<div
  class="store-page"
  style="--store-page-columns: {{ columns }};"
  data-store-page
>

  {%- comment -%} Tab bar {%- endcomment -%}
  <div class="store-page__tabs" role="tablist">
    <button
      class="store-page__tab store-page__tab--active"
      role="tab"
      aria-selected="true"
      aria-controls="store-page-product-{{ section.id }}"
      id="store-page-tab-product-{{ section.id }}"
      data-store-tab="product"
    >
      {{ 'sections.store_page.tab_product' | t | default: 'Product' }}
    </button>
    <button
      class="store-page__tab"
      role="tab"
      aria-selected="false"
      aria-controls="store-page-content-{{ section.id }}"
      id="store-page-tab-content-{{ section.id }}"
      data-store-tab="content"
      tabindex="-1"
    >
      {{ 'sections.store_page.tab_content' | t | default: 'Content' }}
    </button>
  </div>

  {%- comment -%} ── [1] PRODUCT division ── {%- endcomment -%}
  <div
    class="store-page__division"
    id="store-page-product-{{ section.id }}"
    role="tabpanel"
    aria-labelledby="store-page-tab-product-{{ section.id }}"
    data-store-division="product"
  >
    {%- if feed_collection.products != blank -%}

      {%- paginate feed_collection.products by section.settings.products_per_page -%}

        {%- assign row_index = 1 -%}

        <div class="store-page__grid">

          {%- for product in feed_collection.products -%}

            {%- render 'product-card', product: product -%}

            {%- assign position_mod = forloop.index | modulo: columns -%}

            {%- if position_mod == 0 and forloop.last == false -%}

              </div>{{- '' -}}

              {%- for block in section.blocks -%}
                {%- if block.settings.row == row_index -%}
                  {%- case block.type -%}
                    {%- when 'promo_product' -%}
                      {%- render 'promo-product', block: block -%}
                    {%- when 'promo_carousel' -%}
                      {%- render 'promo-carousel', block: block -%}
                  {%- endcase -%}
                {%- endif -%}
              {%- endfor -%}

              {%- assign row_index = row_index | plus: 1 -%}

              <div class="store-page__grid">

            {%- endif -%}

          {%- endfor -%}

        </div>

        {%- for block in section.blocks -%}
          {%- if block.settings.row == row_index -%}
            {%- case block.type -%}
              {%- when 'promo_product' -%}
                {%- render 'promo-product', block: block -%}
              {%- when 'promo_carousel' -%}
                {%- render 'promo-carousel', block: block -%}
            {%- endcase -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if paginate.pages > 1 -%}
          <nav class="store-page__pagination" aria-label="{{ 'general.pagination.label' | t }}">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="store-page__page-link">
                &larr; {{ 'general.pagination.previous' | t }}
              </a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="store-page__page-link">{{ part.title }}</a>
              {%- else -%}
                <span class="store-page__page-link store-page__page-link--current" aria-current="page">
                  {{ part.title }}
                </span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="store-page__page-link">
                {{ 'general.pagination.next' | t }} &rarr;
              </a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      {%- endpaginate -%}

    {%- else -%}
      <p class="store-page__empty">{{ 'collections.general.no_matches' | t }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} ── [2] CONTENT division ── {%- endcomment -%}
  <div
    class="store-page__division"
    id="store-page-content-{{ section.id }}"
    role="tabpanel"
    aria-labelledby="store-page-tab-content-{{ section.id }}"
    data-store-division="content"
    hidden
  >
    {%- if feed_blog != blank and feed_blog.articles != blank -%}

      {%- paginate feed_blog.articles by section.settings.articles_per_page -%}

        <div class="store-page__grid">
          {%- for article in feed_blog.articles -%}
            {%- render 'article-card', article: article -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="store-page__pagination" aria-label="{{ 'general.pagination.label' | t }}">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="store-page__page-link">
                &larr; {{ 'general.pagination.previous' | t }}
              </a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="store-page__page-link">{{ part.title }}</a>
              {%- else -%}
                <span class="store-page__page-link store-page__page-link--current" aria-current="page">
                  {{ part.title }}
                </span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="store-page__page-link">
                {{ 'general.pagination.next' | t }} &rarr;
              </a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      {%- endpaginate -%}

    {%- else -%}
      <p class="store-page__empty">
        {{ 'sections.store_page.no_articles' | t | default: 'No articles found.' }}
      </p>
    {%- endif -%}
  </div>

</div>

<script>
  (function () {
    var page = document.querySelector('[data-store-page]');
    if (!page) return;

    var tabs      = page.querySelectorAll('[data-store-tab]');
    var divisions = page.querySelectorAll('[data-store-division]');

    tabs.forEach(function (tab, i) {
      tab.addEventListener('click', function () {
        var target = tab.dataset.storeTab;

        tabs.forEach(function (t) {
          var active = t.dataset.storeTab === target;
          t.classList.toggle('store-page__tab--active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
          t.setAttribute('tabindex', active ? '0' : '-1');
        });

        divisions.forEach(function (div) {
          if (div.dataset.storeDivision === target) {
            div.removeAttribute('hidden');
          } else {
            div.setAttribute('hidden', '');
          }
        });
      });

      tab.addEventListener('keydown', function (e) {
        var next;
        if (e.key === 'ArrowRight') next = tabs[i + 1] || tabs[0];
        if (e.key === 'ArrowLeft')  next = tabs[i - 1] || tabs[tabs.length - 1];
        if (next) { next.focus(); next.click(); }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Store page",
  "tag": "section",
  "class": "section-store-page",
  "settings": [
    {
      "type": "header",
      "content": "Product division"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used only if this section is placed outside the collection template."
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 16
    },
    {
      "type": "header",
      "content": "Content division"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "promo_product",
      "name": "Sponsored Product",
      "settings": [
        {
          "type": "number",
          "id": "row",
          "label": "Insert after row",
          "info": "1 = after the first row of products, 2 = after the second row, etc."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "checkbox",
          "id": "sponsored",
          "label": "Show 'Sponsored' label",
          "default": true
        },
        {
          "type": "text",
          "id": "sponsor_name",
          "label": "Sponsor name (optional)",
          "info": "Defaults to \"Sponsored\" if left blank."
        }
      ]
    },
    {
      "type": "promo_carousel",
      "name": "Promo Carousel",
      "settings": [
        {
          "type": "number",
          "id": "row",
          "label": "Insert after row",
          "info": "1 = after the first row of products, 2 = after the second row, etc."
        },
        {
          "type": "select",
          "id": "content_type",
          "label": "Carousel content",
          "options": [
            { "value": "banner", "label": "Banners" },
            { "value": "product", "label": "Products" }
          ],
          "default": "product"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Carousel heading"
        },
        {
          "type": "collection",
          "id": "source_collection",
          "label": "Source collection (for products)"
        },
        {
          "type": "range",
          "id": "item_count",
          "label": "Items to show",
          "min": 2,
          "max": 12,
          "step": 1,
          "default": 6
        },
        {
          "type": "range",
          "id": "banner_count",
          "label": "Number of banners",
          "min": 1,
          "max": 3,
          "step": 1,
          "default": 3
        },
        {
          "type": "image_picker",
          "id": "banner_1_image",
          "label": "Banner 1 image"
        },
        {
          "type": "text",
          "id": "banner_1_heading",
          "label": "Banner 1 heading"
        },
        {
          "type": "url",
          "id": "banner_1_link",
          "label": "Banner 1 link"
        },
        {
          "type": "image_picker",
          "id": "banner_2_image",
          "label": "Banner 2 image"
        },
        {
          "type": "text",
          "id": "banner_2_heading",
          "label": "Banner 2 heading"
        },
        {
          "type": "url",
          "id": "banner_2_link",
          "label": "Banner 2 link"
        },
        {
          "type": "image_picker",
          "id": "banner_3_image",
          "label": "Banner 3 image"
        },
        {
          "type": "text",
          "id": "banner_3_heading",
          "label": "Banner 3 heading"
        },
        {
          "type": "url",
          "id": "banner_3_link",
          "label": "Banner 3 link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store page"
    }
  ]
}
{% endschema %}
