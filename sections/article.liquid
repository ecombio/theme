{% comment %}
  Article template section
  https://shopify.dev/docs/storefronts/themes/architecture/templates/article
{% endcomment %}

{{ 'article.css' | asset_url | stylesheet_tag }}

{% comment %} ── Header / Banner ── {% endcomment %}
<header class="article-header">
  <nav class="article-nav">
    <a href="{{ shop.url }}" class="article-nav__logo">{{ shop.name }}</a>
    <ul class="article-nav__links">
      {% for link in linklists.main-menu.links %}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {% endfor %}
    </ul>
  </nav>

  <div class="article-banner" {% if article.image %}style="background-image: url('{{ article.image | image_url: width: 1600 }}')"{% endif %}>
    <div class="article-banner__inner">
      {% if blog.title %}
        <span class="article-banner__eyebrow">{{ blog.title }}</span>
      {% endif %}
      <h1 class="article-banner__title">{{ article.title }}</h1>
      {% assign date = article.published_at | time_tag: format: 'date' %}
      <p class="article-banner__meta">{{ 'blog.article_metadata_html' | t: date: date, author: article.author }}</p>
    </div>
  </div>
</header>

{% comment %} ── Main Article Layout ── {% endcomment %}
<div class="main-article">

  {% comment %} Left Sidebar {% endcomment %}
  <aside class="left-sidebar">
    <div class="sidebar-widget sidebar-widget--sticky">
      <h3 class="sidebar-widget__title">Table of Contents</h3>
      <nav class="sidebar-toc" id="toc">
        <p class="sidebar-widget__text">Loading…</p>
      </nav>
    </div>

    <div class="sidebar-widget">
      <h3 class="sidebar-widget__title">About the Author</h3>
      <p class="sidebar-widget__text">{{ article.author }}</p>
    </div>

    <div class="sidebar-widget">
      <h3 class="sidebar-widget__title">Tags</h3>
      {% if article.tags.size > 0 %}
        <ul class="sidebar-tags">
          {% for tag in article.tags %}
            <li><a href="{{ blog.url }}/tagged/{{ tag | handleize }}">{{ tag }}</a></li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="sidebar-widget__text">No tags.</p>
      {% endif %}
    </div>

    <div class="sidebar-widget">
      <h3 class="sidebar-widget__title">Share</h3>
      <div class="sidebar-share">
        <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener">Twitter</a>
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener">Facebook</a>
      </div>
    </div>
  </aside>

  {% comment %} Article Content {% endcomment %}
  <article class="article-content">
    {{ article.content }}

    {% comment %} Comments {% endcomment %}
    {% if blog.comments_enabled? %}
      <section class="article-comments" id="comments">
        <h2>{{ 'blog.article_comments' | t }}</h2>

        {% paginate article.comments by 10 %}
          {% for comment in article.comments %}
            <div class="article-comment">
              <p class="article-comment__author">{{ comment.author }}</p>
              <p class="article-comment__date">{{ comment.created_at | time_tag: format: 'date' }}</p>
              <p class="article-comment__body">{{ comment.content }}</p>
            </div>
          {% endfor %}
          {{ paginate | default_pagination: anchor: 'comments' }}
        {% endpaginate %}

        {% form 'new_comment', article %}
          <h2>{{ 'blog.comment_form_title' | t }}</h2>
          {{ form.errors | default_errors }}

          <div class="comment-form__field">
            <label for="author">{{ 'blog.comment_form_name' | t }}</label>
            <input type="text" name="comment[author]" id="author" value="{{ form.author }}" required>
          </div>

          <div class="comment-form__field">
            <label for="email">{{ 'blog.comment_form_email' | t }}</label>
            <input type="email" name="comment[email]" id="email" value="{{ form.email }}" required>
          </div>

          <div class="comment-form__field">
            <label for="body">{{ 'blog.comment_form_body' | t }}</label>
            <textarea name="comment[body]" id="body" required>{{ form.body }}</textarea>
          </div>

          <input type="submit" value="{{ 'blog.comment_form_submit' | t }}" class="comment-form__submit">
        {% endform %}
      </section>
    {% endif %}
  </article>

  {% comment %} Right Sidebar {% endcomment %}
  <aside class="right-sidebar">
    <div class="sidebar-widget">
      <h3 class="sidebar-widget__title">Recent Posts</h3>
      <ul class="sidebar-recent">
        {% for post in blog.articles limit: 5 %}
          {% unless post.handle == article.handle %}
            <li><a href="{{ post.url }}">{{ post.title }}</a></li>
          {% endunless %}
        {% endfor %}
      </ul>
    </div>

  </aside>

</div>

<script src="{{ 'article.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:general.article",
  "settings": []
}
{% endschema %}