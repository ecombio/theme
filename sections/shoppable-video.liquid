      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video card",
      "settings": [
        {
          "type": "header",
          "content": "Video — choose one"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted video"
        },
        {
          "type": "url",
          "id": "video_url",
