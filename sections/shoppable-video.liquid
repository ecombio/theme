{% comment %}
  Section: Shoppable Video
  - Single (or carousel of) portrait videos with tappable product hotspots
  - Hotspots open a quick-view card with image, price, variant picker, add to cart
  - Reuses naming conventions / structure from video-carousel.liquid
{% endcomment %}

{%- liquid
  assign section_id   = 'sv-' | append: section.id
  assign heading      = section.settings.heading
  assign subheading   = section.settings.subheading
  assign layout       = section.settings.layout | default: 'single'
  assign card_radius  = section.settings.card_radius | default: 16
-%}

<section
  id="{{ section_id }}"
  class="sv-section"
  data-section-id="{{ section.id }}"
  data-section-type="shoppable-video"
>

  {%- if heading != blank or subheading != blank -%}
    <div class="sv-header">
      {%- if heading != blank -%}
        <h2 class="sv-heading">{{ heading }}</h2>
      {%- endif -%}
      {%- if subheading != blank -%}
        <p class="sv-subheading">{{ subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="sv-track-wrapper">
    <ul id="{{ section_id }}-track" class="sv-track sv-track--{{ layout }}" role="list">
      {%- assign video_counter = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'video' -%}
          {%- assign video_counter = video_counter | plus: 1 -%}
          {%- liquid
            assign hosted_video = block.settings.video
            assign video_url    = block.settings.video_url
            assign thumbnail    = block.settings.thumbnail
            assign video_type   = 'hosted'
            if hosted_video == blank
              assign video_type = 'external'
            endif
          -%}

          <li class="sv-card" {{ block.shopify_attributes }} data-video-type="{{ video_type }}">
            <div class="sv-card__inner">
              <div class="sv-card__media">

                {%- comment %} Poster / thumbnail {%- endcomment %}
                {%- if thumbnail != blank -%}
                  {{
                    thumbnail
                    | image_url: width: 800
                    | image_tag: class: 'sv-card__thumbnail', loading: 'lazy', alt: heading | default: 'Video thumbnail'
                  }}
                {%- elsif hosted_video != blank -%}
                  <img
                    src="{{ hosted_video | video_tag: image_size: '800x' | extract: 'poster' }}"
                    class="sv-card__thumbnail"
                    loading="lazy"
                    alt="Video thumbnail"
                  />
                {%- else -%}
                  <div class="sv-card__thumbnail sv-card__thumbnail--placeholder">
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'sv-placeholder-svg' }}
                  </div>
                {%- endif -%}

                {%- comment %} Video element {%- endcomment %}
                {%- if video_type == 'hosted' and hosted_video != blank -%}
                  <video class="sv-card__video" muted loop playsinline preload="metadata">
                    {%- for source in hosted_video.sources -%}
                      <source src="{{ source.url }}" type="video/{{ source.format }}">
                    {%- endfor -%}
                  </video>
                {%- elsif video_url != blank -%}
                  <div class="sv-card__video sv-card__video--embed" data-embed-url="{{ video_url }}"></div>
                {%- endif -%}

                {%- comment %} Sound toggle {%- endcomment %}
                {%- if video_type == 'hosted' and hosted_video != blank -%}
                  <button class="sv-mute-btn" aria-label="Toggle sound" data-muted="true">
                    <svg class="sv-icon sv-icon--muted" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M3 9v6h4l5 5V4L7 9H3Z" fill="currentColor"/>
                      <path d="M16 9l5 6M21 9l-5 6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                    </svg>
                    <svg class="sv-icon sv-icon--unmuted" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M3 9v6h4l5 5V4L7 9H3Z" fill="currentColor"/>
                      <path d="M15.5 8.5a5 5 0 0 1 0 7M18 6a8 8 0 0 1 0 12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                    </svg>
                  </button>
                {%- endif -%}

                {%- comment %} Play/pause toggle {%- endcomment %}
                <button class="sv-play-btn" aria-label="Play video" data-playing="false">
                  <svg class="sv-icon sv-icon--play" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                    <circle cx="24" cy="24" r="24" fill="white" fill-opacity="0.92"/>
                    <path d="M19 15.5L34 24L19 32.5V15.5Z" fill="currentColor"/>
                  </svg>
                  <svg class="sv-icon sv-icon--pause" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                    <circle cx="24" cy="24" r="24" fill="white" fill-opacity="0.92"/>
                    <path d="M18 15h4v18h-4V15ZM26 15h4v18h-4V15Z" fill="currentColor"/>
                  </svg>
                </button>

                {%- comment %} Product hotspots {%- endcomment %}
                {%- for tag_block in section.blocks -%}
                  {%- if tag_block.type == 'product_tag' and tag_block.settings.video_index == video_counter -%}
                    {%- liquid
                      assign tag_product = tag_block.settings.product
                      assign pos_x = tag_block.settings.position_x | default: 50
                      assign pos_y = tag_block.settings.position_y | default: 50
                    -%}
                    {%- if tag_product != blank -%}
                      <button
                        class="sv-hotspot"
                        style="left: {{ pos_x }}%; top: {{ pos_y }}%;"
                        data-product-handle="{{ tag_product.handle }}"
                        aria-label="View product: {{ tag_product.title | escape }}"
                        {{ tag_block.shopify_attributes }}
                      >
                        <span class="sv-hotspot__dot"></span>
                      </button>

                      {%- comment %} Hidden product data card, read by JS {%- endcomment %}
                      <template class="sv-product-data" data-product-handle="{{ tag_product.handle }}">
                        <div class="sv-quickview__media">
                          {%- if tag_product.featured_image -%}
                            {{ tag_product.featured_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: tag_product.title }}
                          {%- else -%}
                            {{ 'product-1' | placeholder_svg_tag: 'sv-quickview__placeholder' }}
                          {%- endif -%}
                        </div>
                        <div class="sv-quickview__body">
                          <p class="sv-quickview__title">{{ tag_product.title }}</p>
                          <p class="sv-quickview__price">
                            {{ tag_product.price | money }}
                            {%- if tag_product.compare_at_price > tag_product.price -%}
                              <s class="sv-quickview__compare">{{ tag_product.compare_at_price | money }}</s>
                            {%- endif -%}
                          </p>

                          {%- if tag_product.variants.size > 1 -%}
                            <select class="sv-quickview__variant" data-product-id="{{ tag_product.id }}">
                              {%- for variant in tag_product.variants -%}
                                <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                                  {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                                </option>
                              {%- endfor -%}
                            </select>
                          {%- else -%}
                            <input type="hidden" class="sv-quickview__variant" value="{{ tag_product.selected_or_first_available_variant.id }}">
                          {%- endif -%}

                          <button class="sv-quickview__add" data-product-id="{{ tag_product.id }}">
                            {{ 'products.product.add_to_cart' | t | default: 'Add to cart' }}
                          </button>
                          <a href="{{ tag_product.url }}" class="sv-quickview__link">
                            {{ 'products.product.view_details' | t | default: 'View full details' }}
                          </a>
                        </div>
                      </template>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}

              </div>
            </div>
          </li>
        {%- endif -%}
      {%- else -%}
        <li class="sv-card sv-card--placeholder">
          <div class="sv-card__inner">
            <div class="sv-card__media">
              <div class="sv-card__thumbnail sv-card__thumbnail--placeholder">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'sv-placeholder-svg' }}
              </div>
              <button class="sv-hotspot" style="left: 50%; top: 40%;" aria-hidden="true" tabindex="-1">
                <span class="sv-hotspot__dot"></span>
              </button>
            </div>
          </div>
        </li>
      {%- endfor -%}
    </ul>
  </div>

  {%- comment %} Quick-view popup shell (single, repositioned by JS) {%- endcomment %}
  <div id="{{ section_id }}-quickview" class="sv-quickview" hidden>
    <button class="sv-quickview__close" aria-label="Close">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="sv-quickview__content"></div>
  </div>

</section>

{% comment %} =================== STYLES =================== {% endcomment %}
<style>
  #{{ section_id }} {
    --sv-gap:           {{ section.settings.card_gap | default: 16 }}px;
    --sv-radius:        {{ card_radius }}px;
    --sv-heading-color: {{ section.settings.heading_color | default: '#111111' }};
    --sv-bg:            {{ section.settings.section_bg | default: 'transparent' }};
    --sv-card-bg:       {{ section.settings.card_bg | default: '#1a0a2e' }};
    --sv-accent:        {{ section.settings.accent_color | default: '#111111' }};
    --sv-accent-text:   {{ section.settings.accent_text_color | default: '#ffffff' }};
    --sv-cards-visible: {{ section.settings.cards_per_row | default: 3 }};
  }

  .sv-section {
    background: var(--sv-bg);
    padding: {{ section.settings.section_padding_top | default: 60 }}px 0 {{ section.settings.section_padding_bottom | default: 60 }}px;
    position: relative;
  }

  .sv-header {
    padding: 0 {{ section.settings.section_padding_x | default: 40 }}px;
    margin-bottom: 24px;
  }

  .sv-heading {
    margin: 0 0 4px;
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    font-weight: 600;
    color: var(--sv-heading-color);
    line-height: 1.2;
  }

  .sv-subheading {
    margin: 0;
    font-size: 0.95rem;
    opacity: 0.65;
    color: var(--sv-heading-color);
  }

  /* ---- Track ---- */
  .sv-track-wrapper {
    padding: 0 {{ section.settings.section_padding_x | default: 40 }}px;
  }

  .sv-track {
    display: grid;
    gap: var(--sv-gap);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sv-track--single {
    grid-template-columns: 1fr;
    max-width: 480px;
    margin-inline: auto;
  }

  .sv-track--carousel {
    grid-auto-flow: column;
    grid-auto-columns: calc(
      (100% - (var(--sv-cards-visible) - 1) * var(--sv-gap)) / var(--sv-cards-visible)
    );
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 8px;
  }
  .sv-track--carousel::-webkit-scrollbar { display: none; }
  .sv-track--carousel .sv-card { scroll-snap-align: start; }

  /* ---- Card ---- */
  .sv-card {
    border-radius: var(--sv-radius);
    overflow: hidden;
    background: var(--sv-card-bg);
    position: relative;
  }

  .sv-card__inner { height: 100%; }

  .sv-card__media {
    position: relative;
    aspect-ratio: 9 / 16;
    overflow: hidden;
  }

  .sv-card__thumbnail,
  .sv-card__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sv-card__thumbnail--placeholder { background: #2a1a3e; }
  .sv-card__thumbnail--placeholder .sv-placeholder-svg { width: 100%; height: 100%; opacity: 0.15; }

  .sv-card__video { z-index: 1; background: #000; }
  .sv-card__video--embed iframe { width: 100%; height: 100%; border: none; }

  /* ---- Mute toggle ---- */
  .sv-mute-btn {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 5;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(0,0,0,0.4);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(4px);
  }
  .sv-icon { width: 18px; height: 18px; }
  .sv-icon--unmuted { display: none; }
  .sv-mute-btn[data-muted="false"] .sv-icon--muted { display: none; }
  .sv-mute-btn[data-muted="false"] .sv-icon--unmuted { display: block; }

  /* ---- Play/pause toggle ---- */
  .sv-play-btn {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 3;
    padding: 0;
  }
  .sv-icon--play,
  .sv-icon--pause {
    width: 56px;
    height: 56px;
    color: #111;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.25));
    transition: opacity 0.2s ease;
  }
  .sv-icon--pause { display: none; }
  .sv-play-btn[data-playing="true"] .sv-icon--play { opacity: 0; }
  .sv-play-btn[data-playing="true"] .sv-icon--pause { opacity: 0; }
  .sv-play-btn:hover .sv-icon--play,
  .sv-play-btn:hover .sv-icon--pause { opacity: 0.9; }
  .sv-play-btn[data-playing="false"] .sv-icon--play { opacity: 0.95; }

  /* ---- Hotspots ---- */
  .sv-hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 4;
    width: 28px;
    height: 28px;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sv-hotspot__dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 0 0 rgba(255,255,255,0.6);
    animation: sv-pulse 2.2s infinite;
    position: relative;
  }
  .sv-hotspot__dot::after {
    content: '+';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    color: #111;
    line-height: 1;
  }

  @keyframes sv-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(255,255,255,0.55); }
    70%  { box-shadow: 0 0 0 10px rgba(255,255,255,0); }
    100% { box-shadow: 0 0 0 0 rgba(255,255,255,0); }
  }

  .sv-hotspot.is-active .sv-hotspot__dot {
    background: var(--sv-accent);
    animation: none;
  }
  .sv-hotspot.is-active .sv-hotspot__dot::after { color: var(--sv-accent-text); }

  /* ---- Quick-view popup ---- */
  .sv-quickview {
    position: fixed;
    z-index: 9999;
    width: min(320px, calc(100vw - 32px));
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 12px 36px rgba(0,0,0,0.18);
    display: flex;
    overflow: hidden;
  }
  .sv-quickview[hidden] { display: none; }

  .sv-quickview__close {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 2;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .sv-quickview__content {
    display: flex;
    width: 100%;
  }

  .sv-quickview__media {
    width: 110px;
    flex-shrink: 0;
    background: #f5f5f5;
  }
  .sv-quickview__media img,
  .sv-quickview__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sv-quickview__body {
    flex: 1;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .sv-quickview__title {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
    padding-right: 20px;
  }

  .sv-quickview__price {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .sv-quickview__compare {
    opacity: 0.5;
    margin-left: 6px;
    font-weight: 400;
  }

  .sv-quickview__variant {
    width: 100%;
    padding: 6px 8px;
    font-size: 0.8rem;
    border-radius: 6px;
    border: 1px solid rgba(0,0,0,0.15);
  }

  .sv-quickview__add {
    width: 100%;
    padding: 10px;
    border: none;
    border-radius: 8px;
    background: var(--sv-accent);
    color: var(--sv-accent-text);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .sv-quickview__add:hover { opacity: 0.88; }
  .sv-quickview__add[data-state="added"] { background: #1f9d55; }
  .sv-quickview__add[data-state="error"] { background: #c0392b; }

  .sv-quickview__link {
    font-size: 0.75rem;
    text-align: center;
    text-decoration: underline;
    color: inherit;
    opacity: 0.7;
  }

  .sv-product-data { display: none; }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    #{{ section_id }} { --sv-cards-visible: 2.4; }
  }
  @media (max-width: 768px) {
    .sv-header,
    .sv-track-wrapper { padding: 0 20px; }
    #{{ section_id }} { --sv-cards-visible: 1.4; }
    .sv-track--single { max-width: 100%; }
  }
  @media (max-width: 480px) {
    #{{ section_id }} { --sv-cards-visible: 1.1; }
    .sv-quickview {
      left: 16px !important;
      right: 16px !important;
      width: auto;
      bottom: 16px !important;
      top: auto !important;
    }
    .sv-quickview__content { flex-direction: row; }
    .sv-quickview__media { width: 96px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sv-hotspot__dot { animation: none; }
  }
</style>

{% comment %} =================== JAVASCRIPT =================== {% endcomment %}
<script>
(function () {
  'use strict';

  function initShoppableVideo(sectionEl) {
    const sectionId = sectionEl.id;
    const track      = document.getElementById(sectionId + '-track');
    const quickview  = document.getElementById(sectionId + '-quickview');
    const qvContent  = quickview.querySelector('.sv-quickview__content');
    const qvClose    = quickview.querySelector('.sv-quickview__close');

    if (!track) return;

    // ── Play / pause + mute toggles ──────────────────────────────
    track.querySelectorAll('.sv-card').forEach(function (card) {
      const video    = card.querySelector('.sv-card__video');
      const playBtn  = card.querySelector('.sv-play-btn');
      const muteBtn  = card.querySelector('.sv-mute-btn');

      if (video && video.tagName === 'VIDEO') {
        if (playBtn) {
          playBtn.addEventListener('click', function () {
            if (video.paused) {
              video.play().catch(function () {});
              playBtn.dataset.playing = 'true';
            } else {
              video.pause();
              playBtn.dataset.playing = 'false';
            }
          });
          video.addEventListener('ended', function () {
            playBtn.dataset.playing = 'false';
          });
        }
        if (muteBtn) {
          muteBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            video.muted = !video.muted;
            muteBtn.dataset.muted = video.muted ? 'true' : 'false';
          });
        }
      }
    });

    // ── Hotspot click → quick view ───────────────────────────────
    let activeHotspot = null;

    track.querySelectorAll('.sv-hotspot[data-product-handle]').forEach(function (hotspot) {
      hotspot.addEventListener('click', function (e) {
        e.stopPropagation();

        if (activeHotspot === hotspot && !quickview.hidden) {
          closeQuickview();
          return;
        }

        const handle  = hotspot.dataset.productHandle;
        const dataTpl = sectionEl.querySelector('.sv-product-data[data-product-handle="' + handle + '"]');
        if (!dataTpl) return;

        qvContent.innerHTML = '';
        qvContent.appendChild(dataTpl.content.cloneNode(true));
        bindQuickviewActions();

        positionQuickview(hotspot);
        quickview.hidden = false;

        if (activeHotspot) activeHotspot.classList.remove('is-active');
        hotspot.classList.add('is-active');
        activeHotspot = hotspot;
      });
    });

    function positionQuickview(hotspot) {
      if (window.innerWidth <= 480) return; // CSS handles mobile docking

      const rect = hotspot.getBoundingClientRect();
      const qvWidth  = 320;
      const margin   = 12;

      let left = rect.right + margin;
      if (left + qvWidth > window.innerWidth - margin) {
        left = rect.left - qvWidth - margin;
      }
      if (left < margin) left = margin;

      let top = rect.top;
      const qvHeight = 140;
      if (top + qvHeight > window.innerHeight - margin) {
        top = window.innerHeight - qvHeight - margin;
      }
      if (top < margin) top = margin;

      quickview.style.left = left + 'px';
      quickview.style.top  = top + 'px';
    }

    function closeQuickview() {
      quickview.hidden = true;
      if (activeHotspot) activeHotspot.classList.remove('is-active');
      activeHotspot = null;
    }

    qvClose.addEventListener('click', closeQuickview);
    document.addEventListener('click', function (e) {
      if (!quickview.hidden && !quickview.contains(e.target) && !e.target.closest('.sv-hotspot')) {
        closeQuickview();
      }
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !quickview.hidden) closeQuickview();
    });

    // ── Add to cart ───────────────────────────────────────────────
    function bindQuickviewActions() {
      const addBtn = qvContent.querySelector('.sv-quickview__add');
      if (!addBtn) return;

      addBtn.addEventListener('click', function () {
        const variantEl = qvContent.querySelector('.sv-quickview__variant');
        const variantId = variantEl ? variantEl.value : null;
        if (!variantId) return;

        addBtn.disabled = true;
        addBtn.dataset.state = 'loading';
        const originalText = addBtn.textContent;
        addBtn.textContent = '...';

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
        })
          .then(function (res) {
            if (!res.ok) throw new Error('Add to cart failed');
            return res.json();
          })
          .then(function () {
            addBtn.dataset.state = 'added';
            addBtn.textContent = 'Added ✓';
            document.dispatchEvent(new CustomEvent('cart:refresh'));
            setTimeout(function () {
              addBtn.dataset.state = '';
              addBtn.textContent = originalText;
              addBtn.disabled = false;
            }, 1800);
          })
          .catch(function () {
            addBtn.dataset.state = 'error';
            addBtn.textContent = 'Error — try again';
            setTimeout(function () {
              addBtn.dataset.state = '';
              addBtn.textContent = originalText;
              addBtn.disabled = false;
            }, 1800);
          });
      });
    }

    window.addEventListener('resize', function () {
      if (!quickview.hidden && activeHotspot) positionQuickview(activeHotspot);
    });
  }

  function boot() {
    document.querySelectorAll('[data-section-type="shoppable-video"]').forEach(initShoppableVideo);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  document.addEventListener('shopify:section:load', function (e) {
    const s = e.target.querySelector('[data-section-type="shoppable-video"]');
    if (s) initShoppableVideo(s);
  });
})();
</script>

