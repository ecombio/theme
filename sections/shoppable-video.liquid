{% comment %}
  Section: Shoppable Video
  - Carousel of portrait (9:16) cards — entire card is clickable → opens modal
  - Glass chip pinned to card bottom (also opens modal)
  - Modal: video left | full product form right (swatches, size pills, qty, ATC, Buy Now)
  - Namespace: "shv-" + section.id
{% endcomment %}

{%- liquid
  assign s          = 'shv-' | append: section.id
  assign heading    = section.settings.heading
  assign subheading = section.settings.subheading
-%}

<section
  id="{{ s }}"
  class="shv-root"
  data-section-id="{{ section.id }}"
  data-section-type="shoppable-video"
>

  {%- if heading != blank or subheading != blank -%}
    <div class="shv-head">
      <div class="shv-head__text">
        {%- if heading != blank -%}<h2 class="shv-head__title">{{ heading }}</h2>{%- endif -%}
        {%- if subheading != blank -%}<p class="shv-head__sub">{{ subheading }}</p>{%- endif -%}
      </div>
      <div class="shv-head__nav">
        <button class="shv-arrow" data-shv-prev aria-label="Previous">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M10 12.5L5.5 8L10 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="shv-arrow" data-shv-next aria-label="Next">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M6 3.5L10.5 8L6 12.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  {%- endif -%}

  <div class="shv-rail-wrap">
    <ul class="shv-rail" data-shv-rail role="list">

      {%- for block in section.blocks -%}
        {%- if block.type == 'video_card' -%}
          {%- liquid
            assign hosted_video = block.settings.video
            assign video_url    = block.settings.video_url
            assign poster       = block.settings.poster
            assign product      = block.settings.product
            assign has_hosted   = false
            if hosted_video != blank
              assign has_hosted = true
            endif
          -%}

          <li class="shv-card" {{ block.shopify_attributes }}>

            {%- comment %} Entire frame is a button that opens the modal {%- endcomment %}
            <button
              class="shv-card__frame"
              data-shv-card
              data-has-hosted="{{ has_hosted }}"
              {%- if product != blank -%}data-product-handle="{{ product.handle }}"{%- endif -%}
              aria-haspopup="dialog"
              aria-label="Shop {{ product.title | default: 'this video' }}"
            >

              {%- comment %} Poster {%- endcomment %}
              {%- if poster != blank -%}
                {{
                  poster
                  | image_url: width: 760
                  | image_tag:
                    class: 'shv-card__poster',
                    loading: 'lazy',
                    sizes: '(min-width: 990px) 280px, 45vw',
                    widths: '280, 480, 640, 760',
                    alt: product.title | default: 'Video'
                }}
              {%- elsif hosted_video != blank and hosted_video.preview_image != blank -%}
                {{
                  hosted_video.preview_image
                  | image_url: width: 760
                  | image_tag: class: 'shv-card__poster', loading: 'lazy', alt: product.title | default: 'Video'
                }}
              {%- else -%}
                <div class="shv-card__poster shv-card__poster--placeholder">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'shv-ph-svg' }}
                </div>
              {%- endif -%}

              {%- comment %} Hosted video (lazy-loaded on hover) {%- endcomment %}
              {%- if has_hosted -%}
                <video class="shv-card__video" muted loop playsinline preload="none" data-shv-video>
                  {%- for source in hosted_video.sources -%}
                    {%- if source.format == 'mp4' -%}
                      <source data-src="{{ source.url }}" type="video/mp4">
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if hosted_video.sources.first.format != 'mp4' -%}
                    <source data-src="{{ hosted_video.sources.first.url }}" type="video/{{ hosted_video.sources.first.format }}">
                  {%- endif -%}
                </video>
              {%- elsif video_url != blank -%}
                <div class="shv-card__embed" data-embed-url="{{ video_url }}" data-shv-embed></div>
              {%- endif -%}

              {%- comment %} Sound toggle — stops propagation so it doesn't open modal {%- endcomment %}
              {%- if has_hosted -%}
                <span class="shv-sound-btn" data-shv-sound data-on="false" role="button" aria-label="Unmute" tabindex="0">
                  <svg class="shv-icon shv-icon--off" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M3 7.5v5h3.33L11 17V3L6.33 7.5H3Z" fill="currentColor"/>
                    <path d="M14 7l3.5 6M17.5 7L14 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                  </svg>
                  <svg class="shv-icon shv-icon--on" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M3 7.5v5h3.33L11 17V3L6.33 7.5H3Z" fill="currentColor"/>
                    <path d="M13.5 6.5a5 5 0 0 1 0 7M15.5 4.5a8 8 0 0 1 0 11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                  </svg>
                </span>
              {%- endif -%}

              {%- comment %} Gradient shade {%- endcomment %}
              <div class="shv-shade" aria-hidden="true"></div>

              {%- comment %} Glass product chip — sits inside the button frame {%- endcomment %}
              {%- if product != blank -%}
                <span class="shv-chip">
                  <span class="shv-chip__media">
                    {%- if product.featured_image -%}
                      {{ product.featured_image | image_url: width: 100 | image_tag: loading: 'lazy', alt: '' }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'shv-chip__ph' }}
                    {%- endif -%}
                  </span>
                  <span class="shv-chip__body">
                    <span class="shv-chip__name">{{ product.title | truncate: 26 }}</span>
                    <span class="shv-chip__prices">
                      <span class="shv-chip__price">{{ product.price | money }}</span>
                      {%- if product.compare_at_price > product.price -%}
                        <s class="shv-chip__compare">{{ product.compare_at_price | money }}</s>
                      {%- endif -%}
                    </span>
                  </span>
                  <span class="shv-chip__arrow" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M5 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </span>
              {%- endif -%}

            </button>
          </li>

          {%- comment %} Hidden product template — cloned into modal right column {%- endcomment %}
          {%- if product != blank -%}
            <template class="shv-product-data" data-product-handle="{{ product.handle }}">
              <script>
                window.__shvProduct_{{ product.id }} = {
                  variants: {{ product.variants | json }},
                  options:  {{ product.options_with_values | json }}
                };
              </script>
              <div class="shv-pform" data-shv-pform data-product-id="{{ product.id }}">

                {%- comment %} Image gallery {%- endcomment %}
                <div class="shv-pform__gallery">
                  {%- if product.images.size > 1 -%}
                    <div class="shv-pform__gallery-main">
                      {%- for image in product.images limit: 1 -%}
                        {{ image | image_url: width: 700 | image_tag: loading: 'eager', alt: product.title, class: 'shv-pform__gallery-img', data-shv-main-img: '' }}
                      {%- endfor -%}
                    </div>
                    <div class="shv-pform__thumbs">
                      {%- for image in product.images limit: 5 -%}
                        <button class="shv-pform__thumb {% if forloop.first %}is-active{% endif %}" data-src="{{ image | image_url: width: 700 }}" type="button">
                          {{ image | image_url: width: 120 | image_tag: loading: 'lazy', alt: '' }}
                        </button>
                      {%- endfor -%}
                    </div>
                  {%- elsif product.featured_image -%}
                    <div class="shv-pform__gallery-main">
                      {{ product.featured_image | image_url: width: 700 | image_tag: loading: 'eager', alt: product.title, class: 'shv-pform__gallery-img' }}
                    </div>
                  {%- else -%}
                    <div class="shv-pform__gallery-main shv-pform__gallery-main--ph">
                      {{ 'product-1' | placeholder_svg_tag: 'shv-pform__gallery-img' }}
                    </div>
                  {%- endif -%}
                </div>

                {%- comment %} Info + form {%- endcomment %}
                <div class="shv-pform__info">

                  {%- comment %} Header {%- endcomment %}
                  <div class="shv-pform__header">
                    {%- assign cv = product.selected_or_first_available_variant -%}
                    {%- if cv.compare_at_price > cv.price -%}
                      {%- assign savings_pct = cv.compare_at_price | minus: cv.price | times: 100.0 | divided_by: cv.compare_at_price | round -%}
                      <span class="shv-pform__badge">Save {{ savings_pct }}%</span>
                    {%- endif -%}
                    {%- if product.vendor != blank -%}
                      <p class="shv-pform__vendor">{{ product.vendor | upcase }}</p>
                    {%- endif -%}
                    <h3 class="shv-pform__title">{{ product.title }}</h3>
                  </div>

                  {%- comment %} Pricing {%- endcomment %}
                  <div class="shv-pform__pricing">
                    <span class="shv-pform__price {% if cv.compare_at_price > cv.price %}is-sale{% endif %}" data-shv-price>
                      {{ cv.price | money }}
                    </span>
                    {%- if cv.compare_at_price > cv.price -%}
                      <s class="shv-pform__compare" data-shv-compare>{{ cv.compare_at_price | money }}</s>
                    {%- endif -%}
                  </div>

                  {%- comment %} Variant options {%- endcomment %}
                  <div class="shv-pform__variants">

                    {%- comment %} Color swatches {%- endcomment %}
                    {%- assign color_opt = product.options_with_values | where: 'name', 'Color' | first -%}
                    {%- if color_opt -%}
                      {%- assign color_idx = color_opt.position | minus: 1 -%}
                      <div class="shv-pform__option">
                        <div class="shv-pform__option-label">
                          Color: <span class="shv-pform__option-val" data-shv-selected-color>{{ cv.options[color_idx] }}</span>
                        </div>
                        <div class="shv-pform__swatches">
                          {%- for value in color_opt.values -%}
                            <label class="shv-pform__swatch-label" title="{{ value | escape }}">
                              <input
                                type="radio"
                                name="shv-Color-{{ product.id }}"
                                value="{{ value | escape }}"
                                class="shv-pform__swatch-radio"
                                data-shv-option="Color"
                                {% if cv.options[color_idx] == value %}checked{% endif %}
                                aria-label="{{ value | escape }}"
                              >
                              <span
                                class="shv-pform__swatch"
                                style="background-color: var(--swatch-{{ value | handle }}, #ccc);"
                              ></span>
                            </label>
                          {%- endfor -%}
                        </div>
                      </div>
                    {%- endif -%}

                    {%- comment %} Other options (Size, etc.) as pills {%- endcomment %}
                    {%- for option in product.options_with_values -%}
                      {%- if option.name == 'Color' -%}{%- continue -%}{%- endif -%}
                      {%- assign opt_idx = option.position | minus: 1 -%}
                      <div class="shv-pform__option">
                        <div class="shv-pform__option-label">
                          {{ option.name }}: <span class="shv-pform__option-val" data-shv-selected-opt="{{ option.name }}">{{ cv.options[opt_idx] }}</span>
                        </div>
                        <div class="shv-pform__pills">
                          {%- for value in option.values -%}
                            <label class="shv-pform__pill-label">
                              <input
                                type="radio"
                                name="shv-{{ option.name }}-{{ product.id }}"
                                value="{{ value | escape }}"
                                class="shv-pform__pill-radio"
                                data-shv-option="{{ option.name }}"
                                {% if cv.options[opt_idx] == value %}checked{% endif %}
                                aria-label="{{ value | escape }}"
                              >
                              <span class="shv-pform__pill">{{ value }}</span>
                            </label>
                          {%- endfor -%}
                        </div>
                      </div>
                    {%- endfor -%}

                  </div>

                  {%- comment %} Description snippet {%- endcomment %}
                  {%- if product.description != blank -%}
                    <p class="shv-pform__desc">{{ product.description | strip_html | truncatewords: 30 }}</p>
                  {%- endif -%}

                  {%- comment %} Quantity + Add to cart {%- endcomment %}
                  <div class="shv-pform__actions">
                    <div class="shv-pform__qty">
                      <button class="shv-pform__qty-btn" type="button" data-shv-qty-minus aria-label="Decrease">
                        <svg width="14" height="2" viewBox="0 0 14 2" fill="none" aria-hidden="true">
                          <path d="M1 1h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                        </svg>
                      </button>
                      <input class="shv-pform__qty-input" type="number" value="1" min="1" max="99" data-shv-qty aria-label="Quantity">
                      <button class="shv-pform__qty-btn" type="button" data-shv-qty-plus aria-label="Increase">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                        </svg>
                      </button>
                    </div>
                    <button class="shv-pform__atc" type="button" data-shv-atc data-variant-id="{{ cv.id }}">
                      {%- if cv.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
                    </button>
                  </div>

                  {%- comment %} Buy now {%- endcomment %}
                  <form action="/cart" method="post" class="shv-pform__buynow-form">
                    <input type="hidden" name="id" data-shv-buy-variant value="{{ cv.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button class="shv-pform__buynow" type="submit" name="checkout"
                      {% unless cv.available %}disabled{% endunless %}>
                      Buy it now
                    </button>
                  </form>

                  <a class="shv-pform__full-link" href="{{ product.url }}">View full details →</a>

                </div>
              </div>
            </template>
          {%- endif -%}

        {%- endif -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <li class="shv-card">
            <div class="shv-card__frame shv-card__frame--ph">
              <div class="shv-card__poster shv-card__poster--placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'shv-ph-svg' }}</div>
              <div class="shv-shade" aria-hidden="true"></div>
              <span class="shv-chip">
                <span class="shv-chip__media">{{ 'product-1' | placeholder_svg_tag: 'shv-chip__ph' }}</span>
                <span class="shv-chip__body">
                  <span class="shv-chip__name">Example Product</span>
                  <span class="shv-chip__prices"><span class="shv-chip__price">$209.00</span><s class="shv-chip__compare">$299.00</s></span>
                </span>
                <span class="shv-chip__arrow" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </span>
            </div>
          </li>
        {%- endfor -%}
      {%- endfor -%}

    </ul>
  </div>

  {%- comment %} Modal {%- endcomment %}
  <div class="shv-modal" data-shv-modal hidden role="dialog" aria-modal="true" aria-label="Shop this video">
    <div class="shv-modal__backdrop" data-shv-close></div>
    <div class="shv-modal__panel">
      <button class="shv-modal__close" data-shv-close aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M14 4L4 14M4 4l10 10" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="shv-modal__video-col" data-shv-modal-video></div>
      <div class="shv-modal__product-col" data-shv-modal-product></div>
    </div>
  </div>

</section>

{% comment %} =================== STYLES =================== {% endcomment %}
<style>
  #{{ s }} {
    --shv-accent:    {{ section.settings.accent_color | default: '#ffffff' }};
    --shv-accent-fg: {{ section.settings.accent_text_color | default: '#111111' }};
    --shv-bg:        {{ section.settings.section_bg | default: '#111114' }};
    --shv-fg:        {{ section.settings.heading_color | default: '#f0f0ee' }};
    --shv-gap:       {{ section.settings.card_gap | default: 12 }}px;
    --shv-radius:    {{ section.settings.card_radius | default: 20 }}px;
    --shv-visible:   {{ section.settings.cards_per_row | default: 4 }};
    --shv-px:        {{ section.settings.section_padding_x | default: 36 }}px;
  }

  .shv-root {
    background: var(--shv-bg);
    color: var(--shv-fg);
    padding: {{ section.settings.section_padding_top | default: 52 }}px 0 {{ section.settings.section_padding_bottom | default: 52 }}px;
  }

  /* ── Head ── */
  .shv-head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 16px; padding: 0 var(--shv-px); margin-bottom: 20px;
  }
  .shv-head__title { margin: 0 0 3px; font-size: clamp(1.25rem, 2.2vw, 1.8rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.15; }
  .shv-head__sub { margin: 0; font-size: 0.88rem; opacity: 0.5; }
  .shv-head__nav { display: flex; gap: 8px; flex-shrink: 0; }
  .shv-arrow {
    width: 36px; height: 36px; border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.14);
    background: rgba(255,255,255,0.05);
    color: var(--shv-fg); display: flex; align-items: center; justify-content: center;
    cursor: pointer; backdrop-filter: blur(6px); transition: background 0.15s;
  }
  .shv-arrow:hover { background: rgba(255,255,255,0.12); }
  .shv-arrow:disabled { opacity: 0.2; pointer-events: none; }

  /* ── Rail ── */
  .shv-rail-wrap { padding: 0 var(--shv-px); }
  .shv-rail {
    display: grid; grid-auto-flow: column;
    grid-auto-columns: calc((100% - (var(--shv-visible) - 1) * var(--shv-gap)) / var(--shv-visible));
    gap: var(--shv-gap); list-style: none; margin: 0; padding: 4px 0 12px;
    overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch; scrollbar-width: none;
  }
  .shv-rail::-webkit-scrollbar { display: none; }
  .shv-card { scroll-snap-align: start; }

  /* ── Card frame — now a <button> ── */
  .shv-card__frame {
    position: relative; aspect-ratio: 9 / 16;
    border-radius: var(--shv-radius); overflow: hidden;
    background: #1c1c22; display: block; width: 100%;
    border: none; padding: 0; cursor: pointer;
    outline-offset: 3px;
  }
  .shv-card__frame:focus-visible { outline: 2px solid rgba(255,255,255,0.5); }
  .shv-card__frame--ph { cursor: default; }

  .shv-card__poster, .shv-card__video {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .shv-card__video { z-index: 1; opacity: 0; transition: opacity 0.3s; background: #000; }
  .shv-card__poster--placeholder { background: #222228; }
  .shv-card__poster--placeholder .shv-ph-svg { width: 100%; height: 100%; opacity: 0.1; }

  .shv-card__frame.is-playing .shv-card__video { opacity: 1; }
  .shv-card__frame.is-playing .shv-card__poster { opacity: 0; transition: opacity 0.3s; }

  .shv-card__embed { position: absolute; inset: 0; z-index: 1; }
  .shv-card__embed iframe { width: 100%; height: 100%; border: none; }

  /* ── Sound btn ── */
  .shv-sound-btn {
    position: absolute; top: 12px; right: 12px; z-index: 5;
    width: 32px; height: 32px; border-radius: 50;
    background: rgba(0,0,0,0.38); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.15);
    color: #fff; display: flex; align-items: center; justify-content: center;
    cursor: pointer; border-radius: 50%;
  }
  .shv-icon { width: 14px; height: 14px; }
  .shv-icon--on { display: none; }
  .shv-sound-btn[data-on="true"] .shv-icon--off { display: none; }
  .shv-sound-btn[data-on="true"] .shv-icon--on  { display: block; }

  /* ── Shade + chip ── */
  .shv-shade {
    position: absolute; left: 0; right: 0; bottom: 0; height: 55%;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
    z-index: 2; pointer-events: none;
  }
  .shv-chip {
    position: absolute; left: 10px; right: 10px; bottom: 10px; z-index: 4;
    display: flex; align-items: center; gap: 9px; padding: 8px 10px 8px 8px;
    border-radius: 14px;
    background: rgba(255,255,255,0.13);
    backdrop-filter: blur(18px) saturate(1.5);
    -webkit-backdrop-filter: blur(18px) saturate(1.5);
    border: 1px solid rgba(255,255,255,0.22);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.12);
    color: #fff; text-align: left;
    transition: background 0.2s;
  }
  .shv-card__frame:hover .shv-chip { background: rgba(255,255,255,0.2); }

  .shv-chip__media {
    width: 38px; height: 38px; border-radius: 9px; overflow: hidden; flex-shrink: 0;
    background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.2);
  }
  .shv-chip__media img, .shv-chip__ph { width: 100%; height: 100%; object-fit: cover; display: block; }

  .shv-chip__body { display: flex; flex-direction: column; flex: 1; min-width: 0; gap: 2px; }
  .shv-chip__name { font-size: 0.78rem; font-weight: 600; line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .shv-chip__prices { display: flex; align-items: baseline; gap: 5px; }
  .shv-chip__price { font-size: 0.76rem; font-weight: 500; }
  .shv-chip__compare { font-size: 0.72rem; opacity: 0.5; }

  .shv-chip__arrow {
    flex-shrink: 0; width: 24px; height: 24px; border-radius: 50%;
    background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.28);
    display: flex; align-items: center; justify-content: center; color: #fff;
  }

  /* ── Modal ── */
  .shv-modal {
    position: fixed; inset: 0; z-index: 9999;
    display: flex; align-items: center; justify-content: center; padding: 20px;
  }
  .shv-modal[hidden] { display: none; }

  .shv-modal__backdrop {
    position: absolute; inset: 0;
    background: rgba(8,8,12,0.78);
    backdrop-filter: blur(6px);
    cursor: pointer;
  }

  .shv-modal__panel {
    position: relative; z-index: 1;
    width: min(920px, 100%); max-height: min(700px, 94vh);
    display: grid; grid-template-columns: 0.72fr 1fr;
    border-radius: 24px; overflow: hidden;
    background: rgba(18,18,22,0.7);
    backdrop-filter: blur(32px) saturate(1.6);
    -webkit-backdrop-filter: blur(32px) saturate(1.6);
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 40px 80px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.07);
    color: #f0f0ee;
  }

  .shv-modal__close {
    position: absolute; top: 14px; right: 14px; z-index: 10;
    width: 32px; height: 32px; border-radius: 50%; border: none;
    background: rgba(255,255,255,0.1); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.16); color: #fff;
    display: flex; align-items: center; justify-content: center; cursor: pointer;
    transition: background 0.15s;
  }
  .shv-modal__close:hover { background: rgba(255,255,255,0.2); }

  /* ── Video column ── */
  .shv-modal__video-col { position: relative; background: #000; min-height: 0; }
  .shv-modal__video-col video,
  .shv-modal__video-col iframe,
  .shv-modal__video-col img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; border: none; display: block;
  }

  /* ── Product column ── */
  .shv-modal__product-col {
    overflow-y: auto; display: flex; flex-direction: column;
    border-left: 1px solid rgba(255,255,255,0.06);
  }
  .shv-modal__product-col::-webkit-scrollbar { width: 4px; }
  .shv-modal__product-col::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 2px; }

  /* ── Product form layout ── */
  .shv-pform { display: flex; flex-direction: column; }

  .shv-pform__gallery { position: relative; background: rgba(255,255,255,0.04); }
  .shv-pform__gallery-main { aspect-ratio: 4 / 3; overflow: hidden; }
  .shv-pform__gallery-main--ph { background: rgba(255,255,255,0.05); }
  .shv-pform__gallery-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity 0.2s; }

  .shv-pform__thumbs {
    display: flex; gap: 6px; padding: 8px 10px; overflow-x: auto;
    border-top: 1px solid rgba(255,255,255,0.06);
    scrollbar-width: none;
  }
  .shv-pform__thumbs::-webkit-scrollbar { display: none; }
  .shv-pform__thumb {
    flex-shrink: 0; width: 52px; height: 52px; border-radius: 8px; overflow: hidden;
    border: 2px solid transparent; padding: 0; cursor: pointer; background: none;
    transition: border-color 0.15s;
  }
  .shv-pform__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .shv-pform__thumb.is-active { border-color: rgba(255,255,255,0.6); }
  .shv-pform__thumb:hover { border-color: rgba(255,255,255,0.3); }

  /* ── Info area ── */
  .shv-pform__info { padding: 18px 20px 22px; display: flex; flex-direction: column; gap: 12px; }

  .shv-pform__header { display: flex; flex-direction: column; gap: 4px; }
  .shv-pform__badge {
    display: inline-block; align-self: flex-start;
    padding: 3px 9px; border-radius: 6px;
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.04em;
    color: #f0f0ee;
  }
  .shv-pform__vendor { margin: 0; font-size: 0.66rem; letter-spacing: 0.1em; opacity: 0.4; }
  .shv-pform__title { margin: 0; font-size: 1.05rem; font-weight: 600; line-height: 1.3; letter-spacing: -0.01em; }

  .shv-pform__pricing { display: flex; align-items: baseline; gap: 8px; }
  .shv-pform__price { font-size: 1.1rem; font-weight: 700; }
  .shv-pform__price.is-sale { color: #ff6b6b; }
  .shv-pform__compare { font-size: 0.88rem; opacity: 0.4; }

  /* ── Variants ── */
  .shv-pform__variants { display: flex; flex-direction: column; gap: 12px; }
  .shv-pform__option { display: flex; flex-direction: column; gap: 7px; }
  .shv-pform__option-label { font-size: 0.78rem; font-weight: 600; opacity: 0.7; }
  .shv-pform__option-val { font-weight: 500; opacity: 1; }

  /* Swatches */
  .shv-pform__swatches { display: flex; flex-wrap: wrap; gap: 6px; }
  .shv-pform__swatch-label { cursor: pointer; }
  .shv-pform__swatch-radio { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }
  .shv-pform__swatch {
    display: block; width: 26px; height: 26px; border-radius: 50%;
    border: 2px solid transparent; outline: 2px solid transparent;
    outline-offset: 2px; transition: outline-color 0.15s;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.15);
  }
  .shv-pform__swatch-radio:checked + .shv-pform__swatch { outline-color: rgba(255,255,255,0.7); }
  .shv-pform__swatch-label:hover .shv-pform__swatch { outline-color: rgba(255,255,255,0.35); }

  /* Pills */
  .shv-pform__pills { display: flex; flex-wrap: wrap; gap: 6px; }
  .shv-pform__pill-label { cursor: pointer; }
  .shv-pform__pill-radio { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }
  .shv-pform__pill {
    display: block; padding: 5px 13px; border-radius: 8px; font-size: 0.8rem; font-weight: 500;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.14);
    transition: background 0.15s, border-color 0.15s;
  }
  .shv-pform__pill-radio:checked + .shv-pform__pill {
    background: rgba(255,255,255,0.9); color: #111; border-color: transparent;
  }
  .shv-pform__pill-label:hover .shv-pform__pill { background: rgba(255,255,255,0.15); }

  /* Description */
  .shv-pform__desc { margin: 0; font-size: 0.8rem; line-height: 1.6; opacity: 0.55; }

  /* Actions */
  .shv-pform__actions { display: flex; gap: 10px; align-items: stretch; }

  .shv-pform__qty {
    display: flex; align-items: center;
    border: 1px solid rgba(255,255,255,0.16); border-radius: 10px;
    background: rgba(255,255,255,0.06); overflow: hidden; flex-shrink: 0;
  }
  .shv-pform__qty-btn {
    width: 36px; height: 44px; border: none; background: transparent;
    color: #f0f0ee; cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background 0.15s;
  }
  .shv-pform__qty-btn:hover { background: rgba(255,255,255,0.1); }
  .shv-pform__qty-input {
    width: 38px; text-align: center; border: none; background: transparent;
    color: #f0f0ee; font-size: 0.9rem; font-weight: 600;
    -moz-appearance: textfield;
  }
  .shv-pform__qty-input::-webkit-outer-spin-button,
  .shv-pform__qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

  .shv-pform__atc {
    flex: 1; padding: 0 16px; height: 44px; border: none; border-radius: 10px;
    background: var(--shv-accent); color: var(--shv-accent-fg);
    font-size: 0.88rem; font-weight: 700; cursor: pointer; letter-spacing: 0.01em;
    transition: opacity 0.2s, background 0.2s;
  }
  .shv-pform__atc:hover { opacity: 0.88; }
  .shv-pform__atc:disabled { opacity: 0.4; cursor: not-allowed; }
  .shv-pform__atc[data-state="loading"] { opacity: 0.5; }
  .shv-pform__atc[data-state="added"] { background: #2a9d5c; color: #fff; }
  .shv-pform__atc[data-state="error"]  { background: #c0392b; color: #fff; }

  .shv-pform__buynow-form { width: 100%; }
  .shv-pform__buynow {
    width: 100%; height: 44px; border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.22);
    background: rgba(255,255,255,0.07);
    color: #f0f0ee; font-size: 0.88rem; font-weight: 600; cursor: pointer;
    transition: background 0.15s;
  }
  .shv-pform__buynow:hover { background: rgba(255,255,255,0.14); }
  .shv-pform__buynow:disabled { opacity: 0.35; cursor: not-allowed; }

  .shv-pform__full-link {
    display: block; text-align: center; font-size: 0.76rem;
    text-decoration: underline; color: inherit; opacity: 0.45;
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) { #{{ s }} { --shv-visible: 3; } }
  @media (max-width: 768px) {
    #{{ s }} { --shv-visible: 2.2; --shv-px: 20px; }
    .shv-modal__panel { grid-template-columns: 1fr; grid-template-rows: 42vh 1fr; max-height: 92vh; }
  }
  @media (max-width: 480px) {
    #{{ s }} { --shv-visible: 1.25; }
    .shv-modal { padding: 0; }
    .shv-modal__panel { border-radius: 0; width: 100%; height: 100%; max-height: 100%; grid-template-rows: 38vh 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .shv-card__video, .shv-card__poster { transition: none; }
  }

  .shv-product-data { display: none; }
</style>

{% comment %} =================== JS =================== {% endcomment %}
<script>
(function () {
  'use strict';

  function init(root) {
    var rail       = root.querySelector('[data-shv-rail]');
    var modal      = root.querySelector('[data-shv-modal]');
    var videoCol   = modal.querySelector('[data-shv-modal-video]');
    var productCol = modal.querySelector('[data-shv-modal-product]');

    if (!rail) return;

    // ── Arrow nav ────────────────────────────────────────────────
    root.querySelector('[data-shv-prev]').addEventListener('click', function () { scroll(-1); });
    root.querySelector('[data-shv-next]').addEventListener('click', function () { scroll(1); });
    function scroll(dir) {
      var c = rail.querySelector('.shv-card');
      if (!c) return;
      rail.scrollBy({ left: dir * (c.offsetWidth + parseInt(getComputedStyle(rail).gap || 0)), behavior: 'smooth' });
    }

    // ── Hover-to-play + sound ───────────────────────────────────
    root.querySelectorAll('[data-shv-card]').forEach(function (frame) {
      var vid      = frame.querySelector('[data-shv-video]');
      var soundBtn = frame.querySelector('[data-shv-sound]');
      var loaded   = false;

      function loadSrc() {
        if (loaded || !vid) return;
        vid.querySelectorAll('source[data-src]').forEach(function (s) { s.src = s.dataset.src; });
        vid.load();
        loaded = true;
      }
      function play()  { if (!vid) return; loadSrc(); frame.classList.add('is-playing'); vid.play().catch(function(){}); }
      function pause() { frame.classList.remove('is-playing'); if (vid) { vid.pause(); vid.currentTime = 0; } }

      frame.addEventListener('mouseenter', play);
      frame.addEventListener('mouseleave', pause);

      // Sound toggle — stop propagation to avoid triggering modal open
      if (soundBtn) {
        soundBtn.addEventListener('click', function (e) {
          e.stopPropagation();
          if (!vid) return;
          vid.muted = !vid.muted;
          soundBtn.dataset.on = vid.muted ? 'false' : 'true';
          soundBtn.setAttribute('aria-label', vid.muted ? 'Unmute' : 'Mute');
        });
      }

      // ── Click anywhere on card → open modal ──────────────────
      frame.addEventListener('click', function (e) {
        // Don't open if click came from the sound button
        if (e.target.closest('[data-shv-sound]')) return;
        openModal(frame);
      });
    });

    // ── Modal ────────────────────────────────────────────────────
    function openModal(frame) {
      var handle    = frame.dataset.productHandle;
      var hasHosted = frame.dataset.hasHosted === 'true';
      var vid       = frame.querySelector('[data-shv-video]');
      var embedEl   = frame.querySelector('[data-shv-embed]');

      // Video column
      videoCol.innerHTML = '';
      if (hasHosted && vid) {
        var v = document.createElement('video');
        v.autoplay = true; v.loop = true; v.playsInline = true; v.controls = true;
        vid.querySelectorAll('source').forEach(function (s) {
          var ns = document.createElement('source');
          ns.src = s.src || s.dataset.src;
          ns.type = s.type;
          v.appendChild(ns);
        });
        videoCol.appendChild(v);
        v.play().catch(function(){});
      } else if (embedEl) {
        var iframe = document.createElement('iframe');
        iframe.src = resolveEmbed(embedEl.dataset.embedUrl);
        iframe.allow = 'autoplay; encrypted-media; fullscreen';
        iframe.allowFullscreen = true;
        videoCol.appendChild(iframe);
      } else {
        var poster = frame.querySelector('.shv-card__poster');
        if (poster) videoCol.appendChild(poster.cloneNode(true));
      }

      // Product column
      productCol.innerHTML = '';
      if (handle) {
        var tpl = root.querySelector('.shv-product-data[data-product-handle="' + handle + '"]');
        if (tpl) {
          productCol.appendChild(tpl.content.cloneNode(true));
          bindProductForm(productCol);
        }
      }

      modal.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
      videoCol.innerHTML = '';
      productCol.innerHTML = '';
    }

    modal.querySelectorAll('[data-shv-close]').forEach(function (el) { el.addEventListener('click', closeModal); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !modal.hidden) closeModal(); });

    // ── Product form logic ────────────────────────────────────────
    function bindProductForm(scope) {
      var pform     = scope.querySelector('[data-shv-pform]');
      if (!pform) return;
      var productId = pform.dataset.productId;
      var pdata     = window['__shvProduct_' + productId];
      if (!pdata) return;

      var variants  = pdata.variants;
      var selected  = {};       // { OptionName: value }

      // Initialise selected from checked radios
      pform.querySelectorAll('[data-shv-option]:checked').forEach(function (r) {
        selected[r.dataset.shvOption] = r.value;
      });

      // Find matching variant
      function findVariant() {
        return variants.find(function (v) {
          return pdata.options.every(function (opt, i) {
            return !selected[opt.name] || v.options[i] === selected[opt.name];
          });
        }) || variants[0];
      }

      // Update UI for active variant
      function updateVariant(variant) {
        // Price
        var priceEl   = pform.querySelector('[data-shv-price]');
        var compareEl = pform.querySelector('[data-shv-compare]');
        if (priceEl) {
          priceEl.textContent = formatMoney(variant.price);
          priceEl.classList.toggle('is-sale', variant.compare_at_price > variant.price);
        }
        if (compareEl) {
          if (variant.compare_at_price > variant.price) {
            compareEl.textContent = formatMoney(variant.compare_at_price);
            compareEl.hidden = false;
          } else {
            compareEl.hidden = true;
          }
        }
        // ATC button
        var atcBtn = pform.querySelector('[data-shv-atc]');
        if (atcBtn) {
          atcBtn.dataset.variantId = variant.id;
          atcBtn.disabled = !variant.available;
          atcBtn.textContent = variant.available ? 'Add to cart' : 'Sold out';
        }
        // Buy now
        var buyVariant = pform.querySelector('[data-shv-buy-variant]');
        if (buyVariant) buyVariant.value = variant.id;
        // Gallery image swap (if variant has image)
        if (variant.featured_image) {
          var mainImg = pform.querySelector('[data-shv-main-img]');
          if (mainImg) mainImg.src = variant.featured_image.src;
        }
      }

      // Option radio change
      pform.querySelectorAll('[data-shv-option]').forEach(function (radio) {
        radio.addEventListener('change', function () {
          selected[radio.dataset.shvOption] = radio.value;
          // Update label display
          var lbl = pform.querySelector('[data-shv-selected-' + radio.dataset.shvOption.toLowerCase() + ']')
                 || pform.querySelector('[data-shv-selected-opt="' + radio.dataset.shvOption + '"]');
          if (lbl) lbl.textContent = radio.value;
          updateVariant(findVariant());
        });
      });

      // Thumbnail click
      pform.querySelectorAll('.shv-pform__thumb').forEach(function (thumb) {
        thumb.addEventListener('click', function () {
          var mainImg = pform.querySelector('[data-shv-main-img]');
          if (mainImg && thumb.dataset.src) mainImg.src = thumb.dataset.src;
          pform.querySelectorAll('.shv-pform__thumb').forEach(function (t) { t.classList.remove('is-active'); });
          thumb.classList.add('is-active');
        });
      });

      // Qty stepper
      var qtyInput = pform.querySelector('[data-shv-qty]');
      pform.querySelector('[data-shv-qty-minus]').addEventListener('click', function () {
        if (qtyInput.value > 1) qtyInput.value = parseInt(qtyInput.value) - 1;
      });
      pform.querySelector('[data-shv-qty-plus]').addEventListener('click', function () {
        qtyInput.value = parseInt(qtyInput.value) + 1;
      });

      // Add to cart
      var atcBtn = pform.querySelector('[data-shv-atc]');
      if (atcBtn) {
        atcBtn.addEventListener('click', function () {
          var variantId = atcBtn.dataset.variantId;
          var qty       = parseInt(qtyInput ? qtyInput.value : 1) || 1;
          if (!variantId) return;

          var orig = atcBtn.textContent;
          atcBtn.disabled = true; atcBtn.dataset.state = 'loading'; atcBtn.textContent = '...';

          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: [{ id: Number(variantId), quantity: qty }] })
          })
            .then(function (r) { if (!r.ok) throw new Error(); return r.json(); })
            .then(function () {
              atcBtn.dataset.state = 'added'; atcBtn.textContent = 'Added ✓';
              document.dispatchEvent(new CustomEvent('cart:refresh'));
              setTimeout(function () {
                atcBtn.dataset.state = ''; atcBtn.textContent = orig; atcBtn.disabled = false;
              }, 2200);
            })
            .catch(function () {
              atcBtn.dataset.state = 'error'; atcBtn.textContent = 'Try again';
              setTimeout(function () {
                atcBtn.dataset.state = ''; atcBtn.textContent = orig; atcBtn.disabled = false;
              }, 2200);
            });
        });
      }
    }

    // ── Helpers ──────────────────────────────────────────────────
    function resolveEmbed(url) {
      try {
        var u = new URL(url);
        if (u.hostname.includes('youtu')) {
          var id = u.searchParams.get('v') || u.pathname.split('/').pop();
          return 'https://www.youtube.com/embed/' + id + '?autoplay=1&rel=0';
        }
        if (u.hostname.includes('vimeo')) {
          return 'https://player.vimeo.com/video/' + u.pathname.split('/').filter(Boolean).pop() + '?autoplay=1';
        }
      } catch(e){}
      return url;
    }

    function formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }
  }

  function boot() {
    document.querySelectorAll('[data-section-type="shoppable-video"]').forEach(init);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  document.addEventListener('shopify:section:load', function (e) {
    var s = e.target.querySelector('[data-section-type="shoppable-video"]');
    if (s) init(s);
  });
})();
</script>

