{% schema %}
{
  "name": "Shoppable Video",
  "tag": "section",
  "class": "section-shoppable-video",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Watch & shop"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Text color",
      "default": "#f0f0ee"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "label": "Cards visible (desktop)",
      "min": 2, "max": 6, "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards",
      "min": 4, "max": 28, "step": 2, "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0, "max": 32, "step": 2, "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#111114"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Button / accent",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_text_color",
      "label": "Button text",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "section_padding_x",
      "label": "Side padding",
