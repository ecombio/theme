          "label": "Poster / thumbnail image",
          "info": "Optional. Auto-detected from hosted video if left blank."
        },
        {
          "type": "header",
          "content": "Product"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Featured product",
          "info": "Shown in the floating chip. Opens a full product card in the modal."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shoppable Video",
      "blocks": [
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "video_card" }
      ]
    }
  ]
}
