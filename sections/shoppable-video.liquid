{% comment %}
  Section: Shoppable Video
  - Carousel of portrait video cards
  - Each card has a floating product chip pinned to the bottom
  - Clicking the chip opens a modal: video (left) + full product card (right)
  - Namespace: "shv-" to avoid collisions with other sections
{% endcomment %}

{%- liquid
  assign s = 'shv-' | append: section.id
  assign heading    = section.settings.heading
  assign subheading = section.settings.subheading
-%}

<section
  id="{{ s }}"
  class="shv-root"
  data-section-id="{{ section.id }}"
  data-section-type="shoppable-video"
>

  {%- if heading != blank or subheading != blank -%}
    <div class="shv-head">
      <div class="shv-head__text">
        {%- if heading != blank -%}
          <h2 class="shv-head__title">{{ heading }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="shv-head__sub">{{ subheading }}</p>
        {%- endif -%}
      </div>
      <div class="shv-head__nav">
        <button class="shv-arrow shv-arrow--prev" data-shv-prev aria-label="Previous">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M11 14L6 9L11 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="shv-arrow shv-arrow--next" data-shv-next aria-label="Next">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M7 4L12 9L7 14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  {%- endif -%}

  <div class="shv-rail-wrap">
    <ul class="shv-rail" data-shv-rail role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'video_card' -%}
          {%- liquid
            assign hosted_video = block.settings.video
            assign video_url    = block.settings.video_url
            assign poster       = block.settings.poster
            assign product      = block.settings.product
            assign video_type   = 'hosted'
            if hosted_video == blank
              assign video_type = 'embed'
            endif
          -%}

          <li class="shv-card" {{ block.shopify_attributes }}>
            <div
              class="shv-card__frame"
              data-shv-card
              data-video-type="{{ video_type }}"
              {%- if product != blank -%}
                data-product-handle="{{ product.handle }}"
              {%- endif -%}
            >

              {%- comment %} Poster {%- endcomment %}
              {%- if poster != blank -%}
                {{
                  poster
                  | image_url: width: 760
                  | image_tag:
                    class: 'shv-card__poster',
                    loading: 'lazy',
                    sizes: '(min-width: 990px) 320px, (min-width: 750px) 45vw, 80vw',
                    widths: '320, 480, 640, 760',
                    alt: block.settings.title | default: 'Video'
                }}
              {%- elsif hosted_video != blank -%}
                <img
                  class="shv-card__poster"
                  loading="lazy"
                  src="{{ hosted_video | video_tag: image_size: '760x' | extract: 'poster' }}"
                  alt="{{ block.settings.title | default: 'Video' }}"
                />
              {%- else -%}
                <div class="shv-card__poster shv-card__poster--placeholder">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'shv-placeholder-svg' }}
                </div>
              {%- endif -%}

              {%- comment %} Inline video {%- endcomment %}
              {%- if video_type == 'hosted' -%}
                <video
                  class="shv-card__video"
                  muted
                  loop
                  playsinline
                  preload="none"
                  data-shv-video
                >
                  {%- for source in hosted_video.sources -%}
                    {%- if source.format == 'mp4' -%}
                      <source data-src="{{ source.url }}" type="video/{{ source.format }}">
                    {%- endif -%}
                  {%- endfor -%}
                </video>
              {%- elsif video_url != blank -%}
                <div class="shv-card__video shv-card__video--embed" data-embed-url="{{ video_url }}" data-shv-embed></div>
              {%- endif -%}

              {%- comment %} Sound toggle {%- endcomment %}
              {%- if video_type == 'hosted' -%}
                <button class="shv-sound" data-shv-sound data-on="false" aria-label="Unmute video">
                  <svg class="shv-icon shv-icon--off" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M3 9v6h4l5 5V4L7 9H3Z" fill="currentColor"/>
                    <path d="M16 9l5 6M21 9l-5 6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                  </svg>
                  <svg class="shv-icon shv-icon--on" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M3 9v6h4l5 5V4L7 9H3Z" fill="currentColor"/>
                    <path d="M15.5 8.5a5 5 0 0 1 0 7M18 6a8 8 0 0 1 0 12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                  </svg>
                </button>
              {%- endif -%}

              {%- comment %} Gradient for legibility under the chip {%- endcomment %}
              <div class="shv-card__shade" aria-hidden="true"></div>

              {%- comment %} Floating product chip {%- endcomment %}
              {%- if product != blank -%}
                <button class="shv-chip" data-shv-chip aria-haspopup="dialog">
                  <span class="shv-chip__media">
                    {%- if product.featured_image -%}
                      {{ product.featured_image | image_url: width: 96 | image_tag: loading: 'lazy', alt: '' }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'shv-chip__placeholder' }}
                    {%- endif -%}
                  </span>
                  <span class="shv-chip__text">
                    <span class="shv-chip__title">{{ product.title }}</span>
                    <span class="shv-chip__price">{{ product.price | money }}</span>
                  </span>
                  <span class="shv-chip__cta" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </button>
              {%- endif -%}
            </div>
          </li>

          {%- comment %} Hidden product data, cloned into modal by JS {%- endcomment %}
          {%- if product != blank -%}
            <template class="shv-data" data-shv-data data-product-handle="{{ product.handle }}">
              <div class="shv-modal__product">
                <div class="shv-modal__gallery">
                  {%- if product.featured_image -%}
                    {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, class: 'shv-modal__image' }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'shv-modal__image shv-modal__image--placeholder' }}
                  {%- endif -%}
                </div>
                <div class="shv-modal__info">
                  <p class="shv-modal__vendor">{{ product.vendor }}</p>
                  <h3 class="shv-modal__title">{{ product.title }}</h3>
                  <p class="shv-modal__price">
                    {{ product.price | money }}
                    {%- if product.compare_at_price > product.price -%}
                      <s class="shv-modal__compare">{{ product.compare_at_price | money }}</s>
                    {%- endif -%}
                  </p>

                  {%- if product.description != blank -%}
                    <div class="shv-modal__desc">{{ product.description | strip_html | truncatewords: 40 }}</div>
                  {%- endif -%}

                  {%- if product.variants.size > 1 -%}
                    <label class="shv-modal__label" for="shv-variant-{{ product.id }}">
                      {{ 'products.product.choose_options' | t | default: 'Options' }}
                    </label>
                    <select class="shv-modal__variant" id="shv-variant-{{ product.id }}" data-product-id="{{ product.id }}">
                      {%- for variant in product.variants -%}
                        <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                          {{ variant.title }}{% unless variant.available %} — {{ 'products.product.sold_out' | t | default: 'Sold out' }}{% endunless %}
                        </option>
                      {%- endfor -%}
                    </select>
                  {%- else -%}
                    <input type="hidden" class="shv-modal__variant" value="{{ product.selected_or_first_available_variant.id }}">
                  {%- endif -%}

                  <button class="shv-modal__add" data-product-id="{{ product.id }}">
                    {{ 'products.product.add_to_cart' | t | default: 'Add to cart' }}
                  </button>
                  <a href="{{ product.url }}" class="shv-modal__link">
                    {{ 'products.product.view_details' | t | default: 'View full details' }}
                  </a>
                </div>
              </div>
            </template>
          {%- endif -%}

        {%- endif -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <li class="shv-card">
            <div class="shv-card__frame">
              <div class="shv-card__poster shv-card__poster--placeholder">
                {{ 'lifestyle-' | append: i | placeholder_svg_tag: 'shv-placeholder-svg' }}
              </div>
              <div class="shv-card__shade" aria-hidden="true"></div>
              <div class="shv-chip shv-chip--placeholder">
                <span class="shv-chip__media">
                  {{ 'product-1' | placeholder_svg_tag: 'shv-chip__placeholder' }}
                </span>
                <span class="shv-chip__text">
                  <span class="shv-chip__title">Product name</span>
                  <span class="shv-chip__price">$00.00</span>
                </span>
              </div>
            </div>
          </li>
        {%- endfor -%}
      {%- endfor -%}
    </ul>
  </div>

  {%- comment %} Modal: video (left) + product (right) {%- endcomment %}
  <div class="shv-modal" data-shv-modal hidden role="dialog" aria-modal="true" aria-label="Product video">
    <div class="shv-modal__backdrop" data-shv-modal-close></div>
    <div class="shv-modal__panel">
      <button class="shv-modal__close" data-shv-modal-close aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="shv-modal__media" data-shv-modal-media></div>
      <div class="shv-modal__product-slot" data-shv-modal-product></div>
    </div>
  </div>

</section>

{% comment %} =================== STYLES =================== {% endcomment %}
<style>
  #{{ s }} {
    --shv-gap:        {{ section.settings.card_gap | default: 14 }}px;
    --shv-radius:     {{ section.settings.card_radius | default: 18 }}px;
    --shv-bg:         {{ section.settings.section_bg | default: '#0c0c0f' }};
    --shv-fg:         {{ section.settings.heading_color | default: '#f5f5f0' }};
    --shv-card-bg:    {{ section.settings.card_bg | default: '#1c1c22' }};
    --shv-accent:     {{ section.settings.accent_color | default: '#f5f5f0' }};
    --shv-accent-fg:  {{ section.settings.accent_text_color | default: '#0c0c0f' }};
    --shv-visible:    {{ section.settings.cards_per_row | default: 4 }};
  }

  .shv-root {
    background: var(--shv-bg);
    color: var(--shv-fg);
    padding: {{ section.settings.section_padding_top | default: 56 }}px 0 {{ section.settings.section_padding_bottom | default: 56 }}px;
  }

  .shv-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    padding: 0 {{ section.settings.section_padding_x | default: 40 }}px;
    margin-bottom: 22px;
  }

  .shv-head__title {
    margin: 0 0 4px;
    font-size: clamp(1.3rem, 2.4vw, 1.9rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  .shv-head__sub {
    margin: 0;
    font-size: 0.92rem;
    opacity: 0.6;
  }

  .shv-head__nav {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .shv-arrow {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.18);
    background: transparent;
    color: var(--shv-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.18s, opacity 0.18s;
  }
  .shv-arrow:hover { background: rgba(255,255,255,0.08); }
  .shv-arrow:disabled { opacity: 0.25; pointer-events: none; }

  /* ---- Rail ---- */
  .shv-rail-wrap {
    padding: 0 {{ section.settings.section_padding_x | default: 40 }}px;
  }

  .shv-rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc(
      (100% - (var(--shv-visible) - 1) * var(--shv-gap)) / var(--shv-visible)
    );
    gap: var(--shv-gap);
    list-style: none;
    margin: 0;
    padding: 4px 0 8px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .shv-rail::-webkit-scrollbar { display: none; }

  .shv-card {
    scroll-snap-align: start;
  }

  .shv-card__frame {
    position: relative;
    aspect-ratio: 9 / 16;
    border-radius: var(--shv-radius);
    overflow: hidden;
    background: var(--shv-card-bg);
  }

  .shv-card__poster,
  .shv-card__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .shv-card__poster--placeholder { background: #232329; }
  .shv-card__poster--placeholder .shv-placeholder-svg { width: 100%; height: 100%; opacity: 0.18; }

  .shv-card__video {
    z-index: 1;
    opacity: 0;
    transition: opacity 0.35s ease;
    background: #000;
  }
  .shv-card__video--embed iframe { width: 100%; height: 100%; border: none; }
  .shv-card__frame.is-playing .shv-card__video { opacity: 1; }
  .shv-card__frame.is-playing .shv-card__poster { opacity: 0; transition: opacity 0.35s ease; }

  /* ---- Shade for chip legibility ---- */
  .shv-card__shade {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 46%;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0) 100%);
    z-index: 2;
    pointer-events: none;
  }

  /* ---- Sound toggle ---- */
  .shv-sound {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 4;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    background: rgba(0,0,0,0.4);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(4px);
  }
  .shv-icon { width: 16px; height: 16px; }
  .shv-icon--on { display: none; }
  .shv-sound[data-on="true"] .shv-icon--off { display: none; }
  .shv-sound[data-on="true"] .shv-icon--on { display: block; }

  /* ---- Floating product chip ---- */
  .shv-chip {
    position: absolute;
    left: 10px;
    right: 10px;
    bottom: 10px;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: calc(var(--shv-radius) - 8px);
    border: none;
    background: rgba(255,255,255,0.94);
    color: #111;
    cursor: pointer;
    text-align: left;
    backdrop-filter: blur(6px);
    transition: transform 0.18s ease, background 0.18s ease;
  }
  .shv-chip:hover { transform: translateY(-2px); background: #fff; }

  .shv-chip__media {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    background: #eee;
  }
  .shv-chip__media img,
  .shv-chip__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .shv-chip__text {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
    gap: 1px;
  }
  .shv-chip__title {
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.25;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .shv-chip__price {
    font-size: 0.76rem;
    opacity: 0.6;
  }
  .shv-chip__cta {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--shv-accent);
    color: var(--shv-accent-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .shv-chip--placeholder { cursor: default; }

  /* ---- Modal ---- */
  .shv-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .shv-modal[hidden] { display: none; }

  .shv-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10,10,12,0.78);
    cursor: pointer;
  }

  .shv-modal__panel {
    position: relative;
    z-index: 1;
    width: min(880px, 100%);
    max-height: min(640px, 92vh);
    background: #fff;
    color: #111;
    border-radius: 20px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 0.85fr 1fr;
  }

  .shv-modal__close {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 3;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.9);
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .shv-modal__media {
    position: relative;
    background: #0c0c0f;
    aspect-ratio: 9 / 16;
    max-height: min(640px, 92vh);
  }
  .shv-modal__media video,
  .shv-modal__media iframe,
  .shv-modal__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: none;
    display: block;
  }

  /* ---- Modal product card ---- */
  .shv-modal__product-slot {
    overflow-y: auto;
  }

  .shv-modal__product {
    display: flex;
    flex-direction: column;
  }

  .shv-modal__gallery {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #f5f5f5;
  }
  .shv-modal__image,
  .shv-modal__image--placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 1;
  }
  .shv-modal__image--placeholder { opacity: 0.2; }

  .shv-modal__info {
    padding: 22px 24px 26px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .shv-modal__vendor {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  .shv-modal__title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .shv-modal__price {
    margin: 2px 0 6px;
    font-size: 1rem;
    font-weight: 500;
  }
  .shv-modal__compare {
    opacity: 0.45;
    margin-left: 8px;
    font-weight: 400;
  }

  .shv-modal__desc {
    font-size: 0.85rem;
    line-height: 1.55;
    opacity: 0.7;
    margin-bottom: 6px;
  }

  .shv-modal__label {
    font-size: 0.75rem;
    font-weight: 600;
    opacity: 0.6;
    margin-bottom: -4px;
  }

  .shv-modal__variant {
    width: 100%;
    padding: 10px 12px;
    font-size: 0.88rem;
    border-radius: 8px;
    border: 1px solid rgba(0,0,0,0.15);
    background: #fff;
  }

  .shv-modal__add {
    width: 100%;
    padding: 13px;
    margin-top: 6px;
    border: none;
    border-radius: 10px;
    background: var(--shv-accent);
    color: var(--shv-accent-fg);
    font-size: 0.92rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s, background 0.2s;
  }
  .shv-modal__add:hover { opacity: 0.9; }
  .shv-modal__add[data-state="added"] { background: #2a9d5c; color: #fff; }
  .shv-modal__add[data-state="error"] { background: #c0392b; color: #fff; }

  .shv-modal__link {
    text-align: center;
    font-size: 0.78rem;
    text-decoration: underline;
    color: inherit;
    opacity: 0.6;
    margin-top: 2px;
  }

  .shv-data { display: none; }

  /* ---- Responsive ---- */
  @media (max-width: 1100px) {
    #{{ s }} { --shv-visible: 3; }
  }
  @media (max-width: 768px) {
    #{{ s }} { --shv-visible: 2.2; }
    .shv-head,
    .shv-rail-wrap { padding: 0 20px; }
    .shv-modal__panel {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
      max-height: 90vh;
    }
    .shv-modal__media { aspect-ratio: 16 / 10; max-height: 38vh; }
  }
  @media (max-width: 480px) {
    #{{ s }} { --shv-visible: 1.5; }
    .shv-chip__title { font-size: 0.74rem; }
    .shv-modal { padding: 0; }
    .shv-modal__panel { border-radius: 0; width: 100%; height: 100%; max-height: 100%; }
    .shv-modal__media { aspect-ratio: 16 / 11; max-height: 34vh; }
  }

  @media (prefers-reduced-motion: reduce) {
    .shv-card__video, .shv-card__poster, .shv-chip { transition: none; }
  }
</style>

{% comment %} =================== JAVASCRIPT =================== {% endcomment %}
<script>
(function () {
  'use strict';

  function initShoppableVideo(root) {
    const rail      = root.querySelector('[data-shv-rail]');
    const prevBtn   = root.querySelector('[data-shv-prev]');
    const nextBtn   = root.querySelector('[data-shv-next]');
    const modal     = root.querySelector('[data-shv-modal]');
    const modalMedia   = modal.querySelector('[data-shv-modal-media]');
    const modalProduct = modal.querySelector('[data-shv-modal-product]');
    const modalCloseEls = modal.querySelectorAll('[data-shv-modal-close]');

    if (!rail) return;

    // ── Carousel arrows ──────────────────────────────────────────
    function scrollByCard(dir) {
      const card = rail.querySelector('.shv-card');
      if (!card) return;
      const width = card.offsetWidth;
      const gap = parseInt(getComputedStyle(rail).gap) || 0;
      rail.scrollBy({ left: dir * (width + gap), behavior: 'smooth' });
    }
    if (prevBtn) prevBtn.addEventListener('click', () => scrollByCard(-1));
    if (nextBtn) nextBtn.addEventListener('click', () => scrollByCard(1));

    function syncArrows() {
      if (!prevBtn || !nextBtn) return;
      prevBtn.disabled = rail.scrollLeft <= 2;
      nextBtn.disabled = rail.scrollLeft + rail.clientWidth >= rail.scrollWidth - 2;
    }
    rail.addEventListener('scroll', syncArrows, { passive: true });
    syncArrows();

    // ── Hover-to-preview on each card ────────────────────────────
    root.querySelectorAll('[data-shv-card]').forEach(function (frame) {
      const video   = frame.querySelector('[data-shv-video]');
      const sources = video ? video.querySelectorAll('source[data-src]') : [];
      const soundBtn = frame.querySelector('[data-shv-sound]');
      let loaded = false;

      function loadSources() {
        if (loaded || !sources.length) return;
        sources.forEach(function (src) { src.src = src.dataset.src; });
        video.load();
        loaded = true;
      }

      function start() {
        if (!video) return;
        loadSources();
        frame.classList.add('is-playing');
        video.play().catch(function () {});
      }
      function stop() {
        frame.classList.remove('is-playing');
        if (video) {
          video.pause();
          video.currentTime = 0;
        }
      }

      frame.addEventListener('mouseenter', start);
      frame.addEventListener('mouseleave', stop);
      frame.addEventListener('focusin', start);
      frame.addEventListener('focusout', stop);

      if (soundBtn) {
        soundBtn.addEventListener('click', function (e) {
          e.stopPropagation();
          if (!video) return;
          video.muted = !video.muted;
          soundBtn.dataset.on = video.muted ? 'false' : 'true';
        });
      }
    });

    // ── Chip click → open modal ──────────────────────────────────
    root.querySelectorAll('[data-shv-chip]').forEach(function (chip) {
      chip.addEventListener('click', function (e) {
        e.stopPropagation();
        const frame = chip.closest('[data-shv-card]');
        if (!frame) return;
        openModal(frame);
      });
    });

    function openModal(frame) {
      const handle = frame.dataset.productHandle;
      const videoType = frame.dataset.videoType;

      // ---- Media (left column) ----
      modalMedia.innerHTML = '';

      if (videoType === 'hosted') {
        const srcVideo = frame.querySelector('[data-shv-video]');
        const v = document.createElement('video');
        v.autoplay = true;
        v.loop = true;
        v.playsInline = true;
        v.controls = true;
        if (srcVideo) {
          srcVideo.querySelectorAll('source').forEach(function (s) {
            const src = document.createElement('source');
            src.src = s.src || s.dataset.src;
            src.type = s.type;
            v.appendChild(src);
          });
        }
        modalMedia.appendChild(v);
        v.play().catch(function () {});
      } else {
        const embedEl = frame.querySelector('[data-shv-embed]');
        const url = embedEl ? embedEl.dataset.embedUrl : null;
        if (url) {
          const iframe = document.createElement('iframe');
          iframe.src = embedUrl(url);
          iframe.allow = 'autoplay; encrypted-media; fullscreen';
          iframe.allowFullscreen = true;
          modalMedia.appendChild(iframe);
        } else {
          const poster = frame.querySelector('.shv-card__poster');
          if (poster) modalMedia.appendChild(poster.cloneNode());
        }
      }

      // ---- Product (right column) ----
      modalProduct.innerHTML = '';
      const dataTpl = root.querySelector('[data-shv-data][data-product-handle="' + handle + '"]');
      if (dataTpl) {
        modalProduct.appendChild(dataTpl.content.cloneNode(true));
        bindAddToCart(modalProduct);
      }

      modal.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
      modalMedia.innerHTML = '';
      modalProduct.innerHTML = '';
    }

    modalCloseEls.forEach(function (el) {
      el.addEventListener('click', closeModal);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });

    // ── Add to cart ───────────────────────────────────────────────
    function bindAddToCart(scope) {
      const addBtn = scope.querySelector('.shv-modal__add');
      if (!addBtn) return;

      addBtn.addEventListener('click', function () {
        const variantEl = scope.querySelector('.shv-modal__variant');
        const variantId = variantEl ? variantEl.value : null;
        if (!variantId) return;

        const originalText = addBtn.textContent;
        addBtn.disabled = true;
        addBtn.dataset.state = 'loading';
        addBtn.textContent = '...';

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
        })
          .then(function (res) {
            if (!res.ok) throw new Error('Add to cart failed');
            return res.json();
          })
          .then(function () {
            addBtn.dataset.state = 'added';
            addBtn.textContent = 'Added';
            document.dispatchEvent(new CustomEvent('cart:refresh'));
            setTimeout(function () {
              addBtn.dataset.state = '';
              addBtn.textContent = originalText;
              addBtn.disabled = false;
            }, 1800);
          })
          .catch(function () {
            addBtn.dataset.state = 'error';
            addBtn.textContent = 'Try again';
            setTimeout(function () {
              addBtn.dataset.state = '';
              addBtn.textContent = originalText;
              addBtn.disabled = false;
            }, 1800);
          });
      });
    }

    // ── Embed URL helper ─────────────────────────────────────────
    function embedUrl(url) {
      try {
        const u = new URL(url);
        if (u.hostname.includes('youtu')) {
          const id = u.searchParams.get('v') || u.pathname.split('/').pop();
          return 'https://www.youtube.com/embed/' + id + '?autoplay=1&rel=0';
        }
        if (u.hostname.includes('vimeo')) {
          const id = u.pathname.split('/').filter(Boolean).pop();
          return 'https://player.vimeo.com/video/' + id + '?autoplay=1';
        }
      } catch (err) {}
      return url;
    }
  }

  function boot() {
    document.querySelectorAll('[data-section-type="shoppable-video"]').forEach(initShoppableVideo);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  document.addEventListener('shopify:section:load', function (e) {
    const s = e.target.querySelector('[data-section-type="shoppable-video"]');
    if (s) initShoppableVideo(s);
  });
})();
</script>

