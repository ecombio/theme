{{ 'article-feed.css' | asset_url | stylesheet_tag }}

{% comment %}
  Article Feed Section
  
  Two ways to filter:
  1. AUTO: reads hub.tags metafield from the current article (category hub page)
     — matches against native Shopify tags on all articles in the blog
  2. MANUAL: owner types tags in the section textarea (overrides auto)
  
  OR logic — article shows if it has ANY matching tag.
{% endcomment %}

{%- liquid
  assign blog_handle = 'articles'
  assign limit       = section.settings.limit | default: 6
  assign show_image  = section.settings.show_image
  assign columns     = section.settings.columns | default: 3
-%}

{%- comment -%}
  Determine filter tags:
  - If textarea has values, use those (manual override)
  - Otherwise fall back to the current article's hub.tags metafield
{%- endcomment -%}
{%- if section.settings.tags != blank -%}
  {%- assign filter_tags = section.settings.tags | downcase | split: "
" -%}
{%- else -%}
  {%- assign filter_tags = article.metafields.hub.tags.value -%}
{%- endif -%}

<div class="article-feed">
  {%- if section.settings.title != blank -%}
    <h2 class="article-feed__title">{{ section.settings.title | escape }}</h2>
  {%- endif -%}

  <div class="article-feed__grid" style="--columns: {{ columns }};">
    {%- assign rendered = 0 -%}

    {%- for article_item in blogs[blog_handle].articles -%}

      {%- assign matched = false -%}

      {%- if filter_tags == blank or filter_tags.size == 0 -%}
        {%- assign matched = true -%}
      {%- else -%}
        {%- for filter_tag in filter_tags -%}
          {%- assign filter_tag_clean = filter_tag | strip | downcase -%}
          {%- if filter_tag_clean == blank -%}{%- continue -%}{%- endif -%}
          {%- for native_tag in article_item.tags -%}
            {%- assign native_tag_lower = native_tag | downcase | strip -%}
            {%- if native_tag_lower == filter_tag_clean -%}
              {%- assign matched = true -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      {%- endif -%}

      {%- unless matched -%}{%- continue -%}{%- endunless -%}

      {%- assign rendered = rendered | plus: 1 -%}
      {%- if rendered > limit -%}{%- break -%}{%- endif -%}

      <a href="{{ article_item.url }}" class="article-feed__card">
        {%- if show_image -%}
          {%- if article_item.image -%}
            {{ article_item.image | image_url: width: 600 | image_tag: class: 'article-feed__image', loading: 'lazy' }}
          {%- else -%}
            <div class="article-feed__image article-feed__image--placeholder"></div>
          {%- endif -%}
        {%- endif -%}

        <div class="article-feed__content">
          {%- if article_item.tags.size > 0 -%}
            <div class="article-feed__card-tags">
              {%- for tag in article_item.tags -%}
                <span class="article-feed__card-tag">{{ tag | escape }}</span>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <h3 class="article-feed__heading">{{ article_item.title | escape }}</h3>

          {%- if article_item.excerpt != blank -%}
            <p class="article-feed__excerpt">
              {{ article_item.excerpt | strip_html | truncate: 110 }}
            </p>
          {%- endif -%}

          <div class="article-feed__meta">
            {{ article_item.published_at | date: "%b %d, %Y" }}
          </div>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Article Feed",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Latest Articles"
    },
    {
      "type": "textarea",
      "id": "tags",
      "label": "Filter by tags (optional override)",
      "info": "One tag per line. Overrides the hub metafield. Leave blank to auto-read from this article's hub.tags metafield."
    },
    {
      "type": "range",
      "id": "limit",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Number of articles"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Columns on desktop"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "Show featured images"
    }
  ],
  "presets": [
    {
      "name": "Article Feed"
    }
  ]
}
{% endschema %}