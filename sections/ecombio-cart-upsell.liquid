    {
      "type": "warranty_offer",
      "name": "Warranty Offer",
      "settings": [
        {
          "type": "product",
          "id": "warranty_product",
          "label": "Warranty Product"
        },
        {
          "type": "text",
          "id": "warranty_title",
          "label": "Warranty Title",
          "default": "2-Year Protection Plan"
        },
        {
          "type": "textarea",
          "id": "warranty_description",
          "label": "Warranty Description"
        },
        {
          "type": "text",
          "id": "add_button_text",
          "label": "Add Button Text",
          "default": "Add Protection"
        }
      ]
    },
    {
      "type": "subscription_offer",
      "name": "Subscription Offer",
      "settings": [
        {
          "type": "product",
          "id": "subscription_product",
          "label": "Subscription Product"
        },
        {
          "type": "text",
          "id": "selling_plan_id",
          "label": "Selling Plan ID",
          "info": "Find this in your Shopify subscription app settings."
        },
        {
          "type": "text",
          "id": "subscription_title",
          "label": "Subscription Title"
        },
        {
          "type": "textarea",
          "id": "subscription_description",
          "label": "Subscription Description"
        },
        {
          "type": "range",
          "id": "subscription_savings_percent",
          "label": "Savings Percentage",
          "min": 0,
          "max": 40,
          "step": 1,
          "default": 10
        },
        {
          "type": "text",
          "id": "add_button_text",
          "label": "Add Button Text",
          "default": "Subscribe & Save"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ECOMBIO Cart Upsell"
    }
  ]
}
{% endschema %}
