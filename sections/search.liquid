{% comment %}
  Search results page — products, articles, and pages.
  Supports filter sidebar (products only), sort, grid/list toggle, and pagination.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/search
{% endcomment %}

<div class="search-page">

  {%- comment -%} ── Search bar ── {%- endcomment -%}
  <div class="search-page__header">
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-page__form">
      <input type="hidden" name="type" value="product,article,page">
      {%- if search.sort_by -%}
        <input type="hidden" name="sort_by" value="{{ search.sort_by }}">
      {%- endif -%}
      <div class="search-page__bar">
        <svg class="search-page__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          class="search-page__input"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.placeholder' | t }}"
          aria-label="{{ 'search.placeholder' | t }}"
          autocomplete="off"
        >
        <button class="search-page__submit" type="submit">
          {{ 'search.submit' | t }}
        </button>
      </div>
    </form>
  </div>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}

      {%- comment -%} ── No results ── {%- endcomment -%}
      <div class="search-page__empty">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M8 11h6M11 8v6"/></svg>
        <h2>{{ 'search.no_results_html' | t: terms: search.terms }}</h2>
        <p>{{ 'search.suggestions' | t | default: 'Try different keywords or browse our categories.' }}</p>
      </div>

    {%- else -%}

      {%- comment -%} ── Results layout ── {%- endcomment -%}
      {%- paginate search.results by 20 -%}

        <div class="search-page__meta">
          {{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}
        </div>

        <div class="search-page__layout">

          {%- comment -%} ── Filter sidebar (products only) ── {%- endcomment -%}
          <aside class="search-page__filters" aria-label="Filters">

            {%- if search.filters != blank -%}
              <form id="SearchFiltersForm" action="{{ routes.search_url }}" method="get">
                <input type="hidden" name="q" value="{{ search.terms | escape }}">
                <input type="hidden" name="type" value="product">
                {%- if search.sort_by -%}
                  <input type="hidden" name="sort_by" value="{{ search.sort_by }}">
                {%- endif -%}

                {%- for filter in search.filters -%}
                  <div class="filter-section">
                    <p class="filter-section__title">{{ filter.label }}</p>

                    {%- case filter.type -%}

                      {%- when 'list' -%}
                        {%- for value in filter.values -%}
                          <label class="filter-option">
                            <input
                              type="checkbox"
                              name="{{ value.param_name }}"
                              value="{{ value.value }}"
                              {% if value.active %}checked{% endif %}
                              {% if value.count == 0 and value.active == false %}disabled{% endif %}
                              onchange="document.getElementById('SearchFiltersForm').submit()"
                            >
                            <span class="filter-option__label">{{ value.label }}</span>
                            <span class="filter-option__count">{{ value.count }}</span>
                          </label>
                        {%- endfor -%}

                      {%- when 'price_range' -%}
                        <div class="filter-price">
                          <input
                            class="filter-price__input"
                            type="number"
                            name="{{ filter.min_value.param_name }}"
                            id="FilterPriceMin"
                            {% if filter.min_value.value -%}value="{{ filter.min_value.value | money_without_currency | remove: ',' }}"{% endif %}
                            placeholder="{{ 'search.filter.price_min' | t | default: 'Min' }}"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                          >
                          <span class="filter-price__sep">–</span>
                          <input
                            class="filter-price__input"
                            type="number"
                            name="{{ filter.max_value.param_name }}"
                            id="FilterPriceMax"
                            {% if filter.max_value.value -%}value="{{ filter.max_value.value | money_without_currency | remove: ',' }}"{% endif %}
                            placeholder="{{ 'search.filter.price_max' | t | default: 'Max' }}"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                          >
                        </div>

                    {%- endcase -%}
                  </div>
                {%- endfor -%}

                {%- comment -%} Active filter tags ── {%- endcomment -%}
                {%- assign active_filter_count = 0 -%}
                {%- for filter in search.filters -%}
                  {%- for value in filter.active_values -%}
                    {%- assign active_filter_count = active_filter_count | plus: 1 -%}
                  {%- endfor -%}
                  {%- if filter.type == 'price_range' -%}
                    {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
                      {%- assign active_filter_count = active_filter_count | plus: 1 -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}

                {%- if active_filter_count > 0 -%}
                  <div class="filter-active-tags">
                    {%- for filter in search.filters -%}
                      {%- for value in filter.active_values -%}
                        <a class="filter-tag" href="{{ value.url_to_remove }}" aria-label="Remove {{ value.label }}">
                          {{ value.label }}
                          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
                        </a>
                      {%- endfor -%}
                      {%- if filter.type == 'price_range' -%}
                        {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
                          <a class="filter-tag" href="{{ filter.url_to_remove }}" aria-label="Remove price filter">
                            {{ filter.min_value.value | default: '' | money_without_currency }}–{{ filter.max_value.value | default: filter.range_max | money_without_currency }}
                            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
                          </a>
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                    <a class="filter-tag filter-tag--clear" href="{{ search.url }}?q={{ search.terms | url_encode }}&type=product">
                      {{ 'search.filter.clear_all' | t | default: 'Clear all' }}
                    </a>
                  </div>
                {%- endif -%}

              </form>
            {%- endif -%}
          </aside>

          {%- comment -%} ── Results area ── {%- endcomment -%}
          <section class="search-page__results">

            {%- comment -%} Toolbar: sort + view toggle ── {%- endcomment -%}
            <div class="results-toolbar">
              <form action="{{ routes.search_url }}" method="get" id="SortForm">
                <input type="hidden" name="q" value="{{ search.terms | escape }}">
                <input type="hidden" name="type" value="product">
                {%- for filter in search.filters -%}
                  {%- for value in filter.active_values -%}
                    <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
                  {%- endfor -%}
                  {%- if filter.type == 'price_range' -%}
                    {%- if filter.min_value.value -%}<input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | remove: ',' }}">{%- endif -%}
                    {%- if filter.max_value.value -%}<input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | remove: ',' }}">{%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
                <select
                  class="results-sort"
                  name="sort_by"
                  aria-label="{{ 'search.sort_by' | t | default: 'Sort by' }}"
                  onchange="document.getElementById('SortForm').submit()"
                >
                  {%- assign sort_by = search.sort_by | default: search.default_sort_by -%}
                  <option value="relevance" {% if sort_by == 'relevance' %}selected{% endif %}>{{ 'search.sort.relevance' | t | default: 'Relevance' }}</option>
                  <option value="price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>{{ 'search.sort.price_asc' | t | default: 'Price: low to high' }}</option>
                  <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>{{ 'search.sort.price_desc' | t | default: 'Price: high to low' }}</option>
                  <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>{{ 'search.sort.newest' | t | default: 'Newest first' }}</option>
                  <option value="best-selling" {% if sort_by == 'best-selling' %}selected{% endif %}>{{ 'search.sort.best_selling' | t | default: 'Best selling' }}</option>
                </select>
              </form>

              <div class="view-toggle" role="group" aria-label="View layout">
                <button class="view-btn view-btn--grid view-btn--active" id="ViewGrid" aria-label="Grid view" onclick="setView('grid', event)" type="button">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                </button>
                <button class="view-btn view-btn--list" id="ViewList" aria-label="List view" onclick="setView('list', event)" type="button">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                </button>
              </div>
            </div>

            {%- comment -%} ── Product grid ── {%- endcomment -%}
            <div class="results-grid" id="ResultsGrid">
              {%- for result in search.results -%}

                {%- assign result_type = result.object_type | default: result.type -%}

                {%- if result_type == 'product' -%}
                  {%- comment -%} Product card ── {%- endcomment -%}
                  <article class="product-card" data-product-id="{{ result.id }}">
                    <a class="product-card__img-link" href="{{ result.url }}" tabindex="-1" aria-hidden="true">
                      {%- if result.featured_image -%}
                        {%- assign img_alt = result.featured_image.alt | escape -%}
                        <div class="product-card__img">
                          <img
                            src="{{ result.featured_image | image_url: width: 600 }}"
                            alt="{{ img_alt }}"
                            width="{{ result.featured_image.width }}"
                            height="{{ result.featured_image.height }}"
                            loading="lazy"
                          >
                        </div>
                      {%- else -%}
                        <div class="product-card__img product-card__img--placeholder">
                          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m3 9 4-4 4 4 4-4 4 4"/><path d="M3 14h18"/></svg>
                        </div>
                      {%- endif -%}

                      {%- comment -%} Badges ── {%- endcomment -%}
                      <div class="product-card__badges">
                        {%- if result.compare_at_price > result.price -%}
                          <span class="badge badge--sale">Sale</span>
                        {%- endif -%}
                        {%- assign new_threshold = 'now' | date: '%s' | minus: 2592000 -%}
                        {%- assign created = result.created_at | date: '%s' | plus: 0 -%}
                        {%- if created > new_threshold -%}
                          <span class="badge badge--new">New</span>
                        {%- endif -%}
                      </div>
                    </a>

                    <div class="product-card__body">
                      {%- if result.vendor -%}
                        <p class="product-card__vendor">{{ result.vendor }}</p>
                      {%- endif -%}
                      <h2 class="product-card__title">
                        <a href="{{ result.url }}">{{ result.title }}</a>
                      </h2>
                      <div class="product-card__price">
                        <span class="product-card__price-current">{{ result.price | money_with_currency }}</span>
                        {%- if result.compare_at_price > result.price -%}
                          <s class="product-card__price-compare">{{ result.compare_at_price | money_with_currency }}</s>
                        {%- endif -%}
                      </div>

                      <button
                        class="product-card__add"
                        type="button"
                        data-variant-id="{{ result.first_available_variant.id }}"
                        {%- unless result.available -%}disabled{%- endunless -%}
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                        {%- if result.available -%}
                          {{ 'products.product.add_to_cart' | t | default: 'Add to cart' }}
                        {%- else -%}
                          {{ 'products.product.sold_out' | t | default: 'Sold out' }}
                        {%- endif -%}
                      </button>
                    </div>
                  </article>

                {%- else -%}
                  {%- comment -%} Article / Page result ── {%- endcomment -%}
                  <article class="content-card">
                    <div class="content-card__body">
                      {%- assign featured_image = result.image | default: result.featured_image -%}
                      {%- if featured_image -%}
                        <div class="content-card__img">
                          {%- assign content_img_alt = featured_image.alt | escape -%}
                          <img src="{{ featured_image | image_url: width: 400 }}" alt="{{ content_img_alt }}" loading="lazy" width="{{ featured_image.width }}" height="{{ featured_image.height }}">
                        </div>
                      {%- endif -%}
                      <span class="content-card__type">{{ result_type | capitalize }}</span>
                      <h2 class="content-card__title"><a href="{{ result.url }}">{{ result.title }}</a></h2>
                      {%- if result.excerpt or result.content -%}
                        <p class="content-card__excerpt">{{ result.excerpt | default: result.content | strip_html | truncate: 140 }}</p>
                      {%- endif -%}
                    </div>
                  </article>
                {%- endif -%}

              {%- endfor -%}
            </div>

            {%- comment -%} ── Pagination ── {%- endcomment -%}
            {%- if paginate.pages > 1 -%}
              <nav class="search-pagination" aria-label="{{ 'general.pagination.label' | t | default: 'Pagination' }}">
                {%- if paginate.previous -%}
                  <a class="page-btn page-btn--arrow" href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t | default: 'Previous' }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
                  </a>
                {%- else -%}
                  <span class="page-btn page-btn--arrow page-btn--disabled" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
                  </span>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a class="page-btn" href="{{ part.url }}">{{ part.title }}</a>
                  {%- elsif part.title == paginate.current_page -%}
                    <span class="page-btn page-btn--current" aria-current="page">{{ part.title }}</span>
                  {%- else -%}
                    <span class="page-btn page-btn--ellipsis" aria-hidden="true">…</span>
                  {%- endif -%}
                {%- endfor -%}

                {%- if paginate.next -%}
                  <a class="page-btn page-btn--arrow" href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t | default: 'Next' }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                {%- else -%}
                  <span class="page-btn page-btn--arrow page-btn--disabled" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                  </span>
                {%- endif -%}
              </nav>
            {%- endif -%}

          </section>
        </div>

      {%- endpaginate -%}

    {%- endif -%}
  {%- endif -%}

</div>

{% stylesheet %}

/* ── Page shell ── */
.search-page {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 1.5rem 4rem;
}

/* ── Search bar ── */
.search-page__header {
  padding-bottom: 1.5rem;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  margin-bottom: 1.5rem;
}
.search-page__form { width: 100%; }
.search-page__bar {
  display: flex;
  align-items: center;
  gap: 8px;
}
.search-page__icon {
  flex-shrink: 0;
  color: #888;
}
.search-page__input {
  flex: 1;
  height: 42px;
  padding: 0 14px;
  font-size: 15px;
  border: 1px solid rgba(0,0,0,0.15);
  border-radius: 8px;
  background: #fff;
  color: inherit;
  appearance: none;
  -webkit-appearance: none;
}
.search-page__input:focus {
  outline: none;
  border-color: rgba(0,0,0,0.4);
  box-shadow: 0 0 0 3px rgba(0,0,0,0.06);
}
.search-page__submit {
  height: 42px;
  padding: 0 20px;
  border-radius: 8px;
  border: none;
  background: #111;
  color: #fff;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
}
.search-page__submit:hover { background: #333; }

/* ── Meta line ── */
.search-page__meta {
  font-size: 13px;
  color: #666;
  margin-bottom: 1rem;
}

/* ── Layout: sidebar + results ── */
.search-page__layout {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 2.5rem;
  align-items: start;
}
@media (max-width: 768px) {
  .search-page__layout { grid-template-columns: 1fr; }
  .search-page__filters { display: none; }
}

/* ── Filter sidebar ── */
.search-page__filters { position: sticky; top: 1.5rem; }

.filter-section { margin-bottom: 1.5rem; }
.filter-section__title {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: #888;
  margin-bottom: 10px;
}
.filter-option {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 3px 0;
  font-size: 14px;
  cursor: pointer;
}
.filter-option input[type="checkbox"] {
  width: 14px;
  height: 14px;
  cursor: pointer;
  accent-color: #111;
}
.filter-option__count {
  margin-left: auto;
  font-size: 12px;
  color: #aaa;
}

.filter-price {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.filter-price__input {
  width: 88px;
  height: 34px;
  padding: 0 10px;
  font-size: 13px;
  border: 1px solid rgba(0,0,0,0.15);
  border-radius: 6px;
  background: #fff;
  color: inherit;
}
.filter-price__sep { font-size: 12px; color: #bbb; }

.filter-active-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(0,0,0,0.06);
}
.filter-tag {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  padding: 4px 10px;
  border: 1px solid rgba(0,0,0,0.15);
  border-radius: 100px;
  background: #f5f5f5;
  color: #333;
  text-decoration: none;
  cursor: pointer;
  transition: border-color 0.15s;
}
.filter-tag:hover { border-color: rgba(0,0,0,0.35); }
.filter-tag--clear {
  background: transparent;
  border-color: transparent;
  color: #888;
  font-size: 12px;
}
.filter-tag--clear:hover { color: #111; border-color: transparent; }

/* ── Toolbar ── */
.results-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
}
.results-sort {
  height: 34px;
  padding: 0 10px;
  font-size: 13px;
  border: 1px solid rgba(0,0,0,0.15);
  border-radius: 6px;
  background: #fff;
  color: inherit;
  cursor: pointer;
}
.view-toggle { display: flex; gap: 4px; }
.view-btn {
  width: 34px;
  height: 34px;
  border: 1px solid rgba(0,0,0,0.1);
  border-radius: 6px;
  background: transparent;
  color: #888;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.12s, color 0.12s;
}
.view-btn--active {
  background: #f2f2f2;
  color: #111;
  border-color: rgba(0,0,0,0.2);
}

/* ── Product grid ── */
.results-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}
.results-grid.is-list { grid-template-columns: 1fr; }
@media (max-width: 960px) {
  .results-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .results-grid { grid-template-columns: 1fr; }
}

/* ── Product card ── */
.product-card {
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: 12px;
  overflow: hidden;
  background: #fff;
  transition: border-color 0.15s;
  display: flex;
  flex-direction: column;
}
.product-card:hover { border-color: rgba(0,0,0,0.18); }

.results-grid.is-list .product-card {
  flex-direction: row;
}
.results-grid.is-list .product-card__img-link {
  width: 160px;
  flex-shrink: 0;
}

.product-card__img-link {
  display: block;
  position: relative;
  text-decoration: none;
}
.product-card__img {
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  background: #f7f7f7;
}
.product-card__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}
.product-card:hover .product-card__img img { transform: scale(1.03); }
.product-card__img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
}

.product-card__badges {
  position: absolute;
  top: 8px;
  left: 8px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 600;
  padding: 3px 7px;
  border-radius: 4px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.badge--sale { background: #fff0f0; color: #c0392b; }
.badge--new  { background: #f0fff4; color: #1a7a3c; }

.product-card__body {
  padding: 12px 14px 14px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.product-card__vendor {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #aaa;
  margin-bottom: 4px;
}
.product-card__title {
  font-size: 14px;
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 8px;
  flex: 1;
}
.product-card__title a {
  text-decoration: none;
  color: inherit;
}
.product-card__title a:hover { text-decoration: underline; }

.product-card__price {
  display: flex;
  align-items: baseline;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 10px;
}
.product-card__price-current { font-size: 15px; font-weight: 500; }
.product-card__price-compare { font-size: 13px; color: #bbb; text-decoration: line-through; }

.product-card__add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: 100%;
  height: 34px;
  border: 1px solid rgba(0,0,0,0.12);
  border-radius: 6px;
  background: transparent;
  color: inherit;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: background 0.12s;
  margin-top: auto;
}
.product-card__add:hover:not(:disabled) { background: #f5f5f5; }
.product-card__add:disabled { opacity: 0.45; cursor: default; }

/* ── Content (article/page) card ── */
.content-card {
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: 12px;
  overflow: hidden;
  background: #fff;
}
.content-card__body { padding: 16px; }
.content-card__img { margin-bottom: 10px; }
.content-card__img img { width: 100%; border-radius: 6px; display: block; }
.content-card__type {
  display: inline-block;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #888;
  margin-bottom: 4px;
}
.content-card__title { font-size: 15px; font-weight: 500; margin-bottom: 6px; }
.content-card__title a { text-decoration: none; color: inherit; }
.content-card__title a:hover { text-decoration: underline; }
.content-card__excerpt { font-size: 13px; color: #666; line-height: 1.6; }

/* ── Pagination ── */
.search-pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 6px;
  margin-top: 2.5rem;
}
.page-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 34px;
  height: 34px;
  padding: 0 4px;
  border: 1px solid rgba(0,0,0,0.1);
  border-radius: 6px;
  background: #fff;
  color: #555;
  font-size: 13px;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.12s;
}
.page-btn:hover:not(.page-btn--current):not(.page-btn--disabled):not(.page-btn--ellipsis) {
  background: #f5f5f5;
}
.page-btn--current {
  background: #111;
  color: #fff;
  border-color: #111;
  cursor: default;
}
.page-btn--disabled { opacity: 0.35; cursor: default; }
.page-btn--ellipsis { border-color: transparent; background: transparent; cursor: default; }
.page-btn--arrow { color: #888; }

/* ── Empty state ── */
.search-page__empty {
  text-align: center;
  padding: 4rem 1rem;
  color: #888;
}
.search-page__empty svg { margin: 0 auto 1rem; display: block; }
.search-page__empty h2 { font-size: 18px; font-weight: 500; color: #111; margin-bottom: 8px; }
.search-page__empty p { font-size: 14px; }

{% endstylesheet %}

{% javascript %}
  (function () {
    /* ── View toggle ── */
    window.setView = function (mode, e) {
      if (e) e.preventDefault();
      var grid = document.getElementById('ResultsGrid');
      var gBtn = document.getElementById('ViewGrid');
      var lBtn = document.getElementById('ViewList');
      if (!grid) return;
      if (mode === 'list') {
        grid.classList.add('is-list');
        lBtn.classList.add('view-btn--active');
        gBtn.classList.remove('view-btn--active');
      } else {
        grid.classList.remove('is-list');
        gBtn.classList.add('view-btn--active');
        lBtn.classList.remove('view-btn--active');
      }
    };

    /* ── Add to cart ── */
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.product-card__add');
      if (!btn || btn.disabled) return;
      var variantId = btn.dataset.variantId;
      if (!variantId) return;

      btn.disabled = true;
      btn.textContent = '…';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          btn.textContent = '✓ Added';
          setTimeout(function () {
            btn.disabled = false;
            btn.innerHTML =
              '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg> Add to cart';
          }, 2000);
          /* Trigger cart update event for themes that listen */
          document.dispatchEvent(new CustomEvent('cart:updated', { detail: data }));
        })
        .catch(function () {
          btn.disabled = false;
          btn.textContent = 'Try again';
        });
    });

    /* ── Price range submit on blur ── */
    ['FilterPriceMin', 'FilterPriceMax'].forEach(function (id) {
      var el = document.getElementById(id);
      if (!el) return;
      el.addEventListener('change', function () {
        var form = document.getElementById('SearchFiltersForm');
        if (form) form.submit();
      });
    });
  })();
{% endjavascript %}

