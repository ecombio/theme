{{ 'footer-bottom-bar.css' | asset_url | stylesheet_tag }}

<div class="footer-bottom-bar" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">

  <div class="footer-bottom-bar__top">
    <div class="footer-bottom-bar__payments">
      {% render 'payment-icons' %}
    </div>
    <div class="footer-bottom-bar__social">
      {% render 'social-icons' %}
    </div>
  </div>

  <div class="footer-bottom-bar__divider"></div>

  <div class="footer-bottom-bar__bottom">
    {% render 'footer-legal-bar' %}
  </div>

</div>

{% schema %}
{
  "name": "Footer bottom bar",
  "tag": "section",
  "class": "footer-bottom-bar-section",
  "settings": [
    {
      "type": "header",
      "content": "Legal"
    },
    {
      "type": "text",
      "id": "legal_text",
      "label": "Copyright text",
      "default": "Your Brand Ltd | All Rights Reserved."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Legal menu",
      "info": "Assign a navigation menu with your legal links e.g. Terms, Privacy Policy"
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "url",
      "id": "social_x",
      "label": "X (Twitter) URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "header",
      "content": "Localization"
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Show country/currency selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_language_selector",
      "label": "Show language selector",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Footer bottom bar"
    }
  ]
}
{% endschema %}
