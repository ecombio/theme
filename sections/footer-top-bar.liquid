{{ 'footer-top-bar.css' | asset_url | stylesheet_tag }}

<section class="footer-top-bar-section" {{ section.shopify_attributes }}>
  <div class="footer__top-bar">
    <div class="footer__top-bar-inner">

      {%- for block in section.blocks -%}

        {%- case block.type -%}

          {%- when 'heading' -%}
            <div class="footer__top-heading" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>

          {%- when 'text' -%}
            <div class="footer__top-text" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>

          {%- when 'logo' -%}
            <div class="footer__top-logo" {{ block.shopify_attributes }}>
              {% if section.settings.logo != blank %}
                <img 
                  src="{{ section.settings.logo | image_url: width: 200 }}" 
                  alt="{{ section.settings.logo.alt | default: shop.name }}" 
                  loading="lazy">
              {% endif %}
            </div>

        {%- endcase -%}

      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Footer Top Bar",
  "class": "shopify-section--footer-top-bar",
  "max_blocks": 5,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading Text",
          "default": "Explore ECOMBIO"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Short description or tagline here.</p>"
        }
      ]
    },
    {
      "type": "logo",
      "name": "Logo",
      "limit": 1
    }
  ],
  "presets": [
    {
      "name": "Footer Top Bar",
      "blocks": [
        {
          "type": "heading"
        }
      ]
    }
  ]
}
{% endschema %}