{%- comment -%}
  sections/product-sections.liquid
  ─────────────────────────────────────────────────────────────────────────────
  Controller section for all below-the-fold content on the product page.

  Blocks (all togglable / reorderable in the Theme Editor):
    • product-description     – Full product description from the metafield or
                                the default product.description
    • product-specs           – Specification table (key/value pairs)
    • product-features        – Icon + text feature highlights
    • complementary-products  – "Bought Together" using Shopify Search &
                                Discovery's product recommendations (intent:
                                complementary)
    • product-reviews         – Review block (renders placeholder / 3rd-party
                                hook; swap in your review app's snippet here)
    • related-products        – Algorithmic "You may also like" recommendations

  Usage:
    Add {% section 'product-sections' %} beneath the main product form on
    your product template (product.json or product.liquid).

  Dependencies:
    • Shopify Search & Discovery app for complementary / related products.
    • Replace the reviews placeholder with your actual review app snippet.
{%- endcomment -%}

{%- liquid
  assign current_product = product
  assign product_url     = current_product.url
-%}

<div
  class="product-sections"
  data-section-id="{{ section.id }}"
  data-section-type="product-sections"
>

  {%- for block in section.blocks -%}

    {%- comment -%}──────────────── PRODUCT DESCRIPTION ────────────────{%- endcomment -%}
    {%- if block.type == 'product-description' -%}

      {%- liquid
        comment
          Use a metafield for long-form HTML if present, otherwise fall back
          to the standard product description.
        endcomment
        assign description_content = current_product.metafields.custom.long_description.value
        if description_content == blank
          assign description_content = current_product.description
        endif
      -%}

      {%- unless description_content == blank -%}
        <section
          class="product-description"
          id="product-description-{{ section.id }}"
          {{ block.shopify_attributes }}
        >
          <div class="product-description__inner container">

            {%- if block.settings.heading != blank -%}
              <h2 class="product-description__heading section-heading">
                {{ block.settings.heading | escape }}
              </h2>
            {%- endif -%}

            <div class="product-description__body rte">
              {{ description_content }}
            </div>

          </div>
        </section>
      {%- endunless -%}

    {%- comment -%}──────────────── PRODUCT SPECIFICATIONS ─────────────{%- endcomment -%}
    {%- elsif block.type == 'product-specs' -%}

      {%- liquid
        comment
          Specs are stored as a metafield of type list.single_line_text_field.
          Each entry should be formatted as "Label::Value", e.g.
          "Material::Stainless Steel 316L"
          Adjust the metafield namespace / key to match your store's setup.
        endcomment
        assign specs_list = current_product.metafields.custom.specifications.value
      -%}

      {%- unless specs_list == blank or specs_list.size == 0 -%}
        <section
          class="product-specs"
          id="product-specs-{{ section.id }}"
          {{ block.shopify_attributes }}
        >
          <div class="product-specs__inner container">

            {%- if block.settings.heading != blank -%}
              <h2 class="product-specs__heading section-heading">
                {{ block.settings.heading | escape }}
              </h2>
            {%- endif -%}

            <table class="product-specs__table" role="table">
              <tbody>
                {%- for spec in specs_list -%}
                  {%- assign spec_parts = spec | split: '::' -%}
                  {%- if spec_parts.size == 2 -%}
                    <tr class="product-specs__row">
                      <th class="product-specs__label" scope="row">
                        {{ spec_parts[0] | strip | escape }}
                      </th>
                      <td class="product-specs__value">
                        {{ spec_parts[1] | strip | escape }}
                      </td>
                    </tr>
                  {%- endif -%}
                {%- endfor -%}
              </tbody>
            </table>

          </div>
        </section>
      {%- endunless -%}

    {%- comment -%}──────────────── PRODUCT FEATURES ───────────────────{%- endcomment -%}
    {%- elsif block.type == 'product-features' -%}

      {%- liquid
        comment
          Features are driven by the block's static settings (up to 6).
          Each feature has an optional icon (SVG snippet name), a title,
          and a short description. A feature row is skipped if both
          title and description are blank.
        endcomment
        assign has_features = false
        for i in (1..6)
          assign title_key = 'feature_' | append: i | append: '_title'
          assign desc_key  = 'feature_' | append: i | append: '_description'
          if block.settings[title_key] != blank or block.settings[desc_key] != blank
            assign has_features = true
            break
          endif
        endfor
      -%}

      {%- if has_features -%}
        <section
          class="product-features"
          id="product-features-{{ section.id }}"
          {{ block.shopify_attributes }}
        >
          <div class="product-features__inner container">

            {%- if block.settings.heading != blank -%}
              <h2 class="product-features__heading section-heading">
                {{ block.settings.heading | escape }}
              </h2>
            {%- endif -%}

            <ul class="product-features__list" role="list">
              {%- for i in (1..6) -%}
                {%- liquid
                  assign title_key = 'feature_' | append: i | append: '_title'
                  assign desc_key  = 'feature_' | append: i | append: '_description'
                  assign icon_key  = 'feature_' | append: i | append: '_icon'
                  assign feat_title = block.settings[title_key]
                  assign feat_desc  = block.settings[desc_key]
                  assign feat_icon  = block.settings[icon_key]
                -%}

                {%- unless feat_title == blank and feat_desc == blank -%}
                  <li class="product-features__item">

                    {%- unless feat_icon == blank -%}
                      <div class="product-features__icon" aria-hidden="true">
                        {%- comment -%}
                          Render a Shopify icon or your own SVG sprite.
                          Swap the line below with {% render feat_icon %} if
                          you have a snippets-based icon system.
                        {%- endcomment -%}
                        {{ feat_icon }}
                      </div>
                    {%- endunless -%}

                    <div class="product-features__copy">
                      {%- unless feat_title == blank -%}
                        <h3 class="product-features__title">
                          {{ feat_title | escape }}
                        </h3>
                      {%- endunless -%}
                      {%- unless feat_desc == blank -%}
                        <p class="product-features__description">
                          {{ feat_desc | escape }}
                        </p>
                      {%- endunless -%}
                    </div>

                  </li>
                {%- endunless -%}
              {%- endfor -%}
            </ul>

          </div>
        </section>
      {%- endif -%}

    {%- comment -%}──────────────── COMPLEMENTARY PRODUCTS ─────────────{%- endcomment -%}
    {%- elsif block.type == 'complementary-products' -%}

      {%- comment -%}
        Uses the Shopify Search & Discovery "complementary" intent.
        Requires the app to be installed and recommendations configured.
        The fetch is done via the Recommendations API and rendered
        server-side using the product-card snippet.
      {%- endcomment -%}

      {%- assign comp_limit = block.settings.products_to_show | default: 4 -%}

      {%- liquid
        assign comp_recs = recommendations.products
        comment
          recommendations object is only populated when accessed via the
          /recommendations/products.json endpoint.  On initial page render we
          check the global object populated by the app; if empty we output a
          container that JavaScript can swap in via fetch.
        endcomment
      -%}

      <section
        class="complementary-products"
        id="complementary-products-{{ section.id }}"
        data-product-id="{{ current_product.id }}"
        data-limit="{{ comp_limit }}"
        data-intent="complementary"
        {{ block.shopify_attributes }}
      >
        <div class="complementary-products__inner container">

          {%- if block.settings.heading != blank -%}
            <h2 class="complementary-products__heading section-heading">
              {{ block.settings.heading | escape }}
            </h2>
          {%- endif -%}

          {%- comment -%}
            Server-side render if recommendations are available synchronously
            (e.g. rendered via the recommendations route).
            Otherwise, JS will populate data-complementary-products-mount.
          {%- endcomment -%}
          <div
            class="complementary-products__grid"
            data-complementary-products-mount
          >
            {%- if recommendations.performed and recommendations.products_count > 0 -%}
              {%- for rec_product in recommendations.products limit: comp_limit -%}
                {%- render 'product-card', product: rec_product -%}
              {%- endfor -%}
            {%- endif -%}
          </div>

        </div>
      </section>

    {%- comment -%}──────────────── PRODUCT REVIEWS ────────────────────{%- endcomment -%}
    {%- elsif block.type == 'product-reviews' -%}

      {%- comment -%}
        ⚠️  INTEGRATION POINT
        Replace the placeholder below with your review app's snippet.

        Common examples:
          Okendo:  {% render 'okendo-reviews', product: current_product %}
          Judge.me: {% render 'judgeme_widgets', widget_type: 'judgeme_review_widget', jm_style: '', concierge_install: false, product: current_product %}
          Yotpo:   <div class="yotpo yotpo-main-widget" data-product-id="{{ current_product.id }}"></div>
          Stamped: {% render 'stamped-main-widget', product: current_product %}

        The outer <section> wrapper is provided here so layout / spacing
        remains consistent regardless of which app you use.
      {%- endcomment -%}

      <section
        class="product-reviews"
        id="product-reviews-{{ section.id }}"
        {{ block.shopify_attributes }}
      >
        <div class="product-reviews__inner container">

          {%- if block.settings.heading != blank -%}
            <h2 class="product-reviews__heading section-heading">
              {{ block.settings.heading | escape }}
            </h2>
          {%- endif -%}

          {%- comment -%} ── REPLACE THIS BLOCK WITH YOUR REVIEW APP SNIPPET ── {%- endcomment -%}
          <div class="product-reviews__widget">
            {{- current_product.metafields.reviews.rating.value -}}
            {%- comment -%}
              Placeholder: renders nothing visible until you add your snippet.
              Delete the two lines above and paste your app snippet here.
            {%- endcomment -%}
          </div>

        </div>
      </section>

    {%- comment -%}──────────────── RELATED PRODUCTS ───────────────────{%- endcomment -%}
    {%- elsif block.type == 'related-products' -%}

      {%- comment -%}
        Uses Shopify's algorithmic "related" recommendations.
        Products are fetched client-side via the Recommendations API
        so the section degrades gracefully if no recommendations exist.
      {%- endcomment -%}

      {%- assign related_limit = block.settings.products_to_show | default: 4 -%}

      <section
        class="related-products"
        id="related-products-{{ section.id }}"
        data-product-id="{{ current_product.id }}"
        data-limit="{{ related_limit }}"
        data-intent="related"
        {{ block.shopify_attributes }}
      >
        <div class="related-products__inner container">

          {%- if block.settings.heading != blank -%}
            <h2 class="related-products__heading section-heading">
              {{ block.settings.heading | escape }}
            </h2>
          {%- endif -%}

          {%- comment -%}
            Populated by JS via /recommendations/products.json.
            If you prefer a server-side collection-based fallback, render
            a collection loop here inside a noscript tag.
          {%- endcomment -%}
          <div
            class="related-products__grid"
            data-related-products-mount
          ></div>

        </div>
      </section>

    {%- endif -%}
  {%- endfor -%}

</div>

{%- comment -%}
  ─────────────────────────────────────────────────────────────────────────────
  Scoped styles
  Scope everything under .product-sections to avoid bleed into other sections.
  Move to assets/product-sections.css if you prefer a separate stylesheet.
  ─────────────────────────────────────────────────────────────────────────────
{%- endcomment -%}
<style>
  /* ── Layout helpers ─────────────────────────────────────────────────────── */
  .product-sections .container {
    max-width: var(--page-width, 1200px);
    margin-inline: auto;
    padding-inline: var(--spacing-md, 2rem);
  }

  .product-sections section {
    padding-block: var(--section-spacing, 4rem);
    border-top: 1px solid var(--color-border, #e5e5e5);
  }

  .product-sections section:first-child {
    border-top: none;
  }

  /* ── Shared heading style ───────────────────────────────────────────────── */
  .product-sections .section-heading {
    font-size: var(--font-size-xl, 1.5rem);
    font-weight: var(--font-weight-bold, 700);
    margin-block-end: var(--spacing-md, 2rem);
  }

  /* ── Product Description ────────────────────────────────────────────────── */
  .product-description__body.rte {
    max-width: 72ch;
  }

  /* ── Product Specifications ─────────────────────────────────────────────── */
  .product-specs__table {
    width: 100%;
    border-collapse: collapse;
  }

  .product-specs__row {
    border-bottom: 1px solid var(--color-border, #e5e5e5);
  }

  .product-specs__label,
  .product-specs__value {
    padding-block: 0.75rem;
    text-align: left;
    vertical-align: top;
  }

  .product-specs__label {
    width: 35%;
    font-weight: var(--font-weight-medium, 600);
    padding-inline-end: 1rem;
    color: var(--color-foreground-secondary, #6b7280);
  }

  /* ── Product Features ───────────────────────────────────────────────────── */
  .product-features__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    gap: var(--spacing-lg, 2.5rem);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .product-features__item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .product-features__icon {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    color: var(--color-accent, currentColor);
  }

  .product-features__title {
    font-size: var(--font-size-base, 1rem);
    font-weight: var(--font-weight-bold, 700);
    margin-block-end: 0.25rem;
  }

  .product-features__description {
    color: var(--color-foreground-secondary, #6b7280);
    font-size: var(--font-size-sm, 0.9rem);
    margin: 0;
  }

  /* ── Complementary & Related Products (shared grid) ─────────────────────── */
  .complementary-products__grid,
  .related-products__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(220px, 100%), 1fr));
    gap: var(--spacing-md, 1.5rem);
  }

  /* ── Reviews ────────────────────────────────────────────────────────────── */
  .product-reviews__widget {
    min-height: 2rem; /* Reserve space while review app initialises */
  }

  /* ── Responsive overrides ───────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .product-sections section {
      padding-block: var(--section-spacing-mobile, 2.5rem);
    }

    .product-specs__label {
      width: 45%;
    }
  }
</style>

{%- comment -%}
  ─────────────────────────────────────────────────────────────────────────────
  JavaScript — Recommendations fetch
  Fetches complementary and related products from the Shopify Recommendations
  API and renders them via your product-card snippet (server-side rendered
  HTML returned by the ?section_id= param trick).

  Requires a snippet at snippets/product-card.liquid.
  ─────────────────────────────────────────────────────────────────────────────
{%- endcomment -%}
<script>
(function () {
  'use strict';

  /**
   * Fetch product recommendations from the Shopify Recommendations API
   * and inject the returned HTML into the given mount element.
   *
   * @param {HTMLElement} section  - The <section> element with data attributes
   * @param {HTMLElement} mount    - The grid container to populate
   */
  function loadRecommendations(section, mount) {
    const productId = section.dataset.productId;
    const limit     = section.dataset.limit || 4;
    const intent    = section.dataset.intent || 'related'; // 'related' | 'complementary'

    if (!productId) return;

    /*
     * We use the ?section_id= query parameter so Shopify renders the response
     * through a section snippet, giving us fully server-rendered product cards.
     *
     * Swap 'product-card-grid' below for whatever section / snippet you use
     * to render a single product card via the recommendations endpoint.
     *
     * Alternatively, fetch JSON and build DOM manually:
     * /recommendations/products.json?product_id=...&limit=...&intent=...
     */
    const url = new URL('/recommendations/products', window.location.origin);
    url.searchParams.set('product_id', productId);
    url.searchParams.set('limit', limit);
    url.searchParams.set('intent', intent);
    /* Uncomment the line below to use section-rendered cards:
    url.searchParams.set('section_id', 'product-card-grid');
    */

    fetch(url.toString(), { headers: { 'X-Requested-With': 'fetch' } })
      .then(function (response) {
        if (!response.ok) throw new Error('Recommendations fetch failed');
        return response.json();
      })
      .then(function (data) {
        if (!data.products || data.products.length === 0) {
          // No recommendations — hide the entire section gracefully
          section.hidden = true;
          return;
        }

        /*
         * If you opted for section-rendered HTML (section_id param above),
         * replace the block below with:
         *   mount.innerHTML = data; // data would be text, not JSON
         *
         * For JSON-only, build minimal cards here or dispatch a custom event
         * that your theme's product-card component listens to.
         */
        const fragment = document.createDocumentFragment();

        data.products.forEach(function (product) {
          const card = document.createElement('div');
          card.className = 'product-card';
          card.innerHTML = [
            '<a class="product-card__link" href="' + product.url + '">',
            product.featured_image
              ? '<img class="product-card__image" src="' + product.featured_image + '" alt="' + product.title + '" loading="lazy" width="400" height="400">'
              : '',
            '<div class="product-card__info">',
            '<p class="product-card__title">' + product.title + '</p>',
            '<p class="product-card__price">' + Shopify.formatMoney(product.price, window.themeMoneyFormat || '${{amount}}') + '</p>',
            '</div>',
            '</a>',
          ].join('');
          fragment.appendChild(card);
        });

        mount.appendChild(fragment);
      })
      .catch(function (err) {
        console.warn('[product-sections] Recommendations error:', err);
        section.hidden = true;
      });
  }

  // Bootstrap on DOMContentLoaded (or immediately if already loaded)
  function init() {
    // Complementary products
    document.querySelectorAll('.complementary-products[data-product-id]').forEach(function (section) {
      const mount = section.querySelector('[data-complementary-products-mount]');
      // Only fetch if mount is empty (not already server-rendered)
      if (mount && mount.children.length === 0) {
        loadRecommendations(section, mount);
      }
    });

    // Related products
    document.querySelectorAll('.related-products[data-product-id]').forEach(function (section) {
      const mount = section.querySelector('[data-related-products-mount]');
      if (mount) {
        loadRecommendations(section, mount);
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

