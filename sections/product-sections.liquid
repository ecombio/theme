  ─────────────────────────────────────────────────────────────────────────────
  Section Schema
  ─────────────────────────────────────────────────────────────────────────────
{%- endcomment -%}
{% schema %}
{
  "name": "Product Sections",
  "tag": "div",
  "class": "product-sections-wrapper",
  "limit": 1,
  "blocks": [

    {
      "type": "product-description",
      "name": "Product Description",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Description"
        },
        {
          "type": "paragraph",
          "content": "Content is pulled from the product description field, or from the metafield 'custom.long_description' if present."
        }
      ]
    },

    {
      "type": "product-specs",
      "name": "Product Specifications",
      "limit": 1,
      "settings": [
