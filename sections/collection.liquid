{{ 'collection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign active_tab = request.query_parameters['tab'] | default: 'products'
  unless active_tab == 'products' or active_tab == 'articles'
    assign active_tab = 'products'
  endunless
-%}

<section class="collection-section">
  <div class="collection-page" data-collection-page data-active-tab="{{ active_tab }}">

    {%- render 'collection-toolbar', active_tab: active_tab -%}

    <div class="collection-body">

      {%- render 'collection-filter' -%}

      <div class="collection-body__feed">
        {%- render 'collection-feed', active_tab: active_tab -%}
      </div>

    </div>

  </div>
</section>

{%- comment -%} Shared backdrop for filter drawer + sort sheet {%- endcomment -%}
<div class="collection-mobile-backdrop" aria-hidden="true"></div>

<script src="{{ 'collection-filter.js' | asset_url }}" defer></script>
<script src="{{ 'collection-feed.js' | asset_url }}" defer></script>
<script src="{{ 'collection.js' | asset_url }}" defer></script>
<script src="{{ 'promo-carousel.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-collection",
  "settings": [
    {
      "type": "text",
      "id": "tab_products_label",
      "label": "Products tab label",
      "default": "Products"
    },
    {
      "type": "text",
      "id": "tab_articles_label",
      "label": "Articles tab label",
      "default": "Articles"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show filters",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sort",
      "default": true
    },
    {
      "type": "header",
      "content": "Sub-collections"
    },
    {
      "type": "select",
      "id": "sub_collection_shape",
      "label": "Sub-collection image shape",
      "options": [
        { "value": "square", "label": "Square (rounded corners)" },
        { "value": "circle", "label": "Circle" }
      ],
      "default": "square"
    },
    {
      "type": "paragraph",
      "content": "Add sub-collection blocks below. If a collection has no image, a default placeholder icon is shown automatically — or set a custom image per block."
    },
    {
      "type": "header",
      "content": "In-feed banners"
    },
    {
      "type": "paragraph",
      "content": "Add 'In-feed banner' blocks below to place promotional banners inside the product grid. Each banner has its own position number and size — set both per block."
    },
    {
      "type": "header",
      "content": "Promo carousels"
    },
    {
      "type": "paragraph",
      "content": "Add a 'Promo carousel' block to insert a tabbed product carousel into the grid, then add one or more 'Carousel tab' blocks set to the same position number to populate it."
    },
    {
      "type": "header",
      "content": "Articles"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "sub_collection",
      "name": "Sub-collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title",
          "info": "Leave blank to use the collection's title"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom image",
          "info": "Leave blank to use the collection's featured image. If neither is set, a default placeholder is shown."
        }
      ]
    },
    {
      "type": "promo_banner",
      "name": "Promo Banner",
      "settings": [
        {
          "type": "number",
          "id": "position",
          "label": "Position in product grid",
          "info": "Banner appears before the Nth product on the current page. E.g. 5 inserts it right before the 5th product. A number larger than the total product count places it at the end. Leave blank or 0 to hide."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (desktop)"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Image (mobile)",
          "info": "Optional. Falls back to the desktop image if not set."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Makes the entire banner clickable"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#ffffff"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Image overlay darkness",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "default": 20
        },
        {
          "type": "header",
          "content": "Size"
        },
        {
          "type": "range",
          "id": "column_span",
          "label": "Width (columns spanned)",
          "min": 1,
          "max": 4,
          "step": 1,
          "default": 2,
          "info": "Capped automatically on smaller screens so it never exceeds the live column count"
        },
        {
          "type": "range",
          "id": "row_span",
          "label": "Height (rows spanned)",
          "min": 1,
          "max": 3,
          "step": 1,
          "default": 1
        }
      ]
    },
    {
      "type": "promo_carousel",
      "name": "Promo carousel",
      "settings": [
        {
          "type": "number",
          "id": "position",
          "label": "Position in product grid",
          "info": "Carousel appears before the Nth product on this page. A number larger than the total product count places it at the end. Leave blank or 0 to hide."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "range",
          "id": "products_per_tab",
          "label": "Products per tab",
          "min": 4,
          "max": 24,
          "step": 1,
          "default": 12
        },
        {
          "type": "range",
          "id": "cards_per_row_desktop",
          "label": "Cards per row (desktop)",
          "min": 2,
          "max": 5,
          "step": 1,
          "default": 3
        },
        {
          "type": "range",
          "id": "cards_per_row_mobile",
          "label": "Cards per row (mobile)",
          "min": 1,
          "max": 3,
          "step": 1,
          "default": 2
        },
        {
          "type": "checkbox",
          "id": "show_arrows",
          "label": "Show arrows",
          "default": true
        },
        {
          "type": "select",
          "id": "arrow_position",
          "label": "Arrow position",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "bottom", "label": "Bottom" },
            { "value": "side", "label": "Side" }
          ],
          "default": "bottom"
        },
        {
          "type": "checkbox",
          "id": "autoplay",
          "label": "Autoplay",
          "default": false
        },
        {
          "type": "range",
          "id": "autoplay_interval",
          "label": "Autoplay interval (seconds)",
          "min": 2,
          "max": 10,
          "step": 1,
          "default": 4
        },
        {
          "type": "header",
          "content": "Banner"
        },
        {
          "type": "checkbox",
          "id": "show_banner",
          "label": "Show side banner",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "banner_image",
          "label": "Banner image"
        },
        {
          "type": "url",
          "id": "banner_link",
          "label": "Banner link"
        }
      ]
    },
    {
      "type": "carousel_tab",
      "name": "Carousel tab",
      "settings": [
        {
          "type": "number",
          "id": "parent_position",
          "label": "Parent carousel position",
          "info": "Must match the position number set on the 'Promo carousel' block this tab belongs to."
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab label",
          "info": "Leave blank to use the collection's title"
        },
        {
          "type": "text",
          "id": "tab_icon",
          "label": "Tab icon (emoji or short text)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection",
      "blocks": []
    }
  ]
}
{% endschema %}
