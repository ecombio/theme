{%- comment -%}
  sections/collection.liquid

  Structure:
    sections/collection.liquid
      ├─ render 'product-filter'                 (facets + sort, plain form)
      └─ div.collection-products
           └─ render 'product-feed'               (loop → product-card ×N,
                                                     interleaved with
                                                     in-feed-carousel blocks)

  Asset ownership:
    • collection.css — loaded HERE. Covers product-filter UI and the
      .collection-products grid wrapper only. Does not touch
      .product-card internals (that's product-card.css, loaded
      separately by this section since that file is section-scoped,
      not global per theme.liquid).
    • product-card.js — global, loaded once in theme.liquid. Not
      re-linked here.
    • product-carousel.css / product-carousel.js — loaded HERE, once,
      only when at least one "carousel" block is configured. These
      files are reused AS-IS from sections/product-carousel.liquid —
      do not fork them. snippets/in-feed-carousel.liquid emits the
      same .product-carousel / data-carousel-* markup contract those
      files already expect.
    • No collection.js yet — filtering/sorting is plain <form> submit
      (full page reload), so there's no collection-specific JS to
      own yet. Add it only when AJAX filtering or the article-card
      tab-switcher lands.

  The .collection-products class is deliberately generic (not
  .product-grid) since a future tab/context-switcher will let this
  same wrapper hold an article-card feed instead. Keep it that way
  until that work starts.

  IN-FEED CAROUSEL BLOCKS:
  Repeatable "carousel" blocks (section.blocks) let a merchant insert
  a horizontally-scrolling carousel every `carousel_interval` products
  inside the feed. Each block can pick its own collection; if left
  blank, it falls back to the current page's collection. Blocks cycle
  in order across insertion points.
{%- endcomment -%}

{{ 'collection.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign carousel_blocks = section.blocks | where: 'type', 'carousel'
-%}
{%- if carousel_blocks.size > 0 -%}
  {{ 'product-carousel.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<div class="collection page-width" data-section-id="{{ section.id }}" data-section-type="collection">

  <div class="collection__header">
    <h1 class="collection__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection__description">{{ collection.description }}</div>
    {%- endif -%}
  </div>

  {%- render 'product-filter', collection: collection -%}

  {%- paginate collection.products by section.settings.products_per_page -%}

    <div
      class="collection-products"
      style="--collection-products-columns-desktop: {{ section.settings.columns_desktop }}; --collection-products-columns-mobile: {{ section.settings.columns_mobile }};"
    >
      {%- render 'product-feed',
        products: collection.products,
        show_quickview: section.settings.show_quickview,
        show_compare: section.settings.show_compare,
        show_eta: section.settings.show_eta,
        carousel_blocks: carousel_blocks,
        carousel_interval: section.settings.carousel_interval,
        fallback_collection: collection
      -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="collection__pagination" role="navigation" aria-label="Pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="collection__pagination-link" rel="prev">&larr; Previous</a>
        {%- endif -%}

        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a
              href="{{ part.url }}"
              class="collection__pagination-link"
              {% if part.title == paginate.current_page %}aria-current="page"{% endif %}
            >{{ part.title }}</a>
          {%- else -%}
            <span class="collection__pagination-ellipsis">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}

        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="collection__pagination-link" rel="next">Next &rarr;</a>
        {%- endif -%}
      </nav>
    {%- endif -%}

  {%- endpaginate -%}

</div>

{%- if carousel_blocks.size > 0 -%}
  <script src="{{ 'product-carousel.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
{
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_quickview",
      "label": "Show quick view button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_compare",
      "label": "Show compare checkbox",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_eta",
      "label": "Show delivery ETA",
      "default": true
    },
    {
      "type": "header",
      "content": "In-feed carousels"
    },
    {
      "type": "range",
      "id": "carousel_interval",
      "label": "Insert a carousel every N products",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 8,
      "info": "Set to 0 to disable in-feed carousels even if blocks are added below."
    }
  ],
  "blocks": [
    {
      "type": "carousel",
      "name": "In-feed Carousel",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Leave blank to use the current collection."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading (optional)"
        },
        {
          "type": "range",
          "id": "products_per_carousel",
          "label": "Products in this carousel",
          "min": 4,
          "max": 24,
          "step": 2,
          "default": 12
        },
        {
          "type": "range",
          "id": "cards_per_row_desktop",
          "label": "Cards visible — desktop",
          "min": 2,
          "max": 5,
          "step": 1,
          "default": 3
        },
        {
          "type": "select",
          "id": "cards_per_row_mobile",
          "label": "Cards visible — mobile",
          "options": [
            { "value": "1", "label": "1" },
            { "value": "2", "label": "2" }
          ],
          "default": "2"
        }
      ]
    }
  ]
}
{% endschema %}