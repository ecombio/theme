{% comment %}
  sections/collection.liquid
  Root section for templates/collection.json.

Renders:
    [1.1] collection-features.liquid  — banner/carousel blocks + sort/filter UI
    [1.2] collection-showroom.liquid — tab router (products / articles / pages)

    [1.2.1] showroom-products.liquid → product-card.liquid
    [1.2.2] showroom-articles.liquid → article-card.liquid
    [1.2.3] showroom-pages.liquid    → page-card.liquid

Metafields read:
  collection.metafields.showroom.articles.value — list of article objects

    collection.metafields.custom.pages.value  — list of page objects
    collection.metafields.custom.description  — optional rich-text override
    collection.metafields.custom.banner_image — optional banner image

  Blocks (rendered by collection-features.liquid — NOT interleaved into
  the product grid anymore):
    "banner"   — a clickable image banner, sized as a percent of the row's
                 width (25/50/75/100%). See collection-banner.liquid and
                 collection-banner.css/.js for rendering and span logic.
    "carousel" — a multi-slide image carousel, always full-row width.
                 See collection-carousel.liquid and collection-carousel.css/.js.

  Block render order follows the order blocks are arranged in the theme
  editor's block list. The old per-block `position` ("insert after
  product #N") setting has been removed from both block types — it
  controlled grid-interleaving, which no longer happens.

  Pagination:
    Opened here around the showroom render so that all sub-snippets
    share the same paginate object. Products per page is controlled
    by the section setting `products_per_page`.

  CSS:
    collection.css — loaded below via stylesheet_tag.

  JS:
    product-card.js        — loaded globally in theme.liquid.
    collection-showroom.js — loaded by collection-showroom.liquid.
    collection-banner.js   — loaded by collection-banner.liquid.
    collection-carousel.js — loaded by collection-carousel.liquid.
    article-card.js / page-card.js — loaded by their respective card snippets.
{% endcomment %}

{{ 'collection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign related_pages = collection.metafields.custom.pages.value
  assign products_per_page = section.settings.products_per_page | default: 12
  assign show_banner       = section.settings.show_banner
  assign show_description  = section.settings.show_description
  assign show_breadcrumb   = section.settings.show_breadcrumb
  assign layout            = section.settings.layout | default: 'sidebar'

  assign banner_image = collection.metafields.custom.banner_image.value
  if banner_image == blank
    assign banner_image = collection.image
  endif
-%}

<div class="collection-section collection-section--layout-{{ layout }}">

  {%- comment -%} ── Breadcrumb ──────────────────────────────────────────── {%- endcomment -%}

  {%- if show_breadcrumb -%}
    <nav class="collection-section__breadcrumb" aria-label="Breadcrumb">
      <ol class="collection-section__breadcrumb-list">
        <li class="collection-section__breadcrumb-item">
          <a href="/" class="collection-section__breadcrumb-link">Home</a>
        </li>
        <li class="collection-section__breadcrumb-item" aria-hidden="true">
          <span class="collection-section__breadcrumb-sep">/</span>
        </li>
        <li class="collection-section__breadcrumb-item">
          <a href="/collections" class="collection-section__breadcrumb-link">Collections</a>
        </li>
        <li class="collection-section__breadcrumb-item" aria-hidden="true">
          <span class="collection-section__breadcrumb-sep">/</span>
        </li>
        <li class="collection-section__breadcrumb-item collection-section__breadcrumb-item--current" aria-current="page">
          {{ collection.title }}
        </li>
      </ol>
    </nav>
  {%- endif -%}

  {%- comment -%} ── Section-level banner (metafield / collection image) ──── {%- endcomment -%}

  {%- if show_banner and banner_image -%}
    <div class="collection-section__banner">
      <img
        class="collection-section__banner-image"
        src="{{ banner_image | image_url: width: 1400 }}"
        alt="{{ banner_image.alt | escape | default: collection.title | escape }}"
        width="1400"
        height="{{ 1400 | divided_by: banner_image.aspect_ratio | round }}"
        loading="eager"
        fetchpriority="high"
      >
      <div class="collection-section__banner-overlay">
        <h1 class="collection-section__banner-title">{{ collection.title }}</h1>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Header (no section-level banner) ────────────────────── {%- endcomment -%}

  {%- unless show_banner and banner_image -%}
    <header class="collection-section__header">
      <h1 class="collection-section__title">{{ collection.title }}</h1>

      {%- if show_description -%}
        {%- liquid
          assign description_content = collection.metafields.custom.description.value
          if description_content == blank
            assign description_content = collection.description
          endif
        -%}
        {%- if description_content != blank -%}
          <div class="collection-section__description">
            {{ description_content }}
          </div>
        {%- endif -%}
      {%- endif -%}
    </header>
  {%- endunless -%}

  {%- comment -%} ── Body: features + showroom ────────────────────────────── {%- endcomment -%}

  <div class="collection-section__body">

    {%- if layout == 'sidebar' -%}
      <aside class="collection-section__sidebar" aria-label="Collection filters">
        {%- render 'collection-features',
          collection: collection,
          blocks:     section.blocks,
          context:    'sidebar'
        -%}
      </aside>
    {%- endif -%}

    <div class="collection-section__main">

      {%- if layout == 'full' -%}
        <div class="collection-section__toolbar">
          {%- render 'collection-features',
            collection: collection,
            blocks:     section.blocks,
            context:    'toolbar'
          -%}
        </div>
      {%- endif -%}


 {%- paginate collection.products by products_per_page -%}
  {%- render 'collection-showroom',
  collection: collection
  -%}
  {%- endpaginate -%}

    </div>

  </div>

</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-collection",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "sidebar", "label": "Sidebar filters" },
        { "value": "full",    "label": "Full width + toolbar" }
      ],
      "default": "sidebar"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 6,
      "max": 48,
      "step": 6,
      "default": 12
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description",
      "default": true
    },
    {
      "type": "header",
      "content": "Banner"
    },
    {
      "type": "checkbox",
      "id": "show_banner",
      "label": "Show banner image",
      "info": "Uses collection.metafields.custom.banner_image if set, otherwise falls back to the collection image.",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Landscape images work best; the banner is always wider than it is tall."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Leave blank for a non-clickable banner."
        },
        {
          "type": "header",
          "content": "Size"
        },
        {
          "type": "select",
          "id": "width",
          "label": "Row width",
          "options": [
            { "value": "25",  "label": "25% of row" },
            { "value": "50",  "label": "50% of row" },
            { "value": "75",  "label": "75% of row" },
            { "value": "100", "label": "100% of row (full width)" }
          ],
          "default": "100"
        }
      ]
    },
    {
      "type": "carousel",
      "name": "Carousel",
      "settings": [
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop the look"
        },
        {
          "type": "header",
          "content": "Style"
        },
        {
          "type": "select",
          "id": "image_shape",
          "label": "Image shape",
          "options": [
            { "value": "circle",  "label": "Circular" },
            { "value": "rounded", "label": "Rounded corners" },
            { "value": "square",  "label": "Square" }
          ],
          "default": "rounded"
        },
        {
          "type": "checkbox",
          "id": "autoplay",
          "label": "Autoplay",
          "default": false
        },
        {
          "type": "range",
          "id": "autoplay_speed",
          "label": "Autoplay speed (seconds)",
          "min": 3,
          "max": 10,
          "step": 1,
          "default": 5
        },
        { "type": "header", "content": "Slide 1" },
        { "type": "image_picker", "id": "slide_1", "label": "Image" },
        { "type": "text", "id": "slide_1_label", "label": "Caption" },
        { "type": "url", "id": "slide_1_link", "label": "Link" },
        { "type": "header", "content": "Slide 2" },
        { "type": "image_picker", "id": "slide_2", "label": "Image" },
        { "type": "text", "id": "slide_2_label", "label": "Caption" },
        { "type": "url", "id": "slide_2_link", "label": "Link" },
        { "type": "header", "content": "Slide 3" },
        { "type": "image_picker", "id": "slide_3", "label": "Image" },
        { "type": "text", "id": "slide_3_label", "label": "Caption" },
        { "type": "url", "id": "slide_3_link", "label": "Link" },
        { "type": "header", "content": "Slide 4" },
        { "type": "image_picker", "id": "slide_4", "label": "Image" },
        { "type": "text", "id": "slide_4_label", "label": "Caption" },
        { "type": "url", "id": "slide_4_link", "label": "Link" },
        { "type": "header", "content": "Slide 5" },
        { "type": "image_picker", "id": "slide_5", "label": "Image" },
        { "type": "text", "id": "slide_5_label", "label": "Caption" },
        { "type": "url", "id": "slide_5_link", "label": "Link" },
        { "type": "header", "content": "Slide 6" },
        { "type": "image_picker", "id": "slide_6", "label": "Image" },
        { "type": "text", "id": "slide_6_label", "label": "Caption" },
        { "type": "url", "id": "slide_6_link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection"
    }
  ]
}
{% endschema %}