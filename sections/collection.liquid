{% comment %}
  Collection Products Section
{% endcomment %}

{{ 'collection.css' | asset_url | stylesheet_tag }}
{{ 'collection.js' | asset_url | script_tag }}

{%- liquid
  assign show_title = section.settings.show_title
  assign per_page = section.settings.products_per_page | default: 20
-%}

<div class="collection-products-section">
  {%- if show_title -%}
    <h1 class="collection-products__title">{{ collection.title }}</h1>
  {%- endif -%}

  <div class="collection-products">
    {% paginate collection.products by per_page %}
      {% for product in collection.products %}
        <div class="collection-product-wrapper">
          {% render 'card-product',
            product: product,
            show_vendor: true,
            show_compare_at_price: true,
            media_aspect_ratio: 'square'
          %}
        </div>
      {% endfor %}

      {{ paginate | default_pagination }}
    {% endpaginate %}
  </div>
</div>

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 20,
      "label": "Products per page"
    }
  ]
}
{% endschema %}