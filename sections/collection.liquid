{{ 'collection.css' | asset_url | stylesheet_tag }}
{{ 'collection-toolbar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign active_tab = request.query_parameters['tab'] | default: 'products'
  unless active_tab == 'products' or active_tab == 'articles'
    assign active_tab = 'products'
  endunless
-%}

<section class="collection-section">
  <div class="collection-page" data-collection-page data-active-tab="{{ active_tab }}">

    {%- comment -%} ── Sticky desktop toolbar ── {%- endcomment -%}
    <div class="collection-toolbar" role="navigation" aria-label="Collection navigation">

      {%- if section.settings.show_filters -%}
        <button
          class="collection-toolbar__filter-toggle"
          type="button"
          aria-expanded="true"
          aria-controls="collection-filter"
          aria-label="Toggle filters"
          data-filter-toggle
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 4h12M4 8h8M6 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Filters
        </button>
      {%- endif -%}

      <div class="tab-switcher" role="tablist" aria-label="Collection view">
        <button
          class="tab-switcher__tab{% if active_tab == 'products' %} tab-switcher__tab--active{% endif %}"
          role="tab"
          type="button"
          aria-selected="{% if active_tab == 'products' %}true{% else %}false{% endif %}"
          aria-controls="panel-products"
          id="tab-products"
          data-tab="products"
          tabindex="{% if active_tab == 'products' %}0{% else %}-1{% endif %}"
        >{{ section.settings.tab_products_label | default: 'Products' }}</button>

        <button
          class="tab-switcher__tab{% if active_tab == 'articles' %} tab-switcher__tab--active{% endif %}"
          role="tab"
          type="button"
          aria-selected="{% if active_tab == 'articles' %}true{% else %}false{% endif %}"
          aria-controls="panel-articles"
          id="tab-articles"
          data-tab="articles"
          tabindex="{% if active_tab == 'articles' %}0{% else %}-1{% endif %}"
        >{{ section.settings.tab_articles_label | default: 'Articles' }}</button>
      </div>

    </div>

    {%- comment -%} ── Fixed mobile bottom bar ── {%- endcomment -%}
    {%- if section.settings.show_filters or section.settings.show_sort -%}
      <div class="collection-mobile-bar" aria-label="Collection controls" role="toolbar">

        {%- if section.settings.show_filters -%}
          <button
            class="collection-mobile-bar__btn"
            type="button"
            aria-expanded="false"
            aria-controls="collection-filter"
            aria-label="Toggle filters"
            data-filter-toggle
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 4h12M4 8h8M6 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Filters
          </button>
        {%- endif -%}

        {%- if section.settings.show_sort -%}
          <button
            class="collection-mobile-bar__btn"
            type="button"
            aria-expanded="false"
            aria-label="Sort products"
            data-mobile-sort-toggle
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 4h8M2 8h6M2 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M12 3v10M9.5 10.5L12 13l2.5-2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Sort
          </button>
        {%- endif -%}

      </div>
    {%- endif -%}

    <div class="collection-body">

      {%- render 'collection-filter' -%}

      <div class="collection-body__feed">
        {%- render 'collection-feed', active_tab: active_tab -%}
      </div>

    </div>

  </div>
</section>

{%- comment -%} Shared backdrop for filter drawer + sort sheet {%- endcomment -%}
<div class="collection-mobile-backdrop" aria-hidden="true"></div>

<script src="{{ 'collection-filter.js' | asset_url }}" defer></script>
<script src="{{ 'collection-feed.js' | asset_url }}" defer></script>
<script src="{{ 'collection.js' | asset_url }}" defer></script>
<script src="{{ 'promo-carousel.js' | asset_url }}" defer></script>

{% schema %}
{
