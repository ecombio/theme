{{ 'collection.css' | asset_url | stylesheet_tag }}
{{ 'collection.js' | asset_url | script_tag }}

{%- liquid
  assign show_title   = section.settings.show_title
  assign per_page     = section.settings.products_per_page | default: 20
  assign show_filters = section.settings.show_filters | default: true
-%}

<div class="collection-products-section">

  {%- if show_title -%}
    <h1 class="collection-products__title">{{ collection.title }}</h1>
  {%- endif -%}

  <div class="collection-sticky-bar">
    {% render 'collection-toolbar', show_filters: show_filters %}
    <div class="collection-active-filters" id="active-filters-bar" aria-label="Active filters"></div>
    {% render 'collection-compare-bar' %}
  </div>

  <div id="filters-backdrop" class="filters-backdrop"></div>

  <div class="collection-layout" id="collection-layout">
    {%- if show_filters -%}
      {% render 'collection-filters' %}
    {%- endif -%}

    <div class="collection-main">
      {% paginate collection.products by per_page %}
        {% render 'collection-grid', products: collection.products %}

        {%- if paginate.pages > 1 -%}
          <div class="collection-pagination">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}
      {% endpaginate %}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show sidebar filters",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 20,
      "label": "Products per page"
    }
  ]
}
{% endschema %}