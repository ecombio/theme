{% comment %}
  sections/collection.liquid
  Root section for templates/collection.json.

  Hierarchy:
    [1.1] snippets/collection-filter.liquid  — sort + filter UI
    [1.2] snippets/collection-feed.liquid    — promo blocks + tabs + grids

  This section owns:
    - Layout mode (sidebar | full)
    - Breadcrumb
    - Collection header (title + description) or banner image
    - Paginate wrapper (opened here so paginate object flows into feed)
    - Section schema + blocks (forwarded to feed → promo)

  It does NOT own:
    - Filter form markup           → collection-filter.liquid → filters.liquid
    - Tab chrome                   → collection-feed.liquid
    - In-feed promo placement      → collection-promo.liquid
    - Block rendering              → promo-block.liquid + block snippets
    - Product / post / page grids  → collection-products/posts/pages.liquid

  Metafields:
    collection.metafields.custom.description  — rich-text description override
    collection.metafields.custom.banner_image — banner image override

  Blocks (defined in schema, forwarded to collection-products → sponsored-ads):
    "banner-image"        — static image, configurable row + width
    "product-carousel"    — horizontally scrolling product cards, configurable row
    "collection-carousel" — image slides, configurable row + shape
    "sponsored-products"  — in-feed sponsored ad: single card or carousel
                             of 1-8 manually picked products, configurable row
    "sponsored-brands"    — in-feed sponsored ad: banner + product carousel,
                             products from either manual picks or a source
                             collection, configurable row

  CSS: collection.css (loaded in theme.liquid <head>)
  JS:  product-card.js (global, theme.liquid)
       collection-feed.js (loaded by collection-feed.liquid)
       filters.js (loaded by filters.liquid)
{% endcomment %}

{%- liquid
  assign products_per_page = section.settings.products_per_page | default: 12
  assign show_banner       = section.settings.show_banner
  assign show_description  = section.settings.show_description
  assign show_breadcrumb   = section.settings.show_breadcrumb
  assign layout            = section.settings.layout | default: 'sidebar'

  assign banner_image = collection.metafields.custom.banner_image.value
  if banner_image == blank
    assign banner_image = collection.image
  endif
-%}

<div class="collection-section collection-section--{{ layout }}">

  {%- comment -%} ── Breadcrumb ──────────────────────────────────────────── {%- endcomment -%}

  {%- if show_breadcrumb -%}
    <nav class="collection-section__breadcrumb" aria-label="Breadcrumb">
      <ol class="collection-section__breadcrumb-list">
        <li class="collection-section__breadcrumb-item">
          <a href="/" class="collection-section__breadcrumb-link">Home</a>
        </li>
        <li class="collection-section__breadcrumb-item" aria-hidden="true">
          <span class="collection-section__breadcrumb-sep">/</span>
        </li>
        <li class="collection-section__breadcrumb-item">
          <a href="/collections" class="collection-section__breadcrumb-link">Collections</a>
        </li>
        <li class="collection-section__breadcrumb-item" aria-hidden="true">
          <span class="collection-section__breadcrumb-sep">/</span>
        </li>
        <li
          class="collection-section__breadcrumb-item collection-section__breadcrumb-item--current"
          aria-current="page"
        >
          {{ collection.title }}
        </li>
      </ol>
    </nav>
  {%- endif -%}

  {%- comment -%} ── Banner header ────────────────────────────────────────── {%- endcomment -%}

  {%- if show_banner and banner_image -%}
    <div class="collection-section__banner">
      <img
        class="collection-section__banner-image"
        src="{{ banner_image | image_url: width: 1400 }}"
        alt="{{ banner_image.alt | escape | default: collection.title | escape }}"
        width="1400"
        height="{{ 1400 | divided_by: banner_image.aspect_ratio | round }}"
        loading="eager"
        fetchpriority="high"
      >
      <div class="collection-section__banner-overlay">
        <h1 class="collection-section__banner-title">{{ collection.title }}</h1>
      </div>
    </div>

  {%- else -%}

    <header class="collection-section__header">
      <h1 class="collection-section__title">{{ collection.title }}</h1>
      {%- if show_description -%}
        {%- liquid
          assign description_content = collection.metafields.custom.description.value
          if description_content == blank
            assign description_content = collection.description
          endif
        -%}
        {%- if description_content != blank -%}
          <div class="collection-section__description">{{ description_content }}</div>
        {%- endif -%}
      {%- endif -%}
    </header>

  {%- endif -%}

  {%- comment -%} ── Body ────────────────────────────────────────────────── {%- endcomment -%}

  <div class="collection-section__body">

    {%- comment -%}
      Sidebar layout: filter renders in its own <aside> column.
      Full layout:    filter renders inside collection-feed as a toolbar
                      strip above the grid. Either way only one render
                      of collection-filter fires per page load.
    {%- endcomment -%}

    {%- if layout == 'sidebar' -%}
      <aside class="collection-section__sidebar" aria-label="Collection filters">
        {%- render 'collection-filter',
          collection: collection,
          context:    'sidebar'
        -%}
      </aside>
    {%- endif -%}

    <div class="collection-section__main">

      {%- if layout == 'full' -%}
        {%- render 'collection-filter',
          collection: collection,
          context:    'toolbar'
        -%}
      {%- endif -%}

      {%- comment -%}
        Paginate is opened here so the paginate object is available
        to every descendant (collection-feed → collection-products).
      {%- endcomment -%}
      {%- paginate collection.products by products_per_page -%}
        {%- render 'collection-feed',
          collection: collection,
          blocks:     section.blocks,
          paginate:   paginate,
          columns:    section.settings.columns_desktop
        -%}
      {%- endpaginate -%}

    </div>

  </div>

</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-collection",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
