{%- comment -%}
  sections/collection.liquid

  Structure:
    sections/collection.liquid
      ├─ collection__header
      ├─ sub-collection__grid [Style 1 only — above toolbar]
      └─ collection__body
           ├─ collection__sidebar
           └─ collection__main
                └─ collection-products
                     ├─ [Style 2] sub-collection <li> items (first, in-feed)
                     └─ product-feed <li> items

  SUB-COLLECTION DISPLAY STYLES
  ──────────────────────────────
  Style 1 — "Above grid"  (sub_display_style = 'above')
    A standalone <ul class="sub-collection__grid"> is rendered between
    the collection header and the toolbar. Uses its own CSS grid whose
    column count is controlled by sub_columns_desktop / sub_columns_mobile.

  Style 2 — "In-feed"  (sub_display_style = 'in-feed')
    Sub-collection cards are rendered as <li> items directly inside
    .collection-products, before the product-feed output. They inherit
    the product grid's column count (--collection-products-columns-*)
    so they align perfectly with the product cards beneath them. No
    separate grid wrapper or column settings are needed for this style.

  PROMO BANNER BLOCKS
  ───────────────────
  Merchants can add one or more "Promo Banner" blocks in the theme editor.
  Each block is rendered as a full-width break inside the product grid,
  after every N products (controlled by banner_after_product on each block).
  The block shares all settings with the standalone promo-banner section
  and delegates markup to snippets/promo-banner.liquid.

  DATA SOURCE
  ───────────
  collection.metafields.custom.sub_collections.value
  Namespace: custom  |  Key: sub_collections
  Type: List · Collection reference
  Merchants set this in the Shopify admin. When blank the grid/feed
  items are silently skipped — no empty state rendered here.

  FALLBACK (no featured_image)
  ────────────────────────────
  Coloured tile with the collection's first letter. Colour is keyed
  deterministically on handle.size mod 8. Pure CSS, no JS.

  ASSET OWNERSHIP
  ───────────────
  collection.css       — layout, sidebar, toolbar, pagination
  sub-collection.css   — card styles (both styles share the same classes)
  product-card.css     — product card
  promo-banner.css     — banner styles (loaded when banner blocks exist)
  product-carousel.css/js — loaded only when carousel blocks exist
{%- endcomment -%}

{{ 'collection.css'   | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign carousel_blocks = section.blocks | where: 'type', 'carousel'
  assign banner_blocks   = section.blocks | where: 'type', 'promo_banner'
  assign show_sub         = section.settings.show_sub_collections
  assign sub_style        = section.settings.sub_display_style
  assign sub_collections  = collection.metafields.custom.sub_collections.value
  assign sub_show_count   = section.settings.sub_show_product_count
  assign sub_cols_desktop = section.settings.sub_columns_desktop
  assign sub_cols_mobile  = section.settings.sub_columns_mobile
-%}

{%- if carousel_blocks.size > 0 -%}
  {{ 'product-carousel.css' | asset_url | stylesheet_tag }}
{%- endif -%}
{%- if banner_blocks.size > 0 -%}
  {{ 'promo-banner.css' | asset_url | stylesheet_tag }}
{%- endif -%}
{%- if show_sub and sub_collections.size > 0 -%}
  {{ 'sub-collection.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- comment -%} Shared fallback palette — computed once, reused in both styles {%- endcomment -%}
{%- assign _palette = '1,e0f2fe,0369a1|2,fef9c3,854d0e|3,dcfce7,166534|4,fce7f3,9d174d|5,ede9fe,5b21b6|6,ffedd5,9a3412|7,e0e7ff,3730a3|8,f0fdf4,15803d' | split: '|' -%}

<div class="collection page-width" data-section-id="{{ section.id }}" data-section-type="collection">

  <div class="collection__header">
    <h1 class="collection__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection__description">{{ collection.description }}</div>
    {%- endif -%}
  </div>

  {%- comment -%}── STYLE 1: sub-collection grid above toolbar ──────────────{%- endcomment -%}
  {%- if show_sub and sub_style == 'above' and sub_collections.size > 0 -%}
    <ul
      class="sub-collection__grid"
      style="
        --sub-collection-columns-desktop: {{ sub_cols_desktop }};
        --sub-collection-columns-mobile:  {{ sub_cols_mobile }};
      "
      role="list"
    >
      {%- for sub in sub_collections -%}
        <li class="sub-collection__item">
          <a class="sub-collection__card" href="{{ sub.url }}">
            <div class="sub-collection__img-zone">
              {%- if sub.featured_image != blank -%}
                {%- assign _sizes = '(max-width: 767px) calc(50vw - 1.5rem), calc((100vw - 4rem) / ' | append: sub_cols_desktop | append: ')' -%}
                {{
                  sub.featured_image
                  | image_url: width: 800
                  | image_tag:
                    class: 'sub-collection__img',
                    loading: 'lazy',
                    widths: '200,300,400,600,800',
                    sizes: _sizes,
                    alt: sub.title
                }}
              {%- else -%}
                {%- assign _idx  = sub.handle.size | modulo: 8 -%}
                {%- assign _pair = _palette[_idx] | split: ',' -%}
                <div
                  class="sub-collection__img-placeholder sub-collection__img-letter"
                  aria-hidden="true"
                  style="background:#{{ _pair[1] }}; color:#{{ _pair[2] }};"
                >{{ sub.title | slice: 0 | upcase }}</div>
              {%- endif -%}
            </div>
            <div class="sub-collection__card-body">
              <span class="sub-collection__card-title">{{ sub.title }}</span>
              {%- if sub_show_count -%}
                <span class="sub-collection__card-count">{{ sub.products_count }} products</span>
              {%- endif -%}
            </div>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

  {%- comment -%}
    Toolbar: spans full width above sidebar/main split.
  {%- endcomment -%}
  <div class="collection__toolbar">
    {%- if collection.filters.size > 0 -%}
      <button
        type="button"
        class="product-filter__toggle-btn"
        aria-expanded="true"
        aria-controls="CollectionSidebar"
        data-filter-toggle
      >
        <svg class="product-filter__toggle-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M2 4h12M4 8h8M6 12h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        Filter
      </button>
    {%- endif -%}

    {%- if collection.sort_options.size > 0 -%}
      <form class="product-filter__sort-form" action="{{ collection.url }}" method="get">
        <label for="CollectionSortBy" class="product-filter__sort-label">Sort by</label>
        <select
          name="sort_by"
          id="CollectionSortBy"
          class="product-filter__sort-select"
          onchange="this.form.submit()"
        >
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>
              {{ option.name }}
            </option>
          {%- endfor -%}
        </select>
        {%- for filter in collection.filters -%}
          {%- for value in filter.values -%}
            {%- if value.active -%}
              <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </form>
    {%- endif -%}
  </div>

  {%- paginate collection.products by section.settings.products_per_page -%}

    <div class="collection__body" id="CollectionBody">

      {%- if collection.filters.size > 0 -%}
        <aside
          class="collection__sidebar"
          id="CollectionSidebar"
          aria-label="Product filters"
        >
          <form
            id="ProductFilterFacetsForm"
            class="product-filter__form"
            action="{{ collection.url }}"
            method="get"
          >
            {%- for filter in collection.filters -%}
              <fieldset class="product-filter__group">
                <legend class="product-filter__group-label">{{ filter.label }}</legend>
                {%- for value in filter.values -%}
                  <label class="product-filter__option">
                    <input
                      type="checkbox"
                      name="{{ value.param_name }}"
                      value="{{ value.value }}"
                      {% if value.active %}checked{% endif %}
                      {% if value.count == 0 and value.active == false %}disabled{% endif %}
                    >
                    <span>{{ value.label }} ({{ value.count }})</span>
                  </label>
                {%- endfor -%}
              </fieldset>
            {%- endfor -%}
            {%- if collection.sort_by != blank -%}
              <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
            {%- endif -%}
            <div class="product-filter__actions">
              <button type="submit" class="product-filter__apply">Apply</button>
              <a href="{{ collection.url }}" class="product-filter__clear">Clear all</a>
            </div>
          </form>
        </aside>
      {%- endif -%}

      <div class="collection__main">

        {%- comment -%}── STYLE 2: dedicated sub-collection row above the product grid ──
          Sits inside collection__main (respects sidebar layout) but
          outside collection-products so product cards start on a fresh row.
          Mirrors the product grid column count for perfect visual alignment.
        {%- endcomment -%}
        {%- if show_sub and sub_style == 'in-feed' and sub_collections.size > 0 -%}
          <ul
            class="sub-collection__grid sub-collection__grid--dedicated"
            style="
              --sub-collection-columns-desktop: {{ section.settings.columns_desktop }};
              --sub-collection-columns-mobile:  {{ section.settings.columns_mobile }};
            "
            role="list"
          >
            {%- for sub in sub_collections -%}
              <li class="sub-collection__item">
                <a class="sub-collection__card" href="{{ sub.url }}">
                  <div class="sub-collection__img-zone">
                    {%- if sub.featured_image != blank -%}
                      {%- assign _prod_cols = section.settings.columns_desktop | append: '' -%}
                      {%- assign _sizes = '(max-width: 767px) calc(50vw - 1.5rem), calc((100vw - 16rem) / ' | append: _prod_cols | append: ')' -%}
                      {{
                        sub.featured_image
                        | image_url: width: 800
                        | image_tag:
                          class: 'sub-collection__img',
                          loading: 'lazy',
                          widths: '200,300,400,600,800',
                          sizes: _sizes,
                          alt: sub.title
                      }}
                    {%- else -%}
                      {%- assign _idx  = sub.handle.size | modulo: 8 -%}
                      {%- assign _pair = _palette[_idx] | split: ',' -%}
                      <div
                        class="sub-collection__img-placeholder sub-collection__img-letter"
                        aria-hidden="true"
                        style="background:#{{ _pair[1] }}; color:#{{ _pair[2] }};"
                      >{{ sub.title | slice: 0 | upcase }}</div>
                    {%- endif -%}
                  </div>
                  <div class="sub-collection__card-body">
                    <span class="sub-collection__card-title">{{ sub.title }}</span>
                    {%- if sub_show_count -%}
                      <span class="sub-collection__card-count">{{ sub.products_count }} products</span>
                    {%- endif -%}
                  </div>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <div
          class="collection-products"
          style="--collection-products-columns-desktop: {{ section.settings.columns_desktop }}; --collection-products-columns-mobile: {{ section.settings.columns_mobile }};"
        >
          {%- comment -%}── Promo banners: render before the product feed if position = 'top' ──
            Col-span class keys:
              banner_width = '1'    → 1 column  (default, product-card sized)
              banner_width = '2'    → 2 columns  (landscape, half-row)
              banner_width = '3'    → 3 columns
              banner_width = 'full' → all columns (full-width break)
          {%- endcomment -%}
          {%- for block in banner_blocks -%}
            {%- if block.settings.banner_position_in_feed == 'top' -%}
              <div
                class="collection-products__banner-slot collection-products__banner-slot--span-{{ block.settings.banner_width }}"
                {{ block.shopify_attributes }}
              >
                {%- render 'promo-banner',
                  banner_settings:   block.settings,
                  banner_section_id: block.id,
                  banner_mode:       'in-feed'
                -%}
              </div>
            {%- endif -%}
          {%- endfor -%}

          {%- render 'product-feed',
            products: collection.products,
            show_quickview: section.settings.show_quickview,
            show_compare: section.settings.show_compare,
            show_eta: section.settings.show_eta,
            carousel_blocks: carousel_blocks,
            banner_blocks: banner_blocks,
            carousel_interval: section.settings.carousel_interval,
            fallback_collection: collection
          -%}

          {%- comment -%}── Promo banners: render after the product feed if position = 'bottom' ──{%- endcomment -%}
          {%- for block in banner_blocks -%}
            {%- if block.settings.banner_position_in_feed == 'bottom' -%}
              <div
                class="collection-products__banner-slot collection-products__banner-slot--span-{{ block.settings.banner_width }}"
                {{ block.shopify_attributes }}
              >
                {%- render 'promo-banner',
                  banner_settings:   block.settings,
                  banner_section_id: block.id,
                  banner_mode:       'in-feed'
                -%}
              </div>
            {%- endif -%}
          {%- endfor -%}

        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="collection__pagination" role="navigation" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="collection__pagination-link" rel="prev">&larr; Previous</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a
                  href="{{ part.url }}"
                  class="collection__pagination-link"
                  {% if part.title == paginate.current_page %}aria-current="page"{% endif %}
                >{{ part.title }}</a>
              {%- else -%}
                <span class="collection__pagination-ellipsis">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="collection__pagination-link" rel="next">Next &rarr;</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      </div><!-- /.collection__main -->

    </div><!-- /.collection__body -->

  {%- endpaginate -%}

</div><!-- /.collection -->

{%- if carousel_blocks.size > 0 -%}
  <script src="{{ 'product-carousel.js' | asset_url }}" defer></script>
{%- endif -%}

{%- if collection.filters.size > 0 -%}
  <script>
    (function () {
      var btn     = document.querySelector('[data-filter-toggle]');
      var body    = document.getElementById('CollectionBody');
      var sidebar = document.getElementById('CollectionSidebar');
      if (!btn || !body || !sidebar) return;
      btn.addEventListener('click', function () {
        var isOpen = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!isOpen));
        body.classList.toggle('collection__body--sidebar-closed', isOpen);
        sidebar.setAttribute('aria-hidden', String(isOpen));
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "header",
      "content": "Sub-collections"
    },
    {
      "type": "checkbox",
      "id": "show_sub_collections",
      "label": "Show sub-collections",
      "default": true,
      "info": "Sub-collections are set via the 'custom.sub_collections' metafield on each collection. Toggle off to hide without clearing metafield data."
    },
    {
      "type": "select",
      "id": "sub_display_style",
      "label": "Display style",
      "options": [
        { "value": "above", "label": "Style 1 — Above the product grid" },
        { "value": "in-feed", "label": "Style 2 — Dedicated row above product grid" }
      ],
      "default": "above",
      "info": "Style 1 shows sub-collections as a separate row above the filter toolbar. Style 2 injects them as the first cards inside the product grid, sharing the same column layout."
    },
    {
      "type": "range",
      "id": "sub_columns_desktop",
      "label": "Sub-collection columns — desktop (Style 1 only)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "sub_columns_mobile",
      "label": "Sub-collection columns — mobile (Style 1 only)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "sub_show_product_count",
      "label": "Show product count on sub-collection cards",
      "default": true
    },
    {
      "type": "header",
      "content": "Product grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_quickview",
      "label": "Show quick view button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_compare",
      "label": "Show compare checkbox",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_eta",
      "label": "Show delivery ETA",
      "default": true
    },
    {
      "type": "header",
      "content": "Promo carousels"
    },
    {
      "type": "range",
      "id": "carousel_interval",
      "label": "Insert a carousel every N products",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 8,
      "info": "Set to 0 to disable in-feed carousels even if blocks are added below."
    }
  ],
  "blocks": [
    {
      "type": "carousel",
      "name": "Promo Carousel",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Leave blank to use the current collection."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading (optional)"
        },
        {
          "type": "range",
          "id": "products_per_carousel",
          "label": "Products in this carousel",
          "min": 4,
          "max": 24,
          "step": 2,
          "default": 12
        },
        {
          "type": "range",
          "id": "cards_per_row_desktop",
          "label": "Cards visible — desktop",
          "min": 2,
          "max": 5,
          "step": 1,
          "default": 3
        },
        {
          "type": "select",
          "id": "cards_per_row_mobile",
          "label": "Cards visible — mobile",
          "options": [
            { "value": "1", "label": "1" },
            { "value": "2", "label": "2" }
          ],
          "default": "2"
        },
        {
          "type": "header",
          "content": "Banner"
        },
        {
          "type": "checkbox",
          "id": "show_banner",
          "label": "Show side banner",
          "default": false,
          "info": "Displays a promotional image beside the carousel. Stacks above the carousel on mobile."
        },
        {
          "type": "image_picker",
          "id": "banner_image",
          "label": "Banner image"
        },
        {
          "type": "url",
          "id": "banner_link",
          "label": "Banner link"
        }
      ]
    },
    {
      "type": "promo_banner",
      "name": "Promo Banner",
      "settings": [
        {
          "type": "select",
          "id": "banner_position_in_feed",
          "label": "Position in collection",
          "options": [
            { "value": "top",    "label": "Top — before all products" },
            { "value": "bottom", "label": "Bottom — after all products" }
          ],
          "default": "top",
          "info": "Controls where the banner appears relative to the product grid on this page."
        },
        {
          "type": "header",
          "content": "Size"
        },
        {
          "type": "select",
          "id": "banner_width",
          "label": "Width",
          "options": [
            { "value": "1",    "label": "1 card — product card size (default)" },
            { "value": "2",    "label": "2 cards — half row, landscape" },
            { "value": "3",    "label": "3 cards — three-quarter row" },
            { "value": "full", "label": "Full row — edge-to-edge banner" }
          ],
          "default": "1",
          "info": "At 1 card the banner slots seamlessly into the product grid. Wider options create a landscape banner break."
        },
        {
          "type": "text",
          "id": "custom_ratio",
          "label": "Custom aspect ratio",
          "placeholder": "e.g. 16:9",
          "info": "Leave blank: 1-card uses square (1:1), wider widths use 16:7. Override with any ratio e.g. 4:3, 16:9."
        },
        {
          "type": "header",
          "content": "Background"
        },
        {
          "type": "image_picker",
          "id": "bg_image",
          "label": "Background image"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay colour",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 90,
          "step": 5,
          "default": 45,
          "unit": "%"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Text alignment",
          "options": [
            { "value": "left",   "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "select",
          "id": "text_valign",
          "label": "Vertical position",
          "options": [
            { "value": "top",    "label": "Top" },
            { "value": "middle", "label": "Middle" },
            { "value": "bottom", "label": "Bottom" }
          ],
          "default": "bottom"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow label",
          "placeholder": "e.g. New arrivals"
        },
        {
          "type": "text",
          "id": "headline",
          "label": "Headline",
          "placeholder": "e.g. Ride further, faster."
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Headline tag",
          "options": [
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" }
          ],
          "default": "h2"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "placeholder": "e.g. Shop the full electric bike range."
        },
        {
          "type": "header",
          "content": "Call to action"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Primary button label",
          "placeholder": "Shop now"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Primary button URL"
        },
        {
          "type": "text",
          "id": "cta2_label",
          "label": "Secondary link label",
          "placeholder": "Learn more"
        },
        {
          "type": "url",
          "id": "cta2_url",
          "label": "Secondary link URL"
        },
        {
          "type": "checkbox",
          "id": "cta_new_tab",
          "label": "Open links in new tab",
          "default": false
        },
        {
          "type": "header",
          "content": "Spacing"
        },
        {
          "type": "range",
