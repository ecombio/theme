{% comment %}
  Collection Products Section
  Uses external collection.css and collection.js
{% endcomment %}

{{ 'collection.css' | asset_url | stylesheet_tag }}
{{ 'collection.js' | asset_url | script_tag }}

{%- liquid
  assign show_title = section.settings.show_title
  assign per_page = section.settings.products_per_page | default: 20
-%}

<div class="collection-products-section">
  {%- if show_title -%}
    <h1 class="collection-products__title">{{ collection.title }}</h1>
  {%- endif -%}

  <div class="collection-products">
    {% paginate collection.products by per_page %}
      {% for product in collection.products %}
        <div class="collection-product">
          {%- if product.featured_image -%}
            <a href="{{ product.url }}" class="collection-product__image-link">
              {{
                product.featured_image
                | image_url: width: 700
                | image_tag:
                  class: 'collection-product__image',
                  alt: product.title | escape,
                  loading: 'lazy',
                  width: 700,
                  height: 700
              }}
            </a>
          {%- endif -%}

          <div class="collection-product__content">
            <a href="{{ product.url }}" class="collection-product__title">
              {{ product.title | escape }}
            </a>

            <div class="collection-product__price">
              {{ product.price | money }}
            </div>
          </div>
        </div>
      {% endfor %}

      {{ paginate | default_pagination }}
    {% endpaginate %}
  </div>
</div>

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 20,
      "label": "Products per page"
    }
  ],
  "presets": [
    {
      "name": "Collection Products"
    }
  ]
}
{% endschema %}