{% comment %}
  Utility Bar
  File: sections/utility-bar.liquid

  A slim 32px bar rendered above the main header via the theme layout.
    Left  — configurable utility links (set in Customizer)
    Right — region picker dropdown + currency + language selectors

  Assets:
    assets/utility-bar.css  — all styles
    assets/utility-bar.js   — behaviour (teleport, focus trap, search, fallbacks)

  Add to layout/theme.liquid above {%- section 'header' -%}:
    {%- section 'utility-bar' -%}
{% endcomment %}

{{ 'utility-bar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign bar_style  = section.settings.bar_style | default: 'hyper'
  assign show_curr  = section.settings.show_currency
  assign show_loc   = section.settings.show_locale
-%}

<div class="utility-bar utility-bar--{{ bar_style }}"
     role="navigation"
     aria-label="Utility bar"
     id="utility-bar">

  <div class="utility-bar__inner">

    {%- comment -%} ── LEFT: utility links ── {%- endcomment -%}
    <div class="utility-bar__col utility-bar__col--left">
      <ul class="utility-bar__links" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'link' -%}
            <li {{ block.shopify_attributes }}>
              <a href="{{ block.settings.url }}" class="utility-bar__link">
                {{- block.settings.label | escape -}}
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    {%- comment -%} ── RIGHT: currency + locale + region picker ── {%- endcomment -%}
    <div class="utility-bar__col utility-bar__col--right">
      <div class="utility-bar__switchers">

        {%- if show_curr and shop.enabled_currencies.size > 1 -%}
          <div class="utility-bar__switcher">
            {%- form 'currency', id: 'utility-bar-currency-form', return_to: request.path -%}
              <label for="utility-bar-currency-select" class="visually-hidden">Currency</label>
              <div class="utility-bar__select-wrap">
                <select id="utility-bar-currency-select"
                        name="currency"
                        class="utility-bar__select"
                        aria-label="Select currency">
                  {%- for currency in shop.enabled_currencies -%}
                    <option value="{{ currency.iso_code }}"
                      {%- if currency == cart.currency %} selected{% endif -%}>
                      {{ currency.iso_code }} &ndash; {{ currency.symbol }}
                    </option>
                  {%- endfor -%}
                </select>
                <svg class="utility-bar__chevron" width="9" height="9" viewBox="0 0 20 20"
                     fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 8l5 5 5-5"/>
                </svg>
              </div>
            {%- endform -%}
          </div>
        {%- endif -%}

        {%- if show_loc and localization.available_languages.size > 1 -%}
          <div class="utility-bar__switcher">
            {%- form 'localization', id: 'utility-bar-locale-form', return_to: request.path -%}
              <label for="utility-bar-locale-select" class="visually-hidden">Language</label>
              <div class="utility-bar__select-wrap">
                <select id="utility-bar-locale-select"
                        name="locale_code"
                        class="utility-bar__select"
                        aria-label="Select language">
                  {%- for language in localization.available_languages -%}
                    <option value="{{ language.iso_code }}"
                      {%- if language.iso_code == localization.language.iso_code %} selected{% endif -%}>
                      {{ language.endonym_name | capitalize }}
                    </option>
                  {%- endfor -%}
                </select>
                <svg class="utility-bar__chevron" width="9" height="9" viewBox="0 0 20 20"
                     fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 8l5 5 5-5"/>
                </svg>
              </div>
            {%- endform -%}
          </div>
        {%- endif -%}

        {%- comment -%} ── Region picker trigger ── {%- endcomment -%}
        <button type="button"
                class="utility-bar__region-btn"
                aria-label="Choose location: {{ localization.country.name }}"
                aria-expanded="false"
                aria-controls="utility-bar-region-dropdown"
                id="utility-bar-region-trigger">
          <img src="https://cdn.shopify.com/shopifycloud/preview-bar/assets/{{ localization.country.iso_code | downcase }}.svg"
               alt="{{ localization.country.name }} flag"
               width="16" height="11"
               class="utility-bar__flag"
               loading="eager">
          <span class="utility-bar__region-label">
            {{ localization.language.endonym_name | capitalize }} ({{ localization.country.iso_code }})
          </span>
          <svg class="utility-bar__chevron region-trigger__chevron"
               width="9" height="9" viewBox="0 0 20 20"
               fill="none" stroke="currentColor" stroke-width="2.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 8l5 5 5-5"/>
          </svg>
        </button>

      </div>
    </div>
  </div>
</div>

{%- comment -%}
  Dropdown is placed here in the DOM but immediately teleported to <body> by JS.
  This escapes every stacking context / overflow:hidden in the header.
{%- endcomment -%}
<div class="region-dropdown"
     id="utility-bar-region-dropdown"
     role="dialog"
     aria-modal="true"
     aria-label="Choose location"
     hidden>

  <div class="region-dropdown__header">
    <p class="region-dropdown__title">Choose location</p>
    <button type="button"
            class="region-dropdown__close"
            aria-label="Close location picker"
            id="utility-bar-region-close">
      <svg width="14" height="14" viewBox="0 0 20 20" fill="none"
           stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 4l12 12M16 4L4 16"/>
      </svg>
    </button>
  </div>

  <p class="region-dropdown__subtitle">
    Changing your location might affect your delivery address options, price, product availability, and currency.
  </p>

  <div class="region-dropdown__search-wrap">
    <input type="text"
           class="region-dropdown__search"
           placeholder="Search your country"
           aria-label="Search countries"
           id="utility-bar-region-search"
           autocomplete="off">
    <svg class="region-dropdown__search-icon" width="14" height="14"
         viewBox="0 0 20 20" fill="none" stroke="currentColor"
         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="9" cy="9" r="6"/><path d="M15 15l3 3"/>
    </svg>
  </div>

  <div class="region-dropdown__section-label">Current country &amp; language</div>

  <div class="region-dropdown__current">
    <img src="https://cdn.shopify.com/shopifycloud/preview-bar/assets/{{ localization.country.iso_code | downcase }}.svg"
         alt="{{ localization.country.name }}"
         width="20" height="14"
         class="region-dropdown__flag">
    <span class="region-dropdown__current-country">{{ localization.country.name }}</span>

    {%- if localization.available_languages.size > 1 -%}
      {%- form 'localization', id: 'utility-bar-region-locale-form', return_to: request.path -%}
        <div class="region-dropdown__lang-wrap">
          <select name="locale_code"
                  class="region-dropdown__lang-select"
                  aria-label="Select language for {{ localization.country.name }}"
                  onchange="this.form.submit()">
            {%- for language in localization.available_languages -%}
              <option value="{{ language.iso_code }}"
                {%- if language.iso_code == localization.language.iso_code %} selected{% endif -%}>
                {{ language.endonym_name | capitalize }} ({{ localization.country.iso_code }})
              </option>
            {%- endfor -%}
          </select>
          <svg width="10" height="10" viewBox="0 0 20 20" fill="none"
               stroke="currentColor" stroke-width="2.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 8l5 5 5-5"/>
          </svg>
        </div>
      {%- endform -%}
    {%- else -%}
      <span class="region-dropdown__lang-static">
        {{ localization.language.endonym_name | capitalize }} ({{ localization.country.iso_code }})
      </span>
    {%- endif -%}
  </div>

  <div class="region-dropdown__divider"></div>

  {%- form 'localization', id: 'utility-bar-region-country-form', return_to: request.path -%}
    <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
    <ul class="region-dropdown__list" id="utility-bar-region-list" role="list">
      {%- for country in localization.available_countries -%}
        {%- unless country.iso_code == localization.country.iso_code -%}
          <li class="region-dropdown__item" data-country="{{ country.name | downcase }}">
            <button type="submit"
                    name="country_code"
                    value="{{ country.iso_code }}"
                    class="region-dropdown__country-btn"
                    form="utility-bar-region-country-form">
              <img src="https://cdn.shopify.com/shopifycloud/preview-bar/assets/{{ country.iso_code | downcase }}.svg"
                   alt="{{ country.name }}"
                   width="20" height="14"
                   class="region-dropdown__flag"
                   loading="lazy">
              <span class="region-dropdown__country-name">{{ country.name }}</span>
              <span class="region-dropdown__country-lang">
                {{ localization.language.endonym_name | capitalize }} ({{ country.iso_code }})
              </span>
            </button>
          </li>
        {%- endunless -%}
      {%- endfor -%}
    </ul>
    <p class="region-dropdown__empty" id="utility-bar-region-empty" aria-live="polite">
      No countries found.
    </p>
  {%- endform -%}

</div>

<script src="{{ 'utility-bar.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Utility Bar",
  "tag": "div",
  "class": "utility-bar-section",
  "limit": 1,
  "settings": [
    {
      "type": "select",
      "id": "bar_style",
      "label": "Bar style",
      "default": "hyper",
      "options": [
        { "value": "hyper", "label": "Hyper (white)" },
        { "value": "focus", "label": "Focus (warm grey)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "label": "Show currency selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_locale",
      "label": "Show language selector",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Utility link",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Track Order"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Utility Bar",
      "blocks": [
        { "type": "link", "settings": { "label": "Track Order", "url": "/apps/track" } },
        { "type": "link", "settings": { "label": "Store Locator", "url": "/pages/stores" } }
      ]
    }
  ]
}
{% endschema %}
