{{ 'faq.css' | asset_url | stylesheet_tag }}

<div class="faq-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="faq-section__inner page-width faq-layout--{{ section.settings.layout }}">

    <div class="faq-section__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="faq-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="faq-section__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.layout == 'split' and section.settings.contact_heading != blank or section.settings.contact_text != blank or section.settings.contact_button_label != blank -%}
        <div class="faq-section__contact">
          {%- if section.settings.contact_heading != blank -%}
            <h3 class="faq-section__contact-heading">{{ section.settings.contact_heading }}</h3>
          {%- endif -%}
          {%- if section.settings.contact_text != blank -%}
            <p class="faq-section__contact-text">{{ section.settings.contact_text }}</p>
          {%- endif -%}
          {%- if section.settings.contact_button_label != blank -%}
            <a href="{{ section.settings.contact_button_link | default: '#' }}" class="faq-section__contact-button">
              {{ section.settings.contact_button_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="faq-section__items" data-faq-items data-allow-multiple="{{ section.settings.allow_multiple_open }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign question = block.settings.question | default: 'Question goes here'
          assign answer = block.settings.answer | default: 'Answer goes here. Add your content in the section blocks.'
        -%}

        {%- if section.settings.layout == 'grid' -%}
          <div class="faq-card" {{ block.shopify_attributes }}>
            <h3 class="faq-card__question">{{ question }}</h3>
            <div class="faq-card__answer rte">{{ answer }}</div>
          </div>
        {%- else -%}
          <div class="faq-item" data-faq-item {{ block.shopify_attributes }}>
            <button type="button" class="faq-item__trigger" data-faq-trigger aria-expanded="{{ block.settings.open_by_default }}">
              <span class="faq-item__question">{{ question }}</span>
              <span class="faq-item__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </span>
            </button>
            <div class="faq-item__panel" data-faq-panel {% unless block.settings.open_by_default %}hidden{% endunless %}>
              <div class="faq-item__answer rte">{{ answer }}</div>
            </div>
          </div>
        {%- endif -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          {%- if section.settings.layout == 'grid' -%}
            <div class="faq-card">
              <h3 class="faq-card__question">Question goes here</h3>
              <div class="faq-card__answer rte">
                <p>Answer goes here. Add FAQ blocks in the section settings to customize this content.</p>
              </div>
            </div>
          {%- else -%}
            <div class="faq-item" data-faq-item>
              <button type="button" class="faq-item__trigger" data-faq-trigger aria-expanded="false">
                <span class="faq-item__question">Question goes here</span>
                <span class="faq-item__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </span>
              </button>
              <div class="faq-item__panel" data-faq-panel hidden>
                <div class="faq-item__answer rte">
                  <p>Answer goes here. Add FAQ blocks in the section settings to customize this content.</p>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>
</div>

<script src="{{ 'faq.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout style",
      "options": [
        { "value": "accordion", "label": "Accordion (centered)" },
        { "value": "two-column", "label": "Accordion (two columns on desktop)" },
        { "value": "split", "label": "Accordion with side panel" },
        { "value": "grid", "label": "Grid cards (always open)" },
        { "value": "minimal", "label": "Minimal list with dividers" }
      ],
      "default": "accordion"
    },
    {
      "type": "checkbox",
      "id": "allow_multiple_open",
      "label": "Allow multiple items open at once",
      "default": false
    },
    {
      "type": "header",
      "content": "Side panel (used with \"Accordion with side panel\")"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Heading",
      "default": "Still have questions?"
    },
    {
      "type": "textarea",
      "id": "contact_text",
      "label": "Text",
      "default": "Our team is happy to help with anything not covered here."
    },
    {
      "type": "text",
      "id": "contact_button_label",
      "label": "Button label",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "contact_button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Share details about your shipping policy here.</p>"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open by default",
          "default": false,
          "info": "Ignored for the grid layout, which is always expanded"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question" },
        { "type": "question" },
        { "type": "question" },
        { "type": "question" }
      ]
    }
  ]
}
{% endschema %}
