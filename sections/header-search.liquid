{% comment %}
  Search Form — Predictive Search
  File: snippets/header-search.liquid

  Rendered twice by sections/main-header.liquid:
    {%- render 'header-search', id_suffix: 'desktop' -%}
    {%- render 'header-search', id_suffix: 'mobile'  -%}

  Assets (loaded once via sections/main-header.liquid, NOT here):
    assets/header-search.css
    assets/header-search.js

  All behaviour and colour settings are driven by
  Online Store → Themes → Customize → Search settings.
{% endcomment %}

{%- assign sfx = id_suffix | default: 'desktop' -%}

{%- comment -%} ── Build trending searches array from settings ── {%- endcomment -%}
{%- assign trending_raw = '' -%}
{%- for i in (1..5) -%}
  {%- assign setting_key = 'search_trending_' | append: i -%}
  {%- assign term = settings[setting_key] -%}
  {%- if term != blank -%}
    {%- assign trending_raw = trending_raw | append: term | append: '|' -%}
  {%- endif -%}
{%- endfor -%}
{%- assign trending_array = trending_raw | split: '|' -%}

{%- comment -%}
  Inject JS config as a window object — single source of truth for header-search.js.
  Only rendered once per page (guarded by sfx == 'desktop').
{%- endcomment -%}
{%- if sfx == 'desktop' -%}
<script>
  window.HEADER_SEARCH_SETTINGS = {
    MIN_QUERY_LENGTH:      {{ settings.search_min_chars        | default: 2 }},
    DEBOUNCE_MS:           {{ settings.search_debounce_ms      | default: 200 }},
    MAX_QUERIES:           {{ settings.search_max_queries      | default: 3 }},
    MAX_PRODUCTS:          {{ settings.search_max_products     | default: 5 }},
    MAX_COLLECTIONS:       {{ settings.search_max_collections  | default: 2 }},
    RECENT_SEARCHES_LIMIT: {{ settings.search_recent_limit     | default: 5 }},
    TRENDING_SEARCHES: [
      {%- for term in trending_array -%}
        {%- unless term == blank -%}
          {{ term | json }}{% unless forloop.last %},{% endunless %}
        {%- endunless -%}
      {%- endfor -%}
    ]
  };
</script>
{%- endif -%}

<div class="header-search"
     id="header-search-{{ sfx }}"
     data-search-instance="{{ sfx }}"
     style="
       --sf-accent:          {{ settings.search_accent_color | default: '#1a1a1a' }};
       --sf-highlight-bg:    {{ settings.search_highlight_bg | default: '#FFF3CD' }};
       --sf-bg-hover:        {{ settings.search_hover_bg     | default: '#F5F5F5' }};
       --sf-border-focus:    {{ settings.search_border_focus | default: '#1a1a1a' }};
     ">

  <form action="{{ routes.search_url }}" method="get" role="search"
        class="header-search__form" autocomplete="off"
        id="header-search-form-{{ sfx }}">

    <input type="hidden" name="type" value="product">

    {%- comment -%} ── CATEGORY PILL ── {%- endcomment -%}
    {%- if settings.search_show_category != false -%}
      <div class="header-search__category" id="header-search-cat-{{ sfx }}">
        <button type="button"
                class="header-search__cat-btn"
                id="header-search-cat-btn-{{ sfx }}"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-controls="header-search-cat-list-{{ sfx }}">
          <span id="header-search-cat-label-{{ sfx }}">All</span>
          <svg class="header-search__chevron" width="12" height="12" viewBox="0 0 20 20"
               fill="none" stroke="currentColor" stroke-width="2.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 8l5 5 5-5"/>
          </svg>
        </button>

        <ul class="header-search__cat-list"
            id="header-search-cat-list-{{ sfx }}"
            role="listbox"
            aria-labelledby="header-search-cat-btn-{{ sfx }}"
            hidden>
          <li role="option" aria-selected="true" data-value="" data-label="All">
            All Categories
          </li>
          {%- for i in (1..5) -%}
            {%- assign label_key = 'search_category_' | append: i | append: '_label' -%}
            {%- assign value_key = 'search_category_' | append: i | append: '_value' -%}
            {%- assign cat_label = settings[label_key] -%}
            {%- assign cat_value = settings[value_key] -%}
            {%- if cat_label != blank and cat_value != blank -%}
              <li role="option" aria-selected="false"
                  data-value="{{ cat_value | escape }}"
                  data-label="{{ cat_label | escape }}">
                {{ cat_label | escape }}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

        <input type="hidden"
               name="q[category]"
               id="header-search-cat-value-{{ sfx }}"
               value="">
        <span class="header-search__divider" aria-hidden="true"></span>
      </div>
    {%- endif -%}

    {%- comment -%} ── SEARCH INPUT ── {%- endcomment -%}
    <input type="search"
           name="q"
           id="header-search-input-{{ sfx }}"
           class="header-search__input"
           placeholder="{{ settings.search_placeholder | default: 'What are you looking for?' | escape }}"
           aria-label="Search products"
           aria-autocomplete="list"
           aria-controls="header-search-dropdown-{{ sfx }}"
           aria-expanded="false"
           role="combobox"
           autocorrect="off"
           autocomplete="off"
           spellcheck="false">

    {%- comment -%} ── CLEAR BUTTON ── {%- endcomment -%}
    <button type="button"
            class="header-search__clear"
            id="header-search-clear-{{ sfx }}"
            aria-label="Clear search"
            hidden>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    {%- comment -%} ── MIC BUTTON (injected by JS if Speech API is available) ── {%- endcomment -%}

    {%- comment -%} ── SUBMIT ── {%- endcomment -%}
    <button type="submit" class="header-search__submit" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
           aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </button>

  </form>

  {%- comment -%} ── DROPDOWN (populated by JS) ── {%- endcomment -%}
  <div class="header-search__dropdown"
       id="header-search-dropdown-{{ sfx }}"
       role="listbox"
       aria-label="Search suggestions"
       aria-live="polite"
       hidden>
  </div>

  {%- comment -%} ── MOBILE BACKDROP ── {%- endcomment -%}
  <div class="header-search__backdrop"
       id="header-search-backdrop-{{ sfx }}"
       aria-hidden="true"
       hidden>
  </div>

</div>
