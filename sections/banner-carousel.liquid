{{ 'banner-carousel.css' | asset_url | stylesheet_tag }}

<div class="banner-carousel-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background-color: {{ section.settings.bg_color }};">
  <div class="banner-carousel-section__inner{% if section.settings.full_width %} banner-carousel-section__inner--full{% else %} page-width{% endif %}">

    <div class="banner-carousel" data-banner-carousel data-autoplay="{{ section.settings.autoplay }}" data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}" style="--slides-mobile: {{ section.settings.columns_mobile }}; --slides-tablet: {{ section.settings.columns_tablet }}; --slides-desktop: {{ section.settings.columns_desktop }}; --slide-gap: {{ section.settings.slide_gap }}px; --slide-radius: {{ section.settings.slide_radius }}px;">
      <div class="banner-carousel__track" data-banner-carousel-track>
        {%- for block in section.blocks -%}
          {%- liquid
            assign image = block.settings.image
            assign mobile_image = block.settings.mobile_image
            assign link = block.settings.link
            assign heading = block.settings.heading
            assign subheading = block.settings.subheading
            assign button_label = block.settings.button_label
          -%}

          <div class="banner-carousel__slide" data-banner-carousel-slide {{ block.shopify_attributes }}>
            <a href="{{ link | default: '#' }}" class="banner-carousel__link" {% if link == blank %}tabindex="-1" aria-disabled="true"{% endif %}>
              <span class="banner-carousel__image-wrap">
                {%- if image != blank -%}
                  <img
                    class="banner-carousel__image banner-carousel__image--desktop"
                    src="{{ image | image_url: width: 1500 }}"
                    srcset="{{ image | image_url: width: 750 }} 750w, {{ image | image_url: width: 1100 }} 1100w, {{ image | image_url: width: 1500 }} 1500w, {{ image | image_url: width: 2000 }} 2000w"
                    sizes="100vw"
                    alt="{{ image.alt | default: heading | escape }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    width="{{ image.width }}"
                    height="{{ image.height }}"
                  >
                {%- else -%}
                  <span class="banner-carousel__placeholder banner-carousel__placeholder--desktop">
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'banner-carousel__placeholder-svg' }}
                  </span>
                {%- endif -%}

                {%- if mobile_image != blank -%}
                  <img
                    class="banner-carousel__image banner-carousel__image--mobile"
                    src="{{ mobile_image | image_url: width: 750 }}"
                    srcset="{{ mobile_image | image_url: width: 450 }} 450w, {{ mobile_image | image_url: width: 750 }} 750w, {{ mobile_image | image_url: width: 1000 }} 1000w"
                    sizes="100vw"
                    alt="{{ mobile_image.alt | default: heading | escape }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    width="{{ mobile_image.width }}"
                    height="{{ mobile_image.height }}"
                  >
                {%- elsif image == blank -%}
                  <span class="banner-carousel__placeholder banner-carousel__placeholder--mobile">
                    {{ 'lifestyle-2' | placeholder_svg_tag: 'banner-carousel__placeholder-svg' }}
                  </span>
                {%- endif -%}
              </span>

              {%- if heading != blank or subheading != blank or button_label != blank -%}
                <span class="banner-carousel__content banner-carousel__content--{{ block.settings.content_position }} banner-carousel__content--align-{{ block.settings.text_align }}">
                  {%- if heading != blank -%}
                    <span class="banner-carousel__heading">{{ heading }}</span>
                  {%- endif -%}
                  {%- if subheading != blank -%}
                    <span class="banner-carousel__subheading">{{ subheading }}</span>
                  {%- endif -%}
                  {%- if button_label != blank -%}
                    <span class="banner-carousel__button">{{ button_label }}</span>
                  {%- endif -%}
                </span>
              {%- endif -%}
            </a>
          </div>
        {%- else -%}
          <div class="banner-carousel__slide" data-banner-carousel-slide>
            <a href="#" class="banner-carousel__link" tabindex="-1" aria-disabled="true">
              <span class="banner-carousel__image-wrap">
                <span class="banner-carousel__placeholder banner-carousel__placeholder--desktop">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'banner-carousel__placeholder-svg' }}
                </span>
                <span class="banner-carousel__placeholder banner-carousel__placeholder--mobile">
                  {{ 'lifestyle-2' | placeholder_svg_tag: 'banner-carousel__placeholder-svg' }}
                </span>
              </span>
              <span class="banner-carousel__content banner-carousel__content--center banner-carousel__content--align-center">
                <span class="banner-carousel__heading">Add a banner</span>
                <span class="banner-carousel__subheading">Add slides in the section settings</span>
              </span>
            </a>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 1 -%}
        <button type="button" class="banner-carousel__btn banner-carousel__btn--prev" data-banner-carousel-prev aria-label="Previous slide">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button type="button" class="banner-carousel__btn banner-carousel__btn--next" data-banner-carousel-next aria-label="Next slide">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>

        <div class="banner-carousel__dots" data-banner-carousel-dots>
          {%- for block in section.blocks -%}
            <button type="button" class="banner-carousel__dot" data-banner-carousel-dot aria-label="Go to slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

<script src="{{ 'banner-carousel.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Banner carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Make section full width",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 0.5,
      "label": "Slides per view (desktop)",
      "default": 1
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "min": 1,
      "max": 4,
      "step": 0.5,
      "label": "Slides per view (tablet)",
      "default": 1
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 0.5,
      "label": "Slides per view (mobile)",
      "default": 1
    },
    {
      "type": "range",
      "id": "slide_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap between slides",
      "default": 0
    },
    {
      "type": "range",
      "id": "slide_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Slide corner radius",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "A placeholder image is shown if blank"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image",
          "info": "Optional. Used on small screens instead of the image above"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Link to a product, collection, blog, page, or any URL"
        },
        {
          "type": "header",
          "content": "Text"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content position",
          "options": [
            { "value": "top-left", "label": "Top left" },
            { "value": "top-center", "label": "Top center" },
            { "value": "top-right", "label": "Top right" },
            { "value": "center", "label": "Center" },
            { "value": "bottom-left", "label": "Bottom left" },
            { "value": "bottom-center", "label": "Bottom center" },
            { "value": "bottom-right", "label": "Bottom right" }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Text alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner carousel",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
