{%- comment -%}
  sections/product-quickview.liquid
  Rendered exclusively via the Shopify Sections Rendering API:
    fetch(`/products/${handle}?sections=product-quickview`)
  Returns JSON; product-quickview.js extracts data['product-quickview'].

  This section is NEVER rendered on a standalone page — it exists only
  to produce the quickview modal's inner HTML on demand.

  Structure:
    .qv
    ├── .qv__media          (product-media division)
    │   ├── .qv__media-main   (featured image)
    │   └── .qv__media-thumbs (thumbnail strip)
    └── .qv__detail         (product-detail division)
        ├── meta            (vendor, title, reviews, price)
        ├── .qv__options    (variant selectors — swatches + pills)
        ├── .qv__eta        (ETA metafield)
        ├── .qv__atc-wrap   (ATC button)
        └── .qv__pdp-link   (View full details →)

  JS hooks (all data-qv-* or data-atc-*):
    [data-qv-main-img]        — primary <img> swapped by thumb clicks
    [data-qv-thumb]           — thumbnail buttons
    [data-qv-swatch]          — color option button
    [data-qv-option-btn]      — non-color option button (size, material…)
    [data-qv-option-selected] — live label showing chosen value
    [data-qv-variant-select]  — hidden <select> kept in sync
    [data-qv-variant-data]    — <script type="application/json"> variant array
    [data-atc-btn]            — ATC button (re-uses product-card.js handler)
    [data-atc-label]          — ATC button label span
{%- endcomment -%}

{%- liquid
  assign qv_product      = product
  assign qv_images       = qv_product.images
  assign qv_featured     = qv_product.featured_image
  assign qv_variants     = qv_product.variants
  assign qv_options      = qv_product.options_with_values
  assign first_variant   = qv_product.first_available_variant | default: qv_variants.first
  assign eta_text        = qv_product.metafields.custom.eta_text
  assign has_single_var  = false
  if qv_product.has_only_default_variant
    assign has_single_var = true
  endif

  assign on_sale     = false
  assign save_amount = 0
  assign save_pct    = 0
  if first_variant.compare_at_price > first_variant.price
    assign on_sale     = true
    assign save_amount = first_variant.compare_at_price | minus: first_variant.price
    assign save_pct    = save_amount | times: 100 | divided_by: first_variant.compare_at_price
  endif
-%}

<div
  class="qv"
  data-product-id="{{ qv_product.id }}"
  data-product-handle="{{ qv_product.handle }}"
>

  {%- comment -%}──────────────────────────────────────────────
    PRODUCT-MEDIA
    Left column on desktop, top section on mobile.
    Main image + thumbnail strip (hidden when ≤ 1 image).
  ──────────────────────────────────────────────────────────{%- endcomment -%}
  <div class="qv__media">

    {%- comment -%} Main image {%- endcomment -%}
    <div class="qv__media-main">
      {%- if qv_featured != blank -%}
        <img
          id="qv-main-img-{{ qv_product.id }}"
          data-qv-main-img
          src="{{ qv_featured | image_url: width: 800 }}"
          alt="{{ qv_featured.alt | default: qv_product.title | escape }}"
          width="800"
          height="800"
          loading="eager"
          class="qv__main-img"
        >
      {%- else -%}
        <div class="qv__main-img qv__main-img--placeholder" aria-hidden="true">
          {{ 'product-1' | placeholder_svg_tag: 'qv__placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Thumbnail strip — only when multiple images exist {%- endcomment -%}
    {%- if qv_images.size > 1 -%}
      <div class="qv__media-thumbs" role="list" aria-label="Product images">
        {%- for img in qv_images limit: 8 -%}
          <button
            type="button"
            class="qv__thumb{% if forloop.first %} is-active{% endif %}"
            role="listitem"
            data-qv-thumb
            data-src="{{ img | image_url: width: 800 }}"
            data-alt="{{ img.alt | default: qv_product.title | escape }}"
            aria-label="View image {{ forloop.index }} of {{ qv_images.size | at_most: 8 }}"
            aria-pressed="{{ forloop.first }}"
          >
            <img
              src="{{ img | image_url: width: 120 }}"
              alt=""
              width="60"
              height="60"
              loading="lazy"
            >
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>{%- comment -%} /.qv__media {%- endcomment -%}

  {%- comment -%}──────────────────────────────────────────────
    PRODUCT-DETAIL
    Right column on desktop, bottom section on mobile.
  ──────────────────────────────────────────────────────────{%- endcomment -%}
  <div class="qv__detail">

    {%- comment -%} Vendor {%- endcomment -%}
    {%- if qv_product.vendor != blank -%}
      <p class="qv__vendor">{{ qv_product.vendor }}</p>
    {%- endif -%}

    {%- comment -%} Title {%- endcomment -%}
    <h2 class="qv__title">
      <a href="{{ qv_product.url }}" class="qv__title-link">
        {{- qv_product.title -}}
      </a>
    </h2>

    {%- comment -%} Judge.me reviews widget {%- endcomment -%}
    <div class="qv__reviews">
      <div
        class="jdgm-widget jdgm-preview-badge"
        data-id="{{ qv_product.id }}"
        data-auto-install="false"
      ></div>
    </div>

    {%- comment -%} Price {%- endcomment -%}
    <div class="qv__price" data-qv-price>
      {%- if on_sale -%}
        <span class="qv__price-current qv__price-current--sale">
          {{- first_variant.price | money -}}
        </span>
        <s class="qv__price-compare">
          {{- first_variant.compare_at_price | money -}}
        </s>
        <span class="qv__price-save-badge">
          Save {{ save_pct }}%
        </span>
      {%- else -%}
        <span class="qv__price-current">
          {{- first_variant.price | money -}}
        </span>
      {%- endif -%}
    </div>

    {%- comment -%}──────────────────────────────────────────
      VARIANT OPTIONS
      Renders each product option as:
        • Color  → swatch buttons  [data-qv-swatch]
        • Others → pill buttons    [data-qv-option-btn]
      Option index (0-based) stored on each button so JS can build
      the currentOptions array correctly when matching variants.
    ──────────────────────────────────────────────────────{%- endcomment -%}
    {%- unless has_single_var -%}
      <div class="qv__options">
        {%- for option in qv_options -%}
          {%- liquid
            assign opt_index      = forloop.index0
            assign opt_name_lower = option.name | downcase
            assign is_color       = false
            if opt_name_lower == 'color' or opt_name_lower == 'colour'
              assign is_color = true
            endif
            assign first_value = option.values | first
          -%}

          <div class="qv__option" data-option-name="{{ option.name | escape }}">

            <div class="qv__option-label">
              <span class="qv__option-name">{{ option.name }}:</span>
              <span class="qv__option-selected" data-qv-option-selected>
                {{- first_value -}}
              </span>
            </div>

            <div
              class="qv__option-values{% if is_color %} qv__option-values--swatches{% endif %}"
              role="radiogroup"
              aria-label="{{ option.name }}"
            >
              {%- for value in option.values -%}
                {%- liquid
                  assign is_first = false
                  if forloop.first
                    assign is_first = true
                  endif
                  assign value_handle = value | handleize
                -%}

                {%- if is_color -%}
                  {%- comment -%}
                    Color swatch — background set via inline style.
                    Expects assets/color-swatches.json OR falls back to
                    CSS-driven color via data-color-value attribute.
                    Override swatch images by uploading
                    `swatch-{handle}.png` to Files and referencing them
                    via a metaobject if needed.
                  {%- endcomment -%}
                  <button
                    type="button"
                    class="qv__swatch{% if is_first %} is-active{% endif %}"
                    data-qv-swatch
                    data-option-index="{{ opt_index }}"
                    data-value="{{ value | escape }}"
                    data-color-value="{{ value_handle }}"
                    aria-label="{{ value | escape }}"
                    aria-checked="{{ is_first }}"
                    style="--swatch-color: {{ value_handle }};"
                  >
                    <span class="qv__swatch-inner" aria-hidden="true"></span>
                  </button>

                {%- else -%}
                  {%- comment -%} Non-color option — pill button {%- endcomment -%}
                  <button
                    type="button"
                    class="qv__option-btn{% if is_first %} is-active{% endif %}"
                    data-qv-option-btn
                    data-option-index="{{ opt_index }}"
                    data-value="{{ value | escape }}"
                    aria-label="{{ option.name }}: {{ value | escape }}"
                    aria-checked="{{ is_first }}"
                  >
                    {{- value -}}
                  </button>
                {%- endif -%}

              {%- endfor -%}
            </div>

          </div>
        {%- endfor -%}
      </div>
    {%- endunless -%}

    {%- comment -%} Hidden variant select — kept in sync by JS {%- endcomment -%}
    <select
      class="qv__variant-select"
      data-qv-variant-select
      aria-label="Selected variant"
      aria-hidden="true"
      tabindex="-1"
    >
      {%- for variant in qv_variants -%}
        <option
          value="{{ variant.id }}"
          {% if variant.id == first_variant.id %}selected{% endif %}
          {% unless variant.available %}disabled{% endunless %}
        >
          {{ variant.title }}
        </option>
      {%- endfor -%}
    </select>

    {%- comment -%}
      Variant data JSON island — parsed by product-quickview.js.
      Scoped to this product ID so multiple QVs on a page don't collide.
    {%- endcomment -%}
    <script
      type="application/json"
      id="qv-variant-data-{{ qv_product.id }}"
      data-qv-variant-data
    >
      [
        {%- for variant in qv_variants -%}
          {
            "id":               {{ variant.id }},
            "title":            {{ variant.title | json }},
            "available":        {{ variant.available }},
            "price":            {{ variant.price }},
            "compare_at_price": {{ variant.compare_at_price | default: 'null' }},
            "options":          {{ variant.options | json }},
            "featured_image":   {%- if variant.featured_image -%}
              {
                "src": {{ variant.featured_image | image_url: width: 800 | json }},
                "alt": {{ variant.featured_image.alt | default: variant.title | json }}
              }
            {%- else -%}null{%- endif -%}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    </script>

    {%- comment -%} ETA metafield {%- endcomment -%}
    {%- if eta_text != blank -%}
      <div class="qv__eta" aria-label="Estimated delivery">
        <svg class="qv__eta-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="4" width="9" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
          <path d="M10 6.5h1.5l1.5 2V11h-3V6.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
          <circle cx="3.5" cy="11.5" r="1" fill="currentColor"/>
          <circle cx="10.5" cy="11.5" r="1" fill="currentColor"/>
        </svg>
        <span>{{ eta_text }}</span>
      </div>
    {%- endif -%}

    {%- comment -%} Add to cart {%- endcomment -%}
    <div class="qv__atc-wrap">
      <button
        type="button"
        class="qv__atc{% unless first_variant.available %} qv__atc--soldout{% endunless %}"
        data-atc-btn
        data-variant-id="{{ first_variant.id }}"
        data-product-title="{{ qv_product.title | escape }}"
        {% unless first_variant.available %}disabled{% endunless %}
        aria-label="Add {{ qv_product.title | escape }} to cart"
      >
        <span data-atc-label>
          {%- if first_variant.available -%}
            Add to cart
          {%- else -%}
            Sold out
          {%- endif -%}
        </span>
      </button>
    </div>

    {%- comment -%} Full PDP link {%- endcomment -%}
    <a
      href="{{ qv_product.url }}"
      class="qv__pdp-link"
      aria-label="View full details for {{ qv_product.title | escape }}"
    >
      View full details
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M2 6h8M6 2l4 4-4 4"/>
      </svg>
    </a>

  </div>{%- comment -%} /.qv__detail {%- endcomment -%}

</div>{%- comment -%} /.qv {%- endcomment -%}

{% schema %}
{
  "name": "Product Quick View",
  "settings": []
}
{% endschema %}