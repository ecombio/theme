{%- comment -%}
  sections/product-quickview.liquid
  Rendered via: /products/{handle}?view=quickview&sections=product-quickview
  Consumed by: card-product-features.js → initQuickView()
{%- endcomment -%}

{{ 'quickview-modal.css'    | asset_url | stylesheet_tag }}
{{ 'product-quickview.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current = product.selected_or_first_available_variant
  assign images  = product.images
-%}

<div class="qv" data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}">

  {%- comment -%} ── LEFT: Gallery ── {%- endcomment -%}
  <div class="qv__gallery">

    <div class="qv__main-img-wrap">
      {%- if product.featured_image -%}
        <img
          id="qv-main-img"
          class="qv__main-img"
          src="{{ product.featured_image | image_url: width: 720 }}"
          alt="{{ product.featured_image.alt | escape | default: product.title }}"
          width="720"
          height="{{ 720 | divided_by: product.featured_image.aspect_ratio | round }}"
          loading="eager"
        >
      {%- else -%}
        <div class="qv__img-placeholder">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <rect x="8" y="8" width="48" height="48" rx="6" stroke="#ccc" stroke-width="2"/>
            <circle cx="24" cy="26" r="6" stroke="#ccc" stroke-width="2"/>
            <path d="M8 48l14-12 10 10 8-8 16 14" stroke="#ccc" stroke-width="2" stroke-linejoin="round"/>
          </svg>
        </div>
      {%- endif -%}

      {%- for tag in product.tags -%}
        {%- if tag contains 'badge:' -%}
          <span class="qv__badge">{{ tag | remove: 'badge:' }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if images.size > 1 -%}
      <div class="qv__thumbs" role="list" aria-label="Product images">
        {%- for img in images limit: 6 -%}
          <button
            class="qv__thumb{% if forloop.first %} is-active{% endif %}"
            type="button"
            role="listitem"
            aria-label="View image {{ forloop.index }}"
            data-qv-thumb
            data-src="{{ img | image_url: width: 720 }}"
            data-alt="{{ img.alt | escape | default: product.title }}"
          >
            <img
              src="{{ img | image_url: width: 120 }}"
              alt="{{ img.alt | escape | default: product.title }}"
              width="120"
              height="{{ 120 | divided_by: img.aspect_ratio | round }}"
              loading="lazy"
            >
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} ── RIGHT: Info ── {%- endcomment -%}
  <div class="qv__info">

    {%- if product.vendor != blank -%}
      <p class="qv__vendor">{{ product.vendor }}</p>
    {%- endif -%}

    <h2 class="qv__title">{{ product.title }}</h2>

    {%- comment -%} Reviews badge placeholder (integrates with Judge.me / Yotpo if present) {%- endcomment -%}
    <div class="qv__reviews-placeholder" aria-hidden="true">
      {%- for i in (1..5) -%}
        <svg class="qv__star qv__star--empty" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M7 1l1.5 3.5L12 5l-2.5 2.5.6 3.5L7 9.5 3.9 11l.6-3.5L2 5l3.5-.5L7 1z" stroke="#C8991A" stroke-width="1.2" fill="none"/>
        </svg>
      {%- endfor -%}
      <span class="qv__reviews-label">No reviews yet</span>
    </div>

    {%- comment -%} Price {%- endcomment -%}
    <div class="qv__price" id="qv-price-{{ product.id }}">
      {%- if current.compare_at_price > current.price -%}
        <s class="qv__price-compare">{{ current.compare_at_price | money }}</s>
        <span class="qv__price-sale-badge">
          Save {{ current.compare_at_price | minus: current.price | money }}
        </span>
      {%- endif -%}
      <span class="qv__price-current">{{ current.price | money }}</span>
    </div>

    {%- comment -%} Estimated arrival — mirrors product-card.liquid ETA metafield {%- endcomment -%}
    {%- assign qv_eta_text = product.metafields.custom.eta_text -%}
    {%- if qv_eta_text != blank -%}
      <div class="qv__eta" aria-label="Estimated delivery">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="4" width="9" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
          <path d="M10 6.5h1.5l1.5 2V11h-3V6.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
          <circle cx="3.5" cy="11.5" r="1" fill="currentColor"/>
          <circle cx="10.5" cy="11.5" r="1" fill="currentColor"/>
        </svg>
        <span>{{ qv_eta_text }}</span>
      </div>
    {%- endif -%}

    {%- comment -%} Description {%- endcomment -%}
    {%- unless product.description == blank -%}
      <div class="qv__desc">
        {{ product.description | strip_html | truncatewords: 32 }}
      </div>
    {%- endunless -%}

    {%- comment -%} Variant selector {%- endcomment -%}
    {%- if product.has_only_default_variant == false -%}
      <div class="qv__variants">
        {%- for option in product.options_with_values -%}
          <div class="qv__option">
            <label class="qv__option-label" for="qv-opt-{{ product.id }}-{{ forloop.index }}">
              {{ option.name }}:
              <span class="qv__option-selected" data-qv-option-selected="{{ option.name }}">
                {{ option.selected_value }}
              </span>
            </label>

            {%- comment -%}
              Render swatches for Color/Colour, buttons for everything else
            {%- endcomment -%}
            {%- assign opt_name_down = option.name | downcase -%}
            {%- if opt_name_down == 'color' or opt_name_down == 'colour' -%}
              <div class="qv__swatches" role="radiogroup" aria-label="{{ option.name }}">
                {%- for value in option.values -%}

                  {%- comment -%}
                    FIX: previously `value | handleize` produced slugs like
                    "glacier", which are NOT valid CSS colors — every swatch
                    silently fell back to the same gray (#ccc) regardless of
                    the actual color name. This map translates known color
                    option values to real hex codes. Add new product colors
                    here as they're introduced.
                  {%- endcomment -%}
                  {%- assign value_down = value | downcase -%}
                  {%- case value_down -%}
                    {%- when 'glacier' -%}
                      {%- assign swatch_color = '#a9c4cf' -%}
                    {%- when 'polar' -%}
                      {%- assign swatch_color = '#e8e9ea' -%}
                    {%- when 'himalayan' -%}
                      {%- assign swatch_color = '#3a3f47' -%}
                    {%- when 'clay' -%}
                      {%- assign swatch_color = '#9c8c7c' -%}
                    {%- when 'black' -%}
                      {%- assign swatch_color = '#1a1a1a' -%}
                    {%- when 'white' -%}
                      {%- assign swatch_color = '#ffffff' -%}
                    {%- when 'navy' -%}
                      {%- assign swatch_color = '#1f3354' -%}
                    {%- when 'red' -%}
                      {%- assign swatch_color = '#c0392b' -%}
                    {%- when 'green' -%}
                      {%- assign swatch_color = '#3a6b4f' -%}
                    {%- when 'gray', 'grey' -%}
                      {%- assign swatch_color = '#8c8c8c' -%}
                    {%- when 'silver' -%}
                      {%- assign swatch_color = '#c7c9cb' -%}
                    {%- when 'teal' -%}
                      {%- assign swatch_color = '#2fa8a0' -%}
                    {%- else -%}
                      {%- comment -%}
                        Unmapped color name. Fall back to a neutral mid-gray
                        (set via CSS default on .qv__swatch) rather than an
                        invalid CSS value — leave swatch_color blank so the
                        inline style is omitted entirely.
                      {%- endcomment -%}
                      {%- assign swatch_color = blank -%}
                  {%- endcase -%}

                  {%- comment -%}
                    Light swatches need a visible border so they don't
                    disappear against the white card background.
                  {%- endcomment -%}
                  {%- assign light_colors = 'polar,white,silver' | split: ',' -%}

                  {%- if value == option.selected_value -%}
                    {%- assign swatch_checked = 'true' -%}
                    {%- assign swatch_active = 'qv__swatch is-active' -%}
                  {%- else -%}
                    {%- assign swatch_checked = 'false' -%}
                    {%- assign swatch_active = 'qv__swatch' -%}
                  {%- endif -%}

                  {%- if light_colors contains value_down -%}
                    {%- assign swatch_active = swatch_active | append: ' qv__swatch--light' -%}
                  {%- endif -%}

                  <button
                    class="{{ swatch_active }}"
                    type="button"
                    role="radio"
                    aria-checked="{{ swatch_checked }}"
                    aria-label="{{ value }}"
                    data-qv-swatch
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value }}"
                    {%- if swatch_color != blank %}
                    style="--swatch-color: {{ swatch_color }};"
                    {%- endif %}
                    title="{{ value }}"
                  ></button>
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="qv__option-btns" role="radiogroup" aria-label="{{ option.name }}">
                {%- for value in option.values -%}
                  {%- if value == option.selected_value -%}
                    {%- assign opt_checked = 'true' -%}
                    {%- assign opt_active = 'qv__option-btn is-active' -%}
                  {%- else -%}
                    {%- assign opt_checked = 'false' -%}
                    {%- assign opt_active = 'qv__option-btn' -%}
                  {%- endif -%}
                  <button
                    class="{{ opt_active }}"
                    type="button"
                    role="radio"
                    aria-checked="{{ opt_checked }}"
                    data-qv-option-btn
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value }}"
                  >{{ value }}</button>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}

        {%- comment -%} Hidden variant select — JS reads & updates this {%- endcomment -%}
        <select class="qv__variant-select visually-hidden" id="qv-variant-{{ product.id }}" data-qv-variant-select aria-label="Selected variant">
          {%- for variant in product.variants -%}
            <option
              value="{{ variant.id }}"
              data-price="{{ variant.price }}"
              data-compare-at="{{ variant.compare_at_price }}"
              data-available="{{ variant.available }}"
              {% if variant == current %}selected{% endif %}
            >{{ variant.title }}</option>
          {%- endfor -%}
        </select>
      </div>
    {%- endif -%}

    {%- comment -%} Actions {%- endcomment -%}
    <div class="qv__actions">
      {%- if current.available -%}
        <button
          class="qv__atc"
          type="button"
          data-atc-btn
          data-variant-id="{{ current.id }}"
        >
          <span data-atc-label>Add to cart</span>
        </button>
      {%- else -%}
        <button class="qv__atc qv__atc--soldout" type="button" disabled>Sold out</button>
      {%- endif -%}

      <a class="qv__pdp-link" href="{{ product.url }}">View full details &rarr;</a>
    </div>

  </div>
</div>

<script>
(function () {
  var wrap = document.querySelector('.qv[data-product-id="{{ product.id }}"]');
  if (!wrap) return;

  /* ── Thumbnail switcher ── */
  var mainImg = wrap.querySelector('#qv-main-img');
  wrap.querySelectorAll('[data-qv-thumb]').forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      if (mainImg) {
        mainImg.src = thumb.getAttribute('data-src');
        mainImg.alt = thumb.getAttribute('data-alt');
      }
      wrap.querySelectorAll('[data-qv-thumb]').forEach(function (t) { t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
    });
  });

  /* ── Variant selection ── */
  var variantSelect = wrap.querySelector('[data-qv-variant-select]');
  var atcBtn        = wrap.querySelector('[data-atc-btn]');
  var priceEl       = wrap.querySelector('#qv-price-{{ product.id }}');

  var productVariants = {{ product.variants | json }};

  /* Current selected options array */
  var selectedOptions = [];
  {%- for option in product.options_with_values -%}
    selectedOptions.push({{ option.selected_value | json }});
  {%- endfor -%}

  function findVariant() {
    return productVariants.find(function (v) {
      return v.options.every(function (opt, i) { return opt === selectedOptions[i]; });
    });
  }

  function updateUI(variant) {
    if (!variant) return;

    /* Update hidden select */
    if (variantSelect) {
      variantSelect.value = variant.id;
    }

    /* Update ATC button */
    if (atcBtn) {
      atcBtn.setAttribute('data-variant-id', variant.id);
      var label = atcBtn.querySelector('[data-atc-label]');
      if (variant.available) {
        atcBtn.disabled = false;
        atcBtn.classList.remove('qv__atc--soldout');
        if (label) label.textContent = 'Add to cart';
      } else {
        atcBtn.disabled = true;
        atcBtn.classList.add('qv__atc--soldout');
        if (label) label.textContent = 'Sold out';
      }
    }

    /* Update price */
    if (priceEl) {
      var currentPrice   = variant.price;
      var comparePrice   = variant.compare_at_price;
      var moneyFormatter = function (cents) {
        return '$' + (cents / 100).toFixed(2).replace(/\.00$/, '');
      };
      var html = '';
      if (comparePrice && comparePrice > currentPrice) {
        html += '<s class="qv__price-compare">' + moneyFormatter(comparePrice) + '</s>';
        html += '<span class="qv__price-sale-badge">Save ' + moneyFormatter(comparePrice - currentPrice) + '</span>';
      }
      html += '<span class="qv__price-current">' + moneyFormatter(currentPrice) + '</span>';
      priceEl.innerHTML = html;
    }
  }

  /* Swatch / option button clicks */
  wrap.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-qv-swatch], [data-qv-option-btn]');
    if (!btn) return;

    var optionIndex = parseInt(btn.getAttribute('data-option-index'), 10);
    var value       = btn.getAttribute('data-value');

    /* Update selected options */
    selectedOptions[optionIndex] = value;

    /* Active state on siblings */
    var group = btn.closest('[role="radiogroup"]');
    if (group) {
      group.querySelectorAll('[data-qv-swatch], [data-qv-option-btn]').forEach(function (b) {
        b.classList.remove('is-active');
        b.setAttribute('aria-checked', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-checked', 'true');
    }

    /* Update selected label */
    var optionName    = btn.closest('.qv__option');
    var selectedLabel = optionName && optionName.querySelector('[data-qv-option-selected]');
    if (selectedLabel) selectedLabel.textContent = value;

    updateUI(findVariant());
  });

})();
</script>

{% schema %}
{
  "name": "Product Quick View",
  "settings": []
}
{% endschema %}