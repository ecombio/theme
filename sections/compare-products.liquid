{{- 'compare-products.css' | asset_url | stylesheet_tag -}}

{%- comment -%}
  Section: compare-products
  URL shape: /pages/compare?handles=handle-a,handle-b,handle-c
  Uses all_products[handle] — the only valid Liquid product lookup by handle.
  NOTE: for loops cannot live inside {%- liquid -%} blocks; they must be standalone.
{%- endcomment -%}

{%- liquid
  assign max_products      = section.settings.max_products      | default: 5
  assign show_vendor       = section.settings.show_vendor       | default: true
  assign show_description  = section.settings.show_description  | default: true
  assign show_sku          = section.settings.show_sku          | default: true
  assign show_availability = section.settings.show_availability | default: true
  assign show_price        = section.settings.show_price        | default: true
  assign show_type         = section.settings.show_type         | default: true
  assign show_weight       = section.settings.show_weight       | default: false

  assign raw_handles = request.query_string | split: 'handles=' | last | split: '&' | first
  assign handle_list = raw_handles | split: ','
  assign products    = '' | split: ''
-%}

{%- comment -%} Build products array — for loop MUST be outside liquid tag {%- endcomment -%}
{%- for handle_raw in handle_list limit: 5 -%}
  {%- assign h = handle_raw | strip -%}
  {%- assign looked_up = all_products[h] -%}
  {%- if looked_up.id -%}
    {%- assign products = products | concat: looked_up -%}
  {%- endif -%}
{%- endfor -%}

<section class="compare-section page-width">

  <header class="compare-header">
    <a href="javascript:history.back()" class="compare-header__back">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M10 13L5 8l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Back
    </a>
    <h1 class="compare-header__title">Compare products</h1>
    {%- if products.size > 0 -%}
      <p class="compare-header__count">{{ products.size }} of {{ max_products }}</p>
    {%- endif -%}
  </header>

  {%- if products.size == 0 -%}

    <div class="compare-empty">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <rect x="6" y="10" width="14" height="28" rx="3" stroke="currentColor" stroke-width="1.8"/>
        <rect x="28" y="10" width="14" height="28" rx="3" stroke="currentColor" stroke-width="1.8"/>
        <path d="M20 24h8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <p>No products to compare. Select some from the collection first.</p>
      <a href="/collections/all" class="btn btn--primary">Browse products</a>
    </div>

  {%- else -%}

    <div class="compare-table-wrap">
      <table class="compare-table">

        <thead>
          <tr class="compare-row compare-row--header">
            <th class="compare-cell compare-cell--label" aria-label="Feature"></th>
            {%- for p in products -%}
              <th class="compare-cell compare-cell--product" scope="col">
                <div class="compare-product-header">
                  <a href="{{ p.url }}" class="compare-product-header__img-link">
                    {%- if p.featured_image -%}
                      {{
                        p.featured_image
                        | image_url: width: 300
                        | image_tag:
                          class: 'compare-product-header__img',
                          loading: 'eager',
                          widths: '150, 200, 300',
                          alt: p.featured_image.alt | escape
                      }}
                    {%- else -%}
                      <div class="compare-product-header__img-placeholder"></div>
                    {%- endif -%}
                  </a>
                  <a href="{{ p.url }}" class="compare-product-header__title">{{ p.title }}</a>
                  {%- if show_vendor and p.vendor != blank -%}
                    <span class="compare-product-header__vendor">{{ p.vendor }}</span>
                  {%- endif -%}
                  <button
                    class="compare-product-header__remove"
                    type="button"
                    aria-label="Remove {{ p.title | escape }} from comparison"
                    data-compare-page-remove="{{ p.handle }}"
                  >
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <path d="M1 1l10 10M11 1L1 11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                    </svg>
                    Remove
                  </button>
                </div>
              </th>
            {%- endfor -%}
          </tr>
        </thead>

        <tbody>

          {%- if show_price -%}
            <tr class="compare-row">
              <th class="compare-cell compare-cell--label" scope="row">Price</th>
              {%- for p in products -%}
                <td class="compare-cell">
                  {%- if p.compare_at_price > p.price -%}
                    <span class="compare-price compare-price--sale">{{ p.price | money }}</span>
                    <s class="compare-price compare-price--was">{{ p.compare_at_price | money }}</s>
                  {%- else -%}
                    <span class="compare-price">{{ p.price | money }}</span>
                  {%- endif -%}
                </td>
              {%- endfor -%}
            </tr>
          {%- endif -%}

          {%- if show_availability -%}
            <tr class="compare-row">
              <th class="compare-cell compare-cell--label" scope="row">Availability</th>
              {%- for p in products -%}
                <td class="compare-cell">
                  {%- if p.available -%}
                    <span class="compare-badge compare-badge--in">In stock</span>
                  {%- else -%}
                    <span class="compare-badge compare-badge--out">Sold out</span>
                  {%- endif -%}
                </td>
              {%- endfor -%}
            </tr>
          {%- endif -%}

          {%- if show_vendor -%}
            <tr class="compare-row">
              <th class="compare-cell compare-cell--label" scope="row">Vendor</th>
              {%- for p in products -%}
                <td class="compare-cell">{{ p.vendor | default: '—' }}</td>
              {%- endfor -%}
            </tr>
          {%- endif -%}

          {%- if show_type -%}
            <tr class="compare-row">
              <th class="compare-cell compare-cell--label" scope="row">Type</th>
              {%- for p in products -%}
                <td class="compare-cell">{{ p.type | default: '—' }}</td>
              {%- endfor -%}
            </tr>
          {%- endif -%}

          {%- if show_sku -%}
            <tr class="compare-row">
              <th class="compare-cell compare-cell--label" scope="row">SKU</th>
              {%- for p in products -%}
                <td class="compare-cell">{{ p.variants.first.sku | default: '—' }}</td>
              {%- endfor -%}
            </tr>
          {%- endif -%}

          {%- if show_weight -%}
            <tr class="compare-row">
              <th class="compare-cell compare-cell--label" scope="row">Weight</th>
              {%- for p in products -%}
                <td class="compare-cell">
                  {%- assign w = p.variants.first.weight -%}
                  {%- if w > 0 -%}{{ w | weight_with_unit }}{%- else -%}—{%- endif -%}
                </td>
              {%- endfor -%}
            </tr>
          {%- endif -%}

          {%- if show_description -%}
            <tr class="compare-row">
              <th class="compare-cell compare-cell--label" scope="row">Description</th>
              {%- for p in products -%}
                <td class="compare-cell compare-cell--description">
                  {%- if p.description != blank -%}
                    <div class="compare-description rte">{{ p.description | truncatewords: 40 }}</div>
                  {%- else -%}—{%- endif -%}
                </td>
              {%- endfor -%}
            </tr>
          {%- endif -%}

          <tr class="compare-row compare-row--atc">
            <th class="compare-cell compare-cell--label" scope="row"></th>
            {%- for p in products -%}
              <td class="compare-cell compare-cell--atc">
                {%- if p.available -%}
                  <button
                    class="btn btn--primary compare-atc-btn"
                    type="button"
                    data-atc-btn
                    data-variant-id="{{ p.variants.first.id }}"
                    data-product-title="{{ p.title | escape }}"
                  >
                    <span class="card-product__atc-label">Add to cart</span>
                  </button>
                {%- else -%}
                  <button class="btn btn--secondary" disabled aria-disabled="true">Sold out</button>
                {%- endif -%}
              </td>
            {%- endfor -%}
          </tr>

        </tbody>
      </table>
    </div>

  {%- endif -%}

</section>

<script>
  document.querySelectorAll('[data-compare-page-remove]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var removeHandle = btn.getAttribute('data-compare-page-remove');
      var url     = new URL(window.location.href);
      var handles = (url.searchParams.get('handles') || '')
        .split(',')
        .filter(function (h) { return h && h.trim() !== removeHandle; });
      if (handles.length === 0) {
        url.searchParams.delete('handles');
      } else {
        url.searchParams.set('handles', handles.join(','));
      }
      window.location.href = url.toString();
    });
  });
</script>

{% schema %}
{
  "name": "Compare Products",
  "settings": [
    {
      "type": "range",
      "id": "max_products",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 5,
      "label": "Max products to compare"
    },
    { "type": "header", "content": "Rows to show" },
    { "type": "checkbox", "id": "show_price",        "label": "Price",        "default": true  },
    { "type": "checkbox", "id": "show_availability", "label": "Availability", "default": true  },
    { "type": "checkbox", "id": "show_vendor",       "label": "Vendor",       "default": true  },
    { "type": "checkbox", "id": "show_type",         "label": "Type",         "default": true  },
    { "type": "checkbox", "id": "show_sku",          "label": "SKU",          "default": true  },
    { "type": "checkbox", "id": "show_description",  "label": "Description",  "default": true  },
    { "type": "checkbox", "id": "show_weight",       "label": "Weight",       "default": false }
  ]
}
{% endschema %}
