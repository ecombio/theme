<nav class="header-menu" role="navigation">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'mega-menu' %}
        {% render block %}
      {% when 'single-link' %}
        {% render block %}
    {% endcase %}
  {% endfor %}
</nav>

{% schema %}
{
  "name": "header-menu",
  "tag": "section",
  "class": "header-menu",
  "settings": [],
  "blocks": [
    {
      "type": "mega-menu",
      "name": "Mega Menu",
      "limit": 6
    },
    {
      "type": "single-link",
      "name": "Single Link",
      "limit": 10
    }
  ],
  "presets": [
    {
      "name": "header-menu",
      "blocks": [
        {
          "type": "mega-menu"
        }
      ]
    }
  ]
}
{% endschema %}