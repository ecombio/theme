{% comment %}
  Header Menu
  File: sections/header-menu.liquid

  Renders the desktop menu bar and the mobile nav drawer.

  Add to layout/theme.liquid, directly after {%- section 'main-header' -%}:
    {%- section 'header-menu' -%}

  Block types: single-link | link-list | mega | highlight | flyout

  `mega` is rendered fully INLINE in this file — it does not delegate to
  a separate block/snippet file, and owns its own styling/behavior pair:
    mega → assets/mega-menu.css + assets/mega-menu.js

  `flyout` delegates entirely to snippets/flyout-menu.liquid, paired with:
    assets/flyout-menu.css
    assets/flyout-menu.js
  Both `mega` and `flyout` remain real Shopify block types (see schema
  below), so "Add block" continues to offer Mega menu / Flyout panel as
  normal in the theme editor.

  The `link-list` block type is also rendered inline (no block file). It
  owns its own panel classes (.link-list-panel__*) in link-list.css.

  Assets (loaded once, here):
    assets/link-list.css
    assets/link-list.js
    assets/mega-menu.css
    assets/mega-menu.js
    assets/flyout-menu.css
    assets/flyout-menu.js

  No promo-image support on the flyout block — not currently implemented.

  REMOVED — delete these from the theme, nothing references them anymore:
    snippets/flyout.liquid
    snippets/flyout-column.liquid
    assets/flyout.css
    assets/flyout.js
    assets/flyout-panel.js
    blocks/mega-menu.liquid
    assets/header-mega-menu.css
    assets/header-mega-menu.js
{% endcomment %}

{{ 'header-menu.css' | asset_url | stylesheet_tag }}
{{ 'link-list.css' | asset_url | stylesheet_tag }}
{{ 'mega-menu.css' | asset_url | stylesheet_tag }}
{{ 'flyout-menu.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign nav_menu = linklists[section.settings.menu] | default: linklists['main-menu']
-%}

{%- comment -%} ═══════════════════════════════════════
    DESKTOP MENU BAR
═══════════════════════════════════════ {%- endcomment -%}

{%- if section.blocks.size > 0 -%}

<nav class="menu-bar" aria-label="Primary navigation">
  <div class="menu-bar__container page-width">
    <ul class="menu-bar__list">

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'single-link' -%}
              <li class="menu-bar__item" {{ block.shopify_attributes }}>
    <a href="{{ block.settings.link | default: '#' }}" class="menu-bar__link">
      {%- if block.settings.icon != blank -%}
        <span class="menu-bar__icon">
          {%- render 'menu-icon', icon: block.settings.icon -%}
        </span>
      {%- endif -%}
      {{ block.settings.label | default: 'Link' }}
    </a>
  </li>

          {%- when 'link-list' -%}
            {%- assign ll_menu = linklists[block.settings.menu] -%}
            <li class="menu-bar__item menu-bar__item--has-link-list" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: ll_menu.links.first.url | default: '#' }}"
                 class="menu-bar__link menu-bar__link--caret link-list-trigger"
                 aria-haspopup="true"
                 aria-expanded="false">
                {%- if block.settings.icon != blank -%}
                  <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
                {%- endif -%}
                {{ block.settings.label | default: ll_menu.title | default: 'Menu' }}
                <svg class="icon-caret-down" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M16.25 7.5L10 13.75L3.75 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              {%- if ll_menu != blank and ll_menu.links.size > 0 -%}
                <div class="link-list-panel" role="region">
                  <div class="link-list-panel__container">
                    <ul class="link-list-panel__nav" role="list">
                      {%- for link in ll_menu.links -%}
                        <li class="link-list-panel__item">
                          <a href="{{ link.url }}"
                             class="link-list-panel__link"
                             {% if link.current %}aria-current="page"{% endif %}>
                            {{ link.title }}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                </div>
              {%- endif -%}
            </li>

          {%- when 'mega' -%}
            {%- comment -%}
              Inline mega menu — markup maps 1:1 onto assets/mega-menu.css
              (mega-menu-items, mega-menu-heading, mega-menu-link, etc.).
            {%- endcomment -%}
            {%- assign mega_menu = linklists[block.settings.menu] -%}
            <li class="menu-bar__item menu-bar__item--has-mega" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: mega_menu.links.first.url | default: '#' }}"
                 class="menu-bar__link menu-bar__link--caret mega-menu-trigger"
                 aria-haspopup="true"
                 aria-expanded="false"
                 data-mega-trigger>
                {%- if block.settings.icon != blank -%}
                  <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
                {%- endif -%}
                {{ block.settings.label | default: 'Shop' }}
                <svg class="icon-caret-down" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M16.25 7.5L10 13.75L3.75 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>

              {%- if mega_menu != blank and mega_menu.links.size > 0 -%}
                {%- assign mega_col_count = mega_menu.links.size -%}
                {%- assign mega_collection = blank -%}
                {%- if block.settings.show_products -%}
                  {%- for link in mega_menu.links -%}
                    {%- if link.type == 'collection_link' and mega_collection == blank -%}
                      {%- assign mega_collection = link.object -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}

                <div class="mega-menu" role="region" data-mega-panel>
                  <div class="mega-menu-items{% if mega_collection != blank %} mega-menu-items--with-products{% endif %}">

                    <div class="mega-menu__text-columns" style="--mega-col-count: {{ mega_col_count }};">
                      {%- for link in mega_menu.links -%}
                        <div class="mega-menu-column">
                          <a href="{{ link.url }}"
                             class="mega-menu-heading"
                             {% if link.current %}aria-current="page"{% endif %}>
                            {{ link.title }}
                          </a>
                          {%- if link.links.size > 0 -%}
                            <ul class="mega-menu-list" role="list">
                              {%- for sublink in link.links -%}
                                <li>
                                  <a href="{{ sublink.url }}"
                                     class="mega-menu-link"
                                     {% if sublink.current %}aria-current="page"{% endif %}>
                                    {{ sublink.title }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      {%- endfor -%}
                    </div>

                    {%- if mega_collection != blank -%}
                      <div class="mega-menu__products">
                        <div class="mega-menu__product-header">
                          <span class="mega-menu-heading">Trending in {{ mega_collection.title }}</span>
                        </div>
                        <div class="mega-menu__product-grid">
                          {%- for product in mega_collection.products limit: 3 -%}
                            <a href="{{ product.url }}" class="mega-menu__product-card">
                              <div class="mega-menu__product-image">
                                <img src="{{ product.featured_image | image_url: width: 300 }}"
                                     alt="{{ product.featured_image.alt | default: product.title | escape }}"
                                     loading="lazy"
                                     width="300"
                                     height="300">
                                {%- if product.compare_at_price > product.price -%}
                                  <span class="mega-menu__badge">Sale</span>
                                {%- endif -%}
                              </div>
                              <div class="mega-menu__product-info">
                                <p class="mega-menu__product-title">{{ product.title }}</p>
                                <p class="mega-menu__product-price">
                                  {%- if product.compare_at_price > product.price -%}
                                    <span class="price--sale">{{ product.price | money }}</span>
                                    <span class="price--compare">{{ product.compare_at_price | money }}</span>
                                  {%- else -%}
                                    {{ product.price | money }}
                                  {%- endif -%}
                                </p>
                              </div>
                            </a>
                          {%- endfor -%}
                        </div>
                      </div>
                    {%- endif -%}

                  </div>
                </div>
              {%- endif -%}
            </li>

          {%- when 'highlight' -%}
            <li class="menu-bar__item menu-bar__item--highlight" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: '#' }}" class="menu-bar__link menu-bar__link--highlight">
                {%- if block.settings.icon != blank -%}
                  <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
                {%- endif -%}
                <span class="reversed-link">{{ block.settings.label | default: 'On Sale' }}</span>
                <svg class="star star-1" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true"><path d="M6 0L7.854 4.146L12 6L7.854 7.854L6 12L4.146 7.854L0 6L4.146 4.146L6 0Z" fill="currentColor"/></svg>
                <svg class="star star-2" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true"><path d="M6 0L7.854 4.146L12 6L7.854 7.854L6 12L4.146 7.854L0 6L4.146 4.146L6 0Z" fill="currentColor"/></svg>
                <svg class="star star-3" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true"><path d="M6 0L7.854 4.146L12 6L7.854 7.854L6 12L4.146 7.854L0 6L4.146 4.146L6 0Z" fill="currentColor"/></svg>
              </a>
            </li>

          {%- when 'flyout' -%}
            {%- render 'flyout-menu', block: block -%}

        {%- endcase -%}
      {%- endfor -%}

    </ul>
  </div>
</nav>

{%- endif -%}

{%- comment -%} ═══════════════════════════════════════
    MOBILE / TABLET DRAWER NAV
    3-level accordion: top links → category headings → nested links
═══════════════════════════════════════ {%- endcomment -%}

<div class="mobile-nav" id="mobile-nav" aria-hidden="true">
  <div class="mobile-nav__overlay" id="mobile-nav-overlay"></div>

  <nav class="mobile-nav__panel" role="navigation" aria-label="Mobile navigation">

    <div class="mobile-nav__header">
      <span class="mobile-nav__header-label">Menu</span>
      <button class="mobile-nav__close" id="mobile-nav-close" aria-label="Close navigation">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <ul class="mobile-nav__list" role="list">
      {%- for link in nav_menu.links -%}

        {%- if link.links.size > 0 -%}
          <li class="mobile-nav__item mobile-nav__item--has-children{%- if link.active %} is-active{%- endif %}">

            <div class="mobile-nav__row">
              <a href="{{ link.url }}"
                 class="mobile-nav__link"
                 {% if link.current %}aria-current="page"{% endif %}>
                {{ link.title }}
              </a>
              <button class="mobile-nav__toggle"
                      aria-expanded="false"
                      aria-label="Expand {{ link.title }}">
                <svg class="mobile-nav__chevron" width="16" height="16"
                     viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor"
                        stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            <ul class="mobile-nav__sub" role="list" hidden>
              {%- for child in link.links -%}

                {%- if child.links.size > 0 -%}
                  <li class="mobile-nav__item mobile-nav__item--has-children mobile-nav__item--l3">
                    <div class="mobile-nav__row">
                      <a href="{{ child.url }}"
                         class="mobile-nav__link mobile-nav__link--sub"
                         {% if child.current %}aria-current="page"{% endif %}>
                        {{ child.title }}
                      </a>
                      <button class="mobile-nav__toggle"
                              aria-expanded="false"
                              aria-label="Expand {{ child.title }}">
                        <svg class="mobile-nav__chevron" width="14" height="14"
                             viewBox="0 0 20 20" fill="none" aria-hidden="true">
                          <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor"
                                stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </div>
                    <ul class="mobile-nav__sub mobile-nav__sub--l3" role="list" hidden>
                      {%- for grandchild in child.links -%}
                        <li>
                          <a href="{{ grandchild.url }}"
                             class="mobile-nav__link mobile-nav__link--deep"
                             {% if grandchild.current %}aria-current="page"{% endif %}>
                            {{ grandchild.title }}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </li>

                {%- else -%}
                  <li class="mobile-nav__item">
                    <a href="{{ child.url }}"
                       class="mobile-nav__link mobile-nav__link--sub"
                       {% if child.current %}aria-current="page"{% endif %}>
                      {{ child.title }}
                    </a>
                  </li>
                {%- endif -%}

              {%- endfor -%}
            </ul>
          </li>

        {%- else -%}
          <li class="mobile-nav__item{% if link.active %} is-active{% endif %}">
            <a href="{{ link.url }}"
               class="mobile-nav__link"
               {% if link.current %}aria-current="page"{% endif %}>
              {{ link.title }}
            </a>
          </li>
        {%- endif -%}

      {%- endfor -%}
    </ul>

  </nav>
</div>

{{- 'link-list.js' | asset_url | script_tag }}
{{- 'mega-menu.js' | asset_url | script_tag }}
{{- 'flyout-menu.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Header Menu",
  "tag": "div",
  "class": "header-menu-section",
  "limit": 1,
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Mobile navigation menu",
      "default": "main-menu",
      "info": "Used for the mobile drawer. Desktop items are configured via blocks below."
    }
  ],
  "blocks": [
    {
      "type": "single-link",
      "name": "Single Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name",
          "info": "Optional. Uses snippets/menu-icon.liquid"
        }
      ]
    },
    {
      "type": "link-list",
      "name": "Link list",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Top-level URL (optional)"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Link list menu"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        }
      ]
    },
    {
      "type": "mega",
      "name": "Mega menu",
      "settings": [
        {
          "type": "header",
          "content": "Nav bar"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL",
          "info": "Optional. Falls back to first menu link."
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        },
        {
          "type": "header",
          "content": "Products"
        },
        {
          "type": "checkbox",
          "id": "show_products",
          "label": "Show trending products",
          "default": false,
          "info": "Pulls the first 3 products from the first collection link found in the chosen menu."
        }
      ]
    },
    {
      "type": "highlight",
      "name": "Highlight link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "On Sale"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        }
      ]
    },
    {
      "type": "@app"
    },
    {
      "type": "flyout",
      "name": "Flyout Menu",
      "settings": [
        {
          "type": "header",
          "content": "Nav bar"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Browse all categories"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Top-level URL (optional)"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Flyout menu",
          "info": "Top-level links become the left-hand category list. Their child links become the column content; grandchild links become indented sub-items."
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header Menu",
      "settings": {
        "menu": "main-menu"
      },
      "blocks": [
        { "type": "single-link", "settings": { "label": "Shop",    "link": "/collections/all" } },
        { "type": "mega" },
        { "type": "single-link", "settings": { "label": "About",   "link": "/pages/about" } },
        { "type": "single-link", "settings": { "label": "Contact", "link": "/pages/contact" } }
      ]
    }
  ]
}
{% endschema %}
