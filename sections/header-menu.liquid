{%- liquid
  assign nav_menu = linklists[section.settings.menu] | default: linklists['main-menu']
-%}

{%- comment -%} ═══════════════════════════════════════
    DESKTOP MENU BAR
═══════════════════════════════════════ {%- endcomment -%}

{%- if section.blocks.size > 0 -%}

<nav class="menu-bar" aria-label="Primary navigation">
  <div class="menu-bar__container page-width--header">
    <ul class="menu-bar__list">

      {%- for block in section.blocks -%}
        {%- case block.type -%}
{%- when 'single-link' -%}
  {%- render 'single-link', block: block -%}

         {%- when 'link-list' -%}
  {%- render 'link-list', block: block -%}
{%- when 'mega-menu' -%}
  {%- render 'mega-menu', block: block -%}

          {%- when 'highlight' -%}
            <li class="menu-bar__item menu-bar__item--highlight" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: '#' }}" class="menu-bar__link menu-bar__link--highlight">
                {%- if block.settings.icon != blank -%}
                  <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
                {%- endif -%}
                <span class="reversed-link">{{ block.settings.label | default: 'On Sale' }}</span>
                <svg class="star star-1" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true"><path d="M6 0L7.854 4.146L12 6L7.854 7.854L6 12L4.146 7.854L0 6L4.146 4.146L6 0Z" fill="currentColor"/></svg>
                <svg class="star star-2" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true"><path d="M6 0L7.854 4.146L12 6L7.854 7.854L6 12L4.146 7.854L0 6L4.146 4.146L6 0Z" fill="currentColor"/></svg>
                <svg class="star star-3" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true"><path d="M6 0L7.854 4.146L12 6L7.854 7.854L6 12L4.146 7.854L0 6L4.146 4.146L6 0Z" fill="currentColor"/></svg>
              </a>
            </li>

          {%- when 'flyout' -%}
            {%- render 'flyout-menu', block: block -%}

        {%- endcase -%}
      {%- endfor -%}

    </ul>
  </div>
</nav>

{%- endif -%}

{%- comment -%} ═══════════════════════════════════════
    MOBILE / TABLET DRAWER NAV
    3-level accordion: top links → category headings → nested links
═══════════════════════════════════════ {%- endcomment -%}

<div class="mobile-nav" id="mobile-nav" aria-hidden="true">
  <div class="mobile-nav__overlay" id="mobile-nav-overlay"></div>

  <nav class="mobile-nav__panel" role="navigation" aria-label="Mobile navigation">

    <div class="mobile-nav__header">
      <span class="mobile-nav__header-label">Menu</span>
      <button class="mobile-nav__close" id="mobile-nav-close" aria-label="Close navigation">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <ul class="mobile-nav__list" role="list">
      {%- for link in nav_menu.links -%}

        {%- if link.links.size > 0 -%}
          <li class="mobile-nav__item mobile-nav__item--has-children{%- if link.active %} is-active{%- endif %}">

            <div class="mobile-nav__row">
              <a href="{{ link.url }}"
                 class="mobile-nav__link"
                 {% if link.current %}aria-current="page"{% endif %}>
                {{ link.title }}
              </a>
              <button class="mobile-nav__toggle"
                      aria-expanded="false"
                      aria-label="Expand {{ link.title }}">
                <svg class="mobile-nav__chevron" width="16" height="16"
                     viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor"
                        stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            <ul class="mobile-nav__sub" role="list" hidden>
              {%- for child in link.links -%}

                {%- if child.links.size > 0 -%}
                  <li class="mobile-nav__item mobile-nav__item--has-children mobile-nav__item--l3">
                    <div class="mobile-nav__row">
                      <a href="{{ child.url }}"
                         class="mobile-nav__link mobile-nav__link--sub"
                         {% if child.current %}aria-current="page"{% endif %}>
                        {{ child.title }}
                      </a>
                      <button class="mobile-nav__toggle"
                              aria-expanded="false"
                              aria-label="Expand {{ child.title }}">
                        <svg class="mobile-nav__chevron" width="14" height="14"
                             viewBox="0 0 20 20" fill="none" aria-hidden="true">
                          <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor"
                                stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </div>
                    <ul class="mobile-nav__sub mobile-nav__sub--l3" role="list" hidden>
                      {%- for grandchild in child.links -%}
                        <li>
                          <a href="{{ grandchild.url }}"
                             class="mobile-nav__link mobile-nav__link--deep"
                             {% if grandchild.current %}aria-current="page"{% endif %}>
                            {{ grandchild.title }}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </li>

                {%- else -%}
                  <li class="mobile-nav__item">
                    <a href="{{ child.url }}"
                       class="mobile-nav__link mobile-nav__link--sub"
                       {% if child.current %}aria-current="page"{% endif %}>
                      {{ child.title }}
                    </a>
                  </li>
                {%- endif -%}

              {%- endfor -%}
            </ul>
          </li>

        {%- else -%}
          <li class="mobile-nav__item{% if link.active %} is-active{% endif %}">
            <a href="{{ link.url }}"
               class="mobile-nav__link"
               {% if link.current %}aria-current="page"{% endif %}>
              {{ link.title }}
            </a>
          </li>
        {%- endif -%}

      {%- endfor -%}
    </ul>

  </nav>
</div>

{{- 'link-list.js' | asset_url | script_tag }}
{{- 'mega-menu.js' | asset_url | script_tag }}
{{- 'flyout-menu.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Header Menu",
  "tag": "div",
  "class": "header-menu-section",
  "limit": 1,
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Mobile navigation menu",
      "default": "main-menu",
      "info": "Used for the mobile drawer. Desktop items are configured via blocks below."
    }
  ],
  "blocks": [
    {
      "type": "single-link",
      "name": "Single Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Single Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name",
          "info": "Optional. Uses snippets/menu-icon.liquid"
        }
      ]
    },
    {
      "type": "link-list",
      "name": "Link list",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Top-level URL (optional)"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Link list menu"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        }
      ]
    },
    {
      "type": "mega-menu",
      "name": "Mega menu",
      "settings": [
        {
          "type": "header",
          "content": "Nav bar"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL",
          "info": "Optional. Falls back to first menu link."
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        },
        {
          "type": "header",
          "content": "Products"
        },
        {
          "type": "checkbox",
          "id": "show_products",
          "label": "Show trending products",
          "default": false,
          "info": "Pulls the first 3 products from the first collection link found in the chosen menu."
        }
      ]
    },
    {
      "type": "highlight",
      "name": "Highlight link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "On Sale"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        }
      ]
    },
    {
      "type": "@app"
    },
    {
      "type": "flyout",
      "name": "Flyout Menu",
      "settings": [
        {
          "type": "header",
          "content": "Nav bar"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Browse all categories"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Top-level URL (optional)"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Flyout menu",
          "info": "Top-level links become the left-hand category list. Their child links become the column content; grandchild links become indented sub-items."
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name"
        },
        {
          "type": "header",
          "content": "Style"
        },
        {
          "type": "select",
          "id": "panel_style",
          "label": "Flyout panel style",
          "info": "Compact keeps the panel left-aligned under its trigger. Full-width span stretches it across most of the header for a bigger, more modern look.",
          "options": [
            {
              "value": "compact",
              "label": "Compact (left-aligned)"
            },
            {
              "value": "full-width",
              "label": "Full-width span"
            }
          ],
          "default": "compact"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header Menu",
      "settings": {
        "menu": "main-menu"
      },
      "blocks": [
        { "type": "single-link", "settings": { "label": "Shop",    "link": "/collections/all" } },
        { "type": "mega-menu" },
        { "type": "single-link", "settings": { "label": "About",   "link": "/pages/about" } },
        { "type": "single-link", "settings": { "label": "Contact", "link": "/pages/contact" } }
      ]
    }
  ]
}
{% endschema %}
