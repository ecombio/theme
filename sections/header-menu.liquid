{% comment %}
  sections/header-menu.liquid
  ─────────────────────────────────────────────────────────────────────────────
  Pure menu bar. Renders inside sections/groups/header-group.json, which owns
  the <header role="banner"> wrapper — this section must NOT define "tag" in
  its schema.

  This section does ONE job: render section.blocks (mega_menu / single_link)
  as a horizontal nav on desktop and an accordion drawer on mobile.
  No logo, no search/account/cart icons, no CTA button, no sticky/transparent
  logic. Add those back in the group or a separate section if needed.
  ─────────────────────────────────────────────────────────────────────────────
{% endcomment %}

{{ 'mega-menu.css' | asset_url | stylesheet_tag }}
{{ 'in-menu-promo.css' | asset_url | stylesheet_tag }}

<div
  id="header-menu-{{ section.id }}"
  class="header-menu"
  data-section-id="{{ section.id }}"
>
  <div class="header-menu__inner">

    {%- comment -%} ── Desktop nav — mega-menu + single-link blocks ── {%- endcomment -%}
    <nav
      id="site-nav-{{ section.id }}"
      class="site-nav"
      aria-label="Primary navigation"
    >
      <ul class="site-nav__list" role="menubar">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'mega_menu' -%}
              <li
                class="site-nav__item site-nav__item--mega"
                role="none"
                {{ block.shopify_attributes }}
              >
                {%- render 'mega-menu', block: block -%}
              </li>

            {%- when 'single_link' -%}
              <li
                class="site-nav__item site-nav__item--single"
                role="none"
                {{ block.shopify_attributes }}
              >
                {%- render 'single-link', block: block -%}
              </li>

          {%- endcase -%}
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} ── Mobile hamburger ── {%- endcomment -%}
    <button
      id="mobile-menu-toggle-{{ section.id }}"
      class="header-menu__hamburger"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="mobile-nav-drawer-{{ section.id }}"
      type="button"
    >
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
    </button>

  </div><!-- /.header-menu__inner -->
</div><!-- /.header-menu -->

{%- comment -%} ── Mobile Nav Drawer — sibling, not nested in nav ── {%- endcomment -%}
<div
  id="mobile-nav-drawer-{{ section.id }}"
  class="mobile-drawer"
  aria-hidden="true"
  role="dialog"
  aria-label="Mobile navigation"
>
  <div class="mobile-drawer__overlay" data-action="close-drawer"></div>
  <div class="mobile-drawer__panel" role="document">
    <button
      class="mobile-drawer__close"
      aria-label="Close navigation"
      data-action="close-drawer"
      type="button"
    >
      <svg aria-hidden="true" focusable="false" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <nav class="mobile-nav" aria-label="Mobile navigation">
      <ul class="mobile-nav__list">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'mega_menu' -%}
              {%- liquid
                assign mobile_menu   = linklists[block.settings.menu]
                assign trigger_label = block.settings.label | default: mobile_menu.title
              -%}
              {%- if mobile_menu != blank -%}
                <li class="mobile-nav__item mobile-nav__item--has-children">
                  <button
                    class="mobile-nav__trigger"
                    aria-expanded="false"
                    aria-controls="mobile-submenu-{{ block.id }}"
                    type="button"
                  >
                    {{- trigger_label | escape -}}
                    <svg class="mobile-nav__chevron" aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="6 9 12 15 18 9"/>
                    </svg>
                  </button>
                  <ul
                    id="mobile-submenu-{{ block.id }}"
                    class="mobile-nav__submenu"
                    hidden
                  >
                    {%- for link in mobile_menu.links -%}
                      {%- if link.links != blank -%}
                        <li class="mobile-nav__subitem mobile-nav__subitem--group">
                          <span class="mobile-nav__group-title">{{- link.title | escape -}}</span>
                          <ul class="mobile-nav__sublist">
                            {%- for child in link.links -%}
                              <li class="mobile-nav__subitem">
                                <a href="{{ child.url }}" class="mobile-nav__link">{{- child.title | escape -}}</a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        </li>
                      {%- else -%}
                        <li class="mobile-nav__subitem">
                          <a href="{{ link.url }}" class="mobile-nav__link">{{- link.title | escape -}}</a>
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                </li>
              {%- endif -%}

            {%- when 'single_link' -%}
              <li class="mobile-nav__item">
                <a
                  href="{{ block.settings.url }}"
                  class="mobile-nav__link mobile-nav__link--top"
                  {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
                >
                  {{- block.settings.label | escape -}}
                </a>
              </li>

          {%- endcase -%}
        {%- endfor -%}
      </ul>
    </nav>
  </div>
</div>

<script src="{{ 'mega-menu.js' | asset_url }}" defer></script>
<script src="{{ 'in-menu-promo.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Header Menu",
  "settings": [],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "Mega Menu",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Nav label",
          "info": "Overrides the link list title."
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Link list",
          "default": "main-menu"
        },
        {
          "type": "select",
          "id": "columns",
          "label": "Column count",
          "options": [
            { "value": "2", "label": "2 columns" },
            { "value": "3", "label": "3 columns" },
            { "value": "4", "label": "4 columns" }
          ],
          "default": "3"
        },
        {
          "type": "header",
          "content": "In-menu promo"
        },
        {
          "type": "checkbox",
          "id": "show_promo",
          "label": "Show promo block",
          "default": false
        },
        {
          "type": "select",
          "id": "promo_position",
          "label": "Promo position",
          "options": [
            { "value": "left",  "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "right"
        },
        {
          "type": "image_picker",
          "id": "promo_image",
          "label": "Promo image"
        },
        {
          "type": "text",
          "id": "promo_eyebrow",
          "label": "Promo eyebrow text"
        },
        {
          "type": "text",
          "id": "promo_heading",
          "label": "Promo heading"
        },
        {
          "type": "textarea",
          "id": "promo_body",
          "label": "Promo body text"
        },
        {
          "type": "text",
          "id": "promo_cta_label",
          "label": "Promo button label"
        },
        {
          "type": "url",
          "id": "promo_cta_url",
          "label": "Promo button URL"
        },
        {
          "type": "color",
          "id": "promo_bg_color",
          "label": "Promo background color",
          "default": "#f5f5f5"
        }
      ]
    },
    {
      "type": "single_link",
      "name": "Single Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open in new tab",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "nofollow",
          "label": "Add nofollow",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header Menu"
    }
  ]
}
{% endschema %}