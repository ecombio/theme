<nav class="header-menu header-menu--{{ section.settings.alignment | default: 'left' }}" role="navigation">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'mega-menu' %}
        {% render block %}
      {% when 'single-link' %}
        {% render block %}
    {% endcase %}
  {% endfor %}
</nav>

{% schema %}
{
  "name": "header-menu",
  "tag": "section",
  "class": "header-menu",
  "settings": [
    {
      "type": "select",
      "id": "alignment",
      "label": "Menu alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "mega-menu",
      "name": "Mega Menu",
      "limit": 6
    },
    {
      "type": "single-link",
      "name": "Single Link",
      "limit": 10
    }
  ],
  "presets": [
    {
      "name": "header-menu",
      "blocks": [
        {
          "type": "mega-menu"
        }
      ]
    }
  ]
}
{% endschema %}