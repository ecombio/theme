{% comment %}
  sections/header-menu.liquid
  A responsive, accessible Shopify header with:
  - Sticky scroll behavior
  - Mega-menu / dropdown support
  - Mobile drawer navigation
  - Cart count badge
  - Search toggle
{% endcomment %}

{{ 'header-menu.css' | asset_url | stylesheet_tag }}

<header
  class="site-header{% if section.settings.sticky %} site-header--sticky{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="header-menu"
  role="banner"
>
  <div class="site-header__inner">

    {%- comment -%} ── Mobile burger ─────────────────────────────── {%- endcomment -%}
    <button
      class="site-header__burger"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mobile-nav-drawer"
      data-burger
    >
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
    </button>

    {%- comment -%} ── Logo ──────────────────────────────────────── {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }} home">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 300 }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width }}"
          height="auto"
          loading="eager"
        >
      {%- else -%}
        <span class="site-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} ── Desktop nav ───────────────────────────────── {%- endcomment -%}
    <nav class="site-header__nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {%- for link in linklists[section.settings.menu].links -%}
          {%- if link.links != blank -%}
            <li class="nav-item nav-item--has-dropdown" data-dropdown-item>
              <button
                class="nav-link nav-link--parent"
                aria-expanded="false"
                aria-haspopup="true"
                data-dropdown-trigger
              >
                {{ link.title }}
                <svg class="nav-chevron" aria-hidden="true" width="10" height="6" viewBox="0 0 10 6">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="nav-dropdown" data-dropdown-panel role="region">
                <ul class="nav-dropdown__list" role="list">
                  {%- for child in link.links -%}
                    <li class="nav-dropdown__item">
                      <a
                        href="{{ child.url }}"
                        class="nav-dropdown__link{% if child.active %} is-active{% endif %}"
                      >{{ child.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            </li>
          {%- else -%}
            <li class="nav-item">
              <a
                href="{{ link.url }}"
                class="nav-link{% if link.active %} is-active{% endif %}"
              >{{ link.title }}</a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} ── Actions (search / account / cart) ─────────── {%- endcomment -%}
    <div class="site-header__actions">

      {%- if section.settings.show_search -%}
        <button
          class="header-action header-action--search"
          aria-label="Toggle search"
          aria-expanded="false"
          data-search-trigger
        >
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="8.5" cy="8.5" r="5.75" stroke="currentColor" stroke-width="1.5"/>
            <path d="M13 13l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      {%- endif -%}

      {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
        <a
          href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
          class="header-action header-action--account"
          aria-label="{% if customer %}My account{% else %}Log in{% endif %}"
        >
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="7" r="3.25" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 17c0-3.314 3.134-6 7-6s7 2.686 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
      {%- endif -%}

      <a
        href="{{ routes.cart_url }}"
        class="header-action header-action--cart"
        aria-label="Cart ({{ cart.item_count }} items)"
        data-cart-link
      >
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M2 2h2l2.5 10h9l2-7H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="8.5" cy="16.5" r="1.25" fill="currentColor"/>
          <circle cx="14.5" cy="16.5" r="1.25" fill="currentColor"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="cart-badge" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

    </div><!-- /.site-header__actions -->
  </div><!-- /.site-header__inner -->

  {%- comment -%} ── Search bar (collapsed by default) ─────────── {%- endcomment -%}
  {%- if section.settings.show_search -%}
    <div class="site-search" data-search-panel aria-hidden="true">
      <div class="site-search__inner">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <label for="header-search-input" class="visually-hidden">Search</label>
          <input
            id="header-search-input"
            type="search"
            name="q"
            placeholder="{{ section.settings.search_placeholder | default: 'Search…' }}"
            autocomplete="off"
            class="site-search__input"
          >
          <button type="submit" class="site-search__submit" aria-label="Submit search">
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 20 20" fill="none">
              <circle cx="8.5" cy="8.5" r="5.75" stroke="currentColor" stroke-width="1.5"/>
              <path d="M13 13l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </form>
        <button class="site-search__close" data-search-close aria-label="Close search">✕</button>
      </div>
    </div>
  {%- endif -%}

</header>

{%- comment -%} ── Mobile drawer ──────────────────────────────────── {%- endcomment -%}
<div
  id="mobile-nav-drawer"
  class="mobile-drawer"
  aria-hidden="true"
  data-mobile-drawer
>
  <div class="mobile-drawer__overlay" data-drawer-overlay></div>
  <nav class="mobile-drawer__panel" aria-label="Mobile navigation">
    <div class="mobile-drawer__header">
      <span class="mobile-drawer__title">{{ shop.name }}</span>
      <button class="mobile-drawer__close" data-drawer-close aria-label="Close navigation">✕</button>
    </div>
    <ul class="mobile-nav" role="list">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- if link.links != blank -%}
          <li class="mobile-nav__item mobile-nav__item--has-children">
            <button class="mobile-nav__link mobile-nav__link--parent" data-mobile-accordion aria-expanded="false">
              {{ link.title }}
              <svg class="nav-chevron" aria-hidden="true" width="10" height="6" viewBox="0 0 10 6">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <ul class="mobile-nav__children" role="list" hidden>
              {%- for child in link.links -%}
                <li><a href="{{ child.url }}" class="mobile-nav__child-link">{{ child.title }}</a></li>
              {%- endfor -%}
            </ul>
          </li>
        {%- else -%}
          <li class="mobile-nav__item">
            <a href="{{ link.url }}" class="mobile-nav__link{% if link.active %} is-active{% endif %}">{{ link.title }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </nav>
</div>

<script src="{{ 'header-menu.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "header-menu",
  "tag": "section",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 140
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search products…"
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Header menu"
    }
  ]
}
{% endschema %}
