{% comment %}
  sections/collection-page.liquid

  Single self-contained section combining:
    - product-filter.liquid (filter sidebar + sort)
    - product-feed.liquid   (product grid + in-feed promo blocks)

  Inlined into one file (rather than rendered as two separate sections)
  so this can ship as ONE section with ONE schema. Liquid only allows a
  single {% schema %} per file, so the two source files' schemas are
  merged below:
    - Both had a top-level "collection" setting with identical meaning;
      kept as a single shared setting.
    - "heading" / "show_sort" (from product-filter) kept as-is.
    - "columns" / "products_per_page" (from product-feed) kept as-is.
    - Blocks (promo_product, promo_carousel) carried over unchanged.

  Works on the collection template (uses the page's `collection` object).
  Falls back to the "collection" setting if placed elsewhere.

  CSS: collection-page.css, product-filter.css, product-feed.css, product-card.css
  JS:  product-filter.js
{% endcomment %}

{{ 'collection-page.css' | asset_url | stylesheet_tag }}
{{ 'product-filter.css' | asset_url | stylesheet_tag }}
{{ 'product-feed.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  if collection != blank
    assign page_collection = collection
  elsif section.settings.collection != blank
    assign page_collection = section.settings.collection
  endif

  assign show_sort = section.settings.show_sort
  assign columns = section.settings.columns | default: 4

  assign active_count = 0
  for filter in page_collection.filters
    if filter.type == 'price_range'
      if filter.min_value.value or filter.max_value.value
        assign active_count = active_count | plus: 1
      endif
    else
      assign active_count = active_count | plus: filter.active_values.size
    endif
  endfor
-%}

<div class="collection-page" data-collection-page>

  <div class="collection-page__layout">

    {%- comment -%} ───────────────────────── Filter sidebar ───────────────────────── {%- endcomment -%}
    <aside class="collection-page__sidebar">
      <div class="product-filter" data-product-filter>

        <div class="product-filter__header">
          <h2 class="product-filter__heading">{{ section.settings.heading | default: 'Filters' }}</h2>
          <span class="product-filter__count" aria-live="polite">
            {{ page_collection.products_count }}
            {{- page_collection.products_count | pluralize: 'result', 'results' }}
          </span>
        </div>

        <button
          class="product-filter__mobile-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="product-filter-drawer"
          data-product-filter-mobile-toggle
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <line x1="1" y1="4"  x2="15" y2="4"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="3" y1="8"  x2="13" y2="8"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="5" y1="12" x2="11" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Filters &amp; sort
          {%- if active_count > 0 -%}
            <span class="product-filter__mobile-count" aria-label="{{ active_count }} active filters">
              {{ active_count }}
            </span>
          {%- endif -%}
        </button>

        <form
          id="product-filter-drawer"
          class="product-filter__body"
          data-product-filter-form
          method="get"
          novalidate
        >

          {%- comment -%} Preserve non-filter params (q, page, etc.) {%- endcomment -%}
          {%- for param in request.query_parameters -%}
            {%- assign param_key = param | first -%}
            {%- unless param_key == 'sort_by' or param_key contains 'filter.' -%}
              <input type="hidden" name="{{ param_key }}" value="{{ param | last | escape }}">
            {%- endunless -%}
          {%- endfor -%}

          {%- comment -%} ── Sort ──────────────────────────────────────────────── {%- endcomment -%}
          {%- if show_sort and page_collection.sort_options.size > 0 -%}
            <div class="product-filter__sort">
              <label class="product-filter__sort-label" for="product-filter-sort">Sort by</label>
              <select
                id="product-filter-sort"
                class="product-filter__sort-select"
                name="sort_by"
                data-product-filter-sort
              >
                {%- for option in page_collection.sort_options -%}
                  <option value="{{ option.value }}"{% if option.value == page_collection.sort_by %} selected{% endif %}>
                    {{ option.name }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endif -%}

          {%- comment -%} ── Active filter chips ───────────────────────────────── {%- endcomment -%}
          {%- if active_count > 0 -%}
            <div class="product-filter__active" aria-label="Active filters" data-product-filter-active>
              {%- for filter in page_collection.filters -%}
                {%- if filter.type == 'price_range' -%}
                  {%- if filter.min_value.value or filter.max_value.value -%}
                    <a class="product-filter__chip" href="{{ filter.url_to_remove }}" aria-label="Remove price filter">
                      Price:
                      {%- if filter.min_value.value -%}
                        {{ filter.min_value.value | money_without_trailing_zeros }}
                      {%- else -%}0{%- endif -%}
                      &ndash;
                      {%- if filter.max_value.value -%}
                        {{ filter.max_value.value | money_without_trailing_zeros }}
                      {%- else -%}
                        {{ filter.range_max | money_without_trailing_zeros }}
                      {%- endif -%}
                      <span aria-hidden="true">&times;</span>
                    </a>
                  {%- endif -%}
                {%- else -%}
                  {%- for value in filter.active_values -%}
                    <a class="product-filter__chip" href="{{ value.url_to_remove }}" aria-label="Remove filter: {{ value.label | escape }}">
                      {{ value.label }}
                      <span aria-hidden="true">&times;</span>
                    </a>
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}

              <a class="product-filter__chip product-filter__chip--clear" href="{{ page_collection.url }}{% if show_sort %}?sort_by={{ page_collection.sort_by }}{% endif %}" data-product-filter-clear-all>
                Clear all
              </a>
            </div>
          {%- endif -%}

          {%- comment -%} ── Filter groups ──────────────────────────────────────── {%- endcomment -%}
          {%- if page_collection.filters.size > 0 -%}
            <div class="product-filter__groups" data-product-filter-groups>
              {%- for filter in page_collection.filters -%}
                <details
                  class="product-filter__group"
                  data-filter-type="{{ filter.type }}"
                  {%- if filter.type == 'price_range' -%}
                    {%- if filter.min_value.value or filter.max_value.value %} open{% endif -%}
                  {%- elsif filter.active_values.size > 0 %} open{%- endif -%}
                >
                  <summary class="product-filter__group-summary">
                    <span class="product-filter__group-label">{{ filter.label }}</span>
                    {%- if filter.type != 'price_range' and filter.active_values.size > 0 -%}
                      <span class="product-filter__group-count">{{ filter.active_values.size }}</span>
                    {%- endif -%}
                    <svg class="product-filter__group-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </summary>

                  <div class="product-filter__group-body">
                    {%- case filter.type -%}

                      {%- when 'boolean', 'list' -%}
                        <ul class="product-filter__list" role="group" aria-label="{{ filter.label }}">
                          {%- for value in filter.values -%}
                            {%- assign input_id = 'product-filter-' | append: filter.param_name | append: '-' | append: forloop.index -%}
                            <li class="product-filter__item{% if value.count == 0 and value.active == false %} product-filter__item--disabled{% endif %}">
                              <label class="product-filter__item-label" for="{{ input_id }}">
                                <input
                                  id="{{ input_id }}"
                                  class="product-filter__checkbox"
                                  type="checkbox"
                                  name="{{ value.param_name }}"
                                  value="{{ value.value | escape }}"
                                  {%- if value.active %} checked{% endif -%}
                                  {%- if value.count == 0 and value.active == false %} disabled{% endif -%}
                                  data-product-filter-checkbox
                                  data-url-add="{{ value.url_to_add }}"
                                  data-url-remove="{{ value.url_to_remove }}"
                                >
                                <span class="product-filter__item-text">{{ value.label }}</span>
                                <span class="product-filter__item-count">({{ value.count }})</span>
                              </label>
                            </li>
                          {%- endfor -%}
                        </ul>

                      {%- when 'price_range' -%}
                        {%- assign price_max = filter.range_max | divided_by: 100 -%}
                        {%- assign price_min_val = filter.min_value.value | divided_by: 100 -%}
                        {%- assign price_max_val = filter.max_value.value | divided_by: 100 -%}

                        <div class="product-filter__price" data-product-filter-price>
                          <div class="product-filter__price-field">
                            <label class="product-filter__price-label" for="product-filter-price-min">Min</label>
                            <div class="product-filter__price-input-wrap">
                              <span class="product-filter__price-symbol">{{ cart.currency.symbol }}</span>
                              <input
                                id="product-filter-price-min"
                                class="product-filter__price-input"
                                type="number"
                                name="{{ filter.min_value.param_name }}"
                                min="0"
                                max="{{ price_max }}"
                                value="{{ price_min_val }}"
                                placeholder="0"
                                data-product-filter-price-min
                              >
                            </div>
                          </div>
                          <span class="product-filter__price-sep" aria-hidden="true">&ndash;</span>
                          <div class="product-filter__price-field">
                            <label class="product-filter__price-label" for="product-filter-price-max">Max</label>
                            <div class="product-filter__price-input-wrap">
                              <span class="product-filter__price-symbol">{{ cart.currency.symbol }}</span>
                              <input
                                id="product-filter-price-max"
                                class="product-filter__price-input"
                                type="number"
                                name="{{ filter.max_value.param_name }}"
                                min="0"
                                max="{{ price_max }}"
                                value="{{ price_max_val }}"
                                placeholder="{{ price_max }}"
                                data-product-filter-price-max
                              >
                            </div>
                          </div>
                          <button class="product-filter__price-apply" type="button" data-product-filter-price-apply>
                            Apply
                          </button>
                        </div>

                    {%- endcase -%}
                  </div>
                </details>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <button class="product-filter__submit" type="submit" data-product-filter-submit>
            Apply filters
          </button>

        </form>

      </div>
    </aside>

    {%- comment -%} ───────────────────────── Product feed ───────────────────────── {%- endcomment -%}
    <div class="collection-page__main">
      <div
        class="product-feed"
        style="--product-feed-columns: {{ columns }};"
        data-product-feed
      >

        {%- if page_collection.products != blank -%}

          {%- paginate page_collection.products by section.settings.products_per_page -%}

            <div class="product-feed__grid">
              {%- assign row_index = 0 -%}
              {%- for product in page_collection.products -%}

                {%- render 'product-card', product: product -%}

                {%- assign position_mod = forloop.index | modulo: columns -%}
                {%- if position_mod == 0 and forloop.last == false -%}
                  {%- assign row_index = row_index | plus: 1 -%}
                  </div>
                  {%- for block in section.blocks -%}
                    {%- if block.settings.row == row_index -%}
                      {%- case block.type -%}
                        {%- when 'promo_product' -%}
                          {%- render 'promo-product', block: block -%}
                        {%- when 'promo_carousel' -%}
                          {%- render 'promo-carousel', block: block -%}
                      {%- endcase -%}
                    {%- endif -%}
                  {%- endfor -%}
                  <div class="product-feed__grid">
                {%- elsif forloop.last -%}
                  {%- assign row_index = row_index | plus: 1 -%}
                {%- endif -%}

              {%- endfor -%}
            </div>

            {%- for block in section.blocks -%}
              {%- if block.settings.row == row_index -%}
                {%- case block.type -%}
                  {%- when 'promo_product' -%}
                    {%- render 'promo-product', block: block -%}
                  {%- when 'promo_carousel' -%}
                    {%- render 'promo-carousel', block: block -%}
                {%- endcase -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if paginate.pages > 1 -%}
              <nav
                class="product-feed__pagination"
                aria-label="{{ 'general.pagination.label' | t }}"
              >
                {%- if paginate.previous -%}
                  <a href="{{ paginate.previous.url }}" class="product-feed__page-link">
                    &larr; {{ 'general.pagination.previous' | t }}
                  </a>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}" class="product-feed__page-link">
                      {{ part.title }}
                    </a>
                  {%- else -%}
                    <span class="product-feed__page-link product-feed__page-link--current" aria-current="page">
                      {{ part.title }}
                    </span>
                  {%- endif -%}
                {%- endfor -%}

                {%- if paginate.next -%}
                  <a href="{{ paginate.next.url }}" class="product-feed__page-link">
                    {{ 'general.pagination.next' | t }} &rarr;
                  </a>
                {%- endif -%}
              </nav>
            {%- endif -%}

          {%- endpaginate -%}

        {%- else -%}

          <p class="product-feed__empty">
            {{ 'collections.general.no_matches' | t }}
          </p>

        {%- endif -%}

      </div>
    </div>

  </div>

</div>

<script src="{{ 'product-filter.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Collection page",
  "tag": "section",
  "class": "section-collection-page",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used only if this section is placed outside the collection template."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Filter heading",
      "default": "Filters"
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sort control",
      "default": true,
      "info": "Turn off if sort is handled elsewhere."
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "promo_product",
      "name": "Sponsored Product",
      "settings": [
        {
          "type": "number",
          "id": "row",
          "label": "Insert after row",
          "info": "1 = after the first row of products, 2 = after the second row, etc."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "checkbox",
          "id": "sponsored",
          "label": "Show 'Sponsored' label",
          "default": true
        },
        {
          "type": "text",
          "id": "sponsor_name",
          "label": "Sponsor name (optional)",
          "info": "Defaults to \"Sponsored\" if left blank."
        }
      ]
    },
    {
      "type": "promo_carousel",
      "name": "Promo Carousel",
      "settings": [
        {
          "type": "number",
          "id": "row",
          "label": "Insert after row",
          "info": "1 = after the first row of products, 2 = after the second row, etc."
        },
        {
          "type": "select",
          "id": "content_type",
          "label": "Carousel content",
          "options": [
            { "value": "banner", "label": "Banners" },
            { "value": "product", "label": "Products" }
          ],
          "default": "product"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Carousel heading"
        },
        {
          "type": "collection",
          "id": "source_collection",
          "label": "Source collection (for products)"
        },
        {
          "type": "range",
          "id": "item_count",
          "label": "Items to show",
          "min": 2,
          "max": 12,
          "step": 1,
          "default": 6
        },
        {
          "type": "range",
          "id": "banner_count",
          "label": "Number of banners",
          "min": 1,
          "max": 3,
          "step": 1,
          "default": 3
        },
        {
          "type": "image_picker",
          "id": "banner_1_image",
          "label": "Banner 1 image"
        },
        {
          "type": "text",
          "id": "banner_1_heading",
          "label": "Banner 1 heading"
        },
        {
          "type": "url",
          "id": "banner_1_link",
          "label": "Banner 1 link"
        },
        {
          "type": "image_picker",
          "id": "banner_2_image",
          "label": "Banner 2 image"
        },
        {
          "type": "text",
          "id": "banner_2_heading",
          "label": "Banner 2 heading"
        },
        {
          "type": "url",
          "id": "banner_2_link",
          "label": "Banner 2 link"
        },
        {
          "type": "image_picker",
          "id": "banner_3_image",
          "label": "Banner 3 image"
        },
        {
          "type": "text",
          "id": "banner_3_heading",
          "label": "Banner 3 heading"
        },
        {
          "type": "url",
          "id": "banner_3_link",
          "label": "Banner 3 link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection page"
    }
  ]
}
{% endschema %}