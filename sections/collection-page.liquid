{% comment %}
  sections/collection-page.liquid

  Owns layout only. Resolves data once and passes it down to two snippets:
    - collection-features  → filters, sorting
    - collection-showroom  → products, articles, pages

  Assets:
    collection-page.css  — layout, features, showroom, card-article, card-page
    collection-page.js   — sort param preservation, filter accordions,
                           price filter apply, checkbox filter navigation

  NOTE: card-product-features.js is loaded globally in theme.liquid (line 122).
  Do NOT load it here — doing so double-registers Add to Cart, Wishlist,
  Compare, and Quick View handlers (each click fires twice).
{% endcomment %}

{%- liquid
  assign results_count    = collection.products_count
  assign related_articles = collection.metafields.custom.articles.value
  assign related_pages    = collection.metafields.custom.pages.value
-%}

{{ 'collection-page.css'        | asset_url | stylesheet_tag }}
{{ 'card-product-carousel.css'  | asset_url | stylesheet_tag }}

{%- paginate collection.products by 24 -%}

  <div class="collection-page">

    {%- render 'collection-features',
      collection:    collection,
      results_count: results_count
    -%}

    {%- render 'collection-showroom',
      collection:       collection,
      paginate:         paginate,
      related_articles: related_articles,
      related_pages:    related_pages
    -%}

  </div>

{%- endpaginate -%}

<script src="{{ 'collection-page.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Collection page",
  "tag": "section",
  "class": "section-collection-page",
  "settings": [],
  "presets": [
    {
      "name": "Collection page"
    }
  ]
}
{% endschema %}