{{ 'main-collection.css' | asset_url | stylesheet_tag }}
{{ 'main-collection.js' | asset_url | script_tag }}
{{ 'card-product-features.js' | asset_url | script_tag }}

{%- liquid
  assign show_title   = section.settings.show_title
  assign per_page     = section.settings.products_per_page | default: 20
  assign show_filters = section.settings.show_filters | default: true

  assign article_blocks = section.blocks | where: 'type', 'article'
  assign page_blocks    = section.blocks | where: 'type', 'page'
  assign article_count  = article_blocks.size
  assign page_count     = page_blocks.size

  assign active_tab = request.parameters.tab | default: 'products'
 

  assign show_banners = true
  assign active_filter_count = 0
  for filter in collection.filters
    assign active_filter_count = active_filter_count | plus: filter.active_values.size
  endfor
  if active_filter_count > 0
    assign show_banners = false
  endif
-%}

<div class="collection-page">

  {%- if show_title -%}
    <h1 class="collection-page__title">{{ collection.title }}</h1>
  {%- endif -%}

  <div class="collection-layout">
    {%- if show_filters and active_tab == 'products' -%}
      {% render 'collection-filters', open: true %}
    {%- endif -%}

    <div class="collection-main">

      <div class="collection-sticky-bar">
        {% render 'collection-toolbar',
          show_filters:  show_filters,
          active_tab:    active_tab,
          article_count: article_count,
          page_count:    page_count,
          per_page:      per_page,
          show_banners:  show_banners,
          context:       'collection',
          section:       section
        %}
        <div class="collection-active-filters" id="active-filters-bar" aria-label="Active filters"></div>
      </div>

      <div id="filters-backdrop" class="filters-backdrop"></div>

      {% render 'collection-showcase',
  active_tab:    active_tab,
  article_count: article_count,
  page_count:    page_count,
  per_page:      per_page,
  show_banners:  show_banners,
  context:       'collection',
  section:       section
%}

    </div>
  </div>

</div>

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show sidebar filters",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 20,
      "label": "Products per page"
    },
    {
      "type": "header",
      "content": "Product card features"
    },
    {
      "type": "checkbox",
      "id": "enable_quickview",
      "label": "Enable Quick View button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_atc",
      "label": "Enable Add to Cart button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_compare",
      "label": "Enable Compare checkbox",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_wishlist",
      "label": "Enable Wishlist button",
      "default": true
    },
    {
      "type": "header",
      "content": "Estimated arrival"
    },
    {
      "type": "checkbox",
      "id": "show_eta",
      "label": "Show estimated arrival on cards",
      "default": false
    },
    {
      "type": "text",
      "id": "eta_label",
      "label": "ETA label prefix",
      "default": "Est. arrival:"
    },
    {
      "type": "range",
      "id": "eta_days_min",
      "label": "Minimum days",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "eta_days_max",
      "label": "Maximum days",
      "min": 1,
      "max": 60,
      "step": 1,
      "default": 7
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "settings": [
        { "type": "article", "id": "article", "label": "Article" }
      ]
    },
    {
      "type": "page",
      "name": "Page",
      "settings": [
        { "type": "page", "id": "page", "label": "Page" }
      ]
    },
    {
      "type": "grid_banner",
      "name": "Grid Banner",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Banner image" },
        { "type": "url", "id": "link", "label": "Link URL" },
        { "type": "text", "id": "label", "label": "Aria label", "default": "Promotional banner" },
        { "type": "range", "id": "position", "min": 1, "max": 48, "step": 1, "default": 3, "label": "Insert before product #" },
        {
          "type": "select", "id": "span", "label": "Width",
          "options": [
            { "value": "1", "label": "1 column" },
            { "value": "2", "label": "2 columns" },
            { "value": "full", "label": "Full row" }
          ],
          "default": "2"
        },
        { "type": "text", "id": "overlay_text", "label": "Overlay text (optional)" }
      ]
    },
    {
      "type": "grid_carousel",
      "name": "Grid Carousel",
      "settings": [
        { "type": "collection", "id": "source_collection", "label": "Collection to show" },
        { "type": "range", "id": "position", "min": 1, "max": 48, "step": 1, "default": 4, "label": "Insert before product #" },
        {
          "type": "select", "id": "span", "label": "Width",
          "options": [
            { "value": "2", "label": "2 columns" },
            { "value": "full", "label": "Full row" }
          ],
          "default": "full"
        },
        { "type": "text", "id": "heading", "label": "Carousel heading", "default": "You might also like" },
        { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "default": 6, "label": "Products to show" }
      ]
    },
    {
      "type": "subcollection_carousel",
      "name": "Sub-collection Carousel",
      "settings": [
        { "type": "range", "id": "position", "min": 1, "max": 48, "step": 1, "default": 5, "label": "Insert before product #" },
        {
          "type": "select", "id": "span", "label": "Width",
          "options": [
            { "value": "2", "label": "2 columns" },
            { "value": "full", "label": "Full row" }
          ],
          "default": "full"
        },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by category" },
        {
          "type": "select", "id": "tile_style", "label": "Tile shape",
          "options": [
            { "value": "portrait", "label": "Portrait (tall)" },
            { "value": "square", "label": "Square" },
            { "value": "landscape", "label": "Landscape (wide)" }
          ],
          "default": "portrait"
        },
        { "type": "checkbox", "id": "show_product_count", "label": "Show product count on tile", "default": true },
        { "type": "url", "id": "view_all_url", "label": "\"View all\" link URL (optional)" },
        { "type": "text", "id": "view_all_label", "label": "\"View all\" link text", "default": "View all" },
        { "type": "header", "content": "Sub-collections (up to 8)" },
        { "type": "collection", "id": "subcollection_1", "label": "Sub-collection 1" },
        { "type": "collection", "id": "subcollection_2", "label": "Sub-collection 2" },
        { "type": "collection", "id": "subcollection_3", "label": "Sub-collection 3" },
        { "type": "collection", "id": "subcollection_4", "label": "Sub-collection 4" },
        { "type": "collection", "id": "subcollection_5", "label": "Sub-collection 5" },
        { "type": "collection", "id": "subcollection_6", "label": "Sub-collection 6" },
        { "type": "collection", "id": "subcollection_7", "label": "Sub-collection 7" },
        { "type": "collection", "id": "subcollection_8", "label": "Sub-collection 8" }
      ]
    }
  ],
  "presets": [
    { "name": "Collection Products" }
  ]
}
{% endschema %}