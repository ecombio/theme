{% comment %}
  Section: collection-banner (HYPER Theme)
  Now with full rich text editor control — no collection data, no metafields.
{% endcomment %}

{{ 'collection-banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign desktop_image = section.settings.default_image
  assign mobile_image  = section.settings.default_image_mobile
  assign has_image     = false

  if desktop_image != blank or mobile_image != blank
    assign has_image = true
  endif

  assign layout       = section.settings.image_position
  assign text_align   = section.settings.text_alignment
  assign img_height   = section.settings.image_height
  assign parallax     = section.settings.enable_parallax
  assign parallax_dir = section.settings.parallax_direction
-%}

<div
  class="collection-banner collection-banner--layout-{{ layout }} collection-banner--height-{{ img_height }}{% if parallax %} collection-banner--parallax collection-banner--parallax-{{ parallax_dir }}{% endif %}{% unless has_image %} collection-banner--no-image{% endunless %}"
  data-section-id="{{ section.id }}"
  style="--cb-pt: {{ section.settings.padding_top | default: 28 }}px; --cb-pb: {{ section.settings.padding_bottom | default: 28 }}px;"
>

  {%- if has_image and layout != 'background' -%}
    <div class="collection-banner__media">

      {%- if mobile_image != blank -%}
        <div class="collection-banner__img-wrap collection-banner__img-wrap--mobile">
          {{
            mobile_image
            | image_url: width: 800
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              widths: '400, 600, 800',
              class: 'collection-banner__img',
              alt: section.settings.banner_richtext | strip_html | truncate: 80 | escape
          }}
        </div>
      {%- endif -%}

      <div class="collection-banner__img-wrap{% if mobile_image != blank %} collection-banner__img-wrap--desktop{% endif %}{% if parallax %} collection-banner__img-wrap--parallax{% endif %}">
        {{
          desktop_image
          | image_url: width: 1400
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '600, 800, 1000, 1200, 1400',
            class: 'collection-banner__img',
            alt: section.settings.banner_richtext | strip_html | truncate: 80 | escape
        }}
      </div>

    </div>
  {%- elsif has_image and layout == 'background' -%}
    <div class="collection-banner__bg{% if parallax %} collection-banner__bg--parallax{% endif %}">
      {{
        desktop_image
        | image_url: width: 1600
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '800, 1200, 1600',
          class: 'collection-banner__bg-img',
          alt: ''
      }}
      {%- if section.settings.overlay_opacity > 0 -%}
        <div
          class="collection-banner__overlay"
          style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"
        ></div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.settings.banner_richtext != blank -%}
    <div class="collection-banner__content collection-banner__content--{{ text_align }}">
      <div class="collection-banner__custom-content rte">
        {{ section.settings.banner_richtext }}
      </div>
    </div>
  {%- endif -%}

</div>

{%- if parallax -%}
<script>
(function () {
  const banner = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!banner) return;
  const imgs = banner.querySelectorAll('.collection-banner__img-wrap--parallax, .collection-banner__bg--parallax');
  if (!imgs.length || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const dir = '{{ parallax_dir }}';
  function onScroll() {
    const rect   = banner.getBoundingClientRect();
    const center = rect.top + rect.height / 2 - window.innerHeight / 2;
    const pct    = center / window.innerHeight;
    const px     = pct * 40;

    imgs.forEach((el) => {
      if (dir === 'vertical')   el.style.transform = `translateY(${px}px)`;
      if (dir === 'horizontal') el.style.transform = `translateX(${px}px)`;
      if (dir === 'zoom')       el.style.transform = `scale(${1 + Math.abs(pct) * 0.08})`;
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Collection banner",
  "settings": [
    {
      "type": "header",
      "content": "Banner content"
    },
    {
      "type": "richtext",
      "id": "banner_richtext",
      "label": "Banner content",
      "info": "Full rich text editor. Put whatever you want here — headings, offers, buttons, etc. This completely replaces collection title/description."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 28
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Banner image"
    },
    {
      "type": "image_picker",
      "id": "default_image",
      "label": "Default image (desktop)"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "background", "label": "Background (full bleed)" }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "image_height",
      "label": "Image height",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "large", "label": "Large" },
        { "value": "extra_medium", "label": "Extra medium" },
        { "value": "medium", "label": "Medium" },
        { "value": "small", "label": "Small" },
        { "value": "extra_small", "label": "Extra small" }
      ],
      "default": "extra_small"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Background overlay opacity (only for Background layout)",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Parallax"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "Enable parallax effect",
      "default": false
    },
    {
      "type": "select",
      "id": "parallax_direction",
      "label": "Parallax direction",
      "options": [
        { "value": "vertical", "label": "Vertical" },
        { "value": "horizontal", "label": "Horizontal" },
        { "value": "zoom", "label": "Zoom" }
      ],
      "default": "vertical"
    },
    {
      "type": "header",
      "content": "Mobile image (optional)"
    },
    {
      "type": "image_picker",
      "id": "default_image_mobile",
      "label": "Mobile image",
      "info": "Falls back to desktop image if left blank"
    }
  ],
  "presets": [
    {
      "name": "Collection banner"
    }
  ]
}
{% endschema %}