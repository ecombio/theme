{% comment %}
  sections/collection-products.liquid
  Primary collection grid with in-feed promo blocks (promo_product + promo_carousel).
  Uses the same row-insertion pattern as Discover.
{% endcomment %}

{{ 'collection-products.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign columns     = section.settings.columns | default: 4
  assign per_page    = section.settings.products_per_page | default: 24
  assign product_row_index = 1
-%}

<section class="collection-products" data-section-id="{{ section.id }}">

  <div class="collection-products__header">
    <h1 class="collection-products__title">{{ collection.title }}</h1>
    <span class="collection-products__count">{{ collection.products_count }} products</span>
  </div>

  <div class="collection-products__layout">

    {# ── Filters (sidebar + mobile drawer) ── #}
    <div class="collection-products__sidebar">
      {%- render 'collection-filter', collection: collection, context: 'sidebar' -%}
    </div>

    {# ── Product Grid + In-Feed Promos ── #}
    <div class="collection-products__main">

      {%- paginate collection.products by per_page -%}

        <div class="product-grid" style="--grid-columns: {{ columns }};" data-product-grid>
          {%- for product in collection.products -%}

            <div class="product-grid__item">
              {%- render 'product-card', product: product -%}
            </div>

            {%- assign position_mod = forloop.index | modulo: columns -%}
            {%- if position_mod == 0 and forloop.last == false -%}

              </div>

              {# ── Promo blocks after this row ── #}
              <div class="promo-blocks" data-promo-row="{{ product_row_index }}">
                {%- for block in section.blocks -%}
                  {%- if block.settings.row == product_row_index -%}
                    {%- case block.type -%}
                      {%- when 'promo_product' -%}
                        {%- render 'promo-product', block: block -%}
                      {%- when 'promo_carousel' -%}
                        {%- render 'promo-carousel', block: block -%}
                    {%- endcase -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>

              {%- assign product_row_index = product_row_index | plus: 1 -%}
              <div class="product-grid" data-product-grid>

            {%- endif -%}

          {%- endfor -%}
        </div>

        {# ── Trailing promo blocks (after last/partial row) ── #}
        <div class="promo-blocks" data-promo-row="{{ product_row_index }}">
          {%- for block in section.blocks -%}
            {%- if block.settings.row == product_row_index -%}
              {%- case block.type -%}
                {%- when 'promo_product' -%}
                  {%- render 'promo-product', block: block -%}
                {%- when 'promo_carousel' -%}
                  {%- render 'promo-carousel', block: block -%}
              {%- endcase -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          {%- render 'pagination', paginate: paginate -%}
        {%- endif -%}

      {%- endpaginate -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Products",
  "class": "section-collection-products",
  "settings": [
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "promo_product",
      "name": "Promo Product",
      "settings": [
        {
          "type": "number",
          "id": "row",
          "label": "Insert after row",
          "info": "1 = after first row, 2 = after second row, etc."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "checkbox",
          "id": "sponsored",
          "label": "Show 'Sponsored' label",
          "default": true
        },
        {
          "type": "text",
          "id": "sponsor_name",
          "label": "Sponsor name (optional)"
        }
      ]
    },
    {
      "type": "promo_carousel",
      "name": "Promo Carousel",
      "settings": [
        {
          "type": "number",
          "id": "row",
          "label": "Insert after row",
          "info": "1 = after first row, 2 = after second row, etc."
        },
        {
          "type": "select",
          "id": "content_type",
          "label": "Carousel content",
          "options": [
            { "value": "product", "label": "Products" },
            { "value": "banner", "label": "Banners" }
          ],
          "default": "product"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "collection",
          "id": "source_collection",
          "label": "Source collection (for products)"
        },
        {
          "type": "range",
          "id": "item_count",
          "label": "Items to show",
          "min": 2,
          "max": 12,
          "default": 6
        },
        {
          "type": "range",
          "id": "banner_count",
          "label": "Number of banners",
          "min": 1,
          "max": 3,
          "default": 3
        },
        { "type": "image_picker", "id": "banner_1_image", "label": "Banner 1 image" },
        { "type": "text", "id": "banner_1_heading", "label": "Banner 1 heading" },
        { "type": "url", "id": "banner_1_link", "label": "Banner 1 link" },
        { "type": "image_picker", "id": "banner_2_image", "label": "Banner 2 image" },
        { "type": "text", "id": "banner_2_heading", "label": "Banner 2 heading" },
        { "type": "url", "id": "banner_2_link", "label": "Banner 2 link" },
        { "type": "image_picker", "id": "banner_3_image", "label": "Banner 3 image" },
        { "type": "text", "id": "banner_3_heading", "label": "Banner 3 heading" },
        { "type": "url", "id": "banner_3_link", "label": "Banner 3 link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Products",
      "blocks": []
    }
  ]
}
{% endschema %}