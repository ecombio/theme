{% comment %}
  snippets/cart-header.liquid
  Minimal header shell rendered only when the cart is empty.
  Replaces the global theme header for this state.
  Usage: {%- render 'cart-header' -%}
{% endcomment %}

<header class="cart-header" role="banner">

  <a class="cart-header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }} home">
    <div class="cart-header__logo-mark" aria-hidden="true">
      {%- if settings.logo != blank -%}
        <img
          src="{{ settings.logo | image_url: width: 40 }}"
          alt="{{ shop.name | escape }}"
          width="20"
          height="20"
          loading="eager"
          class="cart-header__logo-img"
        >
      {%- else -%}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
             stroke="white" stroke-width="2.5" stroke-linecap="round"
             stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
      {%- endif -%}
    </div>
    <span class="cart-header__logo-name">{{ shop.name }}</span>
  </a>

  <span class="cart-header__page-label" aria-hidden="true">Cart</span>

  <a class="cart-header__back" href="{{ routes.all_products_collection_url }}">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
         stroke-linejoin="round" aria-hidden="true" focusable="false">
      <line x1="19" y1="12" x2="5" y2="12"/>
      <polyline points="12 19 5 12 12 5"/>
    </svg>
    Keep shopping
  </a>

</header>
