{%- comment -%}
  snippets/article-card.liquid

  Renders a single article card for the article feed tab on collection pages.

  Required variables
  ──────────────────
  article  {object}  — Shopify article object

  Optional variables
  ──────────────────
  show_excerpt  {boolean}  — show article excerpt (default: true)
  show_author   {boolean}  — show author name (default: false)
  image_ratio   {string}   — 'landscape' | 'square' | 'portrait' (default: 'landscape')

  Usage
  ─────
  {%- render 'article-card',
      article:      article,
      show_excerpt: true,
      show_author:  false,
      image_ratio:  'landscape'
  -%}
{%- endcomment -%}

{%- liquid
  assign show_excerpt = show_excerpt | default: true
  assign show_author  = show_author  | default: false
  assign image_ratio  = image_ratio  | default: 'landscape'

  case image_ratio
    when 'square'
      assign ratio_value = '1/1'
    when 'portrait'
      assign ratio_value = '3/4'
    else
      assign ratio_value = '16/9'
  endcase

  assign read_time_words  = article.content | strip_html | split: ' ' | size
  assign read_time_minutes = read_time_words | divided_by: 200
  if read_time_minutes < 1
    assign read_time_minutes = 1
  endif
-%}

<article class="article-card" aria-label="{{ article.title | escape }}">
  <a class="article-card__link" href="{{ article.url }}" tabindex="-1" aria-hidden="true">
    <div class="article-card__img-zone" style="--article-img-ratio: {{ ratio_value }};">
      {%- if article.image != blank -%}
        {{
          article.image
          | image_url: width: 800
          | image_tag:
            class: 'article-card__img',
            loading: 'lazy',
            widths: '400,600,800',
            sizes: '(max-width: 767px) calc(100vw - 3rem), calc((100vw - 16rem) / 3)',
            alt: article.image.alt | default: article.title | escape
        }}
      {%- else -%}
        <div class="article-card__img-placeholder" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 6h16M4 10h10M4 14h12M4 18h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
      {%- endif -%}
      <div class="article-card__progress-bar" aria-hidden="true"></div>
    </div>
  </a>

  <div class="article-card__body">
    <div class="article-card__meta">
      {%- if article.tags.size > 0 -%}
        <span class="article-card__tag">{{ article.tags | first }}</span>
        <span class="article-card__meta-sep" aria-hidden="true">·</span>
      {%- endif -%}
      <time class="article-card__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
        {{- article.published_at | date: '%b %-d, %Y' -}}
      </time>
      <span class="article-card__meta-sep" aria-hidden="true">·</span>
      <span class="article-card__read-time">{{ read_time_minutes }} min read</span>
      {%- if show_author and article.author != blank -%}
        <span class="article-card__meta-sep" aria-hidden="true">·</span>
        <span class="article-card__author">{{ article.author }}</span>
      {%- endif -%}
    </div>

    <h3 class="article-card__title">
      <a class="article-card__title-link" href="{{ article.url }}">{{ article.title | escape }}</a>
    </h3>

    {%- if show_excerpt -%}
      {%- assign _excerpt_source = article.excerpt | default: article.content -%}
      {%- if _excerpt_source != blank -%}
        <p class="article-card__excerpt">
          {{- _excerpt_source | strip_html | truncate: 120 -}}
        </p>
      {%- endif -%}
    {%- endif -%}

    <a class="article-card__cta" href="{{ article.url }}" aria-label="Read {{ article.title | escape }}">
      Read article
      <svg class="article-card__cta-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</article>
