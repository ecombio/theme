{%- comment -%}
  snippets/collection-feed.liquid
  Owns the tab panel shell — products panel and articles panel.
  Tab switching logic lives in assets/collection-feed.js.

  Expects:
    active_tab  {String}  'products' | 'articles' — passed from collection.liquid

  Renders:
    product-feed              → products panel
    article-feed               → articles panel
    collection-after-item-lists → related articles + after-items content,
                                   shown regardless of active tab

  JS hook attributes:
    [data-panel]  — panel switching target, read by collection-feed.js
{%- endcomment -%}

{{ 'collection-feed.css' | asset_url | stylesheet_tag }}

<div class="collection-feed" data-collection-feed>

  {%- comment -%} Products panel {%- endcomment -%}
  <div
    id="panel-products"
    class="collection-feed__panel"
    role="tabpanel"
    aria-labelledby="tab-products"
    data-panel="products"
    {%- if active_tab != 'products' %} hidden{%- endif %}
  >
    {%- render 'product-feed' -%}
  </div>

  {%- comment -%} Articles panel {%- endcomment -%}
  <div
    id="panel-articles"
    class="collection-feed__panel"
    role="tabpanel"
    aria-labelledby="tab-articles"
    data-panel="articles"
    {%- if active_tab != 'articles' %} hidden{%- endif %}
  >
    {%- render 'article-feed' -%}
  </div>

  {%- comment -%} Related articles + after-items — always visible, not tab-dependent {%- endcomment -%}
  {%- render 'related-articles' -%}
  {%- render 'after-items' -%}

</div>