{% comment %}
  Header Menu (snippet)
  File: snippets/header-menu.liquid

  Renders the desktop menu bar and the mobile nav drawer. This is a
  presentation-only snippet — it has no schema of its own. The blocks and
  settings that drive it (single/highlight/dropdown/mega/flyout block types,
  and the mobile navigation link list) live in the parent section's schema
  (sections/main-header.liquid) and are passed in as parameters.

  Usage (from sections/main-header.liquid):
    {%- render 'header-menu', blocks: section.blocks, nav_menu: nav_menu -%}

  Params:
    blocks    — section.blocks array from the parent section. Blocks of type
                single | highlight | dropdown | mega | flyout are rendered in
                the desktop menu bar; other block types are ignored here.
    nav_menu  — a linklist object used to populate the mobile drawer
                (3-level accordion: top links → category headings → nested links)

  Assets used (load these once from the parent section, not here):
    assets/header-menu.css
    assets/header-mega-menu.js
    assets/flyout-panel.js
    assets/flyout-menu.js
    assets/flyout.js
{% endcomment %}

{%- comment -%} ═══════════════════════════════════════
    DESKTOP MENU BAR
═══════════════════════════════════════ {%- endcomment -%}

{%- assign menu_blocks_count = 0 -%}
{%- for block in blocks -%}
  {%- if block.type == 'single' or block.type == 'highlight' or block.type == 'dropdown' or block.type == 'mega' or block.type == 'flyout' -%}
    {%- assign menu_blocks_count = menu_blocks_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- if menu_blocks_count > 0 -%}

<nav class="menu-bar" aria-label="Primary navigation">
  <div class="menu-bar__container page-width">
    <ul class="menu-bar__list">

      {%- for block in blocks -%}
        {%- case block.type -%}

          {%- when 'single' -%}
            <li class="menu-bar__item" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: '#' }}" class="menu-bar__link">
                {%- if block.settings.icon != blank -%}
                  <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
                {%- endif -%}
                {{ block.settings.label | default: 'Link' }}
              </a>
            </li>

          {%- when 'highlight' -%}
            <li class="menu-bar__item menu-bar__item--highlight" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: '#' }}" class="menu-bar__link menu-bar__link--highlight">
                {%- if block.settings.icon != blank -%}
                  <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
                {%- endif -%}
                <span class="reversed-link">{{ block.settings.label | default: 'On Sale' }}</span>
                <svg class="star star-1" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true"><path d="M6 0L7.854 4.146L12 6L7.854 7.854L6 12L4.146 7.854L0 6L4.146 4.146L6 0Z" fill="currentColor"/></svg>
                <svg class="star star-2" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true"><path d="M6 0L7.854 4.146L12 6L7.854 7.854L6 12L4.146 7.854L0 6L4.146 4.146L6 0Z" fill="currentColor"/></svg>
                <svg class="star star-3" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true"><path d="M6 0L7.854 4.146L12 6L7.854 7.854L6 12L4.146 7.854L0 6L4.146 4.146L6 0Z" fill="currentColor"/></svg>
              </a>
            </li>

          {%- when 'dropdown' -%}
            {%- assign dd_menu = block.settings.menu -%}
            <li class="menu-bar__item menu-bar__item--has-dropdown" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: dd_menu.links.first.url | default: '#' }}"
                 class="menu-bar__link menu-bar__link--caret"
                 aria-haspopup="true"
                 aria-expanded="false">
                {%- if block.settings.icon != blank -%}
                  <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
                {%- endif -%}
                {{ block.settings.label | default: dd_menu.title | default: 'Menu' }}
                <svg class="icon-caret-down" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M16.25 7.5L10 13.75L3.75 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              {%- if dd_menu != blank and dd_menu.links.size > 0 -%}
                <div class="dropdown" role="region">
                  <div class="dropdown__container">
                    <ul class="dropdown__nav" role="list">
                      {%- for link in dd_menu.links -%}
                        <li class="dropdown__item{% if link.links.size > 0 %} dropdown__item--has-child{% endif %}">
                          {%- if link.links.size > 0 -%}
                            <span class="dropdown__link dropdown__link--parent">
                              {{ link.title }}
                              <svg class="icon-caret-right" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                                <path d="M7.5 3.75L13.75 10L7.5 16.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            </span>
                            <div class="dropdown dropdown--child">
                              <div class="dropdown__container">
                                <ul class="dropdown__nav" role="list">
                                  {%- for child in link.links -%}
                                    <li><a href="{{ child.url }}" class="dropdown__link">{{ child.title }}</a></li>
                                  {%- endfor -%}
                                </ul>
                              </div>
                            </div>
                          {%- else -%}
                            <a href="{{ link.url }}" class="dropdown__link">{{ link.title }}</a>
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                </div>
              {%- endif -%}
            </li>

          {%- when 'mega' -%}
            {%- assign mega_menu = block.settings.menu -%}
            <li class="menu-bar__item menu-bar__item--has-mega" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: mega_menu.links.first.url | default: '#' }}"
                 class="menu-bar__link menu-bar__link--caret"
                 aria-haspopup="true"
                 aria-expanded="false">
                {%- if block.settings.icon != blank -%}
                  <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
                {%- endif -%}
                {{ block.settings.label | default: mega_menu.title | default: 'Menu' }}
                <svg class="icon-caret-down" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M16.25 7.5L10 13.75L3.75 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              {%- if mega_menu != blank and mega_menu.links.size > 0 -%}
                <div class="mega-menu" role="region">
                  {%- render 'header-mega-menu', menu: mega_menu, show_products: block.settings.show_products -%}
                </div>
              {%- endif -%}
            </li>

          {%- when 'flyout' -%}
            {%- assign flyout_menu = block.settings.menu -%}
            <li class="menu-bar__item menu-bar__item--has-flyout" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: '#' }}"
                 class="menu-bar__link menu-bar__link--flyout"
                 aria-haspopup="true"
                 aria-expanded="false">
                {%- if block.settings.icon != blank -%}
                  <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
                {%- endif -%}
                {{ block.settings.label | default: 'Browse all categories' }}
                <svg class="icon-caret-down" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M16.25 7.5L10 13.75L3.75 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              {%- if flyout_menu != blank and flyout_menu.links.size > 0 -%}
                <div class="mega-menu mega-menu--flyout" role="region">
                  {%- render 'flyout', menu: flyout_menu, uid: block.id -%}
                </div>
              {%- endif -%}
            </li>

        {%- endcase -%}
      {%- endfor -%}

    </ul>
  </div>
</nav>

{%- endif -%}

{%- comment -%} ═══════════════════════════════════════
    MOBILE / TABLET DRAWER NAV
    3-level accordion: top links → category headings → nested links
═══════════════════════════════════════ {%- endcomment -%}

<div class="mobile-nav" id="mobile-nav" aria-hidden="true">
  <div class="mobile-nav__overlay" id="mobile-nav-overlay"></div>

  <nav class="mobile-nav__panel" role="navigation" aria-label="Mobile navigation">

    <div class="mobile-nav__header">
      <span class="mobile-nav__header-label">Menu</span>
      <button class="mobile-nav__close" id="mobile-nav-close" aria-label="Close navigation">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <ul class="mobile-nav__list" role="list">
      {%- for link in nav_menu.links -%}

        {%- if link.links.size > 0 -%}
          <li class="mobile-nav__item mobile-nav__item--has-children{%- if link.active %} is-active{%- endif %}">

            <div class="mobile-nav__row">
              <a href="{{ link.url }}"
                 class="mobile-nav__link"
                 {% if link.current %}aria-current="page"{% endif %}>
                {{ link.title }}
              </a>
              <button class="mobile-nav__toggle"
                      aria-expanded="false"
                      aria-label="Expand {{ link.title }}">
                <svg class="mobile-nav__chevron" width="16" height="16"
                     viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor"
                        stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            <ul class="mobile-nav__sub" role="list" hidden>
              {%- for child in link.links -%}

                {%- if child.links.size > 0 -%}
                  <li class="mobile-nav__item mobile-nav__item--has-children mobile-nav__item--l3">
                    <div class="mobile-nav__row">
                      <a href="{{ child.url }}"
                         class="mobile-nav__link mobile-nav__link--sub"
                         {% if child.current %}aria-current="page"{% endif %}>
                        {{ child.title }}
                      </a>
                      <button class="mobile-nav__toggle"
                              aria-expanded="false"
                              aria-label="Expand {{ child.title }}">
                        <svg class="mobile-nav__chevron" width="14" height="14"
                             viewBox="0 0 20 20" fill="none" aria-hidden="true">
                          <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor"
                                stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </div>
                    <ul class="mobile-nav__sub mobile-nav__sub--l3" role="list" hidden>
                      {%- for grandchild in child.links -%}
                        <li>
                          <a href="{{ grandchild.url }}"
                             class="mobile-nav__link mobile-nav__link--deep"
                             {% if grandchild.current %}aria-current="page"{% endif %}>
                            {{ grandchild.title }}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </li>

                {%- else -%}
                  <li class="mobile-nav__item">
                    <a href="{{ child.url }}"
                       class="mobile-nav__link mobile-nav__link--sub"
                       {% if child.current %}aria-current="page"{% endif %}>
                      {{ child.title }}
                    </a>
                  </li>
                {%- endif -%}

              {%- endfor -%}
            </ul>
          </li>

        {%- else -%}
          <li class="mobile-nav__item{% if link.active %} is-active{% endif %}">
            <a href="{{ link.url }}"
               class="mobile-nav__link"
               {% if link.current %}aria-current="page"{% endif %}>
              {{ link.title }}
            </a>
          </li>
        {%- endif -%}

      {%- endfor -%}
    </ul>

  </nav>
</div>