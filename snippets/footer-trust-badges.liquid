{%- liquid
  assign show_any = false
  if section.settings.trust_gdpr or section.settings.trust_soc2 or section.settings.trust_iso or section.settings.trust_secure
    assign show_any = true
  endif
-%}

{%- if show_any -%}
  <ul class="fbb__badges" role="list" aria-label="Trust and compliance badges">

    {%- if section.settings.trust_gdpr -%}
      <li class="fbb__badge fbb__badge--gdpr">
        <svg class="fbb__badge-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7A9 9 0 1 0 18 10.5a9 9 0 0 0-12-8.5z"/>
        </svg>
        <span class="fbb__badge-label">GDPR Compliant</span>
      </li>
    {%- endif -%}

    {%- if section.settings.trust_soc2 -%}
      <li class="fbb__badge fbb__badge--soc2">
        <svg class="fbb__badge-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M4.5 19.5h11a2 2 0 0 0 2-2v-15a2 2 0 0 0-2-2h-11a2 2 0 0 0-2 2v15a2 2 0 0 0 2 2z"/>
        </svg>
        <span class="fbb__badge-label">SOC 2</span>
      </li>
    {%- endif -%}

    {%- if section.settings.trust_iso -%}
      <li class="fbb__badge fbb__badge--iso">
        <svg class="fbb__badge-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5z"/>
        </svg>
        <span class="fbb__badge-label">ISO Certified</span>
      </li>
    {%- endif -%}

    {%- if section.settings.trust_secure -%}
      <li class="fbb__badge fbb__badge--secure">
        <svg class="fbb__badge-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25z"/>
        </svg>
        <span class="fbb__badge-label">Secure Payments</span>
      </li>
    {%- endif -%}

  </ul>
{%- endif -%}
