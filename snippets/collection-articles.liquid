{% comment %}
  Snippet: collection-articles
  Called by: snippets/collection-showcase.liquid
  Calls:     snippets/card-article.liquid

  Context-aware: collection page renders article blocks added by the merchant
  in the section editor; search page loops search.results filtered to articles.

  Parameters:
    - context {String}  — 'collection' | 'search'
    - section {Object}  — for block access on collection pages
{% endcomment %}

{%- if context == 'search' -%}

  {%- assign article_results = search.results | where: 'object_type', 'article' -%}
  {%- if article_results.size > 0 -%}
    <div class="collection-articles-grid">
      {%- for article in article_results -%}
        {% render 'card-article', article: article %}
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="collection-empty">No articles found for &ldquo;{{ search.terms | escape }}&rdquo;.</p>
  {%- endif -%}

{%- else -%}

  {%- assign article_blocks = section.blocks | where: 'type', 'article' -%}
  {%- if article_blocks.size > 0 -%}
    <div class="collection-articles-grid">
      {%- for block in article_blocks -%}
        {%- assign article = block.settings.article -%}
        {%- if article != blank -%}
          {% render 'card-article', article: article %}
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="collection-empty">No articles have been added to this collection yet.</p>
  {%- endif -%}

{%- endif -%}
