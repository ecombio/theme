{% comment %}
  Snippet: article-summarizer.liquid
  Usage:   {% render 'article-summarizer', article: article %}
  Place directly after {{ article.content }} in your article template.

  On click:
    1. Resolves the prompt: uses article.metafields.custom.ai_summarizer if set,
       otherwise falls back to a built-in default prompt.
    2. Appends the prompt as ?q= to the AI URL so it pre-fills the chat input.
    3. Also copies it to clipboard as a reliable fallback.
    4. Shows a toast with clear next-step instructions.

  No API keys. No backend. No streaming.
{% endcomment %}

{% assign excerpt = article.content | strip_html | strip_newlines | truncate: 2000 %}
{% assign custom_prompt = article.metafields.custom.ai_summarizer | escape %}

<div
  class="ma-summarizer"
  data-title="{{ article.title | escape }}"
  data-excerpt="{{ excerpt | escape }}"
  {% if custom_prompt != blank %}data-custom-prompt="{{ custom_prompt }}"{% endif %}
>
  <div class="ma-summarizer__inner">
    <div class="ma-summarizer__header">
      <span class="ma-summarizer__eyebrow">AI Summary</span>
      <p class="ma-summarizer__heading">Too long? Get the gist in seconds.</p>
      <p class="ma-summarizer__subtext">Pick an AI — the prompt loads automatically in the new tab.</p>
    </div>

    <div class="ma-summarizer__buttons">

      <button
        class="ma-summarizer__btn ma-summarizer__btn--claude"
        data-ai="claude"
        data-url="https://claude.ai/new"
        type="button"
        aria-label="Summarize with Claude"
      >
        <span class="ma-summarizer__btn-icon" aria-hidden="true">
          <!--
            Claude / Anthropic mark: a swept wedge with a concave notch on the
            upper-left edge. The shape narrows to a rounded tip at top-right and
            has a rectangular slot cut from its lower-left body.
          -->
          <svg viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="
              M148 6
              C127 5 112 20 112 41
              L112 68
              L90 68
              C55 68 27 96 27 131
              C27 158 51 173 74 164
              L79 162
              C93 157 101 143 101 128
              L101 101
              L127 101
              C148 101 166 88 173 69
              L194 13
              C199 0 175 -2 148 6Z
            " fill="currentColor"/>
          </svg>
        </span>
        <span class="ma-summarizer__btn-label">
          <span class="ma-summarizer__btn-name">Claude</span>
          <span class="ma-summarizer__btn-hint">by Anthropic</span>
        </span>
        <span class="ma-summarizer__btn-arrow" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <button
        class="ma-summarizer__btn ma-summarizer__btn--chatgpt"
        data-ai="chatgpt"
        data-url="https://chatgpt.com/"
        type="button"
        aria-label="Summarize with ChatGPT"
      >
        <span class="ma-summarizer__btn-icon" aria-hidden="true">
          <!--
            OpenAI mark: six thick rounded arms radiating from the centre,
            each rotated 60°. Uses a <use> element to avoid repeating the path.
          -->
          <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <rect id="oai-arm" x="44" y="5" width="12" height="38" rx="6" fill="currentColor"/>
            </defs>
            <use href="#oai-arm" transform="rotate(0   50 50)"/>
            <use href="#oai-arm" transform="rotate(60  50 50)"/>
            <use href="#oai-arm" transform="rotate(120 50 50)"/>
            <use href="#oai-arm" transform="rotate(180 50 50)"/>
            <use href="#oai-arm" transform="rotate(240 50 50)"/>
            <use href="#oai-arm" transform="rotate(300 50 50)"/>
          </svg>
        </span>
        <span class="ma-summarizer__btn-label">
          <span class="ma-summarizer__btn-name">ChatGPT</span>
          <span class="ma-summarizer__btn-hint">by OpenAI</span>
        </span>
        <span class="ma-summarizer__btn-arrow" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <button
        class="ma-summarizer__btn ma-summarizer__btn--gemini"
        data-ai="gemini"
        data-url="https://gemini.google.com/app"
        type="button"
        aria-label="Summarize with Gemini"
      >
        <span class="ma-summarizer__btn-icon" aria-hidden="true">
          <!--
            Gemini star: the real mark uses a 4-pointed star where the path
            curves inward sharply at the diagonals. Modelled as a single closed
            path: top point → right point → bottom point → left point, with
            strong cubic bezier pulls that create the characteristic pinch.
          -->
          <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="gem-g" x1="0" y1="0" x2="100" y2="100" gradientUnits="userSpaceOnUse">
                <stop offset="0%"   stop-color="#4285F4"/>
                <stop offset="50%"  stop-color="#9B72CB"/>
                <stop offset="100%" stop-color="#D96570"/>
              </linearGradient>
            </defs>
            <!--
              4-pointed star: top(50,2) right(98,50) bottom(50,98) left(2,50)
              Control points pulled tight toward centre on diagonal approach,
              and pushed wide on the cardinal approach to make each arm fat.
            -->
            <path d="
              M50,2
              C53,26 74,47 98,50
              C74,53 53,74 50,98
              C47,74 26,53 2,50
              C26,47 47,26 50,2
              Z
            " fill="url(#gem-g)"/>
          </svg>
        </span>
        <span class="ma-summarizer__btn-label">
          <span class="ma-summarizer__btn-name">Gemini</span>
          <span class="ma-summarizer__btn-hint">by Google</span>
        </span>
        <span class="ma-summarizer__btn-arrow" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <button
        class="ma-summarizer__btn ma-summarizer__btn--grok"
        data-ai="grok"
        data-url="https://grok.com/"
        type="button"
        aria-label="Summarize with Grok"
      >
        <span class="ma-summarizer__btn-icon" aria-hidden="true">
          <!--
            X / Grok mark: two thick diagonal bands crossing at centre.
            Each band is a parallelogram (4 points) with angled ends —
            not a simple line. This matches the actual X Corp / xAI logo geometry.
          -->
          <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Top-left to bottom-right band -->
            <polygon points="8,4 32,4 92,96 68,96" fill="currentColor"/>
            <!-- Top-right to bottom-left band -->
            <polygon points="68,4 92,4 32,96 8,96" fill="currentColor"/>
          </svg>
        </span>
        <span class="ma-summarizer__btn-label">
          <span class="ma-summarizer__btn-name">Grok</span>
          <span class="ma-summarizer__btn-hint">by xAI</span>
        </span>
        <span class="ma-summarizer__btn-arrow" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <button
        class="ma-summarizer__btn ma-summarizer__btn--perplexity"
        data-ai="perplexity"
        data-url="https://www.perplexity.ai/"
        type="button"
        aria-label="Summarize with Perplexity"
      >
        <span class="ma-summarizer__btn-icon" aria-hidden="true">
          <!--
            Perplexity mark: a rounded-corner hexagon (pointed top & bottom)
            with a vertical stem down the centre and two short horizontal bars
            crossing it — one near the top, one near the bottom.
            This matches their actual logomark geometry.
          -->
          <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Outer hexagon: pointed top + bottom, flat left + right sides -->
            <path d="M50,4 L88,26 L88,74 L50,96 L12,74 L12,26 Z"
                  fill="none" stroke="currentColor" stroke-width="8" stroke-linejoin="round"/>
            <!-- Centre vertical line -->
            <line x1="50" y1="4" x2="50" y2="96"
                  stroke="currentColor" stroke-width="8" stroke-linecap="round"/>
            <!-- Upper horizontal crossbar -->
            <line x1="12" y1="32" x2="88" y2="32"
                  stroke="currentColor" stroke-width="8" stroke-linecap="round"/>
            <!-- Lower horizontal crossbar -->
            <line x1="12" y1="68" x2="88" y2="68"
                  stroke="currentColor" stroke-width="8" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="ma-summarizer__btn-label">
          <span class="ma-summarizer__btn-name">Perplexity</span>
          <span class="ma-summarizer__btn-hint">by Perplexity AI</span>
        </span>
        <span class="ma-summarizer__btn-arrow" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <button
        class="ma-summarizer__btn ma-summarizer__btn--mistral"
        data-ai="mistral"
        data-url="https://chat.mistral.ai/"
        type="button"
        aria-label="Summarize with Mistral"
      >
        <span class="ma-summarizer__btn-icon" aria-hidden="true">
          <!--
            Mistral mark: three horizontal rectangular bars stacked vertically,
            all left-aligned, with the bottom bar widest and top bar narrowest.
            This matches Mistral AI's actual logomark exactly.
          -->
          <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Bottom bar — full width -->
            <rect x="8"  y="72" width="84" height="20" rx="4" fill="currentColor"/>
            <!-- Middle bar — medium width -->
            <rect x="8"  y="42" width="58" height="20" rx="4" fill="currentColor"/>
            <!-- Top bar — shortest -->
            <rect x="8"  y="12" width="32" height="20" rx="4" fill="currentColor"/>
          </svg>
        </span>
        <span class="ma-summarizer__btn-label">
          <span class="ma-summarizer__btn-name">Mistral</span>
          <span class="ma-summarizer__btn-hint">by Mistral AI</span>
        </span>
        <span class="ma-summarizer__btn-arrow" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <button
        class="ma-summarizer__btn ma-summarizer__btn--deepseek"
        data-ai="deepseek"
        data-url="https://chat.deepseek.com/"
        type="button"
        aria-label="Summarize with DeepSeek"
      >
        <span class="ma-summarizer__btn-icon" aria-hidden="true">
          <!--
            DeepSeek mark: a stylised whale/sea-creature silhouette.
            The body is an organic rounded blob, wider at left and tapering
            to a small upturned tail at top-right. A filled circle sits inside
            the body for the eye. This matches DeepSeek's actual product logo.
          -->
          <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Body: sweeping organic shape, left-heavy, tail curls up-right -->
            <path d="
              M18,70
              C10,60 8,42 16,30
              C24,18 40,12 56,16
              C68,19 76,26 80,34
              C86,28 90,18 88,10
              C92,14 94,26 88,36
              C96,44 96,58 86,66
              C76,76 58,80 42,76
              C32,73 22,78 18,70
              Z
            " fill="currentColor"/>
            <!-- Eye: small filled circle in the upper body area -->
            <circle cx="62" cy="36" r="6" fill="white"/>
            <circle cx="64" cy="36" r="3" fill="currentColor"/>
          </svg>
        </span>
        <span class="ma-summarizer__btn-label">
          <span class="ma-summarizer__btn-name">DeepSeek</span>
          <span class="ma-summarizer__btn-hint">by DeepSeek</span>
        </span>
        <span class="ma-summarizer__btn-arrow" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

    </div>

    <p class="ma-summarizer__footer">The prompt is also copied to your clipboard — paste it if it doesn't appear automatically.</p>
  </div>
</div>

<div class="ma-summarizer-toast" id="ma-summarizer-toast" role="status" aria-live="polite">
  <span class="ma-summarizer-toast__icon" aria-hidden="true">
    <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
  <span class="ma-summarizer-toast__text"></span>
</div>
