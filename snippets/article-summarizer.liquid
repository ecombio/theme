{% comment %}
  Snippet: article-summarizer.liquid
  Usage:   {% render 'article-summarizer', article: article %}
  Place directly after {{ article.content }} in your article template.

  On click:
    1. Resolves the prompt: uses article.metafields.custom.ai_summarizer if set,
       otherwise falls back to a built-in default prompt.
    2. Appends the prompt as ?q= to the AI URL so it pre-fills the chat input.
    3. Also copies it to clipboard as a reliable fallback.
    4. Shows a toast with clear next-step instructions.

  No API keys. No backend. No streaming.
{% endcomment %}

{% assign excerpt = article.content | strip_html | strip_newlines | truncate: 2000 %}
{% assign custom_prompt = article.metafields.custom.ai_summarizer | escape %}

<div
  class="ma-summarizer"
  data-title="{{ article.title | escape }}"
  data-excerpt="{{ excerpt | escape }}"
  {% if custom_prompt != blank %}data-custom-prompt="{{ custom_prompt }}"{% endif %}
>
  <div class="ma-summarizer__inner">
    <div class="ma-summarizer__header">
      <span class="ma-summarizer__eyebrow">AI Summary</span>
      <p class="ma-summarizer__heading">Too long? Get the gist in seconds.</p>
      <p class="ma-summarizer__subtext">Pick an AI — the prompt loads automatically in the new tab.</p>
    </div>

    <div class="ma-summarizer__buttons">

      <button
        class="ma-summarizer__btn ma-summarizer__btn--claude"
        data-ai="claude"
        data-url="https://claude.ai/new"
        type="button"
        aria-label="Summarize with Claude"
      >
        <span class="ma-summarizer__btn-icon" aria-hidden="true">
          <!-- Anthropic/Claude logomark — the upward-sweeping speech shape -->
          <svg viewBox="0 0 46 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M32.7 0c-4.2-.18-7.7 2.65-7.7 6.85v5.4H20.3C11.7 12.3 4.7 19.3 4.7 27.9c0 6.7 6.4 11.2 12.6 8.9l.93-.35C21.4 34.9 23.6 31.6 23.6 28v-5.4h5.65c3.98 0 7.47-2.36 8.82-5.93l3.9-10.48C44.3 1.4 38.8-.07 32.7 0z" fill="currentColor"/>
          </svg>
        </span>
        <span class="ma-summarizer__btn-label">
          <span class="ma-summarizer__btn-name">Claude</span>
          <span class="ma-summarizer__btn-hint">by Anthropic</span>
        </span>
        <span class="ma-summarizer__btn-arrow" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <button
        class="ma-summarizer__btn ma-summarizer__btn--chatgpt"
        data-ai="chatgpt"
        data-url="https://chatgpt.com/"
        type="button"
        aria-label="Summarize with ChatGPT"
      >
        <span class="ma-summarizer__btn-icon" aria-hidden="true">
          <!-- OpenAI logomark — bold rounded O with inner negative space -->
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" clip-rule="evenodd"
              d="M12 2.25A9.75 9.75 0 1 0 21.75 12 9.76 9.76 0 0 0 12 2.25zm0 2.5a7.25 7.25 0 1 1 0 14.5 7.25 7.25 0 0 1 0-14.5zm0 2.25a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 2.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5z"
              fill="currentColor"/>
          </svg>
        </span>
        <span class="ma-summarizer__btn-label">
          <span class="ma-summarizer__btn-name">ChatGPT</span>
          <span class="ma-summarizer__btn-hint">by OpenAI</span>
        </span>
        <span class="ma-summarizer__btn-arrow" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <button
        class="ma-summarizer__btn ma-summarizer__btn--gemini"
        data-ai="gemini"
        data-url="https://gemini.google.com/app"
        type="button"
        aria-label="Summarize with Gemini"
      >
        <span class="ma-summarizer__btn-icon" aria-hidden="true">
          <!-- Gemini star — two crossing ellipses give the lens-flare thickness variation -->
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="gemini-grad" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#4285F4"/>
                <stop offset="50%" stop-color="#9B72CB"/>
                <stop offset="100%" stop-color="#D96570"/>
              </linearGradient>
            </defs>
            <!-- Vertical ellipse: wide at top/bottom, narrow at sides -->
            <ellipse cx="12" cy="12" rx="3.2" ry="11" fill="url(#gemini-grad)"/>
            <!-- Horizontal ellipse: wide at left/right, narrow at top/bottom -->
            <ellipse cx="12" cy="12" rx="11" ry="3.2" fill="url(#gemini-grad)"/>
          </svg>
        </span>
        <span class="ma-summarizer__btn-label">
          <span class="ma-summarizer__btn-name">Gemini</span>
          <span class="ma-summarizer__btn-hint">by Google</span>
        </span>
        <span class="ma-summarizer__btn-arrow" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

    </div>

    <p class="ma-summarizer__footer">The prompt is also copied to your clipboard — paste it if it doesn't appear automatically.</p>
  </div>
</div>

<div class="ma-summarizer-toast" id="ma-summarizer-toast" role="status" aria-live="polite">
  <span class="ma-summarizer-toast__icon" aria-hidden="true">
    <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
  <span class="ma-summarizer-toast__text"></span>
</div>
