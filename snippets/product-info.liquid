<div class="product-info-container" id="ProductInfo">
  <div class="product-info-wrapper">

    <!-- Header / Title -->
    <div class="product-header">
      <span class="product-badge">Save 6%</span>
      <h1 class="product-title">Task Chair Luxe</h1>
      <div class="product-vendor">
        Vendor: <a href="/collections/vendors?q=Mason">Mason</a>
      </div>
      <div class="product-type">Type: <a href="/collections/chairs">Chairs</a></div>
    </div>

    <!-- Pricing -->
    <div class="product-pricing">
      <div class="price-wrapper">
        <span class="price sale-price" id="ProductPrice">$559.00</span>
        <span class="compare-price" id="ProductComparePrice">$599.00</span>
      </div>
    </div>

    <!-- Features + Stock -->
    <div class="product-features">
      <div class="feature-item">
        <svg class="feature-icon" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M16.875 5.625L8.125 14.375L3.75 10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Modern</span>
      </div>
      <div class="feature-item">
        <svg class="feature-icon" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M16.875 5.625L8.125 14.375L3.75 10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Eco-certified</span>
      </div>
      <div class="feature-item">
        <svg class="feature-icon" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M16.875 5.625L8.125 14.375L3.75 10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Warranty</span>
      </div>
    </div>

    <div class="stock-indicator available" id="StockIndicator">
      <span class="stock-dot"></span>
      <span class="stock-text">Available in stock (12)</span>
    </div>

    <!-- Description -->
    <div class="product-description">
      This is a demonstration store by FoxEcom. All images, videos, and other content belong exclusively to FoxEcom and are not authorized for reuse on any other stores.
    </div>

    <!-- Color Variant -->
    <div class="product-variants">
      <div class="variant-option">
        <label class="variant-label">
          Color: <span class="selected-value" id="SelectedColor">Chocolate</span>
        </label>
        <fieldset class="variant-fieldset">
          <legend class="visually-hidden">Color</legend>
          <div class="color-swatches">
            <label class="color-swatch-label" title="Chocolate">
              <input
                type="radio"
                name="Color"
                value="Chocolate"
                class="color-input"
                checked
                aria-label="Chocolate"
              >
              <span class="color-swatch" style="background-color: #7B4F2E;"></span>
            </label>
            <label class="color-swatch-label" title="Walnut">
              <input
                type="radio"
                name="Color"
                value="Walnut"
                class="color-input"
                aria-label="Walnut"
              >
              <span class="color-swatch" style="background-color: #4A3728;"></span>
            </label>
            <label class="color-swatch-label" title="Natural Oak">
              <input
                type="radio"
                name="Color"
                value="Natural Oak"
                class="color-input"
                aria-label="Natural Oak"
              >
              <span class="color-swatch" style="background-color: #C8A97A;"></span>
            </label>
            <label class="color-swatch-label" title="Slate">
              <input
                type="radio"
                name="Color"
                value="Slate"
                class="color-input"
                aria-label="Slate"
              >
              <span class="color-swatch" style="background-color: #6B7280;"></span>
            </label>
          </div>
        </fieldset>
      </div>

      <!-- Material Variant -->
      <div class="variant-option">
        <label class="variant-label">
          Material: <span class="selected-value" id="SelectedMaterial">Oak</span>
        </label>
        <fieldset class="variant-fieldset">
          <legend class="visually-hidden">Material</legend>
          <div class="variant-buttons">
            <label>
              <input
                type="radio"
                name="Material"
                value="Oak"
                class="variant-radio"
                checked
                aria-label="Oak"
              >
              <span class="variant-button">Oak</span>
            </label>
            <label>
              <input
                type="radio"
                name="Material"
                value="Wool"
                class="variant-radio"
                aria-label="Wool"
              >
              <span class="variant-button">Wool</span>
            </label>
            <label>
              <input
                type="radio"
                name="Material"
                value="Velvet"
                class="variant-radio"
                aria-label="Velvet"
              >
              <span class="variant-button">Velvet</span>
            </label>
          </div>
        </fieldset>
      </div>
    </div>

    <!-- Quantity + Actions -->
    <div class="quantity-and-actions">
      <div class="quantity-actions-row">
        <!-- Quantity Selector -->
        <div class="quantity-selector-wrapper">
          <label for="ProductQuantity" class="visually-hidden">Quantity</label>
          <div class="quantity-selector">
            <button class="quantity-button" type="button" name="minus" aria-label="Decrease quantity">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M3.125 10H16.875" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>
            <input
              type="number"
              id="ProductQuantity"
              name="quantity"
              value="1"
              min="1"
              max="99"
              class="quantity-input"
              aria-label="Quantity"
            >
            <button class="quantity-button" type="button" name="plus" aria-label="Increase quantity">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M3.125 10H16.875M10 3.125V16.875" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Add to Cart -->
        <button type="button" class="button button-primary add-to-cart" id="AddToCart">
          Add To Cart
        </button>
      </div>

      <!-- Buy It Now -->
      <button type="button" class="button button-secondary buy-now" id="BuyNow">
        Buy It Now
      </button>
    </div>

    <!-- Shipping Info -->
    <div class="product-shipping-info">
      <div class="shipping-item">
        <svg class="shipping-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="5.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="18.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        <span>Free International Shipping over $500</span>
      </div>
      <div class="shipping-item">
        <svg class="shipping-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M3 12h14M3 12l4-4M3 12l4 4M21 5v14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Free Returns Within 30 days</span>
      </div>
    </div>

    <!-- Pickup Availability -->
    <div class="pickup-availability">
      <div class="pickup-header">
        <svg class="pickup-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M9 22V12h6v10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="pickup-info">
          <div class="pickup-title">Pickup available at California Store</div>
          <div class="pickup-subtitle">Usually ready in 24 hours</div>
        </div>
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" class="pickup-chevron" aria-hidden="true">
          <path d="M7.5 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    <!-- Limited-time offer banner -->
    <div class="promo-banner" id="PromoBanner" role="alert">
      <div class="promo-banner-inner">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="promo-icon">
          <path d="M10 3v1M10 16v1M3 10H2M18 10h-1M5.05 5.05l-.707-.707M15.657 15.657l-.707-.707M15.657 4.343l-.707.707M5.05 14.95l-.707.707" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        <div class="promo-text">
          <strong>Limited time offer</strong>
          <span>Get $20 off when you spend $1,000 or more! <a href="#" class="promo-link">Learn more</a></span>
        </div>
        <button class="promo-close" aria-label="Dismiss offer" onclick="this.closest('.promo-banner').remove()">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

  </div>
</div>
