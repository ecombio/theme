{% comment %}
  snippets/collection-posts.liquid
  Renders the posts grid for collection-showroom.liquid.

  Expects:
    posts  {Array} — collection.metafields.custom.posts.value
                     (array of Shopify article objects)

  Card rendering: delegates to post-card.liquid.
{% endcomment %}

<div class="collection-posts">
  <div class="collection-posts__grid">
    {%- for post in posts -%}
      {%- render 'post-card', post: post -%}
    {%- endfor -%}
  </div>
</div>
