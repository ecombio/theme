{% comment %}
  snippets/header-menu-item.liquid
  ─────────────────────────────────────────────────────────────────────────────
  Dispatcher — routes block.type to the correct sub-snippet.

  BLOCK TYPES → SUB-SNIPPETS:
    link      → header-menu-item--link.liquid
    linklist  → header-menu-item--linklist.liquid
    mega      → header-menu-item--mega.liquid
  ─────────────────────────────────────────────────────────────────────────────
{% endcomment %}

{%- case block.type -%}
  {%- when 'link' -%}
    {%- render 'header-menu-item--link', block: block -%}
  {%- when 'linklist' -%}
    {%- render 'header-menu-item--linklist', block: block -%}
  {%- when 'mega' -%}
    {%- render 'header-menu-item--mega', block: block -%}
{%- endcase -%}
