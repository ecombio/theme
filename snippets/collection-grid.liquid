{% comment %}
  Snippet: collection-grid
  Renders the product grid and empty state.
  Parameters:
    - products {Object} - collection.products (required)
  Used in: sections/collection-products.liquid
{% endcomment %}

<div class="collection-products" id="collection-grid">
  {% for product in products %}
    <div class="collection-product-wrapper">
      {% render 'card-product',
        product: product,
        show_vendor: true,
        show_compare_at_price: true
      %}
    </div>
  {% else %}
    <p class="collection-empty">No products match the selected filters.</p>
  {% endfor %}
</div>
