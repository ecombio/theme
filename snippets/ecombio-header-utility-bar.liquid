{% comment %}
  ECOMBIO Header Utility Bar
  File: snippets/ecombio-header-utility-bar.liquid

  Renders a slim 32px bar above the main header.
    Left  — utility links (pipe-delimited setting: "Label|/url, Label 2|/url-2")
    Right — currency selector + language/locale selector

  Colours pulled directly from the live --hyper token set:
    bg           #111111  (one step darker than the header's #1a1a1a)
    text         #a0a0a0
    hover        #FFF3CD  (same amber used across the header)
    dividers     rgba(255,255,255,0.08)

  Adapts to header_style:
    hyper  → dark bar (default, matches live site)
    focus  → light warm-grey bar (#f5f4f2) with subdued text

  Usage (sections/header.liquid, immediately before <header>):
    {%- render 'ecombio-header-utility-bar',
          header_style:  header_style,
          links:         section.settings.utility_links,
          show_currency: section.settings.show_currency_switcher,
          show_locale:   section.settings.show_locale_switcher
    -%}
{% endcomment %}

{%- liquid
  assign bar_style = header_style | default: 'hyper'
  assign show_curr = show_currency | default: true
  assign show_loc  = show_locale   | default: true
  assign link_pairs = links | split: ','
-%}

<div class="ecombio-utility-bar ecombio-utility-bar--{{ bar_style }}" role="navigation" aria-label="Utility bar">
  <div class="ecombio-utility-bar__inner">

    {%- comment -%} ── LEFT: links ── {%- endcomment -%}
    <ul class="ecombio-utility-bar__links" role="list">
      {%- for pair in link_pairs -%}
        {%- assign parts = pair | strip | split: '|' -%}
        {%- if parts.size == 2 -%}
          <li>
            <a href="{{ parts[1] | strip | escape }}" class="ecombio-utility-bar__link">
              {{- parts[0] | strip | escape -}}
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    {%- comment -%} ── RIGHT: currency + locale ── {%- endcomment -%}
    <div class="ecombio-utility-bar__switchers">

      {%- if show_curr and shop.enabled_currencies.size > 1 -%}
        <div class="ecombio-utility-bar__switcher">
          {%- form 'currency', id: 'ecombio-currency-form' -%}
            <label for="ecombio-currency-select" class="visually-hidden">Currency</label>
            <div class="ecombio-utility-bar__select-wrap">
              <select id="ecombio-currency-select"
                      name="currency"
                      class="ecombio-utility-bar__select"
                      aria-label="Select currency"
                      onchange="this.form.submit()">
                {%- for currency in shop.enabled_currencies -%}
                  <option value="{{ currency.iso_code }}"
                    {%- if currency == cart.currency %} selected{% endif -%}>
                    {{ currency.iso_code }} &ndash; {{ currency.symbol }}
                  </option>
                {%- endfor -%}
              </select>
              <svg class="ecombio-utility-bar__chevron" width="9" height="9" viewBox="0 0 20 20"
                   fill="none" stroke="currentColor" stroke-width="2.5"
                   stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 8l5 5 5-5"/>
              </svg>
            </div>
          {%- endform -%}
        </div>
      {%- endif -%}

      {%- if show_loc and localization.available_languages.size > 1 -%}
        <div class="ecombio-utility-bar__switcher ecombio-utility-bar__switcher--locale">
          {%- form 'localization', id: 'ecombio-locale-form' -%}
            <label for="ecombio-locale-select" class="visually-hidden">Language</label>
            <div class="ecombio-utility-bar__select-wrap">
              <select id="ecombio-locale-select"
                      name="locale_code"
                      class="ecombio-utility-bar__select"
                      aria-label="Select language"
                      onchange="this.form.submit()">
                {%- for language in localization.available_languages -%}
                  <option value="{{ language.iso_code }}"
                    {%- if language.iso_code == localization.language.iso_code %} selected{% endif -%}>
                    {{ language.endonym_name | capitalize }}
                  </option>
                {%- endfor -%}
              </select>
              <svg class="ecombio-utility-bar__chevron" width="9" height="9" viewBox="0 0 20 20"
                   fill="none" stroke="currentColor" stroke-width="2.5"
                   stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 8l5 5 5-5"/>
              </svg>
            </div>
          {%- endform -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% stylesheet %}
/* ─────────────────────────────────────────────
   ECOMBIO UTILITY BAR
   Tokens matched to live ecombio-header--hyper
   ───────────────────────────────────────────── */

.ecombio-utility-bar {
  width: 100%;
  height: 32px;
  display: flex;
  align-items: center;
}

.ecombio-utility-bar__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  max-width: 1184px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ── Links ── */
.ecombio-utility-bar__links {
  display: flex;
  align-items: center;
  list-style: none;
  margin: 0;
  padding: 0;
}

.ecombio-utility-bar__link {
  display: flex;
  align-items: center;
  height: 32px;
  padding: 0 14px;
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.15s ease;
}

.ecombio-utility-bar__links li:first-child .ecombio-utility-bar__link {
  padding-left: 0;
}

.ecombio-utility-bar__links li + li .ecombio-utility-bar__link {
  border-left: 1px solid rgba(255, 255, 255, 0.08);
}

/* ── Switchers ── */
.ecombio-utility-bar__switchers {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.ecombio-utility-bar__switcher {
  display: flex;
  align-items: center;
}

/* vertical rule between switchers */
.ecombio-utility-bar__switcher--locale {
  border-left: 1px solid rgba(255, 255, 255, 0.1);
  padding-left: 4px;
}

.ecombio-utility-bar__select-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.ecombio-utility-bar__select {
  appearance: none;
  -webkit-appearance: none;
  background: transparent;
  border: none;
  outline: none;
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  cursor: pointer;
  padding: 0 22px 0 8px;
  height: 32px;
  transition: color 0.15s ease;
}

.ecombio-utility-bar__chevron {
  position: absolute;
  right: 4px;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
}

/* ─────────────────────────────────────────────
   HYPER variant — dark, matches #1a1a1a header
   ───────────────────────────────────────────── */
.ecombio-utility-bar--hyper {
  background-color: #111111;
  border-bottom: 1px solid rgba(255, 255, 255, 0.07);
}

.ecombio-utility-bar--hyper .ecombio-utility-bar__link {
  color: #a0a0a0;
}

.ecombio-utility-bar--hyper .ecombio-utility-bar__link:hover {
  color: #c4301c;
}

.ecombio-utility-bar--hyper .ecombio-utility-bar__switcher--locale {
  border-left-color: rgba(255, 255, 255, 0.1);
}

.ecombio-utility-bar--hyper .ecombio-utility-bar__links li + li .ecombio-utility-bar__link {
  border-left-color: rgba(255, 255, 255, 0.08);
}

.ecombio-utility-bar--hyper .ecombio-utility-bar__select {
  color: #a0a0a0;
}

.ecombio-utility-bar--hyper .ecombio-utility-bar__select:hover {
  color: #c4301c;
}

.ecombio-utility-bar--hyper .ecombio-utility-bar__select option {
  background: #1a1a1a;
  color: #e0e0e0;
}

.ecombio-utility-bar--hyper .ecombio-utility-bar__chevron {
  color: #555555;
}

/* ─────────────────────────────────────────────
   FOCUS variant — light warm-grey
   ───────────────────────────────────────────── */
.ecombio-utility-bar--focus {
  background-color: #f5f4f2;
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

.ecombio-utility-bar--focus .ecombio-utility-bar__link {
  color: #6a6a6a;
}

.ecombio-utility-bar--focus .ecombio-utility-bar__link:hover {
  color: #1a1a1a;
}

.ecombio-utility-bar--focus .ecombio-utility-bar__links li + li .ecombio-utility-bar__link {
  border-left-color: rgba(0, 0, 0, 0.1);
}

.ecombio-utility-bar--focus .ecombio-utility-bar__switcher--locale {
  border-left-color: rgba(0, 0, 0, 0.1);
}

.ecombio-utility-bar--focus .ecombio-utility-bar__select {
  color: #6a6a6a;
}

.ecombio-utility-bar--focus .ecombio-utility-bar__select:hover {
  color: #1a1a1a;
}

.ecombio-utility-bar--focus .ecombio-utility-bar__chevron {
  color: #aaaaaa;
}

/* ── Mobile: hide links, right-align switchers ── */
@media (max-width: 749px) {
  .ecombio-utility-bar__links {
    display: none;
  }
  .ecombio-utility-bar__inner {
    justify-content: flex-end;
  }
}
{% endstylesheet %}