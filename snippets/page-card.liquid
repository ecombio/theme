{% comment %}
  snippets/page-card.liquid
  Self-contained page card used by collection-pages.liquid.

  Expects:
    page  {Object} — a Shopify page object

  Loads: page-card.css + page-card.js (via tags below)
{% endcomment %}

{{ 'page-card.css' | asset_url | stylesheet_tag }}

<div class="page-card" data-page-id="{{ page.id }}">

  {%- comment -%} ── Icon / visual indicator ──────────────────────────────── {%- endcomment -%}

  <div class="page-card__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="page-card__icon-svg">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="16" y1="13" x2="8" y2="13"/>
      <line x1="16" y1="17" x2="8" y2="17"/>
      <polyline points="10 9 9 9 8 9"/>
    </svg>
  </div>

  {%- comment -%} ── Info ────────────────────────────────────────────────── {%- endcomment -%}

  <div class="page-card__info">

    <h3 class="page-card__title">
      <a href="{{ page.url }}" class="page-card__title-link">{{ page.title }}</a>
    </h3>

    {%- if page.content != blank -%}
      <p class="page-card__excerpt">
        {{ page.content | strip_html | truncate: 100 }}
      </p>
    {%- endif -%}

    <a href="{{ page.url }}" class="page-card__cta" aria-label="View {{ page.title | escape }}">
      View page &rarr;
    </a>

  </div>

</div>

<script src="{{ 'page-card.js' | asset_url }}" defer></script>
