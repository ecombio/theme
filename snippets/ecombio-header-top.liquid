{% comment %}
  ECOMBIO Header — Top Bar
  File: snippets/ecombio-header-top.liquid

  Renders the utility bar above the main header.

  Parameters:
    header_style  {string}  — 'hyper' or 'focus'
    links         {string}  — section.settings.utility_links
    show_currency {boolean} — section.settings.show_currency_switcher
    show_locale   {boolean} — section.settings.show_locale_switcher
{% endcomment %}

{%- render 'ecombio-header-utility-bar',
      header_style:  header_style,
      links:         links,
      show_currency: show_currency,
      show_locale:   show_locale
-%}
