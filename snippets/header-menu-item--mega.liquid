{% comment %}
  snippets/header-menu-item--mega.liquid
  ─────────────────────────────────────────────────────────────────────────────
  Block type: mega
  Full-width panel. Text columns from a 3-level Shopify linklist.

  NAV STRUCTURE (3 levels via the linked menu):
    Level 1  →  column heading    (menu.links)
    Level 2  →  subheading or direct link  (column.links)
    Level 3  →  links under subheading     (item.links)

  BLOCK SETTINGS:
    label  {string}    — trigger button text
    menu   {linklist}  — mega menu source (3-level)
  ─────────────────────────────────────────────────────────────────────────────
{% endcomment %}

{%- assign mega_menu = block.settings.menu -%}

<div
  class="header__menu-item header__menu-item--mega"
  data-menu-dropdown
  {{ block.shopify_attributes }}
>

  <!-- Trigger ────────────────────────────────────────────────────────────── -->
  <button
    type="button"
    class="header__menu-link header__menu-link--dropdown"
    aria-haspopup="true"
    aria-expanded="false"
    data-menu-toggle
  >
    {{- block.settings.label | escape -}}
    <span class="header__menu-caret" aria-hidden="true">▾</span>
  </button>

  <!-- Panel ──────────────────────────────────────────────────────────────── -->
  {%- if mega_menu != blank and mega_menu.links.size > 0 -%}
    <div class="header__mega-panel" hidden>
      <div class="header__mega-inner page-width">

        <div
          class="header__mega-columns"
          style="--mega-col-count: {{ mega_menu.links.size }};"
        >
          {%- for column in mega_menu.links -%}
            <div class="header__mega-column">

              <a href="{{ column.url }}" class="header__mega-heading">
                {{- column.title -}}
              </a>

              {%- for item in column.links -%}
                {%- if item.links.size > 0 -%}
                  <p class="header__mega-subheading">{{- item.title -}}</p>
                  <ul class="header__mega-list" role="list">
                    {%- for child in item.links -%}
                      <li>
                        <a href="{{ child.url }}" class="header__mega-link">
                          {{- child.title -}}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- else -%}
                  <a href="{{ item.url }}" class="header__mega-link">
                    {{- item.title -}}
                  </a>
                {%- endif -%}
              {%- endfor -%}

            </div>
          {%- endfor -%}
        </div>

      </div>
    </div>
  {%- endif -%}

</div>
