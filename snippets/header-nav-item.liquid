{% comment %}
  snippets/header-nav-item.liquid
  ─────────────────────────────────────────────────────────────────────────────
  ROW 4 (sub): A single navigation item — either a plain leaf link or a
  disclosure dropdown button with a submenu.

  This is the KEY composability point in the whole nav system:
    - Swap ONLY this file to get a mega-menu, flyout, or mobile accordion.
    - header-nav.liquid and header.liquid stay completely unchanged.

  VARIABLES (passed in via `with` from snippets/header-nav.liquid):
    link          {link object}  — one item from menu.links.
                                   Has .title, .url, .handle, .active,
                                   .current, and .links (child array).
    deals_handle  {string}       — handle that gets red/bold deals styling.
                                   e.g. "great-deals". Pass "" to disable.

  RENDERS:
    Leaf link     → <a> with aria-current when active.
    Parent link   → <div data-nav-dropdown> wrapping a <button data-nav-toggle>
                    and a hidden <ul> submenu. header.js opens/closes it.

  STEP 3 NOTE (mega-menu):
    Replace the <ul class="header__nav-submenu"> block with a
    <div class="header__nav-mega"> panel. No other file needs to change.
  ─────────────────────────────────────────────────────────────────────────────
{% endcomment %}

{% comment %} Resolve deal styling once, reuse in both branches below {% endcomment %}
{%- assign link_classes = 'header__nav-link' -%}
{%- if deals_handle != blank and link.handle == deals_handle -%}
  {%- assign link_classes = 'header__nav-link header__nav-link--deals' -%}
{%- endif -%}

{%- if link.links != blank -%}

  {% comment %} ── PARENT: has child links → disclosure dropdown ── {% endcomment %}
  <div class="header__nav-item header__nav-item--dropdown" data-nav-dropdown>

    <button
      type="button"
      class="{{ link_classes }} header__nav-link--dropdown"
      aria-haspopup="true"
      aria-expanded="false"
      data-nav-toggle
    >
      {{- link.title -}}
      <span class="header__nav-caret" aria-hidden="true">▾</span>
    </button>

    <ul class="header__nav-submenu" role="list" hidden>
      {%- for child_link in link.links -%}
        <li>
          <a
            href="{{ child_link.url }}"
            class="header__nav-submenu-link{% if child_link.active %} header__nav-submenu-link--active{% endif %}"
            {% if child_link.current %}aria-current="page"{% endif %}
          >
            {{- child_link.title -}}
          </a>
        </li>
      {%- endfor -%}
    </ul>

  </div>

{%- else -%}

  {% comment %} ── LEAF: no children → plain anchor ── {% endcomment %}
  <a
    href="{{ link.url }}"
    class="{{ link_classes }}"
    {% if link.active %}aria-current="page"{% endif %}
  >
    {{- link.title -}}
  </a>

{%- endif -%}
