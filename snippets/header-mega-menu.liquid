{% comment %}
  ECOMBIO Header Mega Menu — Text columns + optional product grid
  File: snippets/header-mega-menu.liquid

  Called from snippets/ecombio-header-menu-bar.liquid for 'mega' blocks:
    {%- render 'header-mega-menu', menu: mega_menu, show_products: block.settings.show_products -%}

  NOTE: The .mega-menu wrapper div is rendered by the parent (ecombio-header-menu-bar.liquid).
        This snippet renders only the inner panel content.

  Params:
    menu          {linklist}  The mega menu nav object
    show_products {bool}      Whether to render the right-hand product grid

  Nav structure (3 levels max):
    Level 1  →  column heading   (passed in as `menu`)
    Level 2  →  subheading or direct link
    Level 3  →  links under subheading
{% endcomment %}

{%- assign show_products = show_products | default: false -%}

{%- if menu != blank and menu.links.size > 0 -%}
  <div class="mega-menu-items{% if show_products %} mega-menu-items--with-products{% endif %}">

    {%- comment -%}── LEFT: TEXT COLUMNS ──{%- endcomment -%}
    <div class="mega-menu__text-columns" style="--mega-col-count: {{ menu.links.size }};">

      {%- for column in menu.links -%}
        <div class="mega-menu-column">

          <a href="{{ column.url }}" class="mega-menu-heading">
            {{- column.title -}}
          </a>

          {%- for item in column.links -%}
            {%- if item.links.size > 0 -%}
              <div class="mega-menu-subheading">{{ item.title }}</div>
              <ul class="mega-menu-list">
                {%- for link in item.links -%}
                  <li>
                    <a href="{{ link.url }}" class="mega-menu-link">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <a href="{{ item.url }}" class="mega-menu-link">{{ item.title }}</a>
            {%- endif -%}
          {%- endfor -%}

        </div>
      {%- endfor -%}

    </div>

    {%- comment -%}── RIGHT: PRODUCT GRID (optional) ──{%- endcomment -%}
    {%- if show_products -%}
      <div class="mega-menu__products">

        <div class="mega-menu__product-header">
          <h2 class="mega-menu-heading">Trending Products</h2>
        </div>

        <div class="mega-menu__product-grid">
          {%- for product in collections.all.products limit: 6 -%}
            <a href="{{ product.url }}" class="mega-menu__product-card">

              <div class="mega-menu__product-image">
                <img
                  src="{{ product.featured_image | image_url: width: 400 }}"
                  alt="{{ product.title | escape }}"
                  loading="lazy"
                  width="400"
                >
                {%- if product.compare_at_price > product.price -%}
                  <span class="mega-menu__badge">Sale</span>
                {%- endif -%}
              </div>

              <div class="mega-menu__product-info">
                <h3 class="mega-menu__product-title">{{ product.title }}</h3>
                <div class="mega-menu__product-price">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="price--sale">{{ product.price | money }}</span>
                    <s class="price--compare">{{ product.compare_at_price | money }}</s>
                  {%- else -%}
                    {{ product.price | money }}
                  {%- endif -%}
                </div>
              </div>

            </a>
          {%- endfor -%}
        </div>

      </div>
    {%- endif -%}

  </div>
{%- endif -%}
