{% comment %}
  snippets/collection-products.liquid
  [1.2.1] Product grid adapter.

  Owns:
    - Row-by-row iteration of collection.products
    - After each row: calls collection-promo to inject any blocks targeting that row
    - Empty state
    - Pagination controls

  Parameters:
    collection  {Object}  required
    blocks      {Array}   required — forwarded to collection-promo
    paginate    {Object}  required
    columns     {Number}  optional — default 4

  Pitfall — row math:
    Shopify Liquid has no modulo operator. We track row index by
    comparing (forloop.index / columns | floor) to the previous value.
    A simpler approach: just check (forloop.index | modulo: columns) == 0
    using the `modulo` filter (available in Liquid via Ruby's %).
    After the last product of each row fires, inject promos for that row.

  CSS: collection-products.css
  JS:  none — product-card.js is global (theme.liquid)
{% endcomment %}

{{ 'collection-products.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign columns = columns | default: 4
-%}

<div
  class="collection-products"
  style="--collection-products-columns: {{ columns }};"
  data-collection-products
>

  {%- if collection.products != blank -%}

    {%- comment -%}
      We render the grid row-by-row so we can inject promo blocks
      between rows. Each `columns` products = one row.

      Strategy:
        1. Open .collection-products__grid
        2. For each product, render product-card
        3. At the end of each full row (forloop.index divisible by columns),
           close the grid, call collection-promo for that row number,
           then re-open the grid for the next row.
        4. After the loop, close the final (possibly partial) grid.

      Pitfall: Don't close + reopen the grid wrapper on partial last rows
      or you'll get an unclosed/double-closed div. The final close is
      always outside the loop.
    {%- endcomment -%}

    {%- assign row_index = 0 -%}
    <div class="collection-products__grid">

      {%- for product in collection.products -%}

        {%- render 'product-card', product: product -%}

        {%- comment -%}
          End of a full row: close grid, inject promos, reopen grid.
          Skip this on the very last product to avoid an empty trailing grid div.
        {%- endcomment -%}
        {%- assign position_mod = forloop.index | modulo: columns -%}
        {%- if position_mod == 0 and forloop.last == false -%}
          {%- assign row_index = row_index | plus: 1 -%}
          </div>
          {%- render 'collection-promo',
            blocks:    blocks,
            row_index: row_index
          -%}
          <div class="collection-products__grid">
        {%- elsif forloop.last -%}
          {%- comment -%}
            On the last product, calculate which row we just finished
            (may be a partial row) and inject any promos for it too.
          {%- endcomment -%}
          {%- assign row_index = row_index | plus: 1 -%}
        {%- endif -%}

      {%- endfor -%}

    </div>

    {%- comment -%}
      Inject promos targeting the final row (after grid closes).
    {%- endcomment -%}
    {%- render 'collection-promo',
      blocks:    blocks,
      row_index: row_index
    -%}

  {%- else -%}

    <p class="collection-products__empty">
      {{ 'collections.general.no_matches' | t }}
    </p>

  {%- endif -%}

  {%- comment -%} ── Pagination ───────────────────────────────────────────── {%- endcomment -%}

  {%- if paginate.pages > 1 -%}
    <nav
      class="collection-products__pagination"
      aria-label="{{ 'general.pagination.label' | t }}"
    >
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="collection-products__page-link">
          &larr; {{ 'general.pagination.previous' | t }}
        </a>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <a href="{{ part.url }}" class="collection-products__page-link">
            {{ part.title }}
          </a>
        {%- else -%}
          <span class="collection-products__page-link collection-products__page-link--current" aria-current="page">
            {{ part.title }}
          </span>
        {%- endif -%}
      {%- endfor -%}

      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="collection-products__page-link">
          {{ 'general.pagination.next' | t }} &rarr;
        </a>
      {%- endif -%}
    </nav>
  {%- endif -%}

</div>
