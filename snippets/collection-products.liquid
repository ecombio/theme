{% comment %}
  snippets/collection-products.liquid
  Renders the products grid and pagination for collection-showroom.liquid.

  Expects:
    collection  {Object} — the Shopify collection object
    paginate    {Object} — paginate object opened upstream in collection.liquid

  Card rendering: delegates to product-card.liquid.
  product-card.js is loaded globally via theme.liquid — do NOT load it here.

  NOTE: banner/carousel section blocks are handled entirely by
  collection-features.liquid now. This snippet has no awareness of
  section.blocks at all — don't reintroduce a `blocks` param here.

  NOTE on the products source: use `collection.products` directly, NOT
  `paginate.collection.products`. The `paginate` object only exposes
  pagination metadata (pages, parts, next, previous, items) — it has no
  `.collection` property. Inside the `{% paginate collection.products by N %}`
  block opened in collection.liquid, `collection.products` is already
  sliced to the current page, which is what you want here.
{% endcomment %}

{%- liquid
  assign products_on_page = collection.products.size
-%}

<div class="collection-products">

  {%- if products_on_page > 0 -%}
    <div class="collection-products__grid">
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    </div>

  {%- else -%}

    <p class="collection-products__empty">
      {{ 'collections.general.no_matches' | t }}
    </p>

  {%- endif -%}

  {%- if paginate.pages > 1 -%}
    <nav
      class="collection-products__pagination"
      aria-label="{{ 'general.pagination.label' | t }}"
    >
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="collection-products__page-link">
          &larr; {{ 'general.pagination.previous' | t }}
        </a>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <a href="{{ part.url }}" class="collection-products__page-link">
            {{ part.title }}
          </a>
        {%- else -%}
          <span
            class="collection-products__page-link collection-products__page-link--current"
            aria-current="page"
          >
            {{ part.title }}
          </span>
        {%- endif -%}
      {%- endfor -%}

      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="collection-products__page-link">
          {{ 'general.pagination.next' | t }} &rarr;
        </a>
      {%- endif -%}
    </nav>
  {%- endif -%}

</div>