{% comment %}
  snippets/collection-products.liquid
  Renders the products grid and pagination for collection-showroom.liquid.
  Also interleaves any "banner" section blocks at their configured
  grid slot (e.g. a clickable landscape banner after the 3rd product).

  Expects:
    collection  {Object} — the Shopify collection object
    paginate    {Object} — paginate object opened upstream in collection.liquid
    blocks      {Array}  — section.blocks, forwarded from collection.liquid
                            via collection-showroom.liquid. May be blank.

  Block settings read (per block, type == "banner"):
    position  {Number} — 1-indexed product slot AFTER which the banner
                          renders on the CURRENT page. 0 or blank = before
                          the first product. Values beyond the page's
                          product count render after the last product.
    width     {String} — "25" | "50" | "75" | "100", percent of row width.
                          Resolved to an actual grid-column span by
                          collection-banner.js against the grid's live
                          column count.

  Card rendering: delegates to product-card.liquid.
  Banner rendering: delegates to collection-banner.liquid.
  product-card.js is loaded globally via theme.liquid — do NOT load it here.

  IMPORTANT — paginate.collection.products vs collection.products:
    Inside a {% paginate %} block, `collection.products` is NOT sliced
    to the current page; it still returns the full collection. The
    page-sliced array is only available via `paginate.collection.products`.
    This snippet must loop over paginate.collection.products, or every
    page will render the full product list while pagination links
    still appear (since paginate.pages/parts are computed correctly
    from the paginate tag itself, independent of which array you loop).

  NOTE on pagination + block position:
    "position" is evaluated per page, not globally across the whole
    collection. A banner set to position 3 will appear after the 3rd
    product on every page, not only on page 1. If a merchant wants a
    banner to appear only once, instruct them to place it via a
    standalone section instead of a collection block.
{% endcomment %}

{%- liquid
  assign banner_blocks = blocks | where: 'type', 'banner'
  assign products_on_page = paginate.collection.products.size
-%}

<div class="collection-products">

  {%- if products_on_page > 0 -%}
    <div class="collection-products__grid">

      {%- comment -%} Banners positioned before the first product (position 0 or blank) {%- endcomment -%}
      {%- for block in banner_blocks -%}
        {%- liquid
          assign block_position = block.settings.position | default: 0
        -%}
        {%- if block_position <= 0 -%}
          {%- render 'collection-banner', block: block -%}
        {%- endif -%}
      {%- endfor -%}

      {%- for product in paginate.collection.products -%}
        {%- render 'product-card', product: product -%}

        {%- comment -%} Banners positioned after THIS product index {%- endcomment -%}
        {%- assign current_index = forloop.index -%}
        {%- for block in banner_blocks -%}
          {%- liquid
            assign block_position = block.settings.position | default: 0
          -%}
          {%- if block_position == current_index -%}
            {%- render 'collection-banner', block: block -%}
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%}
          On the last product, also render any banner blocks whose
          configured position is greater than the number of products
          on this page (so they aren't silently dropped on short pages).
        {%- endcomment -%}
        {%- if forloop.last -%}
          {%- for block in banner_blocks -%}
            {%- liquid
              assign block_position = block.settings.position | default: 0
            -%}
            {%- if block_position > products_on_page -%}
              {%- render 'collection-banner', block: block -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}

    </div>
  {%- else -%}
    <p class="collection-products__empty">
      {{ 'collections.general.no_matches' | t }}
    </p>

    {%- comment -%} No products at all on this page — still show banners so merchants can preview them. {%- endcomment -%}
    {%- for block in banner_blocks -%}
      {%- render 'collection-banner', block: block -%}
    {%- endfor -%}
  {%- endif -%}

  {%- if paginate.pages > 1 -%}
    <nav
      class="collection-products__pagination"
      aria-label="{{ 'general.pagination.label' | t }}"
    >
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="collection-products__page-link">
          &larr; {{ 'general.pagination.previous' | t }}
        </a>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <a href="{{ part.url }}" class="collection-products__page-link">
            {{ part.title }}
          </a>
        {%- else -%}
          <span
            class="collection-products__page-link collection-products__page-link--current"
            aria-current="page"
          >
            {{ part.title }}
          </span>
        {%- endif -%}
      {%- endfor -%}

      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="collection-products__page-link">
          {{ 'general.pagination.next' | t }} &rarr;
        </a>
      {%- endif -%}
    </nav>
  {%- endif -%}

</div>
