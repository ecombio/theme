<div class="product-accordion-section">
  <!-- Product Details -->
  <details class="accordion-item">
    <summary class="accordion-summary">
      <h2 class="accordion-title">Product Details</h2>
      <svg class="accordion-icon plus" width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M3.125 10H16.875" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M10 3.125V16.875" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </summary>
    <div class="accordion-content">
      {%- if product.description != blank -%}
        {{ product.description }}
      {%- endif -%}
    </div>
  </details>

  <!-- Materials & Care -->
  <details class="accordion-item">
    <summary class="accordion-summary">
      <h2 class="accordion-title">Materials & Care</h2>
      <svg class="accordion-icon plus" width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M3.125 10H16.875" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M10 3.125V16.875" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </summary>
    <div class="accordion-content">
      {%- if product.metafields.custom.materials_care -%}
        {{ product.metafields.custom.materials_care }}
      {%- else -%}
        <p>Made with premium materials. Clean with a soft, dry cloth. Avoid harsh chemicals.</p>
      {%- endif -%}
    </div>
  </details>
</div>
