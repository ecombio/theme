{% comment %}
  snippets/collection-carousel.liquid
  Renders a single carousel block inside the products grid
  (collection-products.liquid). Designed to span the full grid row.

  Expects:
    block  {Block} — a section block of type "carousel", with settings:
      heading       {String}
      image_shape   {String} — "circle" | "rounded" | "square"
      autoplay      {Boolean}
      autoplay_speed{Number} — seconds
      slide_1..6    {Image}  — block image-picker settings
      slide_*_label {String} — optional caption per slide
      slide_*_link  {Url}    — optional link per slide

  Self-contained: loads collection-carousel.css and collection-carousel.js.
  Multiple instances can exist on one page — JS scopes by data-carousel-id.

  NOTE: This snippet renders an <li>-equivalent wrapper sized to span the
  full grid row (collection-products__grid is a CSS grid). It is inserted
  directly into the product loop's markup by collection-products.liquid,
  not wrapped in a separate container, so it lines up with grid columns.
{% endcomment %}

{{ 'collection-carousel.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign shape = block.settings.image_shape | default: 'rounded'
  assign autoplay = block.settings.autoplay
  assign autoplay_speed = block.settings.autoplay_speed | default: 5
  assign carousel_id = 'carousel-' | append: block.id

  assign slides = ''
  assign slide_count = 0
  for i in (1..6)
    assign slide_key = 'slide_' | append: i
    assign slide_image = block.settings[slide_key]
    if slide_image != blank
      assign slide_count = slide_count | plus: 1
    endif
  endfor
-%}

<div
  class="collection-carousel collection-carousel--shape-{{ shape }}"
  id="{{ carousel_id }}"
  data-carousel
  data-carousel-id="{{ carousel_id }}"
  data-autoplay="{{ autoplay }}"
  data-autoplay-speed="{{ autoplay_speed }}"
  {{ block.shopify_attributes }}
>

  {%- if block.settings.heading != blank -%}
    <h3 class="collection-carousel__heading">{{ block.settings.heading | escape }}</h3>
  {%- endif -%}

  {%- if slide_count > 0 -%}
    <div class="collection-carousel__viewport">
      <ul class="collection-carousel__track" role="list" style="--slide-count: {{ slide_count }};">
        {%- for i in (1..6) -%}
          {%- liquid
            assign slide_key = 'slide_' | append: i
            assign label_key = 'slide_' | append: i | append: '_label'
            assign link_key  = 'slide_' | append: i | append: '_link'
            assign slide_image = block.settings[slide_key]
            assign slide_label = block.settings[label_key]
            assign slide_link  = block.settings[link_key]
          -%}
          {%- if slide_image != blank -%}
            <li class="collection-carousel__slide" data-carousel-slide aria-hidden="{% if i == 1 %}false{% else %}true{% endif %}">
              {%- if slide_link != blank -%}<a href="{{ slide_link }}" class="collection-carousel__slide-link">{%- endif -%}
                <div class="collection-carousel__image-wrap">
                  <img
                    class="collection-carousel__image"
                    src="{{ slide_image | image_url: width: 800 }}"
                    srcset="{{ slide_image | image_url: width: 400 }} 400w, {{ slide_image | image_url: width: 800 }} 800w, {{ slide_image | image_url: width: 1200 }} 1200w"
                    sizes="(min-width: 990px) 33vw, 90vw"
                    alt="{{ slide_image.alt | escape | default: slide_label | escape }}"
                    width="800"
                    height="{{ 800 | divided_by: slide_image.aspect_ratio | round }}"
                    loading="lazy"
                  >
                </div>
                {%- if slide_label != blank -%}
                  <span class="collection-carousel__slide-label">{{ slide_label | escape }}</span>
                {%- endif -%}
              {%- if slide_link != blank -%}</a>{%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    {%- if slide_count > 1 -%}
      <button type="button" class="collection-carousel__arrow collection-carousel__arrow--prev" data-carousel-prev aria-label="Previous slide">
        &larr;
      </button>
      <button type="button" class="collection-carousel__arrow collection-carousel__arrow--next" data-carousel-next aria-label="Next slide">
        &rarr;
      </button>

      <div class="collection-carousel__dots" role="tablist" aria-label="Carousel slides" data-carousel-dots>
        {%- for i in (1..slide_count) -%}
          <button
            type="button"
            class="collection-carousel__dot{% if i == 1 %} collection-carousel__dot--active{% endif %}"
            role="tab"
            aria-selected="{% if i == 1 %}true{% else %}false{% endif %}"
            aria-label="Go to slide {{ i }}"
            data-carousel-dot
            data-slide-index="{{ forloop.index0 }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}

</div>

<script src="{{ 'collection-carousel.js' | asset_url }}" defer></script>
