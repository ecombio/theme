{% comment %}
  snippets/collection-carousel.liquid
  [1.2.1 → 1.1.3] In-feed image slide carousel.

  Injected between product rows by collection-promo → promo-block.
  Always full row width. Supports up to 6 slides.
  Image shape is controlled per-block: circular / square / rounded.

  Parameters:
    block  {Object}  required — Shopify block with settings:
      heading      {String}   — carousel heading
      image_shape  {String}   — 'circle' | 'square' | 'rounded'
      autoplay     {Boolean}  — enable autoplay
      autoplay_speed {Number} — seconds between slides (3–10)
      slide_1      {image}    — slide image
      slide_1_label {String}  — slide caption
      slide_1_link  {URL}     — slide link
      … slide_2 through slide_6

  CSS: collection-carousel.css
  JS:  collection-carousel.js
{% endcomment %}

{{ 'collection-carousel.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign cc_heading   = block.settings.heading
  assign cc_shape     = block.settings.image_shape | default: 'rounded'
  assign cc_autoplay  = block.settings.autoplay
  assign cc_speed     = block.settings.autoplay_speed | default: 5

  assign cc_slides = ''
-%}

{%- comment -%}
  Build slide array. Liquid can't build arrays dynamically, so we
  iterate a fixed range and check each slide setting individually.
{%- endcomment -%}

<div
  class="collection-carousel collection-carousel--{{ cc_shape }}"
  data-collection-carousel
  data-autoplay="{{ cc_autoplay }}"
  data-speed="{{ cc_speed }}"
  {{ block.shopify_attributes }}
>

  {%- if cc_heading != blank -%}
    <h2 class="collection-carousel__heading">{{ cc_heading }}</h2>
  {%- endif -%}

  <div class="collection-carousel__track" data-collection-carousel-track>

    {%- comment -%} Slide 1 {%- endcomment -%}
    {%- if block.settings.slide_1 != blank -%}
      <div class="collection-carousel__slide" data-collection-carousel-slide>
        {%- if block.settings.slide_1_link != blank -%}
          <a href="{{ block.settings.slide_1_link }}" class="collection-carousel__slide-link">
        {%- endif -%}
          <div class="collection-carousel__img-wrap">
            <img
              class="collection-carousel__img"
              src="{{ block.settings.slide_1 | image_url: width: 600 }}"
              alt="{{ block.settings.slide_1.alt | escape | default: block.settings.slide_1_label | escape }}"
              width="600"
              height="600"
              loading="lazy"
            >
          </div>
          {%- if block.settings.slide_1_label != blank -%}
            <span class="collection-carousel__caption">{{ block.settings.slide_1_label }}</span>
          {%- endif -%}
        {%- if block.settings.slide_1_link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Slide 2 {%- endcomment -%}
    {%- if block.settings.slide_2 != blank -%}
      <div class="collection-carousel__slide" data-collection-carousel-slide>
        {%- if block.settings.slide_2_link != blank -%}
          <a href="{{ block.settings.slide_2_link }}" class="collection-carousel__slide-link">
        {%- endif -%}
          <div class="collection-carousel__img-wrap">
            <img class="collection-carousel__img" src="{{ block.settings.slide_2 | image_url: width: 600 }}" alt="{{ block.settings.slide_2.alt | escape | default: block.settings.slide_2_label | escape }}" width="600" height="600" loading="lazy">
          </div>
          {%- if block.settings.slide_2_label != blank -%}
            <span class="collection-carousel__caption">{{ block.settings.slide_2_label }}</span>
          {%- endif -%}
        {%- if block.settings.slide_2_link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Slide 3 {%- endcomment -%}
    {%- if block.settings.slide_3 != blank -%}
      <div class="collection-carousel__slide" data-collection-carousel-slide>
        {%- if block.settings.slide_3_link != blank -%}
          <a href="{{ block.settings.slide_3_link }}" class="collection-carousel__slide-link">
        {%- endif -%}
          <div class="collection-carousel__img-wrap">
            <img class="collection-carousel__img" src="{{ block.settings.slide_3 | image_url: width: 600 }}" alt="{{ block.settings.slide_3.alt | escape | default: block.settings.slide_3_label | escape }}" width="600" height="600" loading="lazy">
          </div>
          {%- if block.settings.slide_3_label != blank -%}
            <span class="collection-carousel__caption">{{ block.settings.slide_3_label }}</span>
          {%- endif -%}
        {%- if block.settings.slide_3_link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Slide 4 {%- endcomment -%}
    {%- if block.settings.slide_4 != blank -%}
      <div class="collection-carousel__slide" data-collection-carousel-slide>
        {%- if block.settings.slide_4_link != blank -%}
          <a href="{{ block.settings.slide_4_link }}" class="collection-carousel__slide-link">
        {%- endif -%}
          <div class="collection-carousel__img-wrap">
            <img class="collection-carousel__img" src="{{ block.settings.slide_4 | image_url: width: 600 }}" alt="{{ block.settings.slide_4.alt | escape | default: block.settings.slide_4_label | escape }}" width="600" height="600" loading="lazy">
          </div>
          {%- if block.settings.slide_4_label != blank -%}
            <span class="collection-carousel__caption">{{ block.settings.slide_4_label }}</span>
          {%- endif -%}
        {%- if block.settings.slide_4_link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Slide 5 {%- endcomment -%}
    {%- if block.settings.slide_5 != blank -%}
      <div class="collection-carousel__slide" data-collection-carousel-slide>
        {%- if block.settings.slide_5_link != blank -%}
          <a href="{{ block.settings.slide_5_link }}" class="collection-carousel__slide-link">
        {%- endif -%}
          <div class="collection-carousel__img-wrap">
            <img class="collection-carousel__img" src="{{ block.settings.slide_5 | image_url: width: 600 }}" alt="{{ block.settings.slide_5.alt | escape | default: block.settings.slide_5_label | escape }}" width="600" height="600" loading="lazy">
          </div>
          {%- if block.settings.slide_5_label != blank -%}
            <span class="collection-carousel__caption">{{ block.settings.slide_5_label }}</span>
          {%- endif -%}
        {%- if block.settings.slide_5_link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Slide 6 {%- endcomment -%}
    {%- if block.settings.slide_6 != blank -%}
      <div class="collection-carousel__slide" data-collection-carousel-slide>
        {%- if block.settings.slide_6_link != blank -%}
          <a href="{{ block.settings.slide_6_link }}" class="collection-carousel__slide-link">
        {%- endif -%}
          <div class="collection-carousel__img-wrap">
            <img class="collection-carousel__img" src="{{ block.settings.slide_6 | image_url: width: 600 }}" alt="{{ block.settings.slide_6.alt | escape | default: block.settings.slide_6_label | escape }}" width="600" height="600" loading="lazy">
          </div>
          {%- if block.settings.slide_6_label != blank -%}
            <span class="collection-carousel__caption">{{ block.settings.slide_6_label }}</span>
          {%- endif -%}
        {%- if block.settings.slide_6_link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>

  <button class="collection-carousel__btn collection-carousel__btn--prev" type="button" aria-label="Previous slide" data-collection-carousel-prev>
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <button class="collection-carousel__btn collection-carousel__btn--next" type="button" aria-label="Next slide" data-collection-carousel-next>
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="collection-carousel__dots" aria-hidden="true" data-collection-carousel-dots></div>

</div>

<script src="{{ 'collection-carousel.js' | asset_url }}" defer></script>
