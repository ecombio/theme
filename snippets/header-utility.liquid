{% comment %}
  Header Utility Bar
  File: snippets/header-utility.liquid

  Renders a slim 32px bar above the main header.
    Left  — utility links (pipe-delimited setting: "Label|/url, Label 2|/url-2")
    Right — region picker (opens dropdown) + currency + language selectors

  Region picker dropdown is teleported to <body> via JS to avoid
  stacking context / overflow:hidden clipping from the header.

  Usage (sections/header.liquid):
    {%- render 'header-utility',
          header_style:  header_style,
          links:         links,
          show_currency: show_currency,
          show_locale:   show_locale
    -%}
{% endcomment %}

{{ 'header-utility.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign bar_style  = header_style | default: 'hyper'
  assign show_curr  = show_currency | default: true
  assign show_loc   = show_locale   | default: true
  assign links_norm = links | newline_to_br | replace: '<br />', ',' | replace: '<br>', ','
  assign link_pairs  = links_norm | split: ','
-%}

<div class="header__utility-bar header__utility-bar--{{ bar_style }}"
     role="navigation"
     aria-label="Utility bar"
     id="header__utility-bar">

  <div class="header__utility-bar-inner">

    {%- comment -%} ── LEFT: links ── {%- endcomment -%}
    <div class="header__utility-bar-col header__utility-bar-col--left">
      <ul class="header__utility-bar-links" role="list">
        {%- for pair in link_pairs -%}
          {%- assign parts = pair | strip | split: '|' -%}
          {%- if parts.size == 2 -%}
            <li>
              <a href="{{ parts[1] | strip | escape }}" class="header__utility-bar-link">
                {{- parts[0] | strip | escape -}}
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    {%- comment -%} ── RIGHT: currency + locale + region picker ── {%- endcomment -%}
    <div class="header__utility-bar-col header__utility-bar-col--right">
      <div class="header__utility-bar-switchers">

        {%- if show_curr and shop.enabled_currencies.size > 1 -%}
          <div class="header__utility-bar-switcher">
            {%- form 'currency', id: 'header-currency-form', return_to: request.path -%}
              <label for="header-currency-select" class="visually-hidden">Currency</label>
              <div class="header__utility-bar-select-wrap">
                <select id="header-currency-select"
                        name="currency"
                        class="header__utility-bar-select"
                        aria-label="Select currency"
                        onchange="this.form.submit()">
                  {%- for currency in shop.enabled_currencies -%}
                    <option value="{{ currency.iso_code }}"
                      {%- if currency == cart.currency %} selected{% endif -%}>
                      {{ currency.iso_code }} &ndash; {{ currency.symbol }}
                    </option>
                  {%- endfor -%}
                </select>
                <svg class="header__utility-bar-chevron" width="9" height="9" viewBox="0 0 20 20"
                     fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 8l5 5 5-5"/>
                </svg>
              </div>
            {%- endform -%}
          </div>
        {%- endif -%}

        {%- if show_loc and localization.available_languages.size > 1 -%}
          <div class="header__utility-bar-switcher">
            {%- form 'localization', id: 'header-locale-form', return_to: request.path -%}
              <label for="header-locale-select" class="visually-hidden">Language</label>
              <div class="header__utility-bar-select-wrap">
                <select id="header-locale-select"
                        name="locale_code"
                        class="header__utility-bar-select"
                        aria-label="Select language"
                        onchange="this.form.submit()">
                  {%- for language in localization.available_languages -%}
                    <option value="{{ language.iso_code }}"
                      {%- if language.iso_code == localization.language.iso_code %} selected{% endif -%}>
                      {{ language.endonym_name | capitalize }}
                    </option>
                  {%- endfor -%}
                </select>
                <svg class="header__utility-bar-chevron" width="9" height="9" viewBox="0 0 20 20"
                     fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 8l5 5 5-5"/>
                </svg>
              </div>
            {%- endform -%}
          </div>
        {%- endif -%}

        {%- comment -%} ── Region picker trigger ── {%- endcomment -%}
        <button type="button"
                class="header__utility-bar-region-btn"
                aria-label="Choose location: {{ localization.country.name }}"
                aria-expanded="false"
                aria-controls="header__region-dropdown"
                id="header__region-trigger">
          <img src="https://cdn.shopify.com/shopifycloud/preview-bar/assets/{{ localization.country.iso_code | downcase }}.svg"
               alt="{{ localization.country.name }} flag"
               width="16" height="11"
               class="header__utility-bar-flag"
               loading="eager">
          <span class="header__utility-bar-region-label">
            {{ localization.language.endonym_name | capitalize }} ({{ localization.country.iso_code }})
          </span>
          <svg class="header__utility-bar-chevron header__region-trigger-chevron"
               width="9" height="9" viewBox="0 0 20 20"
               fill="none" stroke="currentColor" stroke-width="2.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 8l5 5 5-5"/>
          </svg>
        </button>

      </div>
    </div>
  </div>
</div>

{%- comment -%}
  Dropdown is placed here in DOM but immediately teleported to <body> by JS.
  This escapes every stacking context in the header chain.
{%- endcomment -%}
<div class="header__region-dropdown"
     id="header__region-dropdown"
     role="dialog"
     aria-modal="true"
     aria-label="Choose location"
     hidden>

  <div class="header__region-dropdown-header">
    <p class="header__region-dropdown-title">Choose location</p>
    <button type="button"
            class="header__region-dropdown-close"
            aria-label="Close location picker"
            id="header__region-close">
      <svg width="14" height="14" viewBox="0 0 20 20" fill="none"
           stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 4l12 12M16 4L4 16"/>
      </svg>
    </button>
  </div>

  <p class="header__region-dropdown-subtitle">
    Changing your location might affect your delivery address options, price, product availability, and currency.
  </p>

  <div class="header__region-search-wrap">
    <input type="text"
           class="header__region-search"
           placeholder="Search your country"
           aria-label="Search countries"
           id="header__region-search"
           autocomplete="off">
    <svg class="header__region-search-icon" width="14" height="14"
         viewBox="0 0 20 20" fill="none" stroke="currentColor"
         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="9" cy="9" r="6"/><path d="M15 15l3 3"/>
    </svg>
  </div>

  <div class="header__region-section-label">Current country &amp; language</div>

  <div class="header__region-current">
    <img src="https://cdn.shopify.com/shopifycloud/preview-bar/assets/{{ localization.country.iso_code | downcase }}.svg"
         alt="{{ localization.country.name }}"
         width="20" height="14"
         class="header__region-flag">
    <span class="header__region-current-country">{{ localization.country.name }}</span>

    {%- if localization.available_languages.size > 1 -%}
      {%- form 'localization', id: 'header-region-locale-form', return_to: request.path -%}
        <div class="header__region-lang-wrap">
          <select name="locale_code"
                  class="header__region-lang-select"
                  aria-label="Select language for {{ localization.country.name }}"
                  onchange="this.form.submit()">
            {%- for language in localization.available_languages -%}
              <option value="{{ language.iso_code }}"
                {%- if language.iso_code == localization.language.iso_code %} selected{% endif -%}>
                {{ language.endonym_name | capitalize }} ({{ localization.country.iso_code }})
              </option>
            {%- endfor -%}
          </select>
          <svg width="10" height="10" viewBox="0 0 20 20" fill="none"
               stroke="currentColor" stroke-width="2.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 8l5 5 5-5"/>
          </svg>
        </div>
      {%- endform -%}
    {%- else -%}
      <span class="header__region-lang-static">
        {{ localization.language.endonym_name | capitalize }} ({{ localization.country.iso_code }})
      </span>
    {%- endif -%}
  </div>

  <div class="header__region-divider"></div>

  {%- form 'localization', id: 'header-region-country-form', return_to: request.path -%}
    <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
    <ul class="header__region-list" id="header__region-list" role="list">
      {%- for country in localization.available_countries -%}
        {%- unless country.iso_code == localization.country.iso_code -%}
          <li class="header__region-item" data-country="{{ country.name | downcase }}">
            <button type="submit"
                    name="country_code"
                    value="{{ country.iso_code }}"
                    class="header__region-country-btn"
                    form="header-region-country-form">
              <img src="https://cdn.shopify.com/shopifycloud/preview-bar/assets/{{ country.iso_code | downcase }}.svg"
                   alt="{{ country.name }}"
                   width="20" height="14"
                   class="header__region-flag"
                   loading="lazy">
              <span class="header__region-country-name">{{ country.name }}</span>
              <span class="header__region-country-lang">
                {{ localization.language.endonym_name | capitalize }} ({{ country.iso_code }})
              </span>
            </button>
          </li>
        {%- endunless -%}
      {%- endfor -%}
    </ul>
  {%- endform -%}

</div>

<script src="{{ 'header-utility.js' | asset_url }}" defer="defer"></script>