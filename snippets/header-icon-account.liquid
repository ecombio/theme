{% comment %}
  Header — Account Icon
  File: snippets/header-icon-account.liquid

  Leaf component — no parameters. Uses the global `customer` object to
  decide between an account link and a sign-in link.
{% endcomment %}

{%- if customer -%}
  <a href="{{ routes.account_url }}"
     class="main-header__icon-btn"
     aria-label="My account">
{%- else -%}
  <a href="{{ routes.account_login_url }}"
     class="main-header__icon-btn"
     aria-label="Sign in or register">
{%- endif -%}
  <svg class="main-header__icon" width="22" height="22" viewBox="0 0 24 24" fill="none"
       stroke="currentColor" stroke-width="1.75"
       stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
    <circle cx="12" cy="7" r="4"/>
  </svg>
  <span class="main-header__icon-label" aria-hidden="true">
    {%- if customer -%}Account{%- else -%}Sign in / Register{%- endif -%}
  </span>
</a>
