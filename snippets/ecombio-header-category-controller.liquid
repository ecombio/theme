{% comment %}
  Desktop Sticky Header Toggle
  Appears when header is sticky.
  Toggles visibility of the main menu bar.
{% endcomment %}

<button 
  class="ecombio-header__sticky-toggle"
  type="button"
  aria-label="Toggle menu bar"
  aria-expanded="true"
>
  <svg 
    width="20" 
    height="20" 
    viewBox="0 0 24 24" 
    fill="none" 
    stroke="currentColor" 
    stroke-width="2.25" 
    stroke-linecap="round" 
    stroke-linejoin="round"
  >
    <line x1="3" y1="6" x2="21" y2="6"></line>
    <line x1="3" y1="12" x2="21" y2="12"></line>
    <line x1="3" y1="18" x2="21" y2="18"></line>
  </svg>
</button>