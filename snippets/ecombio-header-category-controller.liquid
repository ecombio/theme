{% comment %}
  ECOMBIO Header - Categories Controller
  Drop this right after the logo in the sticky header.
  Shows a compact "Categories" button + dropdown for quick navigation.
{% endcomment %}

<div class="ecombio-header__category-controller">
  <button 
    class="ecombio-header__cat-trigger" 
    type="button"
    aria-haspopup="true" 
    aria-expanded="false"
    aria-controls="ecombio-header-cat-dropdown"
  >
    <!-- Grid icon (matches your existing icon style) -->
    <svg class="ecombio-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="7" height="7"></rect>
      <rect x="14" y="3" width="7" height="7"></rect>
      <rect x="3" y="14" width="7" height="7"></rect>
      <rect x="14" y="14" width="7" height="7"></rect>
    </svg>

    <span class="ecombio-header__cat-text">Categories</span>

    <!-- Chevron -->
    <svg class="ecombio-header__cat-chevron" width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 8l5 5 5-5"></path>
    </svg>
  </button>

  <!-- Dropdown -->
  <div class="ecombio-header__cat-dropdown" id="ecombio-header-cat-dropdown" hidden>
    <ul class="ecombio-header__cat-list">
      <li><a href="/collections/electric-scooters">Electric Scooters</a></li>
      <li><a href="/collections/electric-bikes">Electric Bikes</a></li>
      <li><a href="/collections/electric-skateboards">Electric Skateboards</a></li>
      <li><a href="/collections/accessories">Accessories &amp; Parts</a></li>
      
      <li class="ecombio-header__cat-divider"></li>
      
      <li><a href="/collections/all?sort_by=best-selling" class="ecombio-header__cat-highlight">On Sale</a></li>
      <li><a href="/collections">Browse All Categories →</a></li>
    </ul>
  </div>
</div>