{% comment %}
  Sticky-header only hamburger-style Categories toggle
  Shows as hamburger, turns into X when open
{% endcomment %}

<button 
  class="ecombio-header__cat-toggle hidden lg:flex"
  type="button"
  aria-label="Toggle categories menu"
  aria-expanded="false"
  aria-controls="ecombio-mobile-nav"
>
  <!-- Hamburger lines -->
  <span class="ecombio-header__cat-toggle-line"></span>
  <span class="ecombio-header__cat-toggle-line"></span>
  <span class="ecombio-header__cat-toggle-line"></span>
</button>