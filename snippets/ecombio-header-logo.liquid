{% comment %}
  ECOMBIO Header — Logo
  File: snippets/ecombio-header-logo.liquid

  Parameters:
    - logo       {image}   — image object from section.settings.logo
    - logo_width {integer} — px width from section.settings.logo_width
{% endcomment %}

<div class="ecombio-header__logo">
  <a href="{{ routes.root_url }}" class="ecombio-header__logo-link">
    {%- if logo != blank -%}
      <img
        src="{{ logo | image_url: width: logo_width }}"
        alt="{{ shop.name }}"
        width="{{ logo_width }}"
        height="auto"
        class="ecombio-header__logo-img"
        loading="eager"
      >
    {%- else -%}
      <span class="ecombio-header__logo-text">{{ shop.name }}</span>
    {%- endif -%}
  </a>
</div>
