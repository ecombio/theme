{% comment %}
  Product Specifications Section
  Renders only specs that have values
{% endcomment %}

{% assign top_speed   = product.metafields.custom.spec_top_speed.value %}
{% assign motor       = product.metafields.custom.spec_motor.value %}
{% assign range       = product.metafields.custom.spec_range.value %}
{% assign tires       = product.metafields.custom.spec_tires.value %}
{% assign connectivity = product.metafields.custom.spec_connectivity.value %}
{% assign safety      = product.metafields.custom.spec_safety.value %}

{% if top_speed != blank or motor != blank or range != blank or tires != blank or connectivity != blank or safety != blank %}
  <div class="product-specs">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-1">
      
      {% if top_speed != blank %}
        {% render 'spec-badge', icon: 'bolt', label: 'Top Speed', value: top_speed %}
      {% endif %}

      {% if motor != blank %}
        {% render 'spec-badge', icon: 'bolt', label: 'Motor', value: motor %}
      {% endif %}

      {% if range != blank %}
        {% render 'spec-badge', icon: 'battery', label: 'Range', value: range %}
      {% endif %}

      {% if tires != blank %}
        {% render 'spec-badge', icon: 'tires', label: 'Tires', value: tires %}
      {% endif %}

      {% if connectivity != blank %}
        {% render 'spec-badge', icon: 'connectivity', label: 'Connectivity', value: connectivity %}
      {% endif %}

      {% if safety != blank %}
        {% render 'spec-badge', icon: 'safety', label: 'Safety', value: safety %}
      {% endif %}

    </div>
  </div>
{% endif %}