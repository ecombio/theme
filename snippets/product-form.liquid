<div class="product-form">
  {% form 'product', product %}

    {% assign current_variant = product.selected_or_first_available_variant %}

    {%- comment -%}
      Hidden input that JS keeps updated as the user selects a variant pill.
      The form always submits whichever variant id is set here.
    {%- endcomment -%}
    <input type="hidden" name="id" id="variant-id" value="{{ current_variant.id }}">

    {% if product.variants.size > 1 %}
      <div class="form-group">
        <p class="form-label">
          {%- if product.options.size == 1 -%}
            {{ product.options.first }}
          {%- else -%}
            Variant
          {%- endif -%}
        </p>

        <div class="variant-pills" id="variant-pills">
          {% for variant in product.variants %}
            <button
              type="button"
              class="variant-pill{% if variant == current_variant %} active{% endif %}{% unless variant.available %} sold-out{% endunless %}"
              data-variant-id="{{ variant.id }}"
              data-price="{{ variant.price }}"
              data-compare-at-price="{{ variant.compare_at_price | default: 0 }}"
              data-available="{{ variant.available }}"
              data-inventory-management="{{ variant.inventory_management }}"
              data-inventory-quantity="{{ variant.inventory_quantity }}"
              {% unless variant.available %}aria-disabled="true"{% endunless %}
            >
              {{ variant.title }}
            </button>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    <div class="form-group">
      <p class="form-label">Quantity</p>
      <div class="qty-stepper">
        <button type="button" class="qty-btn" id="qty-dec" aria-label="Decrease quantity">−</button>
        <input
          type="number"
          name="quantity"
          id="quantity"
          class="qty-input"
          min="1"
          {% if current_variant.inventory_management == 'shopify' %}
            max="{{ current_variant.inventory_quantity }}"
          {% endif %}
          value="1"
          aria-label="Quantity"
        >
        <button type="button" class="qty-btn" id="qty-inc" aria-label="Increase quantity">+</button>
      </div>
    </div>

    <button
      type="submit"
      class="add-to-cart-btn"
      id="add-to-cart"
      {% unless current_variant.available %}disabled aria-disabled="true"{% endunless %}
    >
      {% if current_variant.available %}
        Add to cart
      {% else %}
        Sold out
      {% endif %}
    </button>

    <div class="dynamic-checkout">
      {{ form | payment_button }}
    </div>

    <script>
      window.productData = {{ product | json }};
    </script>

  {% endform %}
</div>