{%- comment -%}
  Snippet: card-page
  Called by: snippets/collection-pages.liquid

  Parameters:
    - page {Object} — page object (required)
{%- endcomment -%}

<div class="card-page" data-page-id="{{ page.id }}">

  {%- comment -%} ══ CONTENT ══ {%- endcomment -%}
  <div class="card-page__content">

    <a href="{{ page.url }}" class="card-page__title">{{ page.title }}</a>

    {%- if page.content != blank -%}
      <p class="card-page__excerpt">{{ page.content | strip_html | truncate: 120 }}</p>
    {%- endif -%}

    <a href="{{ page.url }}" class="card-page__link" aria-label="View {{ page.title | escape }}">View page</a>

  </div>

</div>