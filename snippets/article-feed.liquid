{{ 'article-feed.css' | asset_url | stylesheet_tag }}
{{ 'article-card.css' | asset_url | stylesheet_tag }}

{%- comment %} DEBUG: Testing custom.articles metafield {%- endcomment %}

{%- assign metafield_articles = collection.metafields.custom.articles.value -%}

<p style="background: yellow; padding: 15px; margin: 20px 0; font-family: monospace;">
  <strong>DEBUG OUTPUT:</strong><br><br>
  Metafield articles count: {{ metafield_articles.size }}<br>
  Metafield exists: {{ metafield_articles != blank }}
</p>

{%- if metafield_articles.size > 0 -%}
  <div class="article-feed" style="--columns: {{ section.settings.columns | default: 4 }};">
    {%- for article in metafield_articles -%}
      {%- render 'article-card', article: article -%}
    {%- endfor -%}
  </div>
{%- else -%}
  <p style="color: red; padding: 15px;">No articles found in the custom.articles metafield.</p>
{%- endif -%}