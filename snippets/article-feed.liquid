{%- comment -%}
  snippets/article-feed.liquid

  Pure feed: takes an article list, renders article-card per item.
  Owns no filtering, sorting, or pagination logic — that lives on
  the parent section (sections/collection.liquid).

  Mirrors snippets/product-feed.liquid in structure and philosophy:
  no CSS loaded here, no layout assumptions, just iteration + render.
  The parent section loads article-feed.css conditionally.

  DATA SOURCE
  ───────────
  articles are passed in as collection.metafields.custom.articles.value
  — a List · Blog post reference metafield resolved to an array of
  Shopify article objects. The snippet is agnostic to the source;
  it accepts any article array.

  Params
  ──────
  articles        {Array}   required — article object list to render
  show_excerpt    {Boolean} optional — passed through to article-card (default: true)
  show_author     {Boolean} optional — passed through to article-card (default: false)
  image_ratio     {String}  optional — passed through to article-card
                            'landscape' | 'square' | 'portrait' (default: 'landscape')
{%- endcomment -%}

{%- liquid
  assign feed_articles    = articles
  assign feed_show_excerpt = show_excerpt | default: true
  assign feed_show_author  = show_author  | default: false
  assign feed_image_ratio  = image_ratio  | default: 'landscape'
-%}

{%- if feed_articles.size > 0 -%}
  {%- for article in feed_articles -%}
    {%- render 'article-card',
      article:      article,
      show_excerpt: feed_show_excerpt,
      show_author:  feed_show_author,
      image_ratio:  feed_image_ratio
    -%}
  {%- endfor -%}
{%- else -%}
  <div class="article-feed__empty">
    <p>No articles found.</p>
  </div>
{%- endif -%}