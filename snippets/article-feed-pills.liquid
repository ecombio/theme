{{ 'article-feed-pills.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign active_tag = current_tags | first | downcase
  assign seen       = ''
  assign pill_tags  = '' | split: ','

  for article_item in articles
    assign meta_val = article_item.metafields['theme.article-tags'].value
    if meta_val != blank
      for item in meta_val
        assign parts = item | split: ','
        for raw in parts
          assign t = raw | strip
          unless t == blank
            assign marker = t | handleize | prepend: '|' | append: '|'
            unless seen contains marker
              assign seen      = seen | append: marker
              assign pill_tags = pill_tags | append: t | append: '~~' | split: '~~'
            endunless
          endunless
        endfor
      endfor
    endif
  endfor
-%}

{%- if pill_tags.size > 0 -%}
  <nav class="article-feed-pills" aria-label="Filter articles by tag">

    <a href="/blogs/articles"
       class="article-feed-pills__pill{% if active_tag == blank %} article-feed-pills__pill--active{% endif %}">All</a>

    {%- for t in pill_tags -%}
      {%- assign t_slug = t | handleize -%}
      <a href="/blogs/articles/tagged/{{ t_slug }}"
         class="article-feed-pills__pill{% if active_tag == t_slug %} article-feed-pills__pill--active{% endif %}">{{ t | escape }}</a>
    {%- endfor -%}

  </nav>
{%- endif -%}