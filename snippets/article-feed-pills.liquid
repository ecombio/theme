{{ 'article-feed-pills.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Snippet: article-feed-pills.liquid

  Must be called with the articles array passed in, because render
  has isolated scope and cannot access blogs[] directly:

    {%- render 'article-feed-pills', articles: blogs['articles'].articles -%}

  Metafield: article.tags — stored as a plain comma-separated string,
  e.g. "cycling, electric-scooters". This snippet splits on commas,
  de-dupes, and renders pills linking to /blogs/articles/tagged/{slug}.
{%- endcomment -%}

{%- liquid
  assign active_tag = current_tags | first | downcase
  assign all_tags   = '' | split: ','

  for article_item in articles
    assign raw = article_item.metafields.article.tags.value
    if raw != blank
      assign parts = raw | split: ','
      for part in parts
        assign t = part | strip
        if t != blank
          assign t_slug = t | handleize
          unless all_tags contains t_slug
            assign all_tags = all_tags | concat: t_slug | split: ','
          endunless
        endif
      endfor
    endif
  endfor
-%}

{%- if all_tags.size > 0 -%}
  <nav class="article-feed-pills" aria-label="Filter articles by tag">

    <a
      href="{{ blog.url | default: '/blogs/articles' }}"
      class="article-feed-pills__pill{% if active_tag == blank %} article-feed-pills__pill--active{% endif %}"
    >All</a>

    {%- for pill_slug in all_tags -%}
      <a
        href="/blogs/articles/tagged/{{ pill_slug }}"
        class="article-feed-pills__pill{% if active_tag == pill_slug %} article-feed-pills__pill--active{% endif %}"
      >{{ pill_slug | replace: '-', ' ' | capitalize | escape }}</a>
    {%- endfor -%}

  </nav>
{%- endif -%}