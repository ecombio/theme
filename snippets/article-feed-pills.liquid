{{ 'article-feed-pills.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Snippet: article-feed-pills.liquid
  Uses native Shopify article.tags — no metafield needed.

  Call from article-feed section, right after the title block:
    {%- render 'article-feed-pills', articles: blogs['articles'].articles -%}
{%- endcomment -%}

{%- liquid
  assign active_tag   = current_tags | first | downcase
  assign seen_slugs   = ''
  assign all_slugs    = '' | split: ','
  assign all_labels   = '' | split: ','

  for article_item in articles
    for t in article_item.tags
      assign t_slug = t | handleize
      assign marker = t_slug | prepend: '|' | append: '|'
      unless seen_slugs contains marker
        assign seen_slugs = seen_slugs | append: marker
        assign all_slugs  = all_slugs  | concat: t_slug  | split: ','
        assign all_labels = all_labels | concat: t        | split: ','
      endunless
    endfor
  endfor
-%}

{%- if all_slugs.size > 0 -%}
  <nav class="article-feed-pills" aria-label="Filter articles by tag">

    <a
      href="/blogs/articles"
      class="article-feed-pills__pill{% if active_tag == blank %} article-feed-pills__pill--active{% endif %}"
    >All</a>

    {%- for pill_slug in all_slugs -%}
      {%- assign pill_label = all_labels[forloop.index0] -%}
      <a
        href="/blogs/articles/tagged/{{ pill_slug }}"
        class="article-feed-pills__pill{% if active_tag == pill_slug %} article-feed-pills__pill--active{% endif %}"
      >{{ pill_label | escape }}</a>
    {%- endfor -%}

  </nav>
{%- endif -%}