{% comment %}
  Reusable Product Spec Badge
  Usage: {% render 'spec-badge', icon: 'bolt', label: 'Top Speed', value: 'Max 28 MPH' %}
{% endcomment %}

<div class="spec-badge flex items-start gap-3 py-2">
  <div class="mt-0.5 flex-shrink-0 text-[#111111]">
    {% render 'icon', icon: icon, class: 'w-5 h-5' %}
  </div>
  <div class="min-w-0 flex-1">
    <div class="text-xs font-medium tracking-[0.5px] text-gray-500 uppercase">{{ label }}</div>
    <div class="text-sm font-semibold text-[#111111] leading-tight">{{ value }}</div>
  </div>
</div>