{% comment %}
  ============================================================
  SNIPPET: menu-item.liquid (Minimal version for single-link)
  ============================================================
  Currently only supports simple links with optional icon.
  Kept minimal while we focus on single-link block.
{% endcomment %}

{% liquid
  assign title     = title | default: ''
  assign url       = url | default: '#'
  assign icon_type = icon_type | default: ''
  assign extra_class = class | default: ''
%}

<a href="{{ url | escape }}" class="menu-item {{ extra_class }}">
  {%- if icon_type != blank -%}
    <span class="menu-item__icon">
      {% render 'menu-icon', icon: icon_type %}
    </span>
  {%- endif -%}

  <span class="menu-item__text">{{ title }}</span>
</a>