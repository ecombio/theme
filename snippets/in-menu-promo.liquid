{% comment %}
  Mega Menu — In-panel Promo Card
  File: snippets/mega-menu-promo.liquid

  Rendered by blocks/mega-menu.liquid for any `promo` sub-block.
  Position (right | left | bottom) is handled via a modifier class
  on the parent .mega-menu-items element; this snippet is position-agnostic.

  Parameters:
    promo {block} — the promo sub-block object passed from blocks/mega-menu.liquid

  Usage:
    {%- render 'mega-menu-promo', promo: promo_block -%}
{% endcomment %}

{%- liquid
  assign p_image     = promo.settings.image
  assign p_heading   = promo.settings.heading
  assign p_subtext   = promo.settings.subtext
  assign p_cta_label = promo.settings.cta_label
  assign p_cta_link  = promo.settings.cta_link
-%}

<div class="mega-menu__promo" {{ promo.shopify_attributes }}>

  {%- if p_image != blank -%}
    <div class="mega-menu__promo-image">
      {{
        p_image
        | image_url: width: 480
        | image_tag:
            loading: 'lazy',
            alt: p_image.alt | default: p_heading,
            widths: '240, 360, 480'
      }}
    </div>
  {%- endif -%}

  <div class="mega-menu__promo-body">

    {%- if p_heading != blank -%}
      <p class="mega-menu__promo-heading">{{ p_heading }}</p>
    {%- endif -%}

    {%- if p_subtext != blank -%}
      <p class="mega-menu__promo-subtext">{{ p_subtext }}</p>
    {%- endif -%}

    {%- if p_cta_label != blank and p_cta_link != blank -%}
      <a href="{{ p_cta_link }}" class="mega-menu__promo-cta button button--primary">
        {{ p_cta_label }}
      </a>
    {%- endif -%}

  </div>

</div>
