{%- comment -%}
  ============================================================================
  snippets/icon.liquid — Icon registry
  ============================================================================

  Single entry point for all theme icons. Renders inline SVG so icons
  inherit CSS `color` via `currentColor` and require no HTTP requests.

  USAGE:
    {% render 'icon', name: 'search' %}
    {% render 'icon', name: 'cart' %}
    {% render 'icon', name: 'account' %}
    {% render 'icon', name: 'close' %}
    {% render 'icon', name: 'chevron-down' %}
    {% render 'icon', name: 'chevron-right' %}
    {% render 'icon', name: 'hamburger' %}
    {% render 'icon', name: 'arrow-left' %}
    {% render 'icon', name: 'plus' %}
    {% render 'icon', name: 'minus' %}
    {% render 'icon', name: 'check' %}
    {% render 'icon', name: 'star' %}

  VARIABLES:
    name    {string}  Icon identifier. Required.
    size    {number}  Width and height in pixels. Default: 20.
    class   {string}  Additional CSS classes. Optional.

  ADDING A NEW ICON:
    1. Add a new `when` block to the case statement below.
    2. Use `currentColor` for all fill/stroke values.
    3. Remove all hardcoded colours from the SVG source.
    4. Set viewBox to match the source artboard.

  All paths are original artwork. No third-party license required.
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign icon_size = size | default: 20
-%}

{%- case name -%}

  {%- when 'search' -%}
    <svg
      class="icon icon--search{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <circle cx="10.5" cy="10.5" r="6.5" />
      <line x1="15.5" y1="15.5" x2="21" y2="21" />
    </svg>

  {%- when 'account' -%}
    <svg
      class="icon icon--account{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <circle cx="12" cy="8" r="4" />
      <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
    </svg>

  {%- when 'cart' -%}
    <svg
      class="icon icon--cart{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
      <line x1="3" y1="6" x2="21" y2="6" />
      <path d="M16 10a4 4 0 01-8 0" />
    </svg>

  {%- when 'close' -%}
    <svg
      class="icon icon--close{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </svg>

  {%- when 'chevron-down' -%}
    <svg
      class="icon icon--chevron-down{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <polyline points="6 9 12 15 18 9" />
    </svg>

  {%- when 'chevron-right' -%}
    <svg
      class="icon icon--chevron-right{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <polyline points="9 18 15 12 9 6" />
    </svg>

  {%- when 'hamburger' -%}
    <svg
      class="icon icon--hamburger{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <line x1="3" y1="6"  x2="21" y2="6"  />
      <line x1="3" y1="12" x2="21" y2="12" />
      <line x1="3" y1="18" x2="21" y2="18" />
    </svg>

  {%- when 'arrow-left' -%}
    <svg
      class="icon icon--arrow-left{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <line x1="19" y1="12" x2="5" y2="12" />
      <polyline points="12 19 5 12 12 5" />
    </svg>

  {%- when 'plus' -%}
    <svg
      class="icon icon--plus{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <line x1="12" y1="5" x2="12" y2="19" />
      <line x1="5" y1="12" x2="19" y2="12" />
    </svg>

  {%- when 'minus' -%}
    <svg
      class="icon icon--minus{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <line x1="5" y1="12" x2="19" y2="12" />
    </svg>

  {%- when 'check' -%}
    <svg
      class="icon icon--check{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <polyline points="20 6 9 17 4 12" />
    </svg>

  {%- when 'star' -%}
    <svg
      class="icon icon--star{% if class != blank %} {{ class }}{% endif %}"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      fill="currentColor"
      stroke="none"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01L12 2z" />
    </svg>

  {%- else -%}
    {%- comment -%}
      Unknown icon name. Renders nothing but leaves a comment in source
      so developers can catch missing icons during QA without a thrown error.
    {%- endcomment -%}
    <!-- icon "{{ name }}" not found in snippets/icon.liquid -->

{%- endcase -%}