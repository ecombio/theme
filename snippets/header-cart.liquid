{% comment %} snippets/header-cart.liquid {% endcomment %}
<a href="{{ routes.cart_url }}"
   class="header__cart"
   aria-label="Cart{% if cart.item_count > 0 %}, {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}{% endif %}"
   data-cart-trigger
>
  <span class="header__cart-icon-wrap" aria-hidden="true">
    {% render 'icon', name: 'cart', size: 20, class: 'header__cart-icon' %}
    {%- if cart.item_count > 0 -%}
      <span class="header__cart-badge" data-cart-count>
        {{- cart.item_count -}}
      </span>
    {%- endif -%}
  </span>
  <span class="header__cart-label">Cart</span>
</a>