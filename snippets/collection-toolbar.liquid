{% comment %}
  Snippet: collection-toolbar
  Called by: sections/main-collection.liquid, sections/main-search.liquid
  Calls:     snippets/collection-tabs.liquid
             snippets/collection-sort.liquid

  Parameters:
    - show_filters  {Boolean}
    - active_tab    {String}  — 'products' | 'articles' | 'pages'
    - article_count {Number}
    - page_count    {Number}
    - product_count {Number}  — search context only
    - per_page      {Number}
    - show_banners  {Boolean}
    - context       {String}  — 'collection' | 'search'
    - section       {Object}
{% endcomment %}

<div class="collection-toolbar">

  {%- comment -%} ── Filter button — products tab only ── {%- endcomment -%}
  {%- if show_filters and active_tab != 'articles' and active_tab != 'pages' -%}
    <button
      class="collection-toolbar__filter-btn"
      type="button"
      id="filters-open-btn"
      aria-expanded="false"
      aria-controls="collection-filters"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M2 4h12M4 8h8M6 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      Filters
      <span class="collection-toolbar__active-count" id="active-filter-count" aria-live="polite"></span>
    </button>
  {%- endif -%}

  {%- comment -%} ── Count ── {%- endcomment -%}
  <span class="collection-toolbar__count">
    {%- if context == 'search' -%}
      {%- if active_tab == 'articles' -%}
        {{ article_count }} {{ article_count | pluralize: 'article', 'articles' }}
      {%- elsif active_tab == 'pages' -%}
        {{ page_count }} {{ page_count | pluralize: 'page', 'pages' }}
      {%- else -%}
        {{ product_count }} {{ product_count | pluralize: 'product', 'products' }}
      {%- endif -%}
    {%- else -%}
      {%- if collection.products_count == collection.all_products_count -%}
        {{ collection.all_products_count }} {{ collection.all_products_count | pluralize: 'product', 'products' }}
      {%- else -%}
        {{ collection.products_count }} of {{ collection.all_products_count }} products
      {%- endif -%}
    {%- endif -%}
  </span>

  {%- comment -%} ── Tabs + panels ── {%- endcomment -%}
  {% render 'collection-tabs',
    active_tab:    active_tab,
    article_count: article_count,
    page_count:    page_count,
    product_count: product_count,
    per_page:      per_page,
    show_banners:  show_banners,
    context:       context,
    section:       section
  %}

  {%- comment -%} ── Sort — hidden on pages tab ── {%- endcomment -%}
  {%- unless active_tab == 'pages' -%}
    {% render 'collection-sort' %}
  {%- endunless -%}

</div>
