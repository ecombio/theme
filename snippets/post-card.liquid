{% comment %}
  snippets/post-card.liquid
  Self-contained post (article) card used by collection-posts.liquid.

  Expects:
    post  {Object} — a Shopify article object

  Loads: post-card.css + post-card.js (via tags below)
{% endcomment %}

{{ 'post-card.css' | asset_url | stylesheet_tag }}

<article class="post-card" data-post-id="{{ post.id }}">

  {%- comment -%} ── Media ────────────────────────────────────────────────── {%- endcomment -%}

  {%- if post.image -%}
    <a href="{{ post.url }}" class="post-card__media-link" tabindex="-1" aria-hidden="true">
      <div class="post-card__media">
        <img
          class="post-card__image"
          src="{{ post.image | image_url: width: 600 }}"
          alt="{{ post.image.alt | escape | default: post.title | escape }}"
          width="600"
          height="{{ 600 | divided_by: post.image.aspect_ratio | round }}"
          loading="lazy"
        >
      </div>
    </a>
  {%- endif -%}

  {%- comment -%} ── Info ────────────────────────────────────────────────── {%- endcomment -%}

  <div class="post-card__info">

    <div class="post-card__meta">
      {%- if post.blog -%}
        <span class="post-card__blog">{{ post.blog.title }}</span>
        <span class="post-card__meta-sep" aria-hidden="true">&middot;</span>
      {%- endif -%}
      <time class="post-card__date" datetime="{{ post.published_at | date: '%Y-%m-%d' }}">
        {{ post.published_at | date: '%b %-d, %Y' }}
      </time>
    </div>

    <h3 class="post-card__title">
      <a href="{{ post.url }}" class="post-card__title-link">{{ post.title }}</a>
    </h3>

    {%- if post.excerpt_or_content != blank -%}
      <p class="post-card__excerpt">
        {{ post.excerpt_or_content | strip_html | truncate: 120 }}
      </p>
    {%- endif -%}

    {%- if post.tags.size > 0 -%}
      <ul class="post-card__tags" aria-label="Tags">
        {%- for tag in post.tags limit: 3 -%}
          <li class="post-card__tag">{{ tag }}</li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    <a href="{{ post.url }}" class="post-card__read-more" aria-label="Read {{ post.title | escape }}">
      Read more &rarr;
    </a>

  </div>

</article>

<script src="{{ 'post-card.js' | asset_url }}" defer></script>
