{%- comment -%}
  snippets/product-filter.liquid
  Facets (collection.filters) + sort-by, plain <form> submit (no JS).
  Rendered by sections/collection.liquid.

  Params:
    collection {Object} required — the collection object in scope
{%- endcomment -%}

{%- liquid
  assign filter_collection = collection
-%}

<div class="product-filter">

  {%- if filter_collection.filters.size > 0 -%}
    <details class="product-filter__facets">
      <summary class="product-filter__facets-summary">Filter</summary>
      <form class="product-filter__facets-form" action="{{ filter_collection.url }}" method="get">
        {%- for filter in filter_collection.filters -%}
          <fieldset class="product-filter__group">
            <legend class="product-filter__group-label">{{ filter.label }}</legend>
            {%- for value in filter.values -%}
              <label class="product-filter__option">
                <input
                  type="checkbox"
                  name="{{ value.param_name }}"
                  value="{{ value.value }}"
                  {% if value.active %}checked{% endif %}
                  {% if value.count == 0 and value.active == false %}disabled{% endif %}
                >
                <span>{{ value.label }} ({{ value.count }})</span>
              </label>
            {%- endfor -%}
          </fieldset>
        {%- endfor -%}

        {%- comment -%} Preserve current sort when filters are applied {%- endcomment -%}
        {%- if filter_collection.sort_by != blank -%}
          <input type="hidden" name="sort_by" value="{{ filter_collection.sort_by }}">
        {%- endif -%}

        <button type="submit" class="product-filter__apply">Apply</button>
        <a href="{{ filter_collection.url }}" class="product-filter__clear">Clear all</a>
      </form>
    </details>
  {%- endif -%}

  {%- if filter_collection.sort_options.size > 0 -%}
    <form class="product-filter__sort-form" action="{{ filter_collection.url }}" method="get">
      <label for="ProductFilterSort" class="product-filter__sort-label">Sort by</label>
      <select
        name="sort_by"
        id="ProductFilterSort"
        class="product-filter__sort-select"
        onchange="this.form.submit()"
      >
        {%- for option in filter_collection.sort_options -%}
          <option value="{{ option.value }}" {% if option.value == filter_collection.sort_by %}selected{% endif %}>
            {{ option.name }}
          </option>
        {%- endfor -%}
      </select>

      {%- comment -%} Preserve active facets when sort changes {%- endcomment -%}
      {%- for filter in filter_collection.filters -%}
        {%- for value in filter.values -%}
          {%- if value.active -%}
            <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </form>
  {%- endif -%}

</div>
