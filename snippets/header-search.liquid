{% comment %}
  Header Search
  File: snippets/header-search.liquid

  Single owner of the search UX in the header. Renders the always-visible
  search bar twice — once for desktop, once for mobile — because they sit
  in different positions in the header layout. When predictive search is
  enabled it also renders the empty results panel container that JS fills.

  ── PIPELINE ────────────────────────────────────────────────────────────
  Predictive results arrive via Shopify's Section Rendering API:

      GET {{ routes.predictive_search_url }}
          ?q=TERM
          &section_id=predictive-search
          &resources[type]=product,collection,query

  assets/header-search.js handles the fetch and injects the HTML rendered
  by sections/predictive-search.liquid into [data-search-results].
  Do NOT modify the Liquid or Section Rendering API flow from here.

  ── EMPTY / FOCUS STATE ─────────────────────────────────────────────────
  When the user focuses the input without typing, JS shows a panel with:
    1. Recent searches  — up to 5 terms from sessionStorage
    2. Trending searches — from window.HS_TRENDING (see below)
  This is entirely JS-driven; no Liquid changes are needed in the results
  section. When the query reaches 2+ characters, predictive results replace
  the empty state automatically.

  ── TRENDING TERMS (typewriter + empty state) ───────────────────────────
  Sourced from the merchant-editable 'predictive-search-trending' nav menu:
    Admin → Content → Menus → predictive-search-trending
  Each link's Title becomes a typewriter / trending term. The URL is unused.
  If the menu doesn't exist or is empty, a set of built-in defaults is used
  so the typewriter always runs when predictive search is on.

  ── DATA ATTRIBUTES ON [data-search-root] ───────────────────────────────
    data-predictive              — present when predictive search is on
    data-predictive-search-url  — routes.predictive_search_url for fetch
    data-search-url             — routes.search_url for link building in JS
                                   (avoids hardcoding '/search' in JS)

  ── ASSETS ──────────────────────────────────────────────────────────────
    assets/header-search.css  — always loaded (form + panel + empty state)
    assets/header-search.js   — loaded only when predictive search is on

  Rendered from sections/main-header.liquid with a single param:
    {%- render 'header-search',
          enable_predictive_search: section.settings.enable_predictive_search
    -%}
{% endcomment %}

{%- liquid
  assign predictive = true
  if enable_predictive_search == false
    assign predictive = false
  endif
-%}

{{- 'header-search.css' | asset_url | stylesheet_tag -}}

{%- if predictive -%}
  <script src="{{ 'header-search.js' | asset_url }}" defer="defer"></script>

  {%- comment -%}
    Build window.HS_TRENDING from the merchant-editable menu.
    Falls back to built-in defaults so the typewriter always has terms.
  {%- endcomment -%}
  {%- assign trending_menu = linklists['predictive-search-trending'] -%}

  <script>
    window.HS_TRENDING = [
      {%- if trending_menu and trending_menu.links.size > 0 -%}
        {%- for link in trending_menu.links -%}
          {{- link.title | json -}}{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      {%- else -%}
        "sneakers","hoodies","summer dresses","running shoes","gift sets",
        "new arrivals","accessories","sale items"
      {%- endif -%}
    ];
  </script>
{%- endif -%}

{%- comment -%}
  Render once for desktop, once for mobile.
  CSS in header-search.css controls which is visible at each breakpoint:
    Desktop (≥ 1024px) : --desktop visible, --mobile hidden
    Mobile  (≤ 1023px) : --desktop hidden,  --mobile visible
{%- endcomment -%}
{%- for viewport in (1..2) -%}
  {%- assign sfx = 'desktop' -%}
  {%- if viewport == 2 -%}{%- assign sfx = 'mobile' -%}{%- endif -%}

  <div
    class="header-search header-search--{{ sfx }}{% unless predictive %} header-search--basic{% endunless %}"
    data-search-root
    {%- if predictive %}
    data-predictive
    data-predictive-search-url="{{ routes.predictive_search_url }}"
    data-search-url="{{ routes.search_url }}"
    {%- endif %}>

    <form
      action="{{ routes.search_url }}"
      method="get"
      role="search"
      class="header-search__form"
      id="HeaderSearchForm-{{ sfx }}"
      autocomplete="off">

      <input type="hidden" name="type" value="product">

      <label class="visually-hidden" for="HeaderSearch-{{ sfx }}">Search</label>

      <input
        type="search"
        name="q"
        id="HeaderSearch-{{ sfx }}"
        class="header-search__input"
        data-search-input
        placeholder="What are you looking for?"
        value="{{ search.terms | escape }}"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
        {%- if predictive %}
        role="combobox"
        aria-expanded="false"
        aria-owns="HeaderSearchResults-{{ sfx }}"
        aria-controls="HeaderSearchResults-{{ sfx }}"
        aria-haspopup="listbox"
        aria-autocomplete="list"
        {%- endif %}>

      {%- comment -%}
        Clear button — visible whenever the input has a value.
        JS sets hidden=false on init and on every input/change event,
        so it is always in sync regardless of how the value was set
        (typing, voice, browser autofill, pre-filled search.terms).
      {%- endcomment -%}
      <button
        type="button"
        class="header-search__clear"
        data-search-clear
        hidden
        aria-label="Clear search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6"  x2="6"  y2="18"/>
          <line x1="6"  y1="6"  x2="18" y2="18"/>
        </svg>
      </button>

      {%- comment -%}
        Voice button — hidden by default; JS un-hides it only when the
        Web Speech API is available in the current browser.
      {%- endcomment -%}
      <button
        type="button"
        class="header-search__voice"
        data-search-voice
        hidden
        aria-label="Search by voice">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
          <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
          <line x1="12" y1="19" x2="12" y2="23"/>
          <line x1="8"  y1="23" x2="16" y2="23"/>
        </svg>
      </button>

      <button
        type="submit"
        class="header-search__submit"
        aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>

    </form>

    {%- if predictive -%}
      {%- comment -%}
        Panel container — starts empty and hidden.
        JS injects one of three states:
          1. Empty/focus state  (trending + recent) on focus with no value
          2. Predictive results (from predictive-search.liquid) on query ≥ 2 chars
          3. Loading / error messages
      {%- endcomment -%}
      <div
        class="header-search__panel"
        id="HeaderSearchResults-{{ sfx }}"
        data-search-results
        role="listbox"
        aria-label="Search suggestions"
        tabindex="-1"
        hidden></div>

      <span
        class="visually-hidden"
        role="status"
        aria-live="polite"
        data-search-status></span>
    {%- endif -%}

  </div>
{%- endfor -%}
