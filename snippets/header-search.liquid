{% comment %}
  Predictive Search Form Snippet
  File: snippets/header-search.liquid

  Rendered by sections/main-header.liquid — called twice:
    {%- render 'header-search', ..., id_suffix: 'desktop' -%}
    {%- render 'header-search', ..., id_suffix: 'mobile'  -%}

  Params (all passed explicitly from main-header.liquid):
    id_suffix           {String}  — 'desktop' | 'mobile'
    show_category       {Boolean} — show/hide the category pill
    trending_1..5       {String}  — trending search terms
    cat_1..3_label      {String}  — category pill labels
    cat_1..3_value      {String}  — category pill tag values
    accent_color        {String}  — CSS accent colour
    highlight_bg        {String}  — match highlight background
    hover_bg            {String}  — row hover background
    border_focus        {String}  — focus border colour
    voice_enabled       {Boolean} — enable voice search
    placeholder_animate {Boolean} — enable typewriter placeholder

  Assets loaded by sections/main-header.liquid (NOT here):
    assets/header-search.css
    assets/header-search.js

  BEM prefix: .hs  (matches assets/header-search.css)
{% endcomment %}

{%- assign sfx      = id_suffix     | default: 'desktop' -%}
{%- assign show_cat = show_category | default: true -%}

{%- comment -%} ── Build trending array from passed params ── {%- endcomment -%}
{%- assign trending_raw = '' -%}
{%- if trending_1 != blank -%}{%- assign trending_raw = trending_raw | append: trending_1 | append: '|' -%}{%- endif -%}
{%- if trending_2 != blank -%}{%- assign trending_raw = trending_raw | append: trending_2 | append: '|' -%}{%- endif -%}
{%- if trending_3 != blank -%}{%- assign trending_raw = trending_raw | append: trending_3 | append: '|' -%}{%- endif -%}
{%- if trending_4 != blank -%}{%- assign trending_raw = trending_raw | append: trending_4 | append: '|' -%}{%- endif -%}
{%- if trending_5 != blank -%}{%- assign trending_raw = trending_raw | append: trending_5 | append: '|' -%}{%- endif -%}
{%- assign trending_array = trending_raw | split: '|' -%}

{%- comment -%}
  Inject JS config once — guarded by sfx == 'desktop' so we don't
  double-declare when the mobile instance renders.
{%- endcomment -%}
{%- if sfx == 'desktop' -%}
<script>
  window.HS_SETTINGS = {
    MIN_QUERY_LENGTH:      2,
    DEBOUNCE_MS:           200,
    MAX_QUERIES:           3,
    MAX_PRODUCTS:          5,
    MAX_COLLECTIONS:       2,
    RECENT_SEARCHES_LIMIT: 5,
    VOICE_ENABLED:         {{ voice_enabled       | default: true }},
    PLACEHOLDER_ANIMATE:   {{ placeholder_animate | default: true }},
    TRENDING_SEARCHES: [
      {%- assign trend_sep = '' -%}
      {%- for term in trending_array -%}
        {%- unless term == blank -%}
          {{ trend_sep }}{{ term | json }}
          {%- assign trend_sep = ',' -%}
        {%- endunless -%}
      {%- endfor -%}
    ]
  };
</script>
{%- endif -%}

<div class="hs"
     id="hs-{{ sfx }}"
     data-search-instance="{{ sfx }}"
     style="
       --hs-accent:       {{ accent_color | default: '#1a1a1a' }};
       --hs-highlight-bg: {{ highlight_bg | default: '#FFF3CD' }};
       --hs-bg-hover:     {{ hover_bg     | default: '#F5F5F5' }};
       --hs-border-focus: {{ border_focus | default: '#1a1a1a' }};
     ">

  <form action="{{ routes.search_url }}"
        method="get"
        role="search"
        class="hs__form"
        id="hs-form-{{ sfx }}"
        autocomplete="off">

    <input type="hidden" name="type" value="product">

    {%- comment -%} ── CATEGORY PILL ── {%- endcomment -%}
    {%- if show_cat -%}
      <div class="hs__category" id="hs-cat-wrap-{{ sfx }}">

        <button type="button"
                class="hs__cat-btn"
                id="hs-cat-btn-{{ sfx }}"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-controls="hs-cat-list-{{ sfx }}">
          <span class="hs__cat-label" id="hs-cat-label-{{ sfx }}">All</span>
          <svg class="hs__chevron" width="12" height="12" viewBox="0 0 20 20"
               fill="none" stroke="currentColor" stroke-width="2.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 8l5 5 5-5"/>
          </svg>
        </button>

        <ul class="hs__cat-list"
            id="hs-cat-list-{{ sfx }}"
            role="listbox"
            aria-labelledby="hs-cat-btn-{{ sfx }}"
            hidden>

          <li role="option" aria-selected="true"
              data-value="" data-label="All"
              tabindex="0">All Categories</li>

          {%- if cat_1_label != blank and cat_1_value != blank -%}
            <li role="option" aria-selected="false"
                data-value="{{ cat_1_value | escape }}"
                data-label="{{ cat_1_label | escape }}"
                tabindex="0">{{ cat_1_label | escape }}</li>
          {%- endif -%}

          {%- if cat_2_label != blank and cat_2_value != blank -%}
            <li role="option" aria-selected="false"
                data-value="{{ cat_2_value | escape }}"
                data-label="{{ cat_2_label | escape }}"
                tabindex="0">{{ cat_2_label | escape }}</li>
          {%- endif -%}

          {%- if cat_3_label != blank and cat_3_value != blank -%}
            <li role="option" aria-selected="false"
                data-value="{{ cat_3_value | escape }}"
                data-label="{{ cat_3_label | escape }}"
                tabindex="0">{{ cat_3_label | escape }}</li>
          {%- endif -%}

        </ul>

        <input type="hidden"
               class="hs__cat-value"
               id="hs-cat-value-{{ sfx }}"
               name="q[category]"
               value="">

        <span class="hs__divider" aria-hidden="true"></span>
      </div>
    {%- endif -%}

    {%- comment -%} ── SEARCH INPUT ── {%- endcomment -%}
    <input type="search"
           name="q"
           id="hs-input-{{ sfx }}"
           class="hs__input"
           placeholder="What are you looking for?"
           aria-label="Search products"
           aria-autocomplete="list"
           aria-controls="hs-dropdown-{{ sfx }}"
           aria-expanded="false"
           role="combobox"
           autocorrect="off"
           autocomplete="off"
           spellcheck="false">

    {%- comment -%} ── CLEAR BUTTON ── {%- endcomment -%}
    <button type="button"
            class="hs__clear"
            id="hs-clear-{{ sfx }}"
            aria-label="Clear search"
            hidden>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6"  y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    {%- comment -%}
      MIC BUTTON — injected by header-search.js if Web Speech API is available.
    {%- endcomment -%}

    {%- comment -%} ── SUBMIT ── {%- endcomment -%}
    <button type="submit" class="hs__submit" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </button>

  </form>

  {%- comment -%} ── DROPDOWN (all content injected by header-search.js) ── {%- endcomment -%}
  <div class="hs__dropdown"
       id="hs-dropdown-{{ sfx }}"
       role="listbox"
       aria-label="Search suggestions"
       aria-live="polite"
       hidden>
  </div>

  {%- comment -%} ── MOBILE BACKDROP ── {%- endcomment -%}
  <div class="hs__backdrop"
       id="hs-backdrop-{{ sfx }}"
       aria-hidden="true"
       hidden>
  </div>

</div>
