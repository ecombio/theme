{% comment %}
  Predictive Search Form Snippet
  File: snippets/header-search.liquid

  Rendered by sections/main-header.liquid — called twice:
    {%- render 'header-search', show_category: show_cat, id_suffix: 'desktop' -%}
    {%- render 'header-search', show_category: show_cat, id_suffix: 'mobile'  -%}

  Params:
    id_suffix     {String}  — 'desktop' | 'mobile'  (keeps element IDs unique)
    show_category {Boolean} — show/hide the category pill

  Assets loaded by sections/main-header.liquid (NOT here):
    assets/header-search.css
    assets/header-search.js

  The JS config object window.HS_SETTINGS is injected once (desktop instance only).
  header-search.js merges it with its own defaults via Object.assign.

  BEM prefix: .hs  (matches assets/header-search.css)
{% endcomment %}

{%- assign sfx          = id_suffix    | default: 'desktop' -%}
{%- assign show_cat     = show_category | default: true -%}

{%- comment -%} ── Build trending searches pipe-delimited string from settings ── {%- endcomment -%}
{%- assign trending_raw = '' -%}
{%- for i in (1..5) -%}
  {%- assign setting_key = 'search_trending_' | append: i -%}
  {%- assign term        = settings[setting_key] -%}
  {%- if term != blank -%}
    {%- assign trending_raw = trending_raw | append: term | append: '|' -%}
  {%- endif -%}
{%- endfor -%}
{%- assign trending_array = trending_raw | split: '|' -%}

{%- comment -%}
  Inject JS config once — guarded by sfx == 'desktop' so we don't double-declare
  when the mobile instance renders.
{%- endcomment -%}
{%- if sfx == 'desktop' -%}
<script>
  window.HS_SETTINGS = {
    MIN_QUERY_LENGTH:      {{ settings.search_min_chars       | default: 2 }},
    DEBOUNCE_MS:           {{ settings.search_debounce_ms     | default: 200 }},
    MAX_QUERIES:           {{ settings.search_max_queries     | default: 3 }},
    MAX_PRODUCTS:          {{ settings.search_max_products    | default: 5 }},
    MAX_COLLECTIONS:       {{ settings.search_max_collections | default: 2 }},
    RECENT_SEARCHES_LIMIT: {{ settings.search_recent_limit    | default: 5 }},
    VOICE_ENABLED:         {{ settings.search_voice_enabled   | default: true }},
    PLACEHOLDER_ANIMATE:   {{ settings.search_placeholder_animate | default: true }},
    TRENDING_SEARCHES: [
      {%- for term in trending_array -%}
        {%- unless term == blank -%}
          {{ term | json }}{% unless forloop.last %},{% endunless %}
        {%- endunless -%}
      {%- endfor -%}
    ]
  };
</script>
{%- endif -%}

<div class="hs"
     id="hs-{{ sfx }}"
     data-search-instance="{{ sfx }}"
     style="
       --hs-accent:        {{ settings.search_accent_color | default: '#1a1a1a' }};
       --hs-highlight-bg:  {{ settings.search_highlight_bg | default: '#FFF3CD' }};
       --hs-bg-hover:      {{ settings.search_hover_bg     | default: '#F5F5F5' }};
       --hs-border-focus:  {{ settings.search_border_focus | default: '#1a1a1a' }};
     ">

  <form action="{{ routes.search_url }}"
        method="get"
        role="search"
        class="hs__form"
        id="hs-form-{{ sfx }}"
        autocomplete="off">

    <input type="hidden" name="type" value="product">

    {%- comment -%} ── CATEGORY PILL ── {%- endcomment -%}
    {%- if show_cat -%}
      <div class="hs__category" id="hs-cat-wrap-{{ sfx }}">

        <button type="button"
                class="hs__cat-btn"
                id="hs-cat-btn-{{ sfx }}"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-controls="hs-cat-list-{{ sfx }}">
          <span class="hs__cat-label" id="hs-cat-label-{{ sfx }}">All</span>
          <svg class="hs__chevron" width="12" height="12" viewBox="0 0 20 20"
               fill="none" stroke="currentColor" stroke-width="2.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 8l5 5 5-5"/>
          </svg>
        </button>

        <ul class="hs__cat-list"
            id="hs-cat-list-{{ sfx }}"
            role="listbox"
            aria-labelledby="hs-cat-btn-{{ sfx }}"
            hidden>

          <li role="option" aria-selected="true"
              data-value="" data-label="All"
              tabindex="0">All Categories</li>

          {%- for i in (1..5) -%}
            {%- assign lk = 'search_category_' | append: i | append: '_label' -%}
            {%- assign vk = 'search_category_' | append: i | append: '_value' -%}
            {%- assign cat_label = settings[lk] -%}
            {%- assign cat_value = settings[vk] -%}
            {%- if cat_label != blank and cat_value != blank -%}
              <li role="option" aria-selected="false"
                  data-value="{{ cat_value | escape }}"
                  data-label="{{ cat_label | escape }}"
                  tabindex="0">
                {{ cat_label | escape }}
              </li>
            {%- endif -%}
          {%- endfor -%}

        </ul>

        {%- comment -%} Hidden input — value is kept in sync by header-search.js and submitted with the form {%- endcomment -%}
        <input type="hidden"
               class="hs__cat-value"
               id="hs-cat-value-{{ sfx }}"
               name="q[category]"
               value="">

        <span class="hs__divider" aria-hidden="true"></span>
      </div>
    {%- endif -%}

    {%- comment -%} ── SEARCH INPUT ── {%- endcomment -%}
    <input type="search"
           name="q"
           id="hs-input-{{ sfx }}"
           class="hs__input"
           placeholder="{{ settings.search_placeholder | default: 'What are you looking for?' | escape }}"
           aria-label="Search products"
           aria-autocomplete="list"
           aria-controls="hs-dropdown-{{ sfx }}"
           aria-expanded="false"
           role="combobox"
           autocorrect="off"
           autocomplete="off"
           spellcheck="false">

    {%- comment -%} ── CLEAR BUTTON ── {%- endcomment -%}
    <button type="button"
            class="hs__clear"
            id="hs-clear-{{ sfx }}"
            aria-label="Clear search"
            hidden>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6"  y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    {%- comment -%}
      MIC BUTTON — injected here by header-search.js if the Web Speech API
      is available in the browser. Nothing to render in Liquid.
    {%- endcomment -%}

    {%- comment -%} ── SUBMIT ── {%- endcomment -%}
    <button type="submit" class="hs__submit" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </button>

  </form>

  {%- comment -%} ── DROPDOWN  (all content injected by header-search.js) ── {%- endcomment -%}
  <div class="hs__dropdown"
       id="hs-dropdown-{{ sfx }}"
       role="listbox"
       aria-label="Search suggestions"
       aria-live="polite"
       hidden>
  </div>

  {%- comment -%} ── MOBILE BACKDROP ── {%- endcomment -%}
  <div class="hs__backdrop"
       id="hs-backdrop-{{ sfx }}"
       aria-hidden="true"
       hidden>
  </div>

</div>
