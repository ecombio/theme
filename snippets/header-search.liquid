{% comment %}
  Header Search
  File: snippets/header-search.liquid

  Called twice from sections/main-header.liquid:
    variant='desktop' — inside main-header__inner, flex-fills the bar
    variant='mobile'  — inside main-header__search-row, below the bar

  Parameters:
    enable_predictive_search {boolean}
    variant                  {string}  'desktop' or 'mobile'
{% endcomment %}

{%- liquid
  assign predictive = true
  if enable_predictive_search == false
    assign predictive = false
  endif
  assign sfx = variant | default: 'desktop'
-%}

{{- 'header-search.css' | asset_url | stylesheet_tag -}}

{%- if predictive and sfx == 'desktop' -%}
  <script src="{{ 'header-search.js' | asset_url }}" defer="defer"></script>
  {%- assign trending_menu = linklists['predictive-search-trending'] -%}
  <script>
    window.HS_TRENDING = [
      {%- if trending_menu and trending_menu.links.size > 0 -%}
        {%- for link in trending_menu.links -%}
          {{- link.title | json -}}{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      {%- else -%}
        "sneakers","hoodies","summer dresses","running shoes","gift sets",
        "new arrivals","accessories","sale items"
      {%- endif -%}
    ];
  </script>
{%- endif -%}

<div class="header-search header-search--{{ sfx }}{% unless predictive %} header-search--basic{% endunless %}"
     data-search-root
     {%- if predictive %}
     data-predictive
     data-predictive-search-url="{{ routes.predictive_search_url }}"
     data-search-url="{{ routes.search_url }}"
     {%- endif %}>

  <form action="{{ routes.search_url }}" method="get" role="search"
        class="header-search__form"
        id="HeaderSearchForm-{{ sfx }}"
        autocomplete="off">

    <input type="hidden" name="type" value="product">
    <label class="visually-hidden" for="HeaderSearch-{{ sfx }}">Search</label>

    <input type="search" name="q"
           id="HeaderSearch-{{ sfx }}"
           class="header-search__input"
           data-search-input
           placeholder="What are you looking for?"
           value="{{ search.terms | escape }}"
           autocorrect="off" autocapitalize="off" spellcheck="false"
           {%- if predictive %}
           role="combobox"
           aria-expanded="false"
           aria-owns="HeaderSearchResults-{{ sfx }}"
           aria-controls="HeaderSearchResults-{{ sfx }}"
           aria-haspopup="listbox"
           aria-autocomplete="list"
           {%- endif %}>

    <button type="button" class="header-search__clear" data-search-clear hidden aria-label="Clear search">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <button type="button" class="header-search__voice" data-search-voice hidden aria-label="Search by voice">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
        <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
        <line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/>
      </svg>
    </button>

    <button type="submit" class="header-search__submit" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </button>

  </form>

  {%- if predictive -%}
    <div class="header-search__panel"
         id="HeaderSearchResults-{{ sfx }}"
         data-search-results
         role="listbox"
         aria-label="Search suggestions"
         tabindex="-1"
         hidden></div>
    <span class="visually-hidden" role="status" aria-live="polite" data-search-status></span>
  {%- endif -%}

</div>