{%- comment -%}
  ============================================================================
  snippets/header-search.liquid
  ============================================================================

  Search subsystem entry point and v1 implementation.

  Public interface (caller never changes):
    {% render 'header-search', placeholder: section.settings.search_placeholder %}

  Variables:
    placeholder  {String}  Input placeholder text. Passed from header.liquid.

  Data attributes (JS attachment points — no JS reads these in v1):
    data-search-root     Subsystem mount point
    data-search-input    Input field — v2 predictive will listen here
    data-search-submit   Submit button — v2 predictive may intercept here
    data-search-results  Hidden results container — v2 populates this

  V1 scope:
    - Native Shopify form submit via routes.search_url
    - No type scoping (searches all resource types)
    - No JavaScript
    - No predictive results
    - Accessible markup
    - Results container present but hidden — ready for v2 without markup changes

  ============================================================================
{%- endcomment -%}

<div class="header__search" data-search-root>

  <form
    class="header__search-form"
    action="{{ routes.search_url }}"
    method="get"
    role="search"
  >

    <label
      class="header__search-label visually-hidden"
      for="header-search-input"
    >
      {{ 'general.search.label' | t }}
    </label>

    <input
      class="header__search-input"
      data-search-input
      id="header-search-input"
      type="search"
      name="q"
      placeholder="{{ placeholder | escape }}"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label="{{ 'general.search.label' | t }}"
    >

    <button
      class="header__search-submit"
      data-search-submit
      type="submit"
      aria-label="{{ 'general.search.submit' | t }}"
    >
      {%- render 'icon', name: 'search', size: 18 -%}
      <span class="visually-hidden">{{ 'general.search.submit' | t }}</span>
    </button>

  </form>

  <div
    class="header__search-results"
    data-search-results
    aria-live="polite"
    aria-atomic="true"
    hidden
  >
  </div>

</div>
