{% comment %}
  Header Search
  File: snippets/header-search.liquid

  Single owner of the search experience in the header. Renders the
  always-visible search bar — once for desktop, once for mobile, since
  they sit in different places in the header layout — and, when
  predictive search is on, a results panel.

  Results are built server-side. When predictive search is enabled,
  assets/header-search.js fetches Shopify's official Predictive Search
  API through the Section Rendering API:

      {{ routes.predictive_search_url }}?q=...&section_id=predictive-search

  ...and injects the HTML that comes back (rendered by
  sections/predictive-search.liquid) directly into the results panel
  below.

  Rendered from sections/main-header.liquid with a single param:
    {%- render 'header-search', enable_predictive_search: section.settings.enable_predictive_search -%}

  TYPEWRITER PLACEHOLDER
  When predictive search is on, this snippet injects window.HS_TRENDING
  from the predictive-search-trending linklist — the same menu used by
  sections/predictive-search.liquid for empty-state recovery. If the
  menu doesn't exist or has no links, the array is empty and the
  typewriter never starts. No separate merchant config is needed.

  To add trending terms: Admin → Content → Menus → predictive-search-trending.
  Each link title becomes a typewriter term. The URL is unused.

  Assets:
    assets/header-search.css — loaded always (form needs styling either way)
    assets/header-search.js  — loaded only when predictive search is on
{% endcomment %}

{%- liquid
  if enable_predictive_search == false
    assign predictive = false
  else
    assign predictive = true
  endif
-%}

{{ 'header-search.css' | asset_url | stylesheet_tag }}
{%- if predictive -%}
  <script src="{{ 'header-search.js' | asset_url }}" defer="defer"></script>

  {%- comment -%}
    Inject trending terms for the animated typewriter placeholder.
    Sourced from the predictive-search-trending linklist so merchants
    can edit terms without touching code. Empty array = no typewriter.
  {%- endcomment -%}
  {%- assign trending_menu = linklists['predictive-search-trending'] -%}
  <script>
    window.HS_TRENDING = [
      {%- for link in trending_menu.links -%}
        {{ link.title | json }}{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ];
  </script>
{%- endif -%}

{%- for viewport in (1..2) -%}
  {%- assign sfx = 'desktop' -%}
  {%- if viewport == 2 -%}
    {%- assign sfx = 'mobile' -%}
  {%- endif -%}

  <div class="header-search header-search--{{ sfx }}{% unless predictive %} header-search--basic{% endunless %}"
       data-search-root
       {%- if predictive %}
       data-predictive
       data-predictive-search-url="{{ routes.predictive_search_url }}"
       {%- endif %}>

    <form action="{{ routes.search_url }}"
          method="get"
          role="search"
          class="header-search__form"
          id="HeaderSearchForm-{{ sfx }}"
          autocomplete="off">

      <input type="hidden" name="type" value="product">

      <label class="visually-hidden" for="HeaderSearch-{{ sfx }}">Search</label>
      <input
        type="search"
        name="q"
        id="HeaderSearch-{{ sfx }}"
        class="header-search__input"
        data-search-input
        placeholder="What are you looking for?"
        value="{{ search.terms | escape }}"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
        {%- if predictive %}
        role="combobox"
        aria-expanded="false"
        aria-owns="HeaderSearchResults-{{ sfx }}"
        aria-controls="HeaderSearchResults-{{ sfx }}"
        aria-haspopup="listbox"
        aria-autocomplete="list"
        {%- endif %}>

      {%- comment -%} Clear button — works with or without predictive search {%- endcomment -%}
      <button type="button" class="header-search__clear" data-search-clear hidden aria-label="Clear search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      {%- comment -%}
        Voice button — markup always present, hidden by default.
        header-search.js only un-hides it if the browser supports the
        Web Speech API.
      {%- endcomment -%}
      <button type="button" class="header-search__voice" data-search-voice hidden aria-label="Search by voice">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
          <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
          <line x1="12" y1="19" x2="12" y2="23"/>
          <line x1="8" y1="23" x2="16" y2="23"/>
        </svg>
      </button>

      <button type="submit" class="header-search__submit" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
    </form>

    {%- if predictive -%}
      {%- comment -%}
        Empty until header-search.js fetches and injects the rendered
        output of sections/predictive-search.liquid.
      {%- endcomment -%}
      <div class="header-search__panel"
           id="HeaderSearchResults-{{ sfx }}"
           data-search-results
           role="listbox"
           aria-label="Search results"
           tabindex="-1"
           hidden></div>
      <span class="visually-hidden" role="status" aria-live="polite" data-search-status></span>
    {%- endif -%}
  </div>
{%- endfor -%}
