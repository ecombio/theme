{%- comment -%}
  ============================================================================
  snippets/header-search.liquid
  ============================================================================

  Search subsystem shell. Renders the form, input, submit button, and the
  empty results container that predictive-search.js populates at runtime.

  PUBLIC INTERFACE (caller in header.liquid never changes this):
    {% render 'header-search', placeholder: section.settings.search_placeholder %}

  PARAMETERS:
    placeholder  {String}  Input placeholder text. Falls back to translation.

  DATA ATTRIBUTE CONTRACT (JS attachment points — frozen across v1/v2/v3):
    data-search-root     Subsystem mount point — both JS files read this
    data-search-input    Text input
    data-search-submit   Submit button
    data-search-results  Results container — predictive-search.js populates this

  ASSET LOADING:
    header-search.css    Shell styles (form, input, submit button)
    header-search.js     Shell behaviour (typewriter, form submit)
    predictive-search.css  Results panel styles
    predictive-search.js   Fetch, inject, open/close panel

    Loading order matters: CSS before JS, header before predictive.
    Both JS files share the data-search-* contract; neither calls the other.

  OWNS:
    .header__search, .header__search-form, .header__search-input,
    .header__search-submit, .header__search-results (DOM node only —
    visual styles for .header__search-results live in predictive-search.css
    because that component owns the panel boundary).

  DOES NOT OWN:
    .search-results__* — predictive-search.css / predictive-search.liquid

  ============================================================================
{%- endcomment -%}

{{- 'header-search.css'     | asset_url | stylesheet_tag -}}
{{- 'predictive-search.css' | asset_url | stylesheet_tag -}}

<div class="header__search" data-search-root>

  <form
    class="header__search-form"
    action="{{ routes.search_url }}"
    method="get"
    role="search"
  >

    <label
      class="header__search-label visually-hidden"
      for="header-search-input"
    >
      {{- 'general.search.label' | t -}}
    </label>

    <input
      class="header__search-input"
      data-search-input
      id="header-search-input"
      type="search"
      name="q"
      placeholder="{{ placeholder | escape }}"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label="{{ 'general.search.label' | t }}"
      aria-owns="header-search-results"
      aria-autocomplete="list"
    >

    <button
      class="header__search-submit"
      data-search-submit
      type="submit"
      aria-label="{{ 'general.search.submit' | t }}"
    >
      {%- render 'icon', name: 'search', size: 18 -%}
      <span class="visually-hidden">{{ 'general.search.submit' | t }}</span>
    </button>

  </form>

  <div
    class="header__search-results"
    data-search-results
    id="header-search-results"
    role="listbox"
    aria-live="polite"
    aria-atomic="true"
    hidden
  >
  </div>

</div>

<script src="{{ 'header-search.js'     | asset_url }}" defer></script>
<script src="{{ 'predictive-search.js' | asset_url }}" defer></script>