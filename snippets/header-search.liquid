{%- comment -%}
  ============================================================================
  snippets/header-search.liquid
  ============================================================================

  Search subsystem shell. SVGs are inlined directly — no icon snippet
  dependency, so this file is entirely self-contained.

  DATA ATTRIBUTE CONTRACT:
    data-search-root     Subsystem mount point
    data-search-input    Text input
    data-search-submit   Submit button
    data-search-mic      Voice search button (revealed by JS if supported)
    data-search-results  Results container — predictive-search.js populates this
  ============================================================================
{%- endcomment -%}

<div class="header__search" data-search-root>

  <form
    class="header__search-form"
    action="{{ routes.search_url }}"
    method="get"
    role="search"
  >

    <label class="header__search-label visually-hidden" for="header-search-input">
      {{- 'general.search.label' | t -}}
    </label>

    <input
      class="header__search-input"
      data-search-input
      id="header-search-input"
      type="search"
      name="q"
      placeholder="{{ placeholder | escape }}"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label="{{ 'general.search.label' | t }}"
      aria-owns="header-search-results"
      aria-autocomplete="list"
    >

    <!-- Mic button — hidden until JS confirms SpeechRecognition support -->
    <button
      class="header__search-mic"
      data-search-mic
      type="button"
      aria-label="{{ 'general.search.voice' | t }}"
      hidden
    >
      <!-- mic idle -->
      <svg class="icon icon--mic" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <rect x="9" y="2" width="6" height="11" rx="3" />
        <path d="M5 10a7 7 0 0014 0" />
        <line x1="12" y1="21" x2="12" y2="17" />
        <line x1="9"  y1="21" x2="15" y2="21" />
      </svg>
      <!-- mic listening (filled) -->
      <svg class="icon icon--mic-listening" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <rect x="9" y="2" width="6" height="11" rx="3" fill="currentColor" stroke="none" />
        <path d="M5 10a7 7 0 0014 0" />
        <line x1="12" y1="21" x2="12" y2="17" />
        <line x1="9"  y1="21" x2="15" y2="21" />
      </svg>
      <span class="visually-hidden">{{ 'general.search.voice' | t }}</span>
    </button>

    <!-- Submit button -->
    <button
      class="header__search-submit"
      data-search-submit
      type="submit"
      aria-label="{{ 'general.search.submit' | t }}"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <circle cx="10.5" cy="10.5" r="6.5" />
        <line x1="15.5" y1="15.5" x2="21" y2="21" />
      </svg>
      <span class="visually-hidden">{{ 'general.search.submit' | t }}</span>
    </button>

  </form>

  <div
    class="header__search-results"
    data-search-results
    id="header-search-results"
    role="listbox"
    aria-live="polite"
    aria-atomic="true"
    hidden
  ></div>

</div>
