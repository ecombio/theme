{% comment %}
  REUSABLE CATEGORY PILL SNIPPET (Compact + Image Support)
{% endcomment %}

{% assign title = title | default: 'Category' %}
{% assign url   = url   | default: '#' %}
{% assign icon  = icon  | default: 'default' %}
{% assign image = image | default: blank %}

<style>
  .single-pill {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    padding: 6px 16px 6px 6px;
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 999px;
    text-decoration: none;
    flex-shrink: 0;
    cursor: pointer;
  }
  .single-pill__icon {
    width: 36px;
    height: 36px;
    border-radius: 999px;
    overflow: hidden;
    flex-shrink: 0;
    margin-right: 8px;
    background: #fafafa;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .single-pill__icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .single-pill__icon svg {
    width: 18px;
    height: 18px;
    color: #B8956E;
  }
  .single-pill__text {
    font-family: 'Instrument Sans', system-ui, -apple-system, sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: #000000;
    white-space: nowrap;
    line-height: 1.2;
  }
</style>

<a href="{{ url | escape }}" class="single-pill">
  <div class="single-pill__icon">
    {% if image != blank %}
      <img src="{{ image | image_url: width: 96 }}" alt="{{ title | escape }}">
    {% else %}
      {% case icon %}
        {% when 'scooter' %}
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <circle cx="6" cy="17" r="2.5"/><circle cx="18" cy="17" r="2.5"/>
            <path d="M8 17 L16 17"/><path d="M16 17 L19 9"/><path d="M19 9 L22 9"/>
          </svg>
        {% when 'bike' %}
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <circle cx="6" cy="17" r="2.5"/><circle cx="18" cy="17" r="2.5"/>
            <path d="M6 17 L10 10 L14 17"/><path d="M10 10 L15 5"/><path d="M18 17 L15 10"/>
          </svg>
        {% when 'skateboard' %}
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <rect x="3" y="11" width="18" height="3" rx="1.5"/>
            <circle cx="6" cy="17" r="2"/><circle cx="18" cy="17" r="2"/>
          </svg>
        {% when 'accessories' %}
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.8-3.8a6 6 0 01-7.9 7.9l-3.8 3.8a1 1 0 01-1.4 0l-1.6-1.6a1 1 0 000-1.4L6.3 14.7"/>
          </svg>
        {% else %}
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 19v-3a2 2 0 012-2h8a2 2 0 012 2v3M6 10V6a2 2 0 012-2h8a2 2 0 012 2v4M6 10h12M6 14h12"/>
          </svg>
      {% endcase %}
    {% endif %}
  </div>
  <span class="single-pill__text">{{ title }}</span>
</a>