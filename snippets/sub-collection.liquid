{%- comment -%}
  Snippet: sub-collections-carousel
  Renders a horizontally-scrollable row of linked collection cards
  (image + title) directly above the product grid.

  Expects:
    - section.blocks where block.type == 'sub_collection'
        block.settings.collection  -> collection picker
        block.settings.custom_title (optional override)
        block.settings.custom_image (optional override)
    - section.settings.sub_collection_shape -> 'square' | 'circle'
{%- endcomment -%}

{%- liquid
  assign sc_blocks = section.blocks | where: 'type', 'sub_collection'
  assign shape = section.settings.sub_collection_shape | default: 'square'
-%}

{%- if sc_blocks.size > 0 -%}
  <div class="sub-collections sub-collections--{{ shape }}" data-sub-collections>
    <div class="sub-collections__track" data-sub-collections-track>
      {%- for block in sc_blocks -%}
        {%- liquid
          assign sc_collection = block.settings.collection
          assign sc_title = block.settings.custom_title | default: sc_collection.title
          assign sc_image = block.settings.custom_image | default: sc_collection.image
        -%}
        {%- if sc_collection != blank -%}
          <a
            href="{{ sc_collection.url }}"
            class="sub-collections__item"
            {{ block.shopify_attributes }}
          >
            <span class="sub-collections__media">
              {%- if sc_image -%}
                <img
                  src="{{ sc_image | image_url: width: 300 }}"
                  srcset="{{ sc_image | image_url: width: 150 }} 150w, {{ sc_image | image_url: width: 300 }} 300w, {{ sc_image | image_url: width: 450 }} 450w"
                  sizes="120px"
                  alt="{{ sc_image.alt | default: sc_title | escape }}"
                  width="{{ sc_image.width }}"
                  height="{{ sc_image.height }}"
                  loading="lazy"
                  class="sub-collections__image"
                >
              {%- else -%}
                <span class="sub-collections__fallback" aria-hidden="true">
                  {%- render 'sub-collections-fallback-icon' -%}
                </span>
              {%- endif -%}
            </span>
            <span class="sub-collections__title">{{ sc_title }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <button type="button" class="sub-collections__nav sub-collections__nav--prev" data-sub-collections-prev aria-label="Scroll sub-collections left">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <button type="button" class="sub-collections__nav sub-collections__nav--next" data-sub-collections-next aria-label="Scroll sub-collections right">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
  </div>
{%- endif -%}
