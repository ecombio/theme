{% comment %}
  Snippet: product-card-spotlight
  Description: Reusable product card with sale badge, Selling Fast label,
               color swatches, compare-at pricing, and smooth hover effects.
               Matches the visual style of product-spotlight-slider.

  Usage:
    {% render 'product-card-spotlight',
      product: product,
      show_sale_badge: true,
      selling_fast: false,
      swatch_colors: '#8B6F5E,#C4A882'
    %}

  Parameters:
    product        {Object}  — Shopify product object (required)
    show_sale_badge {Bool}   — Force show the Sale badge (default: auto-detect from compare_at_price)
    selling_fast   {Bool}    — Show "Selling Fast" badge (default: false)
    swatch_colors  {String}  — Comma-separated CSS color values for swatches
                               Falls back to product Color option values
    card_class     {String}  — Extra CSS class(es) to add to the card element
{% endcomment %}

{%- liquid
  assign _product      = product
  assign _is_sale      = false

  if _product.compare_at_price > _product.price
    assign _is_sale = true
  endif
  if show_sale_badge == true
    assign _is_sale = true
  endif

  assign _selling_fast = selling_fast | default: false
  assign _extra_class  = card_class | default: ''
-%}

<div class="pss__card {{ _extra_class }}">

  {%- comment -%} ── Image area ── {%- endcomment -%}
  <div class="pss__card-image-wrap">

    {%- if _is_sale -%}
      <span class="pss__badge pss__badge--sale">Sale</span>
    {%- endif -%}

    {%- if _selling_fast -%}
      <span class="pss__badge pss__badge--fast">⚡ Selling Fast</span>
    {%- endif -%}

    <a href="{{ _product.url }}" class="pss__card-link" aria-label="{{ _product.title | escape }}">
      <div class="pss__card-image">
        {%- if _product.featured_image != blank -%}
          {{ _product.featured_image
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              class: 'pss__card-img',
              alt: _product.title,
              widths: '200,300,400,500,600'
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'pss__card-img pss__card-img--placeholder' }}
        {%- endif -%}
      </div>
    </a>
  </div>

  {%- comment -%} ── Info ── {%- endcomment -%}
  <div class="pss__card-info">

    {%- if _product.type != blank -%}
      <p class="pss__card-type">{{ _product.type | upcase }}</p>
    {%- endif -%}

    <h3 class="pss__card-title">
      <a href="{{ _product.url }}">{{ _product.title }}</a>
    </h3>

    <div class="pss__card-price">
      {%- if _is_sale -%}
        <span class="pss__price pss__price--sale">{{ _product.price | money }}</span>
        <span class="pss__price pss__price--compare">{{ _product.compare_at_price | money }}</span>
      {%- else -%}
        <span class="pss__price">{{ _product.price | money }}</span>
      {%- endif -%}
    </div>

    {%- comment -%} ── Swatches ── {%- endcomment -%}
    {%- if swatch_colors != blank -%}
      <div class="pss__swatches" aria-label="Available colours">
        {%- assign _swatches = swatch_colors | split: ',' -%}
        {%- for sw in _swatches -%}
          <span class="pss__swatch" style="background: {{ sw | strip }};" title="{{ sw | strip }}"></span>
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- assign _color_opt = _product.options_by_name['Color'] | default: _product.options_by_name['Colour'] -%}
      {%- if _color_opt != blank -%}
        <div class="pss__swatches" aria-label="Available colours">
          {%- for val in _color_opt.values limit: 5 -%}
            <span class="pss__swatch pss__swatch--label" title="{{ val }}">
              {{ val | slice: 0, 1 }}
            </span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}

  </div>
</div>
