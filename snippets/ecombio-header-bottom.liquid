{% comment %}
  ECOMBIO Header — Bottom Bar
  File: snippets/ecombio-header-bottom.liquid

  Renders the desktop menu bar and the mobile nav drawer.

  Parameters:
    blocks       {blocks}  — section.blocks (passed from header section)
    show_store   {boolean} — section.settings.show_icon_store
    show_account {boolean} — section.settings.show_icon_account
    show_cart    {boolean} — section.settings.show_icon_cart

  Note: section.blocks and icon settings must be passed explicitly —
  render creates an isolated scope with no access to parent section.
{% endcomment %}

{%- render 'ecombio-header-menu-bar', blocks: blocks -%}

{%- render 'ecombio-mobile-nav',
      show_store:   show_store,
      show_account: show_account,
      show_cart:    show_cart
-%}
