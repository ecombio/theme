{%- comment -%}
  Flyout Menu
  File: snippets/flyout-menu.liquid

  Sidebar-style "browse all categories" flyout block — left-hand list of
  top-level categories, right-hand content panel that swaps per category,
  rendered for the 'flyout' block type in sections/header-menu.liquid.

  Pairs with:
    assets/flyout-menu.css
    assets/flyout-menu.js

  Usage (from sections/header-menu.liquid):
    {%- when 'flyout' -%}
      {%- render 'flyout-menu', block: block -%}

  Accepts:
    block - the flyout block, with settings: menu, link, label, icon

  ── LEVEL MAPPING ──────────────────────────────────────────────────
  L1 (flyout_menu.links)   → left sidebar categories
                              e.g. "Electric Scooters"
                              rendered as .flyout-panel__category-link

  L2 (link.links)          → bold column headings in the right panel
                              e.g. "Trending", "Shop by Category",
                              "Shop by Price"
                              rendered as .flyout-panel__group

  L3 (sublink.links)       → indented sub-links under each L2 heading
                              e.g. "Shop all", "New arrivals", "On sale"
                              rendered as .flyout-panel__sublink
  ───────────────────────────────────────────────────────────────────

  Current-page awareness: `flyout_active_index` finds the top-level link
  whose branch contains the page the visitor is currently on (via
  Shopify's `link.active`, which is true for the link itself OR any of
  its descendants) and pre-selects that category + panel instead of
  always defaulting to the first one. Falls back to the first category
  when nothing in the menu matches the current page (e.g. visitor is on
  the homepage).

  Column split: each category's L2 groups (sub_links) are divided into
  two columns via a single (0..1) loop below rather than duplicating the
  column markup — column 0 gets the ceiling half, column 1 gets the
  remainder plus the trailing "All {{ link.title }}" link. The split is
  positional (by count of L2 groups), not by total row count, so a
  heavy group (many L3 sub-links) can make one column visually longer
  than the other. Reorder the menu's L2 items if you want to rebalance
  which groups land in which column.

  Promo image support intentionally not included — see prior removal.
{%- endcomment -%}

{%- assign flyout_menu = linklists[block.settings.menu] -%}

{%- if flyout_menu != blank and flyout_menu.links.size > 0 -%}
  {%- assign flyout_active_index = 0 -%}
  {%- for link in flyout_menu.links -%}
    {%- if link.active and flyout_active_index == 0 -%}
      {%- assign flyout_active_index = forloop.index -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if flyout_active_index == 0 -%}
    {%- assign flyout_active_index = 1 -%}
  {%- endif -%}
{%- endif -%}

<li class="menu-bar__item menu-bar__item--has-flyout" {{ block.shopify_attributes }}>
  <a href="{{ block.settings.link | default: flyout_menu.links.first.url | default: '#' }}"
     class="menu-bar__link menu-bar__link--caret flyout-trigger"
     aria-haspopup="true"
     aria-expanded="false"
     aria-controls="flyout-panel-{{ block.id }}"
     data-flyout-trigger>
    {%- if block.settings.icon != blank -%}
      <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
    {%- endif -%}
    {{ block.settings.label | default: 'Browse all categories' }}
    <svg class="icon-caret-down" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M16.25 7.5L10 13.75L3.75 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>

  {%- if flyout_menu != blank and flyout_menu.links.size > 0 -%}
    <div class="flyout-panel"
         id="flyout-panel-{{ block.id }}"
         role="region"
         aria-label="{{ block.settings.label | default: 'Browse all categories' }}"
         data-flyout-panel>
      <div class="flyout-panel__container">

        {%- comment -%} ── L1: sidebar categories ── {%- endcomment -%}
        <ul class="flyout-panel__categories" role="list">
          {%- for link in flyout_menu.links -%}
            {%- assign panel_id = 'flyout-panel-' | append: block.id | append: '-' | append: forloop.index -%}
            <li class="flyout-panel__category{% if forloop.index == flyout_active_index %} is-active{% endif %}">
              <a href="{{ link.url }}"
                 class="flyout-panel__category-link"
                 data-flyout-category-trigger
                 data-flyout-target="{{ panel_id }}"
                 aria-controls="{{ panel_id }}"
                 {% if link.current %}aria-current="page"{% endif %}>
                {{ link.title }}
                <svg class="icon-caret-right" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M7.5 3.75L13.75 10L7.5 16.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </li>
          {%- endfor -%}
        </ul>

        <div class="flyout-panel__content" data-flyout-content>
          {%- for link in flyout_menu.links -%}
            {%- assign panel_id = 'flyout-panel-' | append: block.id | append: '-' | append: forloop.index -%}

            {%- comment -%}
              L2: this L1 category's groups (e.g. Trending, Shop by
              Category, Shop by Price). Split across two columns by
              count — col1 gets the ceiling half, col2 gets the rest.
            {%- endcomment -%}
            {%- assign sub_links = link.links -%}
            {%- assign col1_limit = sub_links.size | plus: 1 | divided_by: 2 -%}
            {%- assign col2_limit = sub_links.size | minus: col1_limit -%}

            <div class="flyout-panel__panel{% if forloop.index == flyout_active_index %} is-active{% endif %}"
                 id="{{ panel_id }}"
                 role="region"
                 aria-hidden="{% if forloop.index == flyout_active_index %}false{% else %}true{% endif %}"
                 data-flyout-panel-item>

              <div class="flyout-panel__columns">
                {%- for col in (0..1) -%}
                  {%- if col == 0 -%}
                    {%- assign col_offset = 0 -%}
                    {%- assign col_limit = col1_limit -%}
                  {%- else -%}
                    {%- assign col_offset = col1_limit -%}
                    {%- assign col_limit = col2_limit -%}
                  {%- endif -%}
                  <div class="flyout-panel__column">
                    {%- for sublink in sub_links offset: col_offset limit: col_limit -%}
                      {%- comment -%} L2: bold group heading (e.g. "Trending") {%- endcomment -%}
                      <a href="{{ sublink.url }}"
                         class="flyout-panel__group"
                         {% if sublink.current %}aria-current="page"{% endif %}>
                        {{ sublink.title }}
                      </a>
                      {%- if sublink.links.size > 0 -%}
                        {%- comment -%} L3: indented sub-links under this heading (e.g. "Shop all", "New arrivals", "On sale") {%- endcomment -%}
                        <ul class="flyout-panel__sublist" role="list">
                          {%- for grandchild in sublink.links -%}
                            <li>
                              <a href="{{ grandchild.url }}"
                                 class="flyout-panel__sublink"
                                 {% if grandchild.current %}aria-current="page"{% endif %}>
                                {{ grandchild.title }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    {%- endfor -%}

                    {%- if col == 1 -%}
                      <a href="{{ link.url }}" class="flyout-panel__all-link">
                        All {{ link.title }}
                        <svg class="icon-arrow-right" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                          <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>

            </div>
          {%- endfor -%}
        </div>

      </div>
    </div>
  {%- endif -%}
</li>
