{% comment %}
  ECOMBIO Flyout Menu — Horizontal Column Panel
  File: snippets/flyout-menu.liquid

  Renders one horizontal panel per sidebar category.
  Hidden by default; flyout-panel.js toggles flyout-menu--visible.

  Shopify nav depth (3 levels max):
    Level 1  →  sidebar trigger          (flyout-panel)
    Level 2  →  column heading           (this file — col)
    Level 3  →  links under that column  (this file — link)

  Params:
    cat      {link}    The Level-1 nav link (sidebar item)
    panel_id {string}  Scoped ID — must match trigger's data-flyout-target
    active   {bool}    True for the first panel only
{% endcomment %}

<div
  class="flyout-menu{% if active %} flyout-menu--visible{% endif %}"
  id="{{ panel_id }}"
  role="region"
  aria-label="{{ cat.title | escape }}"
  aria-hidden="{% if active %}false{% else %}true{% endif %}"
>
  {%- if cat.links.size > 0 -%}

    <div class="flyout-menu__columns" style="--flyout-col-count: {{ cat.links.size }};">
      {%- for col in cat.links -%}
        <div class="flyout-menu__column">

          {%- if col.links.size > 0 -%}
            {%- comment -%} Level 2 with children → heading + link list {%- endcomment -%}
            <a href="{{ col.url }}" class="flyout-menu__col-heading">{{- col.title -}}</a>
            <ul class="flyout-menu__link-list">
              {%- for link in col.links -%}
                <li>
                  <a href="{{ link.url }}" class="flyout-menu__link">{{- link.title -}}</a>
                </li>
              {%- endfor -%}
            </ul>

          {%- else -%}
            {%- comment -%} Level 2 leaf → heading links directly {%- endcomment -%}
            <a href="{{ col.url }}" class="flyout-menu__col-heading">{{- col.title -}}</a>
            <a href="{{ col.url }}" class="flyout-menu__link">Shop all</a>

          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>

  {%- else -%}

    <div class="flyout-menu__columns" style="--flyout-col-count: 1;">
      <div class="flyout-menu__column">
        <a href="{{ cat.url }}" class="flyout-menu__col-heading">{{- cat.title -}}</a>
        <a href="{{ cat.url }}" class="flyout-menu__link">Shop all</a>
      </div>
    </div>

  {%- endif -%}
</div>
