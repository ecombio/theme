{% comment %}
  ECOMBIO Flyout Menu — Two-panel sidebar nav
  File: snippets/flyout-menu.liquid

  Parameters (passed via render tag):
    menu {linklist} Required. Top-level items become sidebar categories.
                    Their children populate the right-hand content panel.

  Structure:
    Left  → Sidebar: one button per top-level link
    Right → Content panel: swaps on hover, shows children of active category

  Usage:
    {%- render 'flyout-menu', menu: flyout_menu -%}
{% endcomment %}

{%- if menu != blank and menu.links.size > 0 -%}

<div class="flyout-menu" data-flyout-menu>

  {%- comment -%}── LEFT: CATEGORY SIDEBAR ──{%- endcomment -%}
  <ul class="flyout-menu__sidebar" role="list">
    {%- for cat in menu.links -%}
      <li>
        <a
          href="{{ cat.url }}"
          class="flyout-menu__cat{% if forloop.first %} flyout-menu__cat--active{% endif %}"
          data-flyout-target="flyout-section-{{ forloop.index }}"
          aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
        >
          {{ cat.title }}
          <svg class="flyout-menu__chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7.5 3.75L13.75 10L7.5 16.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </li>
    {%- endfor -%}
  </ul>

  {%- comment -%}── RIGHT: CONTENT PANELS ──{%- endcomment -%}
  <div class="flyout-menu__content">
    {%- for cat in menu.links -%}
      <div
        class="flyout-menu__section{% if forloop.first %} flyout-menu__section--visible{% endif %}"
        id="flyout-section-{{ forloop.index }}"
        aria-hidden="{% unless forloop.first %}true{% endunless %}"
      >
        {%- if cat.links.size > 0 -%}

          {%- comment -%}
            Group children into columns of up to 6 links.
            Shopify Liquid doesn't have native chunking, so we use modulo
            to open/close column divs at the right intervals.
          {%- endcomment -%}
          {%- assign col_size = 6 -%}

          <div class="flyout-menu__columns">

            {%- comment -%} Section heading — links back to the category page {%- endcomment -%}
            <div class="flyout-menu__column">
              <a href="{{ cat.url }}" class="flyout-menu__col-heading">{{ cat.title }}</a>

              {%- assign col_count = 0 -%}
              {%- for item in cat.links -%}

                {%- if item.links.size > 0 -%}
                  {%- comment -%} Item has children → render as subheading + list {%- endcomment -%}
                  <p class="flyout-menu__subheading">{{ item.title }}</p>
                  <ul class="flyout-menu__link-list">
                    {%- for child in item.links -%}
                      <li><a href="{{ child.url }}" class="flyout-menu__link">{{ child.title }}</a></li>
                    {%- endfor -%}
                  </ul>

                {%- else -%}
                  {%- comment -%} Leaf link {%- endcomment -%}
                  <a href="{{ item.url }}" class="flyout-menu__link">{{ item.title }}</a>
                  {%- assign col_count = col_count | plus: 1 -%}

                {%- endif -%}

              {%- endfor -%}
            </div>

          </div>

        {%- else -%}
          {%- comment -%} No children — show a simple "Shop all" link {%- endcomment -%}
          <div class="flyout-menu__columns">
            <div class="flyout-menu__column">
              <a href="{{ cat.url }}" class="flyout-menu__col-heading">{{ cat.title }}</a>
              <a href="{{ cat.url }}" class="flyout-menu__link">Shop all</a>
            </div>
          </div>
        {%- endif -%}

      </div>
    {%- endfor -%}
  </div>

</div>

{%- endif -%}