{% comment %}
  ECOMBIO Flyout Menu — Sidebar + Mega Column Hybrid
  File: snippets/flyout-menu.liquid

  Structure:
    Left  → Sidebar: one button per top-level menu link (hover to switch)
    Right → Mega menu columns: each top-level item's children rendered as
            subheading groups + links, exactly like header-mega-menu.liquid

  Menu setup in Shopify admin (Online Store → Navigation):
    Top-level items  = sidebar categories (Electric Scooters, Electric Bikes…)
    Their children   = column headings inside the right panel
    Grandchildren    = grouped links under each subheading

  Usage (already called from ecombio-header-menu-bar.liquid):
    {%- render 'flyout-menu', menu: flyout_menu -%}
{% endcomment %}

{%- if menu != blank and menu.links.size > 0 -%}

<div class="flyout-menu" data-flyout-menu>

  {%- comment -%}── LEFT: CATEGORY SIDEBAR ──{%- endcomment -%}
  <ul class="flyout-menu__sidebar" role="list" aria-label="Product categories">
    {%- for cat in menu.links -%}
      <li>
        <a
          href="{{ cat.url }}"
          class="flyout-menu__cat{% if forloop.first %} flyout-menu__cat--active{% endif %}"
          data-flyout-target="flyout-section-{{ forloop.index }}"
          aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
        >
          {{ cat.title }}
          <svg class="flyout-menu__chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7.5 3.75L13.75 10L7.5 16.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </li>
    {%- endfor -%}
  </ul>

  {%- comment -%}── RIGHT: MEGA COLUMN PANELS ──{%- endcomment -%}
  <div class="flyout-menu__content">
    {%- for cat in menu.links -%}
      <div
        class="flyout-menu__section{% if forloop.first %} flyout-menu__section--visible{% endif %}"
        id="flyout-section-{{ forloop.index }}"
        aria-hidden="{% unless forloop.first %}true{% endunless %}"
        role="region"
        aria-label="{{ cat.title }}"
      >

        {%- if cat.links.size > 0 -%}

          <div class="flyout-menu__columns" style="--flyout-col-count: {{ cat.links.size }};">

            {%- for column in cat.links -%}
              <div class="flyout-menu__column">

                <a href="{{ column.url }}" class="flyout-menu__col-heading">
                  {{ column.title }}
                </a>

                {%- for item in column.links -%}
                  {%- if item.links.size > 0 -%}

                    <p class="flyout-menu__subheading">{{ item.title }}</p>
                    <ul class="flyout-menu__link-list">
                      {%- for link in item.links -%}
                        <li>
                          <a href="{{ link.url }}" class="flyout-menu__link">{{ link.title }}</a>
                        </li>
                      {%- endfor -%}
                    </ul>

                  {%- else -%}

                    <a href="{{ item.url }}" class="flyout-menu__link">{{ item.title }}</a>

                  {%- endif -%}
                {%- endfor -%}

              </div>
            {%- endfor -%}

          </div>

        {%- else -%}

          <div class="flyout-menu__columns">
            <div class="flyout-menu__column">
              <a href="{{ cat.url }}" class="flyout-menu__col-heading">{{ cat.title }}</a>
              <a href="{{ cat.url }}" class="flyout-menu__link">Shop all</a>
            </div>
          </div>

        {%- endif -%}

      </div>
    {%- endfor -%}
  </div>

</div>

{%- endif -%}