```liquid
{% comment %}
  snippets/collection-showroom.liquid
  Tab router — delegates each content type to its own sub-snippet.

  Tabs:
    Products  — always shown           → collection-products.liquid
    Articles  — if metafield present   → showroom-articles.liquid
    Pages     — if metafield present   → collection-pages.liquid

  Expects (passed from collection-page.liquid / sections/collection.liquid):
    collection     {Object} — the Shopify collection object
    paginate       {Object} — paginate object opened upstream
    related_pages  {Array}  — collection.metafields.custom.pages.value

  Self-contained: loads collection-showroom.css and collection-showroom.js.
  Each card type loads its own CSS/JS via its own sub-snippet.

  NOTE: product-card.js is loaded globally in theme.liquid.
  Do NOT re-load it here or in collection-products.liquid — doing so
  double-registers click handlers (double Add to Cart, wishlist toggles
  cancelling out, Quick View fetching twice).

  NOTE: section.blocks (banner/carousel) are handled entirely by
  collection-features.liquid upstream now — this router and
  collection-products.liquid have no awareness of blocks at all.
{% endcomment %}

{{ 'collection-showroom.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign showroom_articles = collection.metafields.showroom.articles.value

  assign has_articles = false
  assign has_pages = false

  if showroom_articles != blank
    assign has_articles = true
  endif

  if related_pages and related_pages.size > 0
    assign has_pages = true
  endif
-%}

<div class="collection-showroom">

  {%- comment -%} ── Tab bar ─────────────────────────────────────────────── {%- endcomment -%}

  <div
    class="collection-showroom__tabs"
    role="tablist"
    aria-label="Collection content"
  >

    <button
      class="collection-showroom__tab collection-showroom__tab--active"
      role="tab"
      aria-selected="true"
      aria-controls="showroom-panel-products"
      id="showroom-tab-products"
      type="button"
      data-showroom-tab="products"
    >
      Products
      <span class="collection-showroom__tab-count">
        ({{ collection.products_count }})
      </span>
    </button>

    {%- if has_articles -%}
      <button
        class="collection-showroom__tab"
        role="tab"
        aria-selected="false"
        aria-controls="showroom-panel-articles"
        id="showroom-tab-articles"
        type="button"
        data-showroom-tab="articles"
        tabindex="-1"
      >
        Articles
        <span class="collection-showroom__tab-count">
          ({{ showroom_articles.size }})
        </span>
      </button>
    {%- endif -%}

    {%- if has_pages -%}
      <button
        class="collection-showroom__tab"
        role="tab"
        aria-selected="false"
        aria-controls="showroom-panel-pages"
        id="showroom-tab-pages"
        type="button"
        data-showroom-tab="pages"
        tabindex="-1"
      >
        Pages
        <span class="collection-showroom__tab-count">
          ({{ related_pages.size }})
        </span>
      </button>
    {%- endif -%}

  </div>

  {%- comment -%} ── Products panel ──────────────────────────────────────── {%- endcomment -%}

  <div
    class="collection-showroom__panel"
    id="showroom-panel-products"
    role="tabpanel"
    aria-labelledby="showroom-tab-products"
    data-showroom-panel="products"
  >
    {%- render 'collection-products',
      collection: collection,
      paginate: paginate
    -%}
  </div>

  {%- comment -%} ── Articles panel ──────────────────────────────────────── {%- endcomment -%}

  {%- if has_articles -%}
    <div
      class="collection-showroom__panel"
      id="showroom-panel-articles"
      role="tabpanel"
      aria-labelledby="showroom-tab-articles"
      data-showroom-panel="articles"
      hidden
    >
      {%- render 'showroom-articles',
        collection: collection
      -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Pages panel ─────────────────────────────────────────── {%- endcomment -%}

  {%- if has_pages -%}
    <div
      class="collection-showroom__panel"
      id="showroom-panel-pages"
      role="tabpanel"
      aria-labelledby="showroom-tab-pages"
      data-showroom-panel="pages"
      hidden
    >
      {%- render 'collection-pages',
        pages: related_pages
      -%}
    </div>
  {%- endif -%}

</div>

<script src="{{ 'collection-showroom.js' | asset_url }}" defer></script>
```
