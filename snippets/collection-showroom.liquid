{% comment %}
  snippets/collection-showroom.liquid
  Renders browsable collection content via a tab switcher.
  Tabs: Products (always), Articles (if metafield populated), Pages (if metafield populated)

  Expects:
    collection       {Object} — the Shopify collection object
    paginate         {Object} — paginate object, opened in collection-page.liquid
    related_articles {Array}  — collection.metafields.custom.articles.value
    related_pages    {Array}  — collection.metafields.custom.pages.value

  NOTE: card-product-features.js is loaded globally in theme.liquid (line 122).
  Do NOT re-load it here — doing so double-registers the click handlers
  for Add to Cart, Wishlist, Compare, and Quick View (each click fires
  twice: double-add to cart, wishlist toggles cancel out, Quick View
  fetches the product twice).

  Card rendering uses card-product-carousel (snippet + CSS) — this is the
  canonical card wired to card-product-features.js. card-product-carousel.css
  is loaded by the parent section (collection-page.liquid), not here.
{% endcomment %}

{%- liquid
  assign has_articles = false
  assign has_pages    = false
  if related_articles and related_articles.size > 0
    assign has_articles = true
  endif
  if related_pages and related_pages.size > 0
    assign has_pages = true
  endif
-%}

<div class="collection-showroom">

  {%- comment -%} ── Tab bar ─────────────────────────────────────────────── {%- endcomment -%}

  <div class="collection-showroom__tabs" role="tablist" aria-label="Collection content">

    <button
      class="collection-showroom__tab collection-showroom__tab--active"
      role="tab"
      aria-selected="true"
      aria-controls="showroom-panel-products"
      id="showroom-tab-products"
      type="button"
      data-showroom-tab="products"
    >
      Products
      <span class="collection-showroom__tab-count">({{ collection.products_count }})</span>
    </button>

    {%- if has_articles -%}
      <button
        class="collection-showroom__tab"
        role="tab"
        aria-selected="false"
        aria-controls="showroom-panel-articles"
        id="showroom-tab-articles"
        type="button"
        data-showroom-tab="articles"
        tabindex="-1"
      >
        Articles
        <span class="collection-showroom__tab-count">({{ related_articles.size }})</span>
      </button>
    {%- endif -%}

    {%- if has_pages -%}
      <button
        class="collection-showroom__tab"
        role="tab"
        aria-selected="false"
        aria-controls="showroom-panel-pages"
        id="showroom-tab-pages"
        type="button"
        data-showroom-tab="pages"
        tabindex="-1"
      >
        Pages
        <span class="collection-showroom__tab-count">({{ related_pages.size }})</span>
      </button>
    {%- endif -%}

  </div>

  {%- comment -%} ── Products panel ──────────────────────────────────────── {%- endcomment -%}

  <div
    class="collection-showroom__panel collection-showroom__panel--active"
    id="showroom-panel-products"
    role="tabpanel"
    aria-labelledby="showroom-tab-products"
    data-showroom-panel="products"
  >

    <div class="collection-showroom__products">
      {%- if collection.products.size > 0 -%}
        {%- for product in collection.products -%}
          {%- render 'card-product-carousel', product: product -%}
        {%- endfor -%}
      {%- else -%}
        <p class="collection-showroom__empty">
          {{ 'collections.general.no_matches' | t }}
        </p>
      {%- endif -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav
        class="collection-showroom__pagination"
        aria-label="{{ 'general.pagination.label' | t }}"
      >
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="collection-showroom__page-link">
            &larr; {{ 'general.pagination.previous' | t }}
          </a>
        {%- endif -%}

        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}" class="collection-showroom__page-link">
              {{ part.title }}
            </a>
          {%- else -%}
            <span
              class="collection-showroom__page-link collection-showroom__page-link--current"
              aria-current="page"
            >
              {{ part.title }}
            </span>
          {%- endif -%}
        {%- endfor -%}

        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="collection-showroom__page-link">
            {{ 'general.pagination.next' | t }} &rarr;
          </a>
        {%- endif -%}
      </nav>
    {%- endif -%}

  </div>

  {%- comment -%} ── Articles panel ──────────────────────────────────────── {%- endcomment -%}

  {%- if has_articles -%}
    <div
      class="collection-showroom__panel"
      id="showroom-panel-articles"
      role="tabpanel"
      aria-labelledby="showroom-tab-articles"
      data-showroom-panel="articles"
      hidden
    >
      <div class="collection-showroom__grid">
        {%- for article in related_articles -%}
          {%- render 'card-article', article: article -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Pages panel ─────────────────────────────────────────── {%- endcomment -%}

  {%- if has_pages -%}
    <div
      class="collection-showroom__panel"
      id="showroom-panel-pages"
      role="tabpanel"
      aria-labelledby="showroom-tab-pages"
      data-showroom-panel="pages"
      hidden
    >
      <div class="collection-showroom__grid">
        {%- for page in related_pages -%}
          {%- render 'card-page', page: page -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div>