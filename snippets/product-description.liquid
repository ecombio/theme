{%- liquid
  assign has_description = false
  assign has_shipping    = false
  assign has_refund      = false
  assign has_warranty    = false

  if product.description != blank
    assign has_description = true
  endif

  assign shipping_page = pages['shipping-policy']
  assign refund_page   = pages['refund-policy']
  assign warranty_page = pages['warranty']

  if shipping_page.content != blank
    assign has_shipping = true
  endif
  if refund_page.content != blank
    assign has_refund = true
  endif
  if warranty_page.content != blank
    assign has_warranty = true
  endif
-%}

<div class="pd-wrap">

  {%- if has_description -%}
  <div class="pd-row">
    <button class="pd-trigger" type="button" id="PdTriggerDescription" aria-haspopup="dialog" aria-expanded="false" aria-controls="PdPanelDescription">
      <span>Description</span>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  {%- endif -%}

  {%- if has_shipping -%}
  <div class="pd-row">
    <button class="pd-trigger" type="button" id="PdTriggerShipping" aria-haspopup="dialog" aria-expanded="false" aria-controls="PdPanelShipping">
      <span>Shipping Policy</span>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  {%- elsif shop.shipping_policy.body != blank -%}
  <div class="pd-row">
    <button class="pd-trigger" type="button" id="PdTriggerShipping" aria-haspopup="dialog" aria-expanded="false" aria-controls="PdPanelShipping">
      <span>Shipping Policy</span>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  {%- endif -%}

  {%- if has_refund -%}
  <div class="pd-row">
    <button class="pd-trigger" type="button" id="PdTriggerRefund" aria-haspopup="dialog" aria-expanded="false" aria-controls="PdPanelRefund">
      <span>Refund &amp; Return Policy</span>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  {%- elsif shop.refund_policy.body != blank -%}
  <div class="pd-row">
    <button class="pd-trigger" type="button" id="PdTriggerRefund" aria-haspopup="dialog" aria-expanded="false" aria-controls="PdPanelRefund">
      <span>Refund &amp; Return Policy</span>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  {%- endif -%}

  {%- if has_warranty -%}
  <div class="pd-row">
    <button class="pd-trigger" type="button" id="PdTriggerWarranty" aria-haspopup="dialog" aria-expanded="false" aria-controls="PdPanelWarranty">
      <span>Warranty</span>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  {%- endif -%}

</div>

<!-- Overlay (shared) -->
<div class="pd-overlay" id="PdOverlay" aria-hidden="true"></div>

<!-- Description panel -->
{%- if has_description -%}
<div class="pd-panel" id="PdPanelDescription" role="dialog" aria-modal="true" aria-labelledby="PdTitleDescription" aria-hidden="true" tabindex="-1">
  <div class="pd-panel__header">
    <h2 class="pd-panel__title" id="PdTitleDescription">Description</h2>
    <button class="pd-panel__close" type="button" aria-label="Close"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button>
  </div>
  <div class="pd-panel__body">{{ product.description }}</div>
</div>
{%- endif -%}

<!-- Shipping panel -->
<div class="pd-panel" id="PdPanelShipping" role="dialog" aria-modal="true" aria-labelledby="PdTitleShipping" aria-hidden="true" tabindex="-1">
  <div class="pd-panel__header">
    <h2 class="pd-panel__title" id="PdTitleShipping">Shipping Policy</h2>
    <button class="pd-panel__close" type="button" aria-label="Close"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button>
  </div>
  <div class="pd-panel__body">
    {%- if has_shipping -%}
      {{ shipping_page.content }}
    {%- else -%}
      {{ shop.shipping_policy.body }}
    {%- endif -%}
  </div>
</div>

<!-- Refund panel -->
<div class="pd-panel" id="PdPanelRefund" role="dialog" aria-modal="true" aria-labelledby="PdTitleRefund" aria-hidden="true" tabindex="-1">
  <div class="pd-panel__header">
    <h2 class="pd-panel__title" id="PdTitleRefund">Refund &amp; Return Policy</h2>
    <button class="pd-panel__close" type="button" aria-label="Close"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button>
  </div>
  <div class="pd-panel__body">
    {%- if has_refund -%}
      {{ refund_page.content }}
    {%- else -%}
      {{ shop.refund_policy.body }}
    {%- endif -%}
  </div>
</div>

<!-- Warranty panel -->
<div class="pd-panel" id="PdPanelWarranty" role="dialog" aria-modal="true" aria-labelledby="PdTitleWarranty" aria-hidden="true" tabindex="-1">
  <div class="pd-panel__header">
    <h2 class="pd-panel__title" id="PdTitleWarranty">Warranty</h2>
    <button class="pd-panel__close" type="button" aria-label="Close"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button>
  </div>
  <div class="pd-panel__body">
    {%- if has_warranty -%}
      {{ warranty_page.content }}
    {%- else -%}
      <p>Please contact us for warranty information.</p>
    {%- endif -%}
  </div>
</div>