{% comment %}
  Header Dropdown Menu
  Uses modern <details> + details-dropdown web component (hover trigger)
{% endcomment %}

{% assign menu_data = menu %}

{% if menu_data and menu_data.links.size > 0 %}
  <ul class="single-menu-items dropdown-menu-items">

    {%- for link in menu_data.links -%}

      <li class="single-menu-item {% if link.links.size > 0 %}has-dropdown{% endif %}">

        {%- if link.links.size > 0 -%}
          <!-- Dropdown with nested support -->
          <details is="details-dropdown" level="top" trigger="hover">
            <summary data-link="{{ link.url }}" class="z-2">
              <span class="menu__item flex items-center relative">
                <span class="flex items-center font-navigation menu__item-text reversed-link">
                  {{ link.title }}
                  <svg class="icon icon-caret-down icon--2xs icon--thick" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16.25 7.5L10 13.75L3.75 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </span>
              </span>
            </summary>

            <div class="dropdown" style="opacity: 0; visibility: hidden;">
              <div class="dropdown__container color-scheme-1" style="transform: translateY(-105%);">
                <ul class="dropdown__nav" role="list">

                  {%- for child in link.links -%}

                    {%- if child.links.size > 0 -%}
                      <!-- Nested Level 3 -->
                      <li class="relative text-subtext">
                        <details level="child" trigger="hover" is="details-dropdown">
                          <summary data-link="{{ child.url }}" class="">
                            <a href="{{ child.url }}" class="reversed-link flex items-center justify-between gap-x-1 no-js-hidden" tabindex="-1">
                              <span class="reversed-link__text">{{ child.title }}</span>
                              <svg class="icon icon-caret-right rtl-flip-x icon--2xs icon--thick" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M7.5 3.75L13.75 10L7.5 16.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                              </svg>
                            </a>
                          </summary>

                          <div class="dropdown">
                            <div class="dropdown__container">
                              <ul class="dropdown__nav" role="list">
                                {%- for grandchild in child.links -%}
                                  <li class="reversed-link text-subtext">
                                    <a class="block" href="{{ grandchild.url }}">
                                      <span class="reversed-link__text">{{ grandchild.title }}</span>
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            </div>
                          </div>
                        </details>
                      </li>

                    {%- else -%}
                      <!-- Simple Level 2 link -->
                      <li class="reversed-link text-subtext">
                        <a href="{{ child.url }}" class="block">
                          <span class="reversed-link__text">{{ child.title }}</span>
                        </a>
                      </li>
                    {%- endif -%}

                  {%- endfor -%}

                </ul>
              </div>
            </div>
          </details>

        {%- else -%}
          <!-- Normal single link (no dropdown) -->
          <a href="{{ link.url }}" class="single-menu-link">
            {{ link.title }}
          </a>
        {%- endif -%}

      </li>

    {%- endfor -%}

  </ul>
{% endif %}