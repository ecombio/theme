{% comment %}
  snippets/product-card.liquid
  Self-contained product card used by collection-products.liquid.

  Expects:
    product  {Object} — a Shopify product object

  Loads: product-card.css (via stylesheet_tag below)
  JS:    product-card.js — loaded globally in theme.liquid. Do NOT load here.

  Data attributes wired to product-card.js:
    [data-product-handle]    — on the card root, used by Wishlist + Quick View
    [data-atc-btn]           — Add to Cart button
    [data-variant-id]        — first available variant ID
    [data-wishlist-btn]      — wishlist toggle
    [data-product-id]        — numeric product ID
    [data-quickview-btn]     — Quick View trigger
    [data-compare-checkbox]  — compare toggle
    [data-product-title]     — for compare bar display
    [data-product-image]     — for compare bar thumbnail
    [data-product-price]     — for compare bar display
{% endcomment %}

{{ 'product-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_image   = product.featured_image | default: product.images.first
  assign on_sale         = false
  if current_variant.compare_at_price > current_variant.price
    assign on_sale = true
  endif
-%}

<div
  class="product-card{% if product.available == false %} product-card--sold-out{% endif %}"
  data-product-handle="{{ product.handle }}"
  data-product-id="{{ product.id }}"
>

  {%- comment -%} ── Media ────────────────────────────────────────────────── {%- endcomment -%}

  <div class="product-card__media">
    <a href="{{ product.url }}" class="product-card__media-link" aria-label="{{ product.title | escape }}" tabindex="-1">
      {%- if product_image -%}
        <img
          class="product-card__image product-card__image--primary"
          src="{{ product_image | image_url: width: 600 }}"
          alt="{{ product_image.alt | escape | default: product.title | escape }}"
          width="600"
          height="{{ 600 | divided_by: product_image.aspect_ratio | round }}"
          loading="lazy"
        >
        {%- if product.images[1] -%}
          <img
            class="product-card__image product-card__image--hover"
            src="{{ product.images[1] | image_url: width: 600 }}"
            alt="{{ product.images[1].alt | escape | default: product.title | escape }}"
            width="600"
            height="{{ 600 | divided_by: product.images[1].aspect_ratio | round }}"
            loading="lazy"
            aria-hidden="true"
          >
        {%- endif -%}
      {%- else -%}
        <div class="product-card__image-placeholder">
          {{ 'image' | placeholder_svg_tag: 'product-card__placeholder-svg' }}
        </div>
      {%- endif -%}
    </a>

    {%- comment -%} ── Badges ─────────────────────────────────────────────── {%- endcomment -%}

    <div class="product-card__badges">
      {%- if on_sale -%}
        <span class="product-card__badge product-card__badge--sale">Sale</span>
      {%- endif -%}
      {%- if product.available == false -%}
        <span class="product-card__badge product-card__badge--sold-out">Sold out</span>
      {%- endif -%}
    </div>

    {%- comment -%} ── Quick actions ───────────────────────────────────────── {%- endcomment -%}

    <div class="product-card__actions">
      <button
        class="product-card__action-btn product-card__action-btn--wishlist"
        type="button"
        aria-label="Add {{ product.title | escape }} to wishlist"
        aria-pressed="false"
        data-wishlist-btn
        data-product-id="{{ product.id }}"
      >
        <svg class="product-card__action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </button>

      <button
        class="product-card__action-btn product-card__action-btn--quickview"
        type="button"
        aria-label="Quick view {{ product.title | escape }}"
        data-quickview-btn
        data-product-handle="{{ product.handle }}"
      >
        <svg class="product-card__action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </button>
    </div>

  </div>

  {%- comment -%} ── Info ────────────────────────────────────────────────── {%- endcomment -%}

  <div class="product-card__info">

    {%- if product.vendor -%}
      <p class="product-card__vendor">{{ product.vendor }}</p>
    {%- endif -%}

    <h3 class="product-card__title">
      <a href="{{ product.url }}" class="product-card__title-link">{{ product.title }}</a>
    </h3>

    <div class="product-card__price">
      {%- if on_sale -%}
        <span class="product-card__price-sale">{{ current_variant.price | money }}</span>
        <span class="product-card__price-compare">{{ current_variant.compare_at_price | money }}</span>
      {%- else -%}
        <span class="product-card__price-regular">
          {%- if product.price_varies -%}
            From {{ product.price_min | money }}
          {%- else -%}
            {{ product.price | money }}
          {%- endif -%}
        </span>
      {%- endif -%}
    </div>

    {%- comment -%} ── Compare checkbox ────────────────────────────────────── {%- endcomment -%}

    <label class="product-card__compare">
      <input
        class="product-card__compare-checkbox"
        type="checkbox"
        data-compare-checkbox
        data-product-id="{{ product.id }}"
        data-product-handle="{{ product.handle }}"
        data-product-title="{{ product.title | escape }}"
        data-product-image="{{ product_image | image_url: width: 96 }}"
        data-product-price="{{ current_variant.price | money }}"
      >
      <span class="product-card__compare-label">Compare</span>
    </label>

  </div>

  {%- comment -%} ── Add to Cart ─────────────────────────────────────────── {%- endcomment -%}

  <div class="product-card__footer">
    {%- if product.available -%}
      <button
        class="product-card__atc"
        type="button"
        data-atc-btn
        data-variant-id="{{ current_variant.id }}"
      >
        <span class="card-product__atc-label">Add to cart</span>
      </button>
    {%- else -%}
      <button class="product-card__atc product-card__atc--disabled" type="button" disabled>
        <span class="card-product__atc-label">Sold out</span>
      </button>
    {%- endif -%}
  </div>

</div>
