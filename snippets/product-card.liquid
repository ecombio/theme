{%- comment -%}
  snippets/product-card.liquid
  Reusable product card. Context-agnostic — works in carousels,
  collection grids, search results, featured collections, sponsored
  ad units, etc.

  Wired to assets/product-card.js (loaded globally via theme.liquid).

  Parameters:
    product        {Object}  required  — Shopify product object
    show_quickview {Boolean} optional  — default true
    show_compare   {Boolean} optional  — default true
    show_eta       {Boolean} optional  — default true
    is_sponsored   {Boolean} optional  — default false
                             When true, renders a "Sponsored" disclosure
                             label on the card. Used by sponsored-products
                             and sponsored-brands so in-feed ad units share
                             the exact same card markup/behavior as
                             organic product cards.

  CSS dependency: assets/product-card.css (loaded by collection-products.liquid;
                  snippets do not load their own assets — see asset ownership rule)

  MIGRATION NOTES (from card-product-carousel.liquid):
    • All CSS classes renamed: .cpc__* → .product-card__*
    • ATC label span: class="card-product__atc-label" → data-atc-label
      (eliminates the JS→CSS class coupling documented in Architecture_Review.pdf)
    • Guard flag renamed: window.__cardProductFeaturesLoaded → window.__productCardLoaded
    • File rename: card-product-carousel.liquid → product-card.liquid
{%- endcomment -%}

{%- liquid
  assign card_product  = product
  assign card_image    = card_product.featured_image
  assign card_image2   = card_product.images[1]
  assign card_url      = card_product.url
  assign card_title    = card_product.title
  assign card_vendor   = card_product.vendor
  assign card_price    = card_product.price
  assign card_comp     = card_product.compare_at_price

  assign on_sale     = false
  assign save_amount = 0
  assign save_pct    = 0
  if card_comp > card_price
    assign on_sale     = true
    assign save_amount = card_comp | minus: card_price
    assign save_pct    = save_amount | times: 100 | divided_by: card_comp
  endif

  assign first_variant = card_product.first_available_variant | default: card_product.variants.first
  assign variant_id    = first_variant.id
  assign eta_text      = card_product.metafields.custom.eta_text

  assign show_quickview = show_quickview | default: true
  assign show_compare   = show_compare   | default: true
  assign show_eta       = show_eta       | default: true
  assign is_sponsored   = is_sponsored   | default: false
-%}

{{- '' -}}
{%- comment -%}
  data-product-handle sits on the wrapper so product-card.js wishlist
  logic can climb up with btn.closest('[data-product-handle]').
{%- endcomment -%}
<div
  class="product-card{% if is_sponsored %} product-card--sponsored{% endif %}"
  data-product-id="{{ card_product.id }}"
  data-product-handle="{{ card_product.handle }}"
  {%- if is_sponsored %}
  data-sponsored="true"
  {%- endif %}
>

  {%- comment -%}── IMAGE ZONE ──{%- endcomment -%}
  <div class="product-card__img-zone">

    {%- if is_sponsored -%}
      <span class="product-card__sponsored-label">Sponsored</span>
    {%- endif -%}

    <a href="{{ card_url }}" class="product-card__image-wrapper" aria-label="{{ card_title | escape }}" tabindex="0">
      {%- if card_image != blank -%}
        {{
          card_image
          | image_url: width: 600
          | image_tag:
            class: 'product-card__img product-card__img--primary',
            loading: 'lazy',
            widths: '200, 300, 400, 600',
            sizes: '(max-width: 767px) 50vw, 25vw',
            alt: card_image.alt | default: card_title | escape
        }}
        {%- if card_image2 != blank -%}
          {{
            card_image2
            | image_url: width: 600
            | image_tag:
              class: 'product-card__img product-card__img--secondary',
              loading: 'lazy',
              widths: '200, 300, 400, 600',
              sizes: '(max-width: 767px) 50vw, 25vw',
              alt: card_image2.alt | default: card_title | escape
          }}
        {%- endif -%}
      {%- else -%}
        <div class="product-card__img-placeholder" aria-hidden="true">
          {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder-svg' }}
        </div>
      {%- endif -%}
    </a>

    {%- comment -%}── Wishlist ──{%- endcomment -%}
    <button
      class="product-card__wishlist-btn"
      type="button"
      aria-label="Add {{ card_title | escape }} to wishlist"
      aria-pressed="false"
      data-wishlist-btn
      data-product-id="{{ card_product.id }}"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path class="product-card__wishlist-path" d="M9 15.5S2 11 2 6a4 4 0 0 1 7-2.65A4 4 0 0 1 16 6c0 5-7 9.5-7 9.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      </svg>
    </button>

    {%- if show_quickview -%}
      <button
        class="product-card__quickview-btn"
        type="button"
        aria-label="Quick view {{ card_title | escape }}"
        data-quickview-btn
        data-product-handle="{{ card_product.handle }}"
      >
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <ellipse cx="7.5" cy="7.5" rx="6" ry="4.5" stroke="currentColor" stroke-width="1.4"/>
          <circle cx="7.5" cy="7.5" r="2" stroke="currentColor" stroke-width="1.4"/>
        </svg>
        Quick view
      </button>
    {%- endif -%}

    {%- if on_sale -%}
      <span class="product-card__badge">Save {{ save_pct }}%</span>
    {%- endif -%}
  </div>

  {%- comment -%}── CARD BODY ──{%- endcomment -%}
  <div class="product-card__body">

    {%- if card_vendor != blank -%}
      <span class="product-card__vendor">{{ card_vendor }}</span>
    {%- endif -%}

    <a href="{{ card_url }}" class="product-card__title">{{ card_title }}</a>

    {%- comment -%}
      Judge.me: raw widget div hydrated after page load by the jdgm script.
    {%- endcomment -%}
    <div class="product-card__reviews">
      <div
        class="jdgm-widget jdgm-preview-badge"
        data-id="{{ card_product.id }}"
        data-auto-install="false"
      ></div>
    </div>

    {%- comment -%}── Pricing ──{%- endcomment -%}
    <div class="product-card__pricing">
      {%- if on_sale -%}
        <span class="product-card__price product-card__price--sale">{{ card_price | money }}</span>
        <div class="product-card__savings-row">
          <span class="product-card__save-badge">Save {{ save_amount | money_without_trailing_zeros }}</span>
          <span class="product-card__comp-value">Comp. Value: <s>{{ card_comp | money }}</s></span>
        </div>
      {%- else -%}
        <span class="product-card__price">{{ card_price | money }}</span>
        <div class="product-card__savings-row" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    {%- comment -%}── ETA row ──{%- endcomment -%}
    {%- if show_eta and eta_text != blank -%}
      <div class="product-card__eta" aria-label="Estimated delivery">
        <svg class="product-card__eta-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="4" width="9" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
          <path d="M10 6.5h1.5l1.5 2V11h-3V6.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
          <circle cx="3.5" cy="11.5" r="1" fill="currentColor"/>
          <circle cx="10.5" cy="11.5" r="1" fill="currentColor"/>
        </svg>
        <span>{{ eta_text }}</span>
      </div>
    {%- endif -%}

    {%- comment -%}── Bottom row: ATC + Compare ──{%- endcomment -%}
    <div class="product-card__bottom-row">

      {%- comment -%}
        ATC label: now uses data-atc-label instead of a CSS class,
        so product-card.js has zero dependency on CSS class names.
      {%- endcomment -%}
      <button
        class="product-card__atc-btn"
        type="button"
        aria-label="Add {{ card_title | escape }} to cart"
        data-atc-btn
        data-variant-id="{{ variant_id }}"
        data-product-title="{{ card_title | escape }}"
      >
        <span data-atc-label>Add to cart</span>
      </button>

      {%- if show_compare -%}
        <label class="product-card__compare-label">
          <input
            class="product-card__compare-checkbox"
            type="checkbox"
            data-compare-checkbox
            data-product-id="{{ card_product.id }}"
            data-product-handle="{{ card_product.handle }}"
            data-product-title="{{ card_title | escape }}"
            data-product-image="{{ card_image | image_url: width: 120 }}"
            data-product-price="{{ card_price | money }}"
            aria-label="Compare {{ card_title | escape }}"
          >
          <span class="product-card__compare-text">Compare</span>
        </label>
      {%- endif -%}

    </div>
  </div>

</div>