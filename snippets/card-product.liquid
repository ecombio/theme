{%- comment -%}
  card-product.liquid
  ───────────────────────────────────────────────────────────────
  Parameters:
    product               – product object (required)
    show_vendor           – boolean
    show_compare_at_price – boolean

  Section-level feature flags (section.settings.*):
    enable_quickview   enable_atc   enable_compare
    enable_wishlist    show_eta
    eta_days_min  eta_days_max  eta_label
{%- endcomment -%}

{%- liquid
  assign p = product

  assign _show_vendor        = show_vendor           | default: false
  assign _show_compare_price = show_compare_at_price | default: false

  assign _quickview = section.settings.enable_quickview | default: false
  assign _atc       = section.settings.enable_atc       | default: false
  assign _compare   = section.settings.enable_compare   | default: false
  assign _wishlist  = section.settings.enable_wishlist  | default: false
  assign _eta       = section.settings.show_eta         | default: false
  assign _eta_min   = section.settings.eta_days_min     | default: 3
  assign _eta_max   = section.settings.eta_days_max     | default: 7
  assign _eta_label = section.settings.eta_label        | default: 'Est. arrival:'

  assign on_sale       = false
  assign savings_amt   = 0
  if p.compare_at_price > p.price
    assign on_sale     = true
    assign savings_amt = p.compare_at_price | minus: p.price
  endif

  assign first_variant = p.variants.first
  assign available     = p.available
-%}

<div
  class="card-product"
  data-product-id="{{ p.id }}"
  data-product-handle="{{ p.handle }}"
>

  {{- '<!-- card-product: ' | append: p.handle | append: ' -->' -}}

  {%- comment -%} ══ IMAGE ZONE ══ {%- endcomment -%}
  <div class="card-product__img-zone">

    <a
      href="{{ p.url }}"
      class="card-product__image-wrapper"
      aria-label="{{ p.title | escape }}"
      tabindex="0"
    >
      {%- if p.featured_image -%}
        {{
          p.featured_image
          | image_url: width: 800
          | image_tag:
            class: 'card-product__image card-product__image--primary',
            loading: 'lazy',
            widths: '300, 400, 600, 800',
            sizes: '(max-width: 379px) 100vw, (max-width: 599px) 50vw, (max-width: 1023px) 33vw, 25vw',
            alt: p.featured_image.alt | escape
        }}
        {%- if p.images[1] -%}
          {{
            p.images[1]
            | image_url: width: 800
            | image_tag:
              class: 'card-product__image card-product__image--secondary',
              loading: 'lazy',
              widths: '300, 400, 600, 800',
              sizes: '(max-width: 379px) 100vw, (max-width: 599px) 50vw, (max-width: 1023px) 33vw, 25vw',
              alt: p.images[1].alt | escape
          }}
        {%- endif -%}
      {%- else -%}
        <div class="card-product__image-placeholder" aria-hidden="true"></div>
      {%- endif -%}

      {%- comment -%} Badges – bottom-left of image {%- endcomment -%}
      {%- unless available -%}
        <span class="card-product__badge card-product__badge--sold-out">Sold out</span>
      {%- endunless -%}
    </a>

    {%- comment -%} Wishlist – top-right corner, always visible {%- endcomment -%}
    {%- if _wishlist -%}
      <button
        class="card-product__wishlist-btn"
        type="button"
        aria-label="Add {{ p.title | escape }} to wishlist"
        aria-pressed="false"
        data-wishlist-btn
        data-product-id="{{ p.id }}"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path class="card-product__wishlist-path"
                d="M9 15.5S2 11 2 6a4 4 0 0 1 7-2.65A4 4 0 0 1 16 6c0 5-7 9.5-7 9.5z"
                stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
        </svg>
      </button>
    {%- endif -%}

    {%- comment -%} Quick View – appears on hover over image zone {%- endcomment -%}
    {%- if _quickview -%}
      <button
        class="card-product__quickview-btn"
        type="button"
        aria-label="Quick view {{ p.title | escape }}"
        data-quickview-btn
        data-product-url="{{ p.url }}"
        data-product-handle="{{ p.handle }}"
      >
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <ellipse cx="7.5" cy="7.5" rx="6" ry="4.5" stroke="currentColor" stroke-width="1.4"/>
          <circle cx="7.5" cy="7.5" r="2" stroke="currentColor" stroke-width="1.4"/>
        </svg>
        Quick view
      </button>
    {%- endif -%}

  </div>{%- comment -%} /.card-product__img-zone {%- endcomment -%}

  {%- comment -%} ══ CONTENT ══ {%- endcomment -%}
  <div class="card-product__content">

    {%- comment -%} Vendor {%- endcomment -%}
    {%- if _show_vendor and p.vendor != blank -%}
      <span class="card-product__vendor">{{ p.vendor }}</span>
    {%- endif -%}

    {%- comment -%} Title {%- endcomment -%}
    <a href="{{ p.url }}" class="card-product__title">{{ p.title }}</a>

    {%- comment -%} ── Judge.me star widget (only renders if app is installed) ── {%- endcomment -%}
{%- assign judgeme_installed = false -%}
{%- for snippet in shop.metafields -%}{%- endfor -%}
<div class="card-product__reviews">
  {%- capture judgeme_output -%}
    {%- render 'judgeme_widgets',
      widget_type: 'judgeme_preview_badge',
      concierge_install: true,
      product: p
    -%}
  {%- endcapture -%}
  {{- judgeme_output -}}
</div>

    {%- comment -%} ── Price block ── {%- endcomment -%}
    <div class="card-product__pricing">
      <span class="card-product__price{% if on_sale %} card-product__price--sale{% endif %}">
        {{ p.price | money }}
      </span>

      {%- if on_sale -%}
        <div class="card-product__savings-row">
          <span class="card-product__save-badge">Save {{ savings_amt | money }}</span>
          {%- if _show_compare_price -%}
            <span class="card-product__comp-value">
              Comp. Value: <s>{{ p.compare_at_price | money }}</s>
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── ETA / delivery line ── {%- endcomment -%}
    {%- if _eta -%}
      {%- if available -%}
        <div class="card-product__eta" aria-label="Estimated delivery">
          <svg class="card-product__eta-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <rect x="1" y="4" width="9" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
            <path d="M10 6.5h1.5l1.5 2V11h-3V6.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
            <circle cx="3.5" cy="11.5" r="1" fill="currentColor"/>
            <circle cx="10.5" cy="11.5" r="1" fill="currentColor"/>
          </svg>
          <span>
            {{ _eta_label }}
            <strong>{{ 'now' | date: '%a, %b %-d' | replace: 'now', '' -}}
            {%- assign eta_date = 'now' | date: '%s' | plus: _eta_max | times: 86400 -%}
            {{- eta_date | date: '%a, %b %-d' }}</strong> • <strong class="card-product__eta-free">FREE</strong>
          </span>
        </div>
      {%- else -%}
        <div class="card-product__eta card-product__eta--unavailable">
          <svg class="card-product__eta-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.3"/>
            <path d="M7 4v3.5l2 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
          <span>Currently unavailable</span>
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- comment -%} ── Bottom row: ATC + Compare ── {%- endcomment -%}
    {%- if _atc or _compare -%}
      <div class="card-product__bottom-row">

        {%- if _atc -%}
          {%- if available -%}
            <button
              class="card-product__atc-btn"
              type="button"
              aria-label="Add {{ p.title | escape }} to cart"
              data-atc-btn
              data-variant-id="{{ first_variant.id }}"
              data-product-title="{{ p.title | escape }}"
            >
              <span class="card-product__atc-label">Add to cart</span>
            </button>
          {%- else -%}
            <button class="card-product__atc-btn card-product__atc-btn--disabled" type="button" disabled aria-disabled="true">
              Sold out
            </button>
          {%- endif -%}
        {%- endif -%}

        {%- if _compare -%}
          <label class="card-product__compare-label">
            <input
              class="card-product__compare-checkbox"
              type="checkbox"
              data-compare-checkbox
              data-product-id="{{ p.id }}"
              data-product-title="{{ p.title | escape }}"
              data-product-image="{{ p.featured_image | image_url: width: 120 }}"
              data-product-price="{{ p.price | money }}"
              aria-label="Compare {{ p.title | escape }}"
            >
            <span class="card-product__compare-text">Compare</span>
          </label>
        {%- endif -%}

      </div>
    {%- endif -%}

  </div>{%- comment -%} /.card-product__content {%- endcomment -%}

</div>
