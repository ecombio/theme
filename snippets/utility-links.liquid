{% comment %}
  Renders the utility bar's left-hand link list.
  Accepts:
    blocks — section.blocks array (only 'link' type blocks are rendered)
{% endcomment %}
<ul class="utility-bar__links" role="list">
  {%- for block in blocks -%}
    {%- if block.type == 'link' -%}
      <li {{ block.shopify_attributes }}>
        <a href="{{ block.settings.url }}" class="utility-bar__link">
          {{- block.settings.label | escape -}}
        </a>
      </li>
    {%- endif -%}
  {%- endfor -%}
</ul>
