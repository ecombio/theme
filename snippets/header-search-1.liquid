{% comment %}
  Snippet: header-search.liquid
  Renders the search bar with optional "All Categories" dropdown.

  Usage:
    render 'header-search', show_category_filter: section.settings.show_category_filter
{% endcomment %}

<div class="ecombio-header__search">
  <form action="{{ routes.search_url }}" method="get" role="search" class="ecombio-header__search-form">
    <input type="hidden" name="type" value="product">

    {%- if show_category_filter -%}
      <div class="ecombio-header__search-category">
        <button
          type="button"
          class="ecombio-header__category-btn"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-label="Filter by category"
          id="header-category-btn"
        >
          <span class="ecombio-header__category-label" id="header-category-label">All Categories</span>
          <svg class="ecombio-header__category-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <ul
          class="ecombio-header__category-dropdown"
          role="listbox"
          aria-label="Categories"
          id="header-category-list"
          hidden
        >
          <li role="option" aria-selected="true" data-value="">All Categories</li>
          {%- for link in linklists.main-menu.links -%}
            <li role="option" aria-selected="false" data-value="{{ link.title | handleize }}">
              {{- link.title -}}
            </li>
          {%- endfor -%}
        </ul>

        <input type="hidden" name="q[product_type]" id="header-category-value" value="">
      </div>

      <div class="ecombio-header__search-divider" aria-hidden="true"></div>
    {%- endif -%}

    <label for="header-search-input" class="visually-hidden">Search</label>
    <input
      type="search"
      id="header-search-input"
      name="q"
      class="ecombio-header__search-input"
      placeholder="What are you looking for?"
      autocomplete="off"
      aria-label="Search"
      value="{{ search.terms | escape }}"
    >

    <button type="submit" class="ecombio-header__search-btn" aria-label="Submit search">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.6"/>
        <path d="M13 13L16.5 16.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
    </button>
  </form>
</div>
