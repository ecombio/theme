{% comment %}
  Link List - Header Menu (supports nested/child links)
  Renders a dropdown panel. Now handles second-level items.
{% endcomment %}

{%- liquid
  assign ll_menu = linklists[block.settings.menu]
-%}

<li class="menu-bar__item menu-bar__item--has-link-list" {{ block.shopify_attributes }}>
  <a href="{{ block.settings.link | default: ll_menu.links.first.url | default: '#' }}"
     class="menu-bar__link menu-bar__link--caret link-list-trigger"
     aria-haspopup="true"
     aria-expanded="false">
    {%- if block.settings.icon != blank -%}
      <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
    {%- endif -%}
    {{ block.settings.label | default: ll_menu.title | default: 'Menu' }}
    <svg class="icon-caret-down" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M16.25 7.5L10 13.75L3.75 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>

  {%- if ll_menu != blank and ll_menu.links.size > 0 -%}
    <div class="link-list-panel" role="region">
      <div class="link-list-panel__container">
        <ul class="link-list-panel__nav" role="list">

          {%- comment %} 
            MAIN LOOP: Goes through every top-level item in the link list.
            Example: "Trending", "Shop by Category", "Shop by Price"
          {% endcomment -%}
          {%- for link in ll_menu.links -%}
            <li class="link-list-panel__item">
              <a href="{{ link.url }}"
                 class="link-list-panel__link"
                 {% if link.current %}aria-current="page"{% endif %}>
                {{ link.title }}
              </a>

              {%- comment %} 
                NESTING CHECK: If this top-level item has child links 
                (e.g. Trending → Shop all, New arrivals, On sale),
                render a sub-list below it.
              {% endcomment -%}
              {%- if link.links.size > 0 -%}
                <ul class="link-list-panel__sub" role="list">
                  {%- for child in link.links -%}
                    <li>
                      <a href="{{ child.url }}"
                         class="link-list-panel__sublink"
                         {% if child.current %}aria-current="page"{% endif %}>
                        {{ child.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            </li>
          {%- endfor -%}

        </ul>
      </div>
    </div>
  {%- endif -%}
</li>