{%- comment -%}
  snippets/pr-card-styles.liquid
  Layout shell CSS for recommendation sections.
  Card-level styles removed — all cards now use product-card.css.
{%- endcomment -%}

<style>
/* ==========================================================
   PR Section Shell — layout only
   Scope: .pr-section, .pr-grid, .pr-header, .pr-heading
   ========================================================== */

/* ── Color Schemes ── */
.pr-section.cs-light  { background: #ffffff; }
.pr-section.cs-gray   { background: #f8f8f8; }
.pr-section.cs-dark   { background: #111111; color: #ffffff; }
.pr-section.cs-accent { background: #C8991A; color: #ffffff; }

/* ── Section Shell ── */
.pr-section {
  padding-top:    var(--pr-pad-top,    52px);
  padding-bottom: var(--pr-pad-bottom, 52px);
}

.pr-inner {
  max-width: var(--page-width, 1200px);
  margin: 0 auto;
  padding: 0 var(--page-margin, 1.5rem);
}

/* ── Header ── */
.pr-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.pr-heading {
  font-size: 1.35rem;
  font-weight: 700;
  margin: 0;
  line-height: 1.2;
}

.cs-dark .pr-heading { color: #ffffff; }

.pr-view-all-link {
  font-size: 0.82rem;
  font-weight: 600;
  color: inherit;
  opacity: 0.65;
  text-decoration: none;
  white-space: nowrap;
  transition: opacity 0.15s ease;
}

.pr-view-all-link:hover { opacity: 1; }

/* ── Grid ── */
.pr-grid {
  display: grid;
  grid-template-columns: repeat(var(--pr-cols, 4), 1fr);
  gap: var(--pr-gap, 16px);
}

@media (max-width: 767px) {
  .pr-grid {
    grid-template-columns: repeat(var(--pr-cols-mob, 2), 1fr);
  }
}

/* ── Empty state ── */
.pr-empty {
  grid-column: 1 / -1;
  text-align: center;
  padding: 2rem;
  font-size: 0.9rem;
  color: #888;
}

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce) {
  .pr-view-all-link { transition: none; }
}
</style>