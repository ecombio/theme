{% comment %}
  Single Link - Header Menu
  Renders a simple top-level menu link.
{% endcomment %}

<li class="menu-bar__item" {{ block.shopify_attributes }}>
  <a href="{{ block.settings.link | default: '#' }}" class="menu-bar__link">
    {%- if block.settings.icon != blank -%}
      <span class="menu-bar__icon">
        {%- render 'menu-icon', icon: block.settings.icon -%}
      </span>
    {%- endif -%}
    {{ block.settings.label | default: 'Link' }}
  </a>
</li>