{%- comment -%}
  snippets/card-product-carousel.liquid
  Carousel card — wired to card-product-features.js.
  Accepts: product
{%- endcomment -%}

{%- liquid
  assign card_product  = product
  assign card_image    = card_product.featured_image
  assign card_image2   = card_product.images[1]
  assign card_url      = card_product.url
  assign card_title    = card_product.title
  assign card_vendor   = card_product.vendor
  assign card_price    = card_product.price
  assign card_comp     = card_product.compare_at_price
  assign on_sale       = false
  if card_comp > card_price
    assign on_sale = true
  endif
  assign save_amount   = card_comp | minus: card_price
  assign first_variant = card_product.first_available_variant | default: card_product.variants.first
  assign variant_id    = first_variant.id
  assign eta_text      = card_product.metafields.custom.eta_text
-%}

{{- '' -}}
{%- comment -%}
  data-product-handle is on the wrapper so the wishlist JS can
  find it with btn.closest('[data-product-handle]')
{%- endcomment -%}
<div
  class="cpc"
  data-product-id="{{ card_product.id }}"
  data-product-handle="{{ card_product.handle }}"
>

  {%- comment -%}── IMAGE ZONE ──{%- endcomment -%}
  <div class="cpc__img-zone">
    <a href="{{ card_url }}" class="cpc__image-wrapper" aria-label="{{ card_title | escape }}" tabindex="0">
      {%- if card_image != blank -%}
        {{
          card_image
          | image_url: width: 600
          | image_tag:
            class: 'cpc__img cpc__img--primary',
            loading: 'lazy',
            widths: '200, 300, 400, 600',
            sizes: '(max-width: 767px) 50vw, 25vw',
            alt: card_image.alt | default: card_title | escape
        }}
        {%- if card_image2 != blank -%}
          {{
            card_image2
            | image_url: width: 600
            | image_tag:
              class: 'cpc__img cpc__img--secondary',
              loading: 'lazy',
              widths: '200, 300, 400, 600',
              sizes: '(max-width: 767px) 50vw, 25vw',
              alt: card_image2.alt | default: card_title | escape
          }}
        {%- endif -%}
      {%- else -%}
        <div class="cpc__img-placeholder" aria-hidden="true">
          {{ 'product-1' | placeholder_svg_tag: 'cpc__placeholder-svg' }}
        </div>
      {%- endif -%}
    </a>

    {%- comment -%}── Wishlist — data-product-id used by JS; handle read from parent .cpc ──{%- endcomment -%}
    <button
      class="cpc__wishlist-btn"
      type="button"
      aria-label="Add {{ card_title | escape }} to wishlist"
      aria-pressed="false"
      data-wishlist-btn
      data-product-id="{{ card_product.id }}"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path class="cpc__wishlist-path" d="M9 15.5S2 11 2 6a4 4 0 0 1 7-2.65A4 4 0 0 1 16 6c0 5-7 9.5-7 9.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      </svg>
    </button>

    {%- if on_sale -%}
      <span class="cpc__badge">Price drop</span>
    {%- endif -%}
  </div>

  {%- comment -%}── CARD BODY ──{%- endcomment -%}
  <div class="cpc__body">

    {%- if card_vendor != blank -%}
      <span class="cpc__vendor">{{ card_vendor }}</span>
    {%- endif -%}

    <a href="{{ card_url }}" class="cpc__title">{{ card_title }}</a>

    {%- comment -%}
      Judge.me: raw widget div (same pattern as card-product.liquid).
      The jdgm script picks up [data-id] and hydrates it after page load.
    {%- endcomment -%}
    <div class="cpc__reviews">
      <div
        class="jdgm-widget jdgm-preview-badge"
        data-id="{{ card_product.id }}"
        data-auto-install="false"
      ></div>
    </div>

    {%- comment -%}── Pricing ──{%- endcomment -%}
    <div class="cpc__pricing">
      {%- if on_sale -%}
        <span class="cpc__price cpc__price--sale">{{ card_price | money }}</span>
        <div class="cpc__savings-row">
          <span class="cpc__save-badge">Save {{ save_amount | money_without_trailing_zeros }}</span>
          <span class="cpc__comp-value">Comp. Value: <s>{{ card_comp | money }}</s></span>
        </div>
      {%- else -%}
        <span class="cpc__price">{{ card_price | money }}</span>
        <div class="cpc__savings-row" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    {%- comment -%}── ETA row (reads from metafield custom.eta_text) ──{%- endcomment -%}
    {%- if eta_text != blank -%}
      <div class="cpc__eta" aria-label="Estimated delivery">
        <svg class="cpc__eta-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="4" width="9" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
          <path d="M10 6.5h1.5l1.5 2V11h-3V6.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
          <circle cx="3.5" cy="11.5" r="1" fill="currentColor"/>
          <circle cx="10.5" cy="11.5" r="1" fill="currentColor"/>
        </svg>
        <span>{{ eta_text }}</span>
      </div>
    {%- endif -%}

    {%- comment -%}── Bottom row: ATC + Compare ──{%- endcomment -%}
    <div class="cpc__bottom-row">

      {%- comment -%}
        ATC: uses card-product__atc-label (not cpc__atc-label) because
        card-product-features.js targets '.card-product__atc-label'
      {%- endcomment -%}
      <button
        class="cpc__atc-btn"
        type="button"
        aria-label="Add {{ card_title | escape }} to cart"
        data-atc-btn
        data-variant-id="{{ variant_id }}"
        data-product-title="{{ card_title | escape }}"
      >
        <span class="card-product__atc-label">Add to cart</span>
      </button>

      {%- comment -%}
        Compare: all data-* attrs read by card-product-features.js initCompare().
        Uses a 120px image for the compare bar thumbnail (matches collection card).
      {%- endcomment -%}
      <label class="cpc__compare-label">
        <input
          class="cpc__compare-checkbox"
          type="checkbox"
          data-compare-checkbox
          data-product-id="{{ card_product.id }}"
          data-product-handle="{{ card_product.handle }}"
          data-product-title="{{ card_title | escape }}"
          data-product-image="{{ card_image | image_url: width: 120 }}"
          data-product-price="{{ card_price | money }}"
          aria-label="Compare {{ card_title | escape }}"
        >
        <span class="cpc__compare-text">Compare</span>
      </label>

    </div>
  </div>

</div>