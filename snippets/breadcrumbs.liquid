{%- liquid
  assign primary_collection = collection
  assign best_parent = nil
  assign largest_count = 0

  for col in product.collections
    if col.handle != primary_collection.handle and col.all_products_count > largest_count
      assign best_parent = col
      assign largest_count = col.all_products_count
    endif
  endfor
-%}

<nav class="breadcrumbs" role="navigation" aria-label="Breadcrumb">
  <div class="breadcrumbs-container">

    <a href="/">Home</a>

    {%- if best_parent -%}
      <span class="breadcrumb-divider" aria-hidden="true"><span class="divider-line"></span></span>
      <a href="{{ best_parent.url }}">{{ best_parent.title }}</a>
    {%- endif -%}

    {%- if primary_collection -%}
      <span class="breadcrumb-divider" aria-hidden="true"><span class="divider-line"></span></span>
      <a href="{{ primary_collection.url }}">{{ primary_collection.title }}</a>
    {%- endif -%}

    <span class="breadcrumb-divider" aria-hidden="true"><span class="divider-line"></span></span>
    <span class="breadcrumb-current" aria-current="page">{{ product.title }}</span>

  </div>
</nav>