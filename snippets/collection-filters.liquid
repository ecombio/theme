{% comment %}
  collection-filters.liquid
  Parameters:
    - open {Boolean} - adds sidebar-open class to show sidebar on page load (desktop)
{% endcomment %}

<aside
  class="collection-filters{% if open %} sidebar-open{% endif %}"
  id="collection-filters"
  aria-label="Product filters"
>

  <div class="collection-filters__header">
    <span class="collection-filters__heading">Filters</span>
    <button
      class="collection-filters__clear"
      id="filters-clear-all"
      type="button"
      aria-label="Clear all filters"
    >Clear all</button>
  </div>

  {%- comment -%} ── Availability (OPEN BY DEFAULT) ── {%- endcomment -%}
  <div class="filter-group" data-filter-group="availability">
    <button
      class="filter-group__toggle"
      type="button"
      aria-expanded="true"
      aria-controls="filter-availability"
    >
      Availability
      <svg class="filter-group__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <div class="filter-group__body" id="filter-availability">
      <label class="filter-option">
        <input
          class="filter-option__checkbox"
          type="checkbox"
          name="filter.p.available"
          value="true"
          {% if request.params['filter.p.available'] == 'true' %}checked{% endif %}
          data-filter-type="availability"
        >
        <span class="filter-option__label">In stock</span>
      </label>
    </div>
  </div>

  {%- comment -%} ── Price ── {%- endcomment -%}
  <div class="filter-group" data-filter-group="price">
    <button
      class="filter-group__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="filter-price"
    >
      Price
      <svg class="filter-group__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <div class="filter-group__body" id="filter-price" hidden>
      <div class="filter-price">
        <div class="filter-price__inputs">
          <div class="filter-price__field">
            <label class="filter-price__label" for="filter-price-min">Min</label>
            <div class="filter-price__input-wrap">
              <span class="filter-price__symbol">$</span>
              <input
                id="filter-price-min"
                class="filter-price__input"
                type="number"
                name="filter.v.price.gte"
                min="0"
                placeholder="0"
                value="{{ request.params['filter.v.price.gte'] }}"
                data-filter-type="price-min"
              >
            </div>
          </div>
          <span class="filter-price__sep">—</span>
          <div class="filter-price__field">
            <label class="filter-price__label" for="filter-price-max">Max</label>
            <div class="filter-price__input-wrap">
              <span class="filter-price__symbol">$</span>
              <input
                id="filter-price-max"
                class="filter-price__input"
                type="number"
                name="filter.v.price.lte"
                min="0"
                placeholder="Any"
                value="{{ request.params['filter.v.price.lte'] }}"
                data-filter-type="price-max"
              >
            </div>
          </div>
        </div>
        <button class="filter-price__apply" type="button" data-filter-price-apply>Apply</button>
      </div>
    </div>
  </div>

  {%- comment -%}
    ── Whitelisted tag groups ──
  {%- endcomment -%}

  {%- assign filter_groups = "Bike Style|Frame|Motor" -%}

  {%- assign tags_Bike-Style = "Commuter,Cargo,Folding,Fat,Road,Step" -%}
  {%- assign tags_Frame      = "Step-through,Mid-step,Diamond,Aluminum frame" -%}
  {%- assign tags_Motor      = "Fat,Electric,Mid-drive,Hub drive" -%}

  {%- assign filter_group_array = filter_groups | split: "|" -%}

  {%- for group_label in filter_group_array -%}
    {%- assign group_id    = group_label | handleize -%}
    {%- assign tag_key     = "tags_" | append: group_id -%}

    {%- if group_id == "bike-style" -%}{%- assign allowed_tags = tags_Bike-Style | split: "," -%}
    {%- elsif group_id == "frame"      -%}{%- assign allowed_tags = tags_Frame      | split: "," -%}
    {%- elsif group_id == "motor"      -%}{%- assign allowed_tags = tags_Motor      | split: "," -%}
    {%- endif -%}

    {%- assign group_has_tags = false -%}
    {%- for allowed in allowed_tags -%}
      {%- assign allowed_h = allowed | strip | handleize -%}
      {%- for tag in collection.all_tags -%}
        {%- assign tag_h = tag | handleize -%}{%- if tag_h == allowed_h -%}{%- assign group_has_tags = true -%}{%- endif -%}
      {%- endfor -%}
    {%- endfor -%}

    {%- if group_has_tags -%}
      <div class="filter-group" data-filter-group="{{ group_id }}">
        <button
          class="filter-group__toggle"
          type="button"
          aria-expanded="false"
          aria-controls="filter-{{ group_id }}"
        >
          {{ group_label }}
          <svg class="filter-group__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="filter-group__body" id="filter-{{ group_id }}" hidden>
          {%- for allowed in allowed_tags -%}
            {%- assign allowed_h = allowed | strip | handleize -%}
            {%- for tag in collection.all_tags -%}
              {%- assign tag_h = tag | handleize -%}
              {%- if tag_h == allowed_h -%}
                <label class="filter-option">
                  <input
                    class="filter-option__checkbox"
                    type="checkbox"
                    name="tag"
                    value="{{ tag_h }}"
                    {% if current_tags contains tag %}checked{% endif %}
                    data-filter-type="tag"
                    data-tag="{{ tag_h }}"
                  >
                  <span class="filter-option__label">{{ allowed | strip }}</span>
                </label>
              {%- endif -%}
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

</aside>