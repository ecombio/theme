{%- comment -%}
  snippets/cart-recommendations.liquid

  Renders the product recommendations shell inside the cart drawer.
  JS (cart-recommendations.js) reads data-* attributes from the drawer root
  and this container, then fetches and injects cards after the drawer opens.

  Usage (inside cart-drawer.liquid, after the items list):
    {%- render 'cart-recommendations',
          show_related: show_related,
          show_complementary: show_complementary,
          related_label: related_label,
          complementary_label: complementary_label
    -%}

  "related" intent       → Shopify ML, works out of the box.
  "complementary" intent → Requires Shopify Search & Discovery app +
                           complementary products configured per product in Admin.
                           Returns 0 products silently; rail hidden automatically.
{%- endcomment -%}

{%- if show_related or show_complementary -%}
  <div
    class="ecombio-cart-recs"
    data-ecombio-recs
    data-related-label="{{ related_label | escape }}"
    data-complementary-label="{{ complementary_label | escape }}"
  >
    {%- comment -%}
      A visually-hidden live region announces state changes to screen readers
      without reading out every product title on each re-render.
      JS updates this element's text when recs load or are unavailable.
    {%- endcomment -%}
    <span
      class="ecombio-cart-recs__status"
      role="status"
      aria-live="polite"
      aria-atomic="true"
    ></span>

    {%- comment -%} Skeleton renders immediately to prevent layout shift. {%- endcomment -%}
    <div class="ecombio-cart-recs__skeleton" aria-hidden="true">
      <div class="ecombio-cart-recs__skeleton-bar"></div>
      <div class="ecombio-cart-recs__skeleton-cards">
        {%- for i in (1..4) -%}
          <div class="ecombio-cart-recs__skeleton-card"></div>
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}
