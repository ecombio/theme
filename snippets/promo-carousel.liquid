{%- comment -%}
  snippets/promo-carousel.liquid

  Evolved replacement for snippets/in-feed-carousel.liquid.
  A single-collection, no-tabs carousel row designed to be
  interleaved inside snippets/product-feed.liquid (breaks the
  .collection-products grid — full-width row, not a grid cell).

  Mirrors the banner support and markup patterns of
  sections/product-carousel.liquid while staying lean:
    • No outer <section> or {% schema %}
    • No tabs
    • No asset loading (parent section owns that — see below)

  MARKUP CONTRACT:
  Emits the same .product-carousel root + data-carousel-* hooks
  that product-carousel.js and product-carousel.css already expect.
  Do NOT fork those files — if carousel behaviour needs to change,
  change it once there and every consumer inherits the fix.

  ASSET LOADING:
  product-carousel.css and product-carousel.js are NOT loaded here.
  They must be loaded once by the parent (sections/collection.liquid)
  — same pattern used for product-card.css. Loading them per-
  snippet-instance would duplicate <link>/<script> tags every time
  this renders inside the feed loop.

  Params (all passed via render tag from snippets/product-feed.liquid):
    collection     {Object}  required — the collection to pull products from
    block_id       {String}  required — unique id for this instance (section.blocks[n].id)
    products_limit {Number}  optional — max products to show; default 12
    cards_desktop  {Number}  optional — visible cards on desktop; default 3
    cards_mobile   {Number}  optional — visible cards on mobile; default 2
    heading        {String}  optional — carousel heading text
    show_banner    {Boolean} optional — whether to render the side banner; default false
    banner_image   {Object}  optional — Shopify image object
    banner_link    {String}  optional — URL the banner links to
{%- endcomment -%}

{%- liquid
  assign pc_collection  = collection
  assign pc_limit       = products_limit | default: 12
  assign pc_cards_desk  = cards_desktop  | default: 3
  assign pc_cards_mob   = cards_mobile   | default: 2
  assign pc_heading     = heading
  assign pc_show_banner = show_banner    | default: false
  assign pc_banner_img  = banner_image
  assign pc_banner_link = banner_link
-%}

{%- if pc_collection != blank and pc_collection.products_count > 0 -%}
  <div
    class="product-carousel in-feed-carousel"
    id="pc-promo-{{ block_id }}"
    data-section-id="pc-promo-{{ block_id }}"
    data-cards-desktop="{{ pc_cards_desk }}"
    data-cards-mobile="{{ pc_cards_mob }}"
    data-autoplay="false"
    data-arrow-style="bottom"
    style="grid-column: 1 / -1;"
  >

    {%- comment -%}── HEADING ──{%- endcomment -%}
    {%- if pc_heading != blank -%}
      <div class="product-carousel__header">
        <div class="product-carousel__heading-group">
          <h2 class="product-carousel__heading">{{ pc_heading }}</h2>
        </div>
      </div>
    {%- endif -%}

    {%- comment -%}
      LAYOUT WRAPPER
      Adds the --has-banner modifier when a banner is enabled,
      exactly matching the pattern in sections/product-carousel.liquid.
      On desktop the banner sits beside the carousel column; on mobile
      (≤767px) product-carousel.css stacks them vertically via the
      flex-direction: column rule on .product-carousel__layout--has-banner.
    {%- endcomment -%}
    <div class="product-carousel__layout{% if pc_show_banner %} product-carousel__layout--has-banner{% endif %}">

      {%- comment -%}── BANNER (optional) ──{%- endcomment -%}
      {%- if pc_show_banner -%}
        <div class="product-carousel__banner">
          {%- if pc_banner_link != blank -%}
            <a href="{{ pc_banner_link }}" class="product-carousel__banner-link">
          {%- endif -%}

          {%- if pc_banner_img != blank -%}
            {{
              pc_banner_img
              | image_url: width: 800
              | image_tag:
                class: 'product-carousel__banner-img',
                loading: 'lazy',
                widths: '200, 300, 400, 600',
                sizes: '(max-width: 767px) 100vw, 220px',
                alt: pc_banner_img.alt | default: pc_heading | escape
            }}
          {%- else -%}
            <div class="product-carousel__banner-placeholder" aria-hidden="true">
              {{ 'collection-1' | placeholder_svg_tag: 'product-carousel__banner-placeholder-svg' }}
            </div>
          {%- endif -%}

          {%- if pc_banner_link != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%}── CAROUSEL COLUMN ──{%- endcomment -%}
      <div class="product-carousel__carousel-col">

        <div class="product-carousel__stage">
          <div class="product-carousel__track-wrapper" data-carousel-wrapper>
            <ul
              class="product-carousel__track"
              data-carousel-track
              role="list"
              aria-label="{{ pc_heading | default: pc_collection.title | escape }}"
            >
              {%- for product in pc_collection.products limit: pc_limit -%}
                <li class="product-carousel__slide" data-carousel-slide>
                  {%- render 'product-card', product: product -%}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        </div>

        <div class="product-carousel__nav">
          <div class="product-carousel__dots" data-carousel-dots></div>
          <div class="product-carousel__arrows">
            <button
              class="product-carousel__arrow product-carousel__arrow--prev"
              type="button"
              aria-label="Previous"
              data-carousel-prev
            >
              <svg width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M11 14L6 9L11 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button
              class="product-carousel__arrow product-carousel__arrow--next"
              type="button"
              aria-label="Next"
              data-carousel-next
            >
              <svg width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M7 4L12 9L7 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>

      </div><!-- /.product-carousel__carousel-col -->
    </div><!-- /.product-carousel__layout -->

  </div><!-- /.product-carousel -->
{%- endif -%}
