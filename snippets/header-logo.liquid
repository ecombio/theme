{% comment %}
  Header — Logo
  File: snippets/header-logo.liquid

  Leaf component — renders the shop logo (or text fallback) linked to home.

  Parameters:
    logo       {image}   — required. e.g. section.settings.logo
    logo_width {integer} — required. base render width in px (2x is derived)
{% endcomment %}

<a href="{{ routes.root_url }}"
   class="main-header__logo-link"
   aria-label="{{ shop.name }} — home">
  {%- if logo != blank -%}
    {%- assign logo_2x = logo_width | times: 2 -%}
    <img class="main-header__logo-img"
         src="{{ logo | image_url: width: logo_width }}"
         srcset="{{ logo | image_url: width: logo_width }} 1x,
                 {{ logo | image_url: width: logo_2x }} 2x"
         alt="{{ logo.alt | default: shop.name | escape }}"
         width="{{ logo_width }}"
         height="{{ logo_width | divided_by: logo.aspect_ratio | round }}"
         loading="eager"
         fetchpriority="high">
  {%- else -%}
    <span class="main-header__logo-text">{{ shop.name }}</span>
  {%- endif -%}
</a>
