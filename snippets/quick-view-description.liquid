{%- comment -%}
  snippets/quick-view-description.liquid
  ======================================
  Full-width tab strip rendered BELOW the two-column media/detail layout
  inside sections/quick-view.liquid.

  Tabs (in order):
    1. Description        — product.description
    2. Shipping Policy    — shipping_policy (passed from section scope)
    3. Returns & Refunds  — refund_policy   (passed from section scope)

  IMPORTANT: shop.policies is NOT accessible inside render-tag isolated scope.
  The section must pass policy bodies explicitly as parameters:
    {%- render 'quick-view-description',
        product:         product,
        shipping_policy: shop.policies.shipping_policy.body,
        refund_policy:   shop.policies.refund_policy.body
    -%}

  Parameters:
    product          {Object}  required — Shopify product object
    shipping_policy  {String}  optional — shop.policies.shipping_policy.body
    refund_policy    {String}  optional — shop.policies.refund_policy.body

  JS hooks (handled by quick-view.js — initDescriptionTabs()):
    [data-qv-desc-wrap]   — root container; guarded against double-init
    [data-qv-tab]         — clickable tab buttons
    [data-qv-tab-panel]   — panel divs; toggled via .is-active + aria-hidden
{%- endcomment -%}

{%- liquid
  assign has_description = false
  assign has_shipping    = false
  assign has_refund      = false

  if product.description != blank
    assign has_description = true
  endif

  if shipping_policy != blank
    assign has_shipping = true
  endif

  if refund_policy != blank
    assign has_refund = true
  endif

  assign any_tab = false
  if has_description or has_shipping or has_refund
    assign any_tab = true
  endif
-%}

{%- if any_tab -%}
<div class="quick-view__desc-wrap" data-qv-desc-wrap>

  {%- comment -%}── Tab strip (tablist) ──{%- endcomment -%}
  <div class="quick-view__tabs" role="tablist" aria-label="Product information tabs">

    {%- if has_description -%}
      <button
        type="button"
        class="quick-view__tab is-active"
        role="tab"
        id="qv-tab-desc-{{ product.id }}"
        aria-selected="true"
        aria-controls="qv-panel-desc-{{ product.id }}"
        tabindex="0"
        data-qv-tab
        data-target="qv-panel-desc-{{ product.id }}"
      >Description</button>
    {%- endif -%}

    {%- if has_shipping -%}
      <button
        type="button"
        class="quick-view__tab{% unless has_description %} is-active{% endunless %}"
        role="tab"
        id="qv-tab-ship-{{ product.id }}"
        aria-selected="{% unless has_description %}true{% else %}false{% endunless %}"
        aria-controls="qv-panel-ship-{{ product.id }}"
        tabindex="{% unless has_description %}0{% else %}-1{% endunless %}"
        data-qv-tab
        data-target="qv-panel-ship-{{ product.id }}"
      >Shipping Policy</button>
    {%- endif -%}

    {%- if has_refund -%}
      {%- liquid
        assign refund_first = false
        unless has_description or has_shipping
          assign refund_first = true
        endunless
      -%}
      <button
        type="button"
        class="quick-view__tab{% if refund_first %} is-active{% endif %}"
        role="tab"
        id="qv-tab-refund-{{ product.id }}"
        aria-selected="{{ refund_first }}"
        aria-controls="qv-panel-refund-{{ product.id }}"
        tabindex="{% if refund_first %}0{% else %}-1{% endif %}"
        data-qv-tab
        data-target="qv-panel-refund-{{ product.id }}"
      >Returns &amp; Refunds</button>
    {%- endif -%}

  </div>{%- comment -%}/.quick-view__tabs{%- endcomment -%}

  {%- comment -%}── Tab panels ──{%- endcomment -%}

  {%- if has_description -%}
    <div
      class="quick-view__tab-panel is-active"
      role="tabpanel"
      id="qv-panel-desc-{{ product.id }}"
      aria-labelledby="qv-tab-desc-{{ product.id }}"
      aria-hidden="false"
      data-qv-tab-panel
      tabindex="0"
    >
      <div class="quick-view__tab-panel-inner rte">
        {{- product.description -}}
      </div>
    </div>
  {%- endif -%}

  {%- if has_shipping -%}
    <div
      class="quick-view__tab-panel{% unless has_description %} is-active{% endunless %}"
      role="tabpanel"
      id="qv-panel-ship-{{ product.id }}"
      aria-labelledby="qv-tab-ship-{{ product.id }}"
      aria-hidden="{% if has_description %}true{% else %}false{% endif %}"
      data-qv-tab-panel
      tabindex="0"
    >
      <div class="quick-view__tab-panel-inner rte">
        {{- shipping_policy -}}
      </div>
    </div>
  {%- endif -%}

  {%- if has_refund -%}
    {%- liquid
      assign refund_hidden = true
      unless has_description or has_shipping
        assign refund_hidden = false
      endunless
    -%}
    <div
      class="quick-view__tab-panel{% unless refund_hidden %} is-active{% endunless %}"
      role="tabpanel"
      id="qv-panel-refund-{{ product.id }}"
      aria-labelledby="qv-tab-refund-{{ product.id }}"
      aria-hidden="{{ refund_hidden }}"
      data-qv-tab-panel
      tabindex="0"
    >
      <div class="quick-view__tab-panel-inner rte">
        {{- refund_policy -}}
      </div>
    </div>
  {%- endif -%}

</div>{%- comment -%}/.quick-view__desc-wrap{%- endcomment -%}
{%- endif -%}
