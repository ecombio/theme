{%- comment -%}
  snippets/quick-view-description.liquid
  ======================================
  Full-width tab strip rendered BELOW the two-column media/detail layout
  inside sections/quick-view.liquid.

  Tabs (in order):
    1. Description        — product.description
    2. Shipping Policy    — shop.policies.shipping_policy
    3. Returns & Refunds  — shop.policies.refund_policy

  A tab is omitted entirely when its content is blank, so stores with only
  a description don't see empty "Shipping" or "Returns" tabs.

  Parameters (passed via render tag from sections/quick-view.liquid):
    product  {Object}  required — Shopify product object

  JS hooks (handled by quick-view.js initDescriptionTabs()):
    [data-qv-tab]        — clickable tab buttons; data-target="#<panel-id>"
    [data-qv-tab-panel]  — panel <div>s; toggled via aria-hidden + .is-active

  Accessibility:
    • role="tablist" / role="tab" / role="tabpanel" pattern
    • aria-selected, aria-controls, aria-labelledby wired in Liquid
    • Keyboard: left/right arrow navigation handled in JS
{%- endcomment -%}

{%- liquid
  assign has_description = false
  assign has_shipping    = false
  assign has_refund      = false

  if product.description != blank
    assign has_description = true
  endif

  if shop.policies.shipping_policy.body != blank
    assign has_shipping = true
  endif

  if shop.policies.refund_policy.body != blank
    assign has_refund = true
  endif

  assign any_tab = false
  if has_description or has_shipping or has_refund
    assign any_tab = true
  endif
-%}

{%- if any_tab -%}
<div
  class="quick-view__desc-wrap"
  data-qv-desc-wrap
>

  {%- comment -%}── Tab strip ──{%- endcomment -%}
  <div
    class="quick-view__tabs"
    role="tablist"
    aria-label="Product information tabs"
  >

    {%- assign first_tab_set = false -%}

    {%- if has_description -%}
      {%- assign first_tab_set = true -%}
      <button
        type="button"
        class="quick-view__tab is-active"
        role="tab"
        id="qv-tab-desc-{{ product.id }}"
        aria-selected="true"
        aria-controls="qv-panel-desc-{{ product.id }}"
        data-qv-tab
        data-target="qv-panel-desc-{{ product.id }}"
      >
        Description
      </button>
    {%- endif -%}

    {%- if has_shipping -%}
      <button
        type="button"
        class="quick-view__tab{% unless first_tab_set %} is-active{% endunless %}"
        role="tab"
        id="qv-tab-ship-{{ product.id }}"
        aria-selected="{% unless first_tab_set %}true{% else %}false{% endunless %}"
        aria-controls="qv-panel-ship-{{ product.id }}"
        data-qv-tab
        data-target="qv-panel-ship-{{ product.id }}"
      >
        Shipping Policy
      </button>
      {%- unless first_tab_set -%}{%- assign first_tab_set = true -%}{%- endunless -%}
    {%- endif -%}

    {%- if has_refund -%}
      <button
        type="button"
        class="quick-view__tab{% unless first_tab_set %} is-active{% endunless %}"
        role="tab"
        id="qv-tab-refund-{{ product.id }}"
        aria-selected="{% unless first_tab_set %}true{% else %}false{% endunless %}"
        aria-controls="qv-panel-refund-{{ product.id }}"
        data-qv-tab
        data-target="qv-panel-refund-{{ product.id }}"
      >
        Returns &amp; Refunds
      </button>
    {%- endif -%}

  </div>{%- comment -%}/.quick-view__tabs{%- endcomment -%}

  {%- comment -%}── Tab panels ──{%- endcomment -%}

  {%- assign first_panel_set = false -%}

  {%- if has_description -%}
    {%- assign first_panel_set = true -%}
    <div
      class="quick-view__tab-panel is-active"
      role="tabpanel"
      id="qv-panel-desc-{{ product.id }}"
      aria-labelledby="qv-tab-desc-{{ product.id }}"
      data-qv-tab-panel
      tabindex="0"
    >
      <div class="quick-view__tab-panel-inner rte">
        {{- product.description -}}
      </div>
    </div>
  {%- endif -%}

  {%- if has_shipping -%}
    <div
      class="quick-view__tab-panel{% unless first_panel_set %} is-active{% endunless %}"
      role="tabpanel"
      id="qv-panel-ship-{{ product.id }}"
      aria-labelledby="qv-tab-ship-{{ product.id }}"
      data-qv-tab-panel
      aria-hidden="{% if first_panel_set %}true{% else %}false{% endif %}"
      tabindex="0"
    >
      <div class="quick-view__tab-panel-inner rte">
        {{- shop.policies.shipping_policy.body -}}
      </div>
    </div>
    {%- unless first_panel_set -%}{%- assign first_panel_set = true -%}{%- endunless -%}
  {%- endif -%}

  {%- if has_refund -%}
    <div
      class="quick-view__tab-panel{% unless first_panel_set %} is-active{% endunless %}"
      role="tabpanel"
      id="qv-panel-refund-{{ product.id }}"
      aria-labelledby="qv-tab-refund-{{ product.id }}"
      data-qv-tab-panel
      aria-hidden="{% if first_panel_set %}true{% else %}false{% endif %}"
      tabindex="0"
    >
      <div class="quick-view__tab-panel-inner rte">
        {{- shop.policies.refund_policy.body -}}
      </div>
    </div>
  {%- endif -%}

</div>{%- comment -%}/.quick-view__desc-wrap{%- endcomment -%}
{%- endif -%}
