{%- comment -%}
  Snippet: related-articles-feed
  Renders article cards sourced from collection.metafields.custom.related_articles.
  Automatically hidden when the metafield is empty.

  Accepts:
    - collection  {Object}  Required. The current collection object.
{%- endcomment -%}

{%- assign articles = collection.metafields.custom.related_articles.value -%}

{%- if articles != blank and articles.size > 0 -%}
  {%- render 'article-feed',
    articles_override: articles,
    heading: 'Related Reading',
    collection: collection
  -%}
{%- endif -%}