{%- liquid
  assign announcement_text = section.settings.announcement_text
  assign announcement_url  = section.settings.announcement_url
  assign announcement_icon = section.settings.announcement_icon
  assign utility_nav       = section.settings.utility_nav
  assign show_locale       = section.settings.show_locale_selector
  assign show_currency     = section.settings.show_currency_selector
-%}

<div
  class="header-utility-bar"
  style="
    background-color: {{ section.settings.color_utility_bg }};
    color: {{ section.settings.color_utility_text }};
  "
>
  <div class="header-utility-bar__inner page-width">

    {%- comment -%} Left — utility nav links {%- endcomment -%}
    {%- if utility_nav != blank -%}
      <nav class="header-utility-bar__nav" aria-label="Utility navigation">
        {%- for link in linklists[utility_nav].links -%}
          <a
            class="header-utility-bar__nav-link"
            href="{{ link.url }}"
            {% if link.active %}aria-current="page"{% endif %}
          >
            {{- link.title -}}
          </a>
        {%- endfor -%}
      </nav>
    {%- endif -%}

    {%- comment -%} Centre — announcement {%- endcomment -%}
    {%- if announcement_text != blank -%}
      <div class="header-utility-bar__announcement">
        {%- if announcement_url != blank -%}
          <a href="{{ announcement_url }}" class="header-utility-bar__announcement-link">
            {%- if announcement_icon != blank -%}
              <span class="header-utility-bar__announcement-icon" aria-hidden="true">{{ announcement_icon }}</span>
            {%- endif -%}
            {{- announcement_text -}}
          </a>
        {%- else -%}
          <p>
            {%- if announcement_icon != blank -%}
              <span class="header-utility-bar__announcement-icon" aria-hidden="true">{{ announcement_icon }}</span>
            {%- endif -%}
            {{- announcement_text -}}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Right — locale / currency selectors {%- endcomment -%}
    <div class="header-utility-bar__selectors">
      {%- if show_locale and localization.available_languages.size > 1 -%}
        <div class="header-utility-bar__locale">
          {%- form 'localization', id: 'HeaderLocaleForm', class: 'header-utility-bar__localization-form' -%}
            <button
              type="button"
              class="header-utility-bar__selector-toggle"
              aria-expanded="false"
              aria-controls="HeaderLocaleList"
            >
              {%- if localization.language.iso_code == 'en' -%}
                <span class="header-utility-bar__flag" aria-hidden="true">🇺🇸</span>
              {%- endif -%}
              {{ localization.language.endonym_name | capitalize }}
              {%- render 'icon-chevron-down' -%}
            </button>
            <ul
              id="HeaderLocaleList"
              class="header-utility-bar__selector-list"
              role="list"
              hidden
            >
              {%- for language in localization.available_languages -%}
                <li>
                  <a
                    href="#"
                    hreflang="{{ language.iso_code }}"
                    lang="{{ language.iso_code }}"
                    class="header-utility-bar__selector-option{% if language.iso_code == localization.language.iso_code %} is-active{% endif %}"
                    {% if language.iso_code == localization.language.iso_code %}aria-current="true"{% endif %}
                    data-value="{{ language.iso_code }}"
                  >
                    {{ language.endonym_name | capitalize }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
            <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
          {%- endform -%}
        </div>
      {%- endif -%}

      {%- if show_currency and localization.available_countries.size > 1 -%}
        <div class="header-utility-bar__currency">
          {%- form 'localization', id: 'HeaderCurrencyForm', class: 'header-utility-bar__localization-form' -%}
            <button
              type="button"
              class="header-utility-bar__selector-toggle"
              aria-expanded="false"
              aria-controls="HeaderCurrencyList"
            >
              {{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}
              {%- render 'icon-chevron-down' -%}
            </button>
            <ul
              id="HeaderCurrencyList"
              class="header-utility-bar__selector-list"
              role="list"
              hidden
            >
              {%- for country in localization.available_countries -%}
                <li>
                  <a
                    href="#"
                    class="header-utility-bar__selector-option{% if country.iso_code == localization.country.iso_code %} is-active{% endif %}"
                    {% if country.iso_code == localization.country.iso_code %}aria-current="true"{% endif %}
                    data-value="{{ country.iso_code }}"
                  >
                    {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                  </a>
                </li>
              {%- endfor -%}
            </ul>
            <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>