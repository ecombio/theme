{% comment %}
  Header — Right Icons
  File: snippets/header-icons.liquid

  Parameters (all optional — fail open, i.e. missing/undefined renders the icon):
    show_store   {boolean} — section.settings.show_icon_store
    show_account {boolean} — section.settings.show_icon_account
    show_cart    {boolean} — section.settings.show_icon_cart

  Snippets used:
    - snippets/header-icon-store.liquid
    - snippets/header-icon-account.liquid
    - snippets/header-icon-cart.liquid
{% endcomment %}

<ul class="main-header__icons" role="list" aria-label="Header actions">
  {%- if show_store != false -%}
    <li>{%- render 'header-store' -%}</li>
  {%- endif -%}

  {%- if show_account != false -%}
    <li>{%- render 'header-account' -%}</li>
  {%- endif -%}

  {%- if show_cart != false -%}
    <li>{%- render 'header-cart' -%}</li>
  {%- endif -%}
</ul>
