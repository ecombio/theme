{% comment %}
  snippets/collection-features.liquid
  Router for the collection's "features" area — promotional banner and
  carousel blocks, plus the sort/filter UI. Rendered directly from
  sections/collection.liquid (once, inside the sidebar <aside> for
  'sidebar' layout, or inside the toolbar <div> for 'full' layout —
  collection.liquid only ever calls one of the two per page load).

  Expects:
    collection {Object} — the Shopify collection object
    blocks     {Array}  — section.blocks, forwarded from collection.liquid
    context    {String} — 'sidebar' | 'toolbar', forwarded to
                           collection-filters.liquid so it can switch
                           between a vertical facet list and a horizontal
                           toolbar layout

  Renders, in this order:
    1. Any "banner" blocks   → collection-banner.liquid
    2. Any "carousel" blocks → collection-carousel.liquid
    3. The filter/sort UI    → collection-filters.liquid

  Banner/carousel blocks render in whatever order they're arranged in
  the theme editor's block list — there's no separate sort here. These
  blocks used to carry a `position` setting ("insert after product #N")
  for interleaving into the product grid from inside
  collection-products.liquid; now that they render up here instead,
  that setting has been removed from both block schemas in
  collection.liquid since it no longer does anything. Reorder blocks
  in the editor to control the order they render in.
{% endcomment %}

{%- liquid
  assign context = context | default: 'sidebar'
-%}

{%- comment -%} ── Banner / carousel blocks ──────────────────────────────── {%- endcomment -%}

{%- for block in blocks -%}
  {%- case block.type -%}
    {%- when 'banner' -%}
      {%- render 'collection-banner', block: block -%}
    {%- when 'carousel' -%}
      {%- render 'collection-carousel', block: block -%}
  {%- endcase -%}
{%- endfor -%}

{%- comment -%} ── Filters / sort ───────────────────────────────────────── {%- endcomment -%}

{%- render 'collection-filters', collection: collection, context: context -%}