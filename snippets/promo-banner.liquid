{%- comment -%}
  snippets/promo-banner.liquid

  Shared markup for the promo banner. Used by:
    • sections/promo-banner.liquid  (standalone — banner_mode = 'standalone')
    • sections/collection.liquid    (in-feed block — banner_mode = 'in-feed')

  Required variables — caller must set before render:
    banner_settings   — section.settings or block.settings
    banner_section_id — unique string for data attributes / theme editor targeting
    banner_mode       — 'standalone' | 'in-feed'
                        standalone: renders the full .promo-banner page-width wrapper
                                    and uses its own width/position CSS classes.
                        in-feed:    no outer wrapper, no width classes — the grid
                                    column already sizes the card. Width option only
                                    controls how many columns the card spans via
                                    col-span modifier classes on the <li> in the caller.

  IN-FEED SPAN WIDTHS (applied by collection.liquid on the <li>, not here)
    1-col  → default, one product card slot
    2-col  → spans 2 columns, landscape banner
    3-col  → spans 3 columns
    full   → spans all columns, full-width break
{%- endcomment -%}

{%- liquid
  assign _mode       = banner_mode | default: 'standalone'
  assign _width      = banner_settings.banner_width
  assign _pos        = banner_settings.banner_position
  assign _align      = banner_settings.text_align
  assign _valign     = banner_settings.text_valign
  assign _has_image  = banner_settings.bg_image
  assign _ov_color   = banner_settings.overlay_color
  assign _ov_opacity = banner_settings.overlay_opacity | divided_by: 100.0

  comment ── Aspect ratio ──────────────────────────────────────────────────
    standalone: derived from width setting (same as before)
    in-feed:    1-card → 1/1 (square, matches most product card ratios)
                2-card → 16/9 (landscape)
                3-card → 16/7 (wide landscape)
                full   → 28/9 (cinematic strip)
                custom_ratio always wins
  endcomment
  assign _custom = banner_settings.custom_ratio | strip
  if _custom != blank
    assign _ratio_parts = _custom | split: ':'
    assign _rw = _ratio_parts[0] | times: 1.0
    assign _rh = _ratio_parts[1] | times: 1.0
    assign _aspect = _rw | append: '/' | append: _rh
  elsif _mode == 'in-feed'
    if _width == '2'
      assign _aspect = '16/9'
    elsif _width == '3'
      assign _aspect = '16/7'
    elsif _width == 'full'
      assign _aspect = '28/9'
    else
      assign _aspect = '1/1'
    endif
  elsif _width == '25'
    assign _aspect = '3/4'
  elsif _width == '50'
    assign _aspect = '16/7'
  elsif _width == '75'
    assign _aspect = '16/5'
  else
    assign _aspect = '28/9'
  endif

  assign _img_alt = banner_settings.headline | default: banner_settings.eyebrow | escape
-%}

{%- assign _palette = '1,e0f2fe,0369a1|2,fef9c3,854d0e|3,dcfce7,166534|4,fce7f3,9d174d|5,ede9fe,5b21b6|6,ffedd5,9a3412|7,e0e7ff,3730a3|8,f0fdf4,15803d' | split: '|' -%}
{%- assign _pi  = banner_section_id.size | modulo: 8 -%}
{%- assign _pal = _palette[_pi] | split: ',' -%}
{%- assign _overlay_rgb = _ov_color | color_to_rgb | remove: 'rgb(' | remove: ')' -%}

{%- if _mode == 'standalone' -%}
<div
  class="promo-banner page-width"
  data-section-id="{{ banner_section_id }}"
  data-section-type="promo-banner"
  style="--promo-pt: {{ banner_settings.padding_top }}px; --promo-pb: {{ banner_settings.padding_bottom }}px;"
>
  <div
    class="promo-banner__frame promo-banner__frame--w{{ _width }} promo-banner__frame--pos-{{ _pos }}"
    style="--promo-aspect: {{ _aspect }};"
  >
{%- else -%}
{%- comment -%} in-feed: no outer wrapper, frame fills 100% of the grid cell {%- endcomment -%}
  <div
    class="promo-banner__frame promo-banner__frame--in-feed"
    data-section-id="{{ banner_section_id }}"
    style="--promo-aspect: {{ _aspect }};"
  >
{%- endif -%}

    {%- comment -%}── Background ─────────────────────────────────────────────{%- endcomment -%}
    <div class="promo-banner__bg">
      {%- if _has_image -%}
        {%- assign _focal = banner_settings.bg_image.presentation.focal_point | default: '50% 50%' -%}
        {{
          banner_settings.bg_image
          | image_url: width: 1200
          | image_tag:
            class: 'promo-banner__img',
            loading: 'lazy',
            widths: '300,400,600,800,1200',
            sizes: '(max-width:767px) 50vw, 25vw',
            alt: _img_alt,
            style: 'object-position: ' | append: _focal
        }}
      {%- else -%}
        <div
          class="promo-banner__img-placeholder"
          aria-hidden="true"
          style="background: linear-gradient(135deg, #{{ _pal[1] }} 0%, #{{ _pal[2] }}55 100%);"
        ></div>
      {%- endif -%}

      <div
        class="promo-banner__overlay"
        aria-hidden="true"
        style="background: rgba({{ _overlay_rgb }}, {{ _ov_opacity }});"
      ></div>
    </div>

    {%- comment -%}── Content ────────────────────────────────────────────────{%- endcomment -%}
    <div class="promo-banner__content promo-banner__content--{{ _align }} promo-banner__content--{{ _valign }}">

      {%- if banner_settings.eyebrow != blank -%}
        <p class="promo-banner__eyebrow">{{ banner_settings.eyebrow }}</p>
      {%- endif -%}

      {%- if banner_settings.headline != blank -%}
        <{{ banner_settings.heading_tag }} class="promo-banner__headline">
          {{ banner_settings.headline }}
        </{{ banner_settings.heading_tag }}>
      {%- endif -%}

      {%- if banner_settings.subtext != blank -%}
        <p class="promo-banner__subtext">{{ banner_settings.subtext }}</p>
      {%- endif -%}

      {%- if banner_settings.cta_label != blank and banner_settings.cta_url != blank -%}
        <div class="promo-banner__ctas">
          <a
            class="promo-banner__cta promo-banner__cta--primary"
            href="{{ banner_settings.cta_url }}"
            {% if banner_settings.cta_new_tab %}target="_blank" rel="noopener"{% endif %}
          >{{ banner_settings.cta_label }}</a>
          {%- if banner_settings.cta2_label != blank and banner_settings.cta2_url != blank -%}
            <a
              class="promo-banner__cta promo-banner__cta--secondary"
              href="{{ banner_settings.cta2_url }}"
              {% if banner_settings.cta_new_tab %}target="_blank" rel="noopener"{% endif %}
            >{{ banner_settings.cta2_label }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div><!-- /.promo-banner__content -->

  </div><!-- /.promo-banner__frame -->

{%- if _mode == 'standalone' -%}
</div><!-- /.promo-banner -->
{%- endif -%}