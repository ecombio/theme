{%- comment -%}
  Snippet: promo-banner
  Renders one in-feed promotional banner as a grid item that lives
  inside the same CSS grid as the product cards.

  Expects:
    block.settings.image
    block.settings.mobile_image (optional)
    block.settings.heading
    block.settings.subheading
    block.settings.link
    block.settings.button_label
    block.settings.column_span  (1-4)
    block.settings.row_span     (1-3)
    block.settings.text_color
    block.settings.overlay_opacity
{%- endcomment -%}

{%- liquid
  assign col_span = block.settings.column_span | default: 2
  assign row_span = block.settings.row_span | default: 1
  assign has_link = false
  if block.settings.link != blank
    assign has_link = true
  endif
-%}

<{% if has_link %}a href="{{ block.settings.link }}"{% else %}div{% endif %}
  class="promo-banner"
  style="--banner-col-span: {{ col_span }}; --banner-row-span: {{ row_span }}; --banner-text-color: {{ block.settings.text_color | default: '#ffffff' }};"
  {{ block.shopify_attributes }}
>
  <span class="promo-banner__media">
    {%- if block.settings.image -%}
      <img
        src="{{ block.settings.image | image_url: width: 1200 }}"
        srcset="
          {{ block.settings.image | image_url: width: 400 }} 400w,
          {{ block.settings.image | image_url: width: 800 }} 800w,
          {{ block.settings.image | image_url: width: 1200 }} 1200w,
          {{ block.settings.image | image_url: width: 1600 }} 1600w
        "
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="{{ block.settings.heading | default: 'Promotional banner' | escape }}"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        loading="lazy"
        class="promo-banner__image promo-banner__image--desktop"
      >
    {%- else -%}
      <span class="promo-banner__fallback" aria-hidden="true"></span>
    {%- endif -%}
    {%- if block.settings.mobile_image -%}
      <img
        src="{{ block.settings.mobile_image | image_url: width: 800 }}"
        srcset="
          {{ block.settings.mobile_image | image_url: width: 400 }} 400w,
          {{ block.settings.mobile_image | image_url: width: 800 }} 800w
        "
        sizes="100vw"
        alt="{{ block.settings.heading | default: 'Promotional banner' | escape }}"
        loading="lazy"
        class="promo-banner__image promo-banner__image--mobile"
      >
    {%- endif -%}
    <span class="promo-banner__overlay" style="opacity: {{ block.settings.overlay_opacity | default: 20 | divided_by: 100.0 }};"></span>
  </span>

  {%- if block.settings.heading != blank or block.settings.subheading != blank or block.settings.button_label != blank -%}
    <span class="promo-banner__content">
      {%- if block.settings.heading != blank -%}
        <span class="promo-banner__heading">{{ block.settings.heading }}</span>
      {%- endif -%}
      {%- if block.settings.subheading != blank -%}
        <span class="promo-banner__subheading">{{ block.settings.subheading }}</span>
      {%- endif -%}
      {%- if block.settings.button_label != blank -%}
        <span class="promo-banner__button">{{ block.settings.button_label }}</span>
      {%- endif -%}
    </span>
  {%- endif -%}
</{% if has_link %}a{% else %}div{% endif %}>