{% comment %}
  Snippet: product-card-swatches
  Renders color swatches for a product card.

  Accepts:
  - product {Object}             - Shopify product object (required)
  - color_option_index {Number}  - Zero-based index of the Color option in product.options

  Each unique color value gets one swatch. Swatch background color is resolved via
  a metafield (product_variant.metafields.color.hex) when present, otherwise it
  falls back to a CSS custom property mapped from the color name.

  Usage:
  {%- render 'product-card-swatches', product: product, color_option_index: 0 -%}
{% endcomment %}

{%- liquid
  assign rendered_colors = ''
  assign swatch_count    = 0
-%}

<div class="product-card-swatches" role="list" aria-label="{{ 'products.product.color_swatches' | t | default: 'Color options' }}">
  {%- for variant in product.variants -%}
    {%- liquid
      assign color_value = variant.options[color_option_index]
      assign color_slug  = color_value | handleize

      unless rendered_colors contains color_slug
        assign rendered_colors = rendered_colors | append: color_slug | append: '|'
        assign swatch_count    = swatch_count | plus: 1
      endunless
    -%}

    {%- unless rendered_colors contains color_slug -%}
      {%- comment -%} already processed above; skip duplicates {%- endcomment -%}
    {%- else -%}
      {%- comment -%}
        Only render the first time we encounter this color.
        The liquid `unless` trick above marks it as seen before assigning,
        so we check swatch_count increase instead via a flag.
      {%- endcomment -%}
    {%- endunless -%}
  {%- endfor -%}

  {%- comment -%}
    Re-iterate cleanly using a seen-set pattern compatible with Liquid 2.
  {%- endcomment -%}
  {%- assign seen = '' -%}
  {%- for variant in product.variants -%}
    {%- liquid
      assign color_value = variant.options[color_option_index]
      assign color_slug  = color_value | handleize
      assign sentinel    = '|' | append: color_slug | append: '|'
    -%}

    {%- unless seen contains sentinel -%}
      {%- assign seen = seen | append: sentinel -%}

      {%- liquid
        assign hex_color = variant.metafields.color.hex | default: ''
        if hex_color == ''
          case color_slug
            when 'light-beige', 'beige'
              assign hex_color = '#d7c8b9'
            when 'yellow'
              assign hex_color = '#f2c862'
            when 'black'
              assign hex_color = '#000000'
            when 'white'
              assign hex_color = '#ffffff'
            when 'olive', 'olive-green'
              assign hex_color = '#334a2c'
            when 'navy-blue', 'navy'
              assign hex_color = '#323854'
            when 'red'
              assign hex_color = '#9f3e37'
            when 'brown'
              assign hex_color = '#9f8568'
            when 'orange'
              assign hex_color = '#955a3d'
            when 'soft-green', 'green'
              assign hex_color = '#cedbba'
            else
              assign hex_color = '#cccccc'
          endcase
        endif
      -%}

      <a
        class="product-card-swatches__swatch{% if variant.id == product.selected_or_first_available_variant.id %} is-active{% endif %}"
        href="{{ product.url }}?variant={{ variant.id }}"
        role="listitem"
        aria-label="{{ color_value | escape }}"
        title="{{ color_value | escape }}"
        style="--swatch-color: {{ hex_color }};"
      >
        <span class="product-card-swatches__tooltip">{{ color_value | escape }}</span>
      </a>
    {%- endunless -%}
  {%- endfor -%}
</div>
