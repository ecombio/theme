{%- comment -%}
  snippets/quick-view-detail.liquid
  Right column (desktop) / bottom section (mobile) of the Quick View modal.
{%- endcomment -%}

<div class="quick-view__detail">

  {%- if product.vendor != blank -%}
    <p class="quick-view__vendor">{{ product.vendor }}</p>
  {%- endif -%}

  <h2 class="quick-view__title">
    <a href="{{ product.url }}" class="quick-view__title-link">
      {{- product.title -}}
    </a>
  </h2>

  <div class="quick-view__reviews">
    <div
      class="jdgm-widget jdgm-preview-badge"
      data-id="{{ product.id }}"
      data-auto-install="false"
    ></div>
  </div>

  <div class="quick-view__price" data-quick-view-price>
    {%- if on_sale -%}
      <span class="quick-view__price-current quick-view__price-current--sale">
        {{- first_variant.price | money -}}
      </span>
      <s class="quick-view__price-compare">
        {{- first_variant.compare_at_price | money -}}
      </s>
      <span class="quick-view__price-save-badge">Save {{ save_pct }}%</span>
    {%- else -%}
      <span class="quick-view__price-current">
        {{- first_variant.price | money -}}
      </span>
    {%- endif -%}
  </div>

  {%- unless has_single_var -%}
    <div class="quick-view__options">
      {%- for option in options -%}
        {%- liquid
          assign opt_index      = forloop.index0
          assign opt_name_lower = option.name | downcase
          assign is_color       = false
          if opt_name_lower == 'color' or opt_name_lower == 'colour'
            assign is_color = true
          endif
          assign first_value = option.values | first
        -%}
        <div class="quick-view__option" data-option-name="{{ option.name | escape }}">
          <div class="quick-view__option-label">
            <span class="quick-view__option-name">{{ option.name }}:</span>
            <span class="quick-view__option-selected" data-quick-view-option-selected>
              {{- first_value -}}
            </span>
          </div>
          <div
            class="quick-view__option-values{% if is_color %} quick-view__option-values--swatches{% endif %}"
            role="radiogroup"
            aria-label="{{ option.name }}"
          >
            {%- for value in option.values -%}
              {%- liquid
                assign is_first     = forloop.first
                assign value_handle = value | handleize
              -%}
              {%- if is_color -%}
                <button
                  type="button"
                  class="quick-view__swatch{% if is_first %} is-active{% endif %}"
                  data-quick-view-swatch
                  data-option-index="{{ opt_index }}"
                  data-value="{{ value | escape }}"
                  data-color-value="{{ value_handle }}"
                  aria-label="{{ value | escape }}"
                  aria-checked="{{ is_first }}"
                  style="--swatch-color: {{ value_handle }};"
                >
                  <span class="quick-view__swatch-inner" aria-hidden="true"></span>
                </button>
              {%- else -%}
                <button
                  type="button"
                  class="quick-view__option-btn{% if is_first %} is-active{% endif %}"
                  data-quick-view-option-btn
                  data-option-index="{{ opt_index }}"
                  data-value="{{ value | escape }}"
                  aria-label="{{ option.name }}: {{ value | escape }}"
                  aria-checked="{{ is_first }}"
                >
                  {{- value -}}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endunless -%}

  <select
    class="quick-view__variant-select"
    data-quick-view-variant-select
    aria-label="Selected variant"
    aria-hidden="true"
    tabindex="-1"
  >
    {%- for variant in variants -%}
      <option
        value="{{ variant.id }}"
        {% if variant.id == first_variant.id %}selected{% endif %}
        {% unless variant.available %}disabled{% endunless %}
      >
        {{ variant.title }}
      </option>
    {%- endfor -%}
  </select>

  <script
    type="application/json"
    id="quick-view-variant-data-{{ product.id }}"
    data-quick-view-variant-data
  >
    [
      {%- for variant in variants -%}
        {
          "id":               {{ variant.id }},
          "title":            {{ variant.title | json }},
          "available":        {{ variant.available }},
          "price":            {{ variant.price }},
          "compare_at_price": {{ variant.compare_at_price | default: 'null' }},
          "options":          {{ variant.options | json }},
          "featured_image":   {%- if variant.featured_image -%}
            {
              "src": {{ variant.featured_image | image_url: width: 800 | json }},
              "alt": {{ variant.featured_image.alt | default: variant.title | json }}
            }
          {%- else -%}null{%- endif -%}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>

  {%- if eta_text != blank -%}
    <div class="quick-view__eta" aria-label="Estimated delivery">
      <svg class="quick-view__eta-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <rect x="1" y="4" width="9" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
        <path d="M10 6.5h1.5l1.5 2V11h-3V6.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
        <circle cx="3.5" cy="11.5" r="1" fill="currentColor"/>
        <circle cx="10.5" cy="11.5" r="1" fill="currentColor"/>
      </svg>
      <span>{{ eta_text }}</span>
    </div>
  {%- endif -%}

  <div class="quick-view__atc-wrap">
    <button
      type="button"
      class="quick-view__atc{% unless first_variant.available %} quick-view__atc--soldout{% endunless %}"
      data-atc-btn
      data-variant-id="{{ first_variant.id }}"
      data-product-title="{{ product.title | escape }}"
      {% unless first_variant.available %}disabled{% endunless %}
      aria-label="Add {{ product.title | escape }} to cart"
    >
      <span data-atc-label>
        {%- if first_variant.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
      </span>
    </button>
  </div>

  <a
    href="{{ product.url }}"
    class="quick-view__pdp-link"
    aria-label="View full details for {{ product.title | escape }}"
  >
    View full details
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M2 6h8M6 2l4 4-4 4"/>
    </svg>
  </a>

</div>{%- comment -%} /.quick-view__detail {%- endcomment -%}
