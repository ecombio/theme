{% comment %}
  Snippet: collection-showcase
  Called by: sections/main-collection.liquid
  Calls:     snippets/collection-products.liquid
             snippets/collection-articles.liquid
             snippets/collection-pages.liquid

  Parameters:
    - active_tab    {String}  — 'products' | 'articles' | 'pages'
    - per_page      {Number}
    - show_banners  {Boolean}
    - context       {String}  — 'collection' | 'search'
    - section       {Object}

  Note: The .collection-showcase wrapper is ALWAYS rendered so that
  content-switcher.js has a stable swap target. Empty state = empty div.
{% endcomment %}

<div class="collection-showcase">

  {%- if active_tab == 'articles' and article_count > 0 -%}
    {% render 'collection-articles',
      context: context,
      section: section
    %}

  {%- elsif active_tab == 'pages' and page_count > 0 -%}
    {% render 'collection-pages',
      context: context,
      section: section
    %}

  {%- elsif collection.products_count > 0 -%}
    {% render 'collection-products',
      context:      context,
      section:      section,
      per_page:     per_page,
      show_banners: show_banners
    %}
  {%- endif -%}

</div>