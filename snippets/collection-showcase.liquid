{% comment %}
  Snippet: collection-showcase
  Called by: sections/main-collection.liquid

  Renders all three panels on page load.
  Tab switching is handled by collection-showcase.js (CSS show/hide, no fetch).

  Parameters:
    - active_tab    {String}  — 'products' | 'articles' | 'pages'
    - per_page      {Number}
    - show_banners  {Boolean}
    - context       {String}  — 'collection' | 'search'
    - section       {Object}
    - meta_articles {Array}   — collection.metafields.custom.articles.value
    - meta_pages    {Array}   — collection.metafields.custom.pages.value
{% endcomment %}

<div class="collection-showcase" id="collection-showcase">

  {{- 'collection-showcase.css' | asset_url | stylesheet_tag -}}

  {%- comment -%} ══ PRODUCTS PANEL ══ {%- endcomment -%}
  <div
    class="collection-showcase__panel{% if active_tab == 'products' %} is-active{% endif %}"
    data-tab="products"
    id="panel-products"
    role="tabpanel"
    aria-labelledby="tab-products"
  >
    {%- if collection.products_count > 0 -%}
      {% render 'collection-products',
        context:      context,
        section:      section,
        per_page:     per_page,
        show_banners: show_banners
      %}
    {%- else -%}
      <p class="collection-showcase__empty">No products found.</p>
    {%- endif -%}
  </div>

  {%- comment -%} ══ ARTICLES PANEL ══ {%- endcomment -%}
  <div
    class="collection-showcase__panel{% if active_tab == 'articles' %} is-active{% endif %}"
    data-tab="articles"
    id="panel-articles"
    role="tabpanel"
    aria-labelledby="tab-articles"
  >
    {% render 'collection-articles',
      context:       context,
      section:       section,
      meta_articles: meta_articles
    %}
  </div>

  {%- comment -%} ══ PAGES PANEL ══ {%- endcomment -%}
  <div
    class="collection-showcase__panel{% if active_tab == 'pages' %} is-active{% endif %}"
    data-tab="pages"
    id="panel-pages"
    role="tabpanel"
    aria-labelledby="tab-pages"
  >
    {% render 'collection-pages',
      context:    context,
      section:    section,
      meta_pages: meta_pages
    %}
  </div>

</div>