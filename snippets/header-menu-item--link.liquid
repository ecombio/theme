{% comment %}
  snippets/header-menu-item--link.liquid
  ─────────────────────────────────────────────────────────────────────────────
  Block type: link
  A single anchor. No children, no dropdown.

  BLOCK SETTINGS:
    label            {string}  — link text
    url              {url}     — destination
    highlight        {bool}    — accent colour styling
    fancy_highlight  {bool}    — red text + animated sparkle stars
                                 (requires highlight to also be enabled)

  STAR PLACEMENT:
    Stars are rendered as siblings of the <a>, not children, so they
    position relative to .header__menu-item--link-fancy (the wrapper div)
    rather than the <a> itself. This avoids the overflow-x:auto clip on
    .header__menu-scroll swallowing absolutely-positioned children.
  ─────────────────────────────────────────────────────────────────────────────
{% endcomment %}

{%- assign is_fancy = false -%}
{%- if block.settings.highlight and block.settings.fancy_highlight -%}
  {%- assign is_fancy = true -%}
{%- endif -%}

{%- if is_fancy -%}

  <div class="header__menu-item header__menu-item--link-fancy" {{ block.shopify_attributes }}>
    <a
      href="{{ block.settings.url }}"
      class="header__menu-link header__menu-link--highlight header__menu-link--fancy"
    >
      <span class="header__menu-fancy-label">
        {{- block.settings.label | escape -}}
      </span>
    </a>

    {%- comment -%}
      Stars sit outside the <a> as siblings so they escape the <a>'s
      inline-flex context and position correctly against the wrapper div.
    {%- endcomment -%}
    {%- render 'icon', name: 'menu-star', size: 10, class: 'header__menu-star--1' -%}
    {%- render 'icon', name: 'menu-star', size: 6,  class: 'header__menu-star--2' -%}
    {%- render 'icon', name: 'menu-star', size: 7,  class: 'header__menu-star--3' -%}
  </div>

{%- else -%}

  {%- assign link_classes = 'header__menu-link' -%}
  {%- if block.settings.highlight -%}
    {%- assign link_classes = 'header__menu-link header__menu-link--highlight' -%}
  {%- endif -%}

  <a
    href="{{ block.settings.url }}"
    class="{{ link_classes }}"
    {{ block.shopify_attributes }}
  >
    {{- block.settings.label | escape -}}
  </a>

{%- endif -%}