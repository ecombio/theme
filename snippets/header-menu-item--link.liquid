{% comment %}
  snippets/header-menu-item--link.liquid
  ─────────────────────────────────────────────────────────────────────────────
  Block type: link
  A single anchor. No children, no dropdown.

  BLOCK SETTINGS:
    label      {string}   — link text
    url        {url}      — destination
    highlight  {bool}     — applies deals/highlight styling when true

  VARIABLES:
    block  {block object}
  ─────────────────────────────────────────────────────────────────────────────
{% endcomment %}

{%- assign classes = 'header__menu-link' -%}
{%- if block.settings.highlight -%}
  {%- assign classes = 'header__menu-link header__menu-link--highlight' -%}
{%- endif -%}

<a
  href="{{ block.settings.url }}"
  class="{{ classes }}"
  {{ block.shopify_attributes }}
>
  {{- block.settings.label | escape -}}
</a>
