{%- comment -%}
  Renders a single Top Bar block.
  Expected variable: block
{%- endcomment -%}

{%- case block.type -%}

  {%- when 'linklist' -%}
    {%- if linklists[block.settings.menu].links.size > 0 -%}
      <ul class="top-bar__links" role="list" {{ block.shopify_attributes }}>
        {%- for link in linklists[block.settings.menu].links -%}
          <li>
            <a
              href="{{ link.url }}"
              class="top-bar__link{% if link.active %} top-bar__link--active{% endif %}"
              {% if link.active %}aria-current="page"{% endif %}
            >{{ link.title }}</a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  {%- when 'text' -%}
    {%- if block.settings.text != blank -%}
      <p class="top-bar__text" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
    {%- endif -%}

  {%- when 'social' -%}
    {%- assign has_social = false -%}
    {%- if block.settings.show_facebook  and shop.social_networks.facebook  != blank -%}{%- assign has_social = true -%}{%- endif -%}
    {%- if block.settings.show_instagram and shop.social_networks.instagram != blank -%}{%- assign has_social = true -%}{%- endif -%}
    {%- if block.settings.show_twitter   and shop.social_networks.twitter   != blank -%}{%- assign has_social = true -%}{%- endif -%}
    {%- if block.settings.show_tiktok    and shop.social_networks.tiktok    != blank -%}{%- assign has_social = true -%}{%- endif -%}
    {%- if block.settings.show_youtube   and shop.social_networks.youtube   != blank -%}{%- assign has_social = true -%}{%- endif -%}
    {%- if block.settings.show_pinterest and shop.social_networks.pinterest != blank -%}{%- assign has_social = true -%}{%- endif -%}

    {%- if has_social -%}
      <ul class="top-bar__social" role="list" {{ block.shopify_attributes }}>

        {%- if block.settings.show_facebook and shop.social_networks.facebook != blank -%}
          <li>
            <a href="{{ shop.social_networks.facebook }}" class="top-bar__social-link" target="_blank" rel="noopener" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="15" height="15" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
              </svg>
            </a>
          </li>
        {%- endif -%}

        {%- if block.settings.show_instagram and shop.social_networks.instagram != blank -%}
          <li>
            <a href="{{ shop.social_networks.instagram }}" class="top-bar__social-link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" width="15" height="15" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
              </svg>
            </a>
          </li>
        {%- endif -%}

        {%- if block.settings.show_twitter and shop.social_networks.twitter != blank -%}
          <li>
            <a href="{{ shop.social_networks.twitter }}" class="top-bar__social-link" target="_blank" rel="noopener" aria-label="Twitter / X">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="15" height="15" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          </li>
        {%- endif -%}

        {%- if block.settings.show_tiktok and shop.social_networks.tiktok != blank -%}
          <li>
            <a href="{{ shop.social_networks.tiktok }}" class="top-bar__social-link" target="_blank" rel="noopener" aria-label="TikTok">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="15" height="15" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.27 8.27 0 004.84 1.55V6.79a4.85 4.85 0 01-1.07-.1z"/>
              </svg>
            </a>
          </li>
        {%- endif -%}

        {%- if block.settings.show_youtube and shop.social_networks.youtube != blank -%}
          <li>
            <a href="{{ shop.social_networks.youtube }}" class="top-bar__social-link" target="_blank" rel="noopener" aria-label="YouTube">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="15" height="15" aria-hidden="true">
                <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.95 1.95C5.12 20 12 20 12 20s6.88 0 8.59-.47a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>
              </svg>
            </a>
          </li>
        {%- endif -%}

        {%- if block.settings.show_pinterest and shop.social_networks.pinterest != blank -%}
          <li>
            <a href="{{ shop.social_networks.pinterest }}" class="top-bar__social-link" target="_blank" rel="noopener" aria-label="Pinterest">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="15" height="15" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.853 0 1.267.64 1.267 1.408 0 .858-.546 2.14-.828 3.33-.236.995.499 1.806 1.476 1.806 1.772 0 3.137-1.868 3.137-4.564 0-2.387-1.715-4.055-4.162-4.055-2.833 0-4.496 2.124-4.496 4.32 0 .855.33 1.772.741 2.272a.3.3 0 01.069.286c-.076.313-.244.995-.276 1.134-.044.181-.146.219-.337.132-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.966-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
              </svg>
            </a>
          </li>
        {%- endif -%}

      </ul>
    {%- endif -%}

  {%- when 'locale_selectors' -%}
    <div class="top-bar__locale" {{ block.shopify_attributes }}>

      {%- if block.settings.show_language and localization.available_languages.size > 1 -%}
        <div class="top-bar__locale-select">
          {%- form 'localization', id: 'top-bar-lang-form' -%}
            <select name="locale_code" aria-label="{{ 'general.language.selector_label' | t }}"
              onchange="document.getElementById('top-bar-lang-form').submit()">
              {%- for language in localization.available_languages -%}
                <option value="{{ language.iso_code }}"
                  {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                  {{ language.endonym_name | capitalize }}
                </option>
              {%- endfor -%}
            </select>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
              width="12" height="12" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          {%- endform -%}
        </div>
      {%- endif -%}

      {%- if block.settings.show_country and localization.available_countries.size > 1 -%}
        <div class="top-bar__locale-select">
          {%- form 'localization', id: 'top-bar-country-form' -%}
            <select name="country_code" aria-label="{{ 'general.country_selector.label' | t }}"
              onchange="document.getElementById('top-bar-country-form').submit()">
              {%- for country in localization.available_countries -%}
                <option value="{{ country.iso_code }}"
                  {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                  {{ country.name }} ({{ country.currency.iso_code }}
                  {{ country.currency.symbol }})
                </option>
              {%- endfor -%}
            </select>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
              width="12" height="12" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          {%- endform -%}
        </div>
      {%- endif -%}

    </div>

{%- endcase -%}
