  <h1>Hello, World!</h1>
  <p>This is a static test page for the ECOMBIO flyout menu. No Shopify, no Liquid — just HTML, CSS, and a little JS. Once everything looks and behaves correctly here, we'll wire it into the theme.</p>
  <p>Try hovering each sidebar category to see the right-hand columns swap. Notice each category has a different column count and different content.</p>
</div>

<script>
  const header  = document.getElementById('header');
  const overlay = document.getElementById('overlay');
  const flyoutItem = document.getElementById('flyout-item');
  const flyoutBtn  = flyoutItem.querySelector('.menu-btn');
  const flyoutPanel = flyoutItem.querySelector('.flyout-panel');

  function setTop() {
    flyoutPanel.style.top = header.getBoundingClientRect().bottom + 'px';
  }

  function open() {
    setTop();
    flyoutItem.classList.add('open');
    flyoutBtn.setAttribute('aria-expanded', 'true');
    overlay.classList.add('show');
  }

  function close() {
    flyoutItem.classList.remove('open');
    flyoutBtn.setAttribute('aria-expanded', 'false');
    overlay.classList.remove('show');
  }

  flyoutBtn.addEventListener('click', e => {
    e.preventDefault();
    flyoutItem.classList.contains('open') ? close() : open();
  });

  overlay.addEventListener('click', close);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });

  // Sidebar hover switching
  const DELAY = 80;
  let timer;
  document.querySelectorAll('.flyout-menu__cat').forEach(cat => {
    cat.addEventListener('mouseenter', () => {
      clearTimeout(timer);
      timer = setTimeout(() => {
        document.querySelectorAll('.flyout-menu__cat').forEach(c => c.classList.remove('active'));
        document.querySelectorAll('.flyout-menu__section').forEach(s => s.classList.remove('visible'));
        cat.classList.add('active');
        const target = document.getElementById(cat.dataset.target);
        if (target) target.classList.add('visible');
      }, DELAY);
    });
    cat.addEventListener('mouseleave', () => clearTimeout(timer));
    cat.addEventListener('click', e => e.preventDefault());
  });
</script>
</body>
</html>
