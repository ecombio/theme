<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ECOMBIO — Flyout Menu Test</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f3f4f6; }

    /* ── HEADER ── */
    .header { background: #fff; border-bottom: 1px solid #e5e7eb; position: sticky; top: 0; z-index: 100; }
    .top-bar { display: flex; align-items: center; gap: 16px; padding: 14px 24px; }
    .logo { font-weight: 900; font-size: 20px; letter-spacing: -1px; color: #111; font-family: 'Arial Black', sans-serif; }
    .logo span { color: #c4301c; }
    .search-wrap { flex: 1; max-width: 480px; display: flex; align-items: center; background: #f3f4f6; border-radius: 999px; padding: 8px 16px; gap: 8px; }
    .search-wrap input { border: none; background: transparent; outline: none; font-size: 13px; width: 100%; }
    .search-wrap svg { width: 16px; height: 16px; color: #9ca3af; flex-shrink: 0; }
    .header-icons { margin-left: auto; display: flex; gap: 20px; color: #374151; font-size: 13px; font-weight: 500; }

    /* ── MENU BAR ── */
    .menu-bar { background: #fff; border-top: 1px solid #e5e7eb; }
    .menu-list { display: flex; list-style: none; padding: 0 12px; align-items: stretch; }
    .menu-item { position: relative; }
    .menu-btn {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 13px 14px; font-size: 13px; font-weight: 600;
      color: #1a1a1a; background: none; border: none; cursor: pointer;
      white-space: nowrap; transition: color 0.15s;
    }
    .menu-btn:hover, .menu-item.open > .menu-btn { color: #c4301c; }
    .menu-btn svg { width: 13px; height: 13px; transition: transform 0.2s; }
    .menu-item.open > .menu-btn svg.caret { transform: rotate(180deg); }
    .menu-btn--hl { color: #c4301c !important; font-weight: 700; }

    /* ── FLYOUT PANEL ── */
    .flyout-panel {
      display: none;
      position: fixed;
      left: 0; right: 0;
      top: 0; /* set by JS */
      background: #fff;
      border-top: 1px solid #e5e7eb;
      border-bottom: 1px solid #e5e7eb;
      box-shadow: 0 16px 40px rgba(0,0,0,0.08);
      z-index: 200;
    }
    .menu-item.open > .flyout-panel { display: flex; }

    /* ── FLYOUT SIDEBAR ── */
    .flyout-menu__sidebar {
      list-style: none;
      width: 220px;
      flex-shrink: 0;
      background: #f9fafb;
      border-right: 1px solid #e5e7eb;
      padding: 10px 0;
      overflow-y: auto;
      max-height: 560px;
    }
    .flyout-menu__cat {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 18px; font-size: 13.5px; font-weight: 600;
      color: #374151; text-decoration: none; cursor: pointer;
      border-left: 2px solid transparent;
      transition: background 0.1s, color 0.1s;
      white-space: nowrap;
    }
    .flyout-menu__cat:hover { background: #fff; color: #c4301c; }
    .flyout-menu__cat.active { background: #fff; color: #c4301c; border-left-color: #c4301c; }
    .flyout-menu__cat svg { width: 13px; height: 13px; color: #9ca3af; flex-shrink: 0; }
    .flyout-menu__cat.active svg, .flyout-menu__cat:hover svg { color: #c4301c; }

    /* ── FLYOUT CONTENT ── */
    .flyout-menu__content { flex: 1; overflow-y: auto; max-height: 560px; }
    .flyout-menu__section { display: none; padding: 24px 32px; }
    .flyout-menu__section.visible { display: block; }

    /* ── COLUMNS ── */
    .flyout-menu__columns {
      display: grid;
      grid-template-columns: repeat(var(--cols, 4), minmax(130px, max-content));
      gap: 0 48px;
      align-items: start;
    }
    .flyout-menu__column { display: flex; flex-direction: column; }
    .flyout-menu__col-heading {
      display: block; font-size: 11px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.8px; color: #111827;
      text-decoration: none; margin-bottom: 12px; padding-bottom: 10px;
      border-bottom: 2px solid #e5e7eb; white-space: nowrap;
      transition: color 0.15s, border-color 0.15s;
    }
    .flyout-menu__col-heading:hover { color: #c4301c; border-color: #c4301c; }
    .flyout-menu__subheading {
      font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.6px; color: #9ca3af; margin: 14px 0 6px; white-space: nowrap;
    }
    .flyout-menu__link-list { list-style: none; padding: 0; margin: 0 0 10px; }
    .flyout-menu__link {
      display: inline-block; padding: 4px 0; font-size: 13.5px;
      color: #374151; text-decoration: none; line-height: 1.5;
      transition: color 0.12s; position: relative; white-space: nowrap;
    }
    .flyout-menu__link::after {
      content: ''; position: absolute; bottom: 2px; left: 0;
      width: 0; height: 1px; background: #c4301c; transition: width 0.18s;
    }
    .flyout-menu__link:hover { color: #c4301c; }
    .flyout-menu__link:hover::after { width: 100%; }

    /* ── OVERLAY ── */
    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.18); z-index: 150; }
    .overlay.show { display: block; }

    /* ── PAGE CONTENT ── */
    .page-content { padding: 48px 24px; max-width: 800px; margin: 0 auto; }
    .page-content h1 { font-size: 28px; font-weight: 700; margin-bottom: 12px; }
    .page-content p { color: #6b7280; line-height: 1.7; margin-bottom: 16px; }
    .test-note {
      background: #fff; border: 1px solid #e5e7eb; border-radius: 12px;
      padding: 16px 20px; font-size: 13px; color: #374151; margin-bottom: 24px;
    }
    .test-note strong { color: #111; }
  </style>
</head>
