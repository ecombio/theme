{% comment %}
  snippets/collection-functions.liquid

  Product grid adapter. Loads CSS/JS and delegates product rendering
  to collection-products.liquid.

  Expects:
    collection  {Object} — Shopify collection object
    paginate    {Object} — paginate object opened upstream in collection.liquid

  Self-contained:
    - collection-functions.css
    - collection-functions.js

  Notes:
    - product-card.js is loaded globally in theme.liquid.
    - Do NOT load product-card.js here or in collection-products.liquid.
    - section.blocks are handled entirely by collection-features.liquid.
{% endcomment %}

{{ 'collection-functions.css' | asset_url | stylesheet_tag }}

<div class="collection-functions">
  {%- render 'collection-products',
    collection: collection,
    paginate:   paginate
  -%}
</div>

<script src="{{ 'collection-functions.js' | asset_url }}" defer></script>
