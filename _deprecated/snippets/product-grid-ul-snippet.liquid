{% comment %}
  Replace the existing <ul class="product-grid ..."> opening tag in
  main-collection-product-grid.liquid with this version.

  The only change: append  product-grid--{{ section.settings.columns_mobile }}-cols-mobile
  so the CSS rule .product-grid--1-cols-mobile can override to a single column
  when the merchant chooses "1 column" in the theme editor.
{% endcomment %}

<ul
  class="product-grid product-grid--{{ section.settings.columns_desktop }}-cols product-grid--{{ section.settings.columns_mobile }}-cols-mobile"
  id="ProductGrid"
  role="list"
>
