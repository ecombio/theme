<link rel="stylesheet" href="{{ 'product.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'product.css' | asset_url }}"></noscript>
<script src="{{ 'product.js' | asset_url }}" defer></script>

{%- render 'breadcrumbs' -%}

<div class="product-page" id="ProductSection">
  <div class="product-layout">

    <!-- Left Column -->
    <div class="product-col product-col--left">
      <div class="product-col__sticky">
        {%- render 'product-media' -%}
      </div>
      <div class="product-col__flow">
        {%- if product.description != blank -%}
          <div class="product-description">{{ product.description }}</div>
        {%- endif -%}
        {%- render 'product-specifications' -%}
        {%- render 'product-accordion' -%}
        {%- render 'product-payment-security' -%}
      </div>
    </div>

    <!-- Right Column -->
    <div class="product-col product-col--right">
      <div class="product-col__sticky">
        {%- render 'product-info' -%}
      </div>
      <div class="product-col__flow">
        {%- render 'product-recommendations' -%}
      </div>
    </div>

  </div>
</div>