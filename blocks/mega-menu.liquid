{% comment %}
  Mega Menu — Shared Block
  File: blocks/mega-menu.liquid

  Self-contained block that owns both the <li> menu bar item wrapper
  and the full mega-menu panel markup.

  Referenced in sections/header-menu.liquid as block type "mega":
    {%- when 'mega' -%}
      {%- render block -%}

  Menu structure expected in the linked linklist:
    Level 1 (top-level linklist links) → one column each
    Level 2 (children of L1)           → direct link  OR  sub-heading with L3 children
    Level 3 (children of L2)           → direct links listed under the L2 sub-heading

  Block settings (defined in {% schema %} below):
    label         — nav bar label text
    link          — optional top-level href; falls back to first menu link
    menu          — link_list handle driving the panel columns
    show_products — checkbox; renders a "Trending Now" product rail when true
    icon          — optional icon name passed to snippets/menu-icon.liquid

  Sub-blocks (block.blocks):
    promo — in-panel promo card with image, heading, subtext, and CTA button
            position setting controls placement: right | left | bottom
{% endcomment %}

{%- liquid
  assign mega_menu     = linklists[block.settings.menu]
  assign show_products = block.settings.show_products

  -%}

{%- comment -%} ── Collect promo sub-block (first one wins) ── {%- endcomment -%}
{%- assign promo_block    = blank -%}
{%- assign promo_position = blank -%}
{%- for sub in block.blocks -%}
  {%- if sub.type == 'mega-menu-promo' and promo_block == blank -%}
    {%- assign promo_block    = sub -%}
    {%- assign promo_position = sub.settings.position | default: 'right' -%}
  {%- endif -%}
{%- endfor -%}

<li class="menu-bar__item menu-bar__item--has-mega" {{ block.shopify_attributes }}>

  {%- comment -%} ── Trigger link (nav bar label) ── {%- endcomment -%}
  <a href="{{ block.settings.link | default: mega_menu.links.first.url | default: '#' }}"
     class="menu-bar__link menu-bar__link--caret"
     aria-haspopup="true"
     aria-expanded="false">
    {%- if block.settings.icon != blank -%}
      <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
    {%- endif -%}
    {{ block.settings.label | default: mega_menu.title | default: 'Menu' }}
    <svg class="icon-caret-down" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M16.25 7.5L10 13.75L3.75 7.5"
            stroke="currentColor" stroke-width="1.5"
            stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>

  {%- comment -%} ── Mega panel ── {%- endcomment -%}
  {%- if mega_menu != blank and mega_menu.links.size > 0 -%}

    {%- comment -%} Cap columns at 6 for the CSS grid variable {%- endcomment -%}
    {%- assign col_count = mega_menu.links.size -%}
    {%- if col_count > 6 -%}{%- assign col_count = 6 -%}{%- endif -%}

    {%- comment -%}
      Resolve a collection for the trending-products rail from the
      first top-level link, when it points at a collection.
    {%- endcomment -%}
    {%- assign featured_collection = blank -%}
    {%- if show_products -%}
      {%- assign first_link = mega_menu.links.first -%}
      {%- if first_link.type == 'collection_link' or first_link.object -%}
        {%- assign featured_collection = first_link.object -%}
      {%- endif -%}
    {%- endif -%}

    {%- comment -%}
      Build modifier classes for mega-menu-items:
        mega-menu-items--with-products   — trending rail present
        mega-menu-items--promo-right     — promo slot on the right
        mega-menu-items--promo-left      — promo slot on the left
        mega-menu-items--promo-bottom    — promo spans below columns
    {%- endcomment -%}
    {%- capture items_classes -%}
      mega-menu-items
      {%- if show_products and featured_collection %} mega-menu-items--with-products{%- endif -%}
      {%- if promo_block != blank %} mega-menu-items--promo-{{ promo_position }}{%- endif -%}
    {%- endcapture -%}

    <div class="mega-menu" role="region">
      <div class="{{ items_classes | strip }}">

        {%- comment -%} ── Left-position promo (rendered before columns) ── {%- endcomment -%}
        {%- if promo_block != blank and promo_position == 'left' -%}
          {%- render promo_block -%}
        {%- endif -%}

        {%- comment -%} ── Column grid ── {%- endcomment -%}
        <div class="mega-menu__text-columns" style="--mega-col-count: {{ col_count }};">
          {%- for column in mega_menu.links -%}
            <div class="mega-menu-column">

              {%- comment -%} L1 — column heading {%- endcomment -%}
              <a href="{{ column.url }}" class="mega-menu-heading">{{ column.title }}</a>

              {%- for item in column.links -%}

                {%- if item.links.size > 0 -%}
                  {%- comment -%} L2 with children — sub-heading + L3 list {%- endcomment -%}
                  <div class="mega-menu-subheading">{{ item.title }}</div>
                  <ul class="mega-menu-list">
                    {%- for link in item.links -%}
                      <li>
                        <a href="{{ link.url }}" class="mega-menu-link">{{ link.title }}</a>
                      </li>
                    {%- endfor -%}
                  </ul>

                {%- else -%}
                  {%- comment -%} L2 direct link {%- endcomment -%}
                  <ul class="mega-menu-list">
                    <li>
                      <a href="{{ item.url }}" class="mega-menu-link">{{ item.title }}</a>
                    </li>
                  </ul>
                {%- endif -%}

              {%- endfor -%}

            </div>
          {%- endfor -%}
        </div>

        {%- comment -%} ── Right-position promo (rendered after columns) ── {%- endcomment -%}
        {%- if promo_block != blank and promo_position == 'right' -%}
          {%- render promo_block -%}
        {%- endif -%}

        {%- comment -%} ── Optional trending-products rail ── {%- endcomment -%}
        {%- if show_products and featured_collection and featured_collection.products.size > 0 -%}
          <div class="mega-menu__products">
            <div class="mega-menu__product-header">
              <span class="mega-menu-heading">Trending Now</span>
            </div>
            <div class="mega-menu__product-grid">
              {%- for product in featured_collection.products limit: 3 -%}
                <a href="{{ product.url }}" class="mega-menu__product-card">
                  <div class="mega-menu__product-image">
                    {%- if product.featured_media -%}
                      {{
                        product.featured_media
                        | image_url: width: 240
                        | image_tag: loading: 'lazy', alt: product.title
                      }}
                    {%- endif -%}
                    {%- if product.compare_at_price > product.price -%}
                      <span class="mega-menu__badge">Sale</span>
                    {%- endif -%}
                  </div>
                  <div class="mega-menu__product-info">
                    <p class="mega-menu__product-title">{{ product.title }}</p>
                    <div class="mega-menu__product-price">
                      {%- if product.compare_at_price > product.price -%}
                        <span class="price--sale">{{ product.price | money }}</span>
                        <span class="price--compare">{{ product.compare_at_price | money }}</span>
                      {%- else -%}
                        {{ product.price | money }}
                      {%- endif -%}
                    </div>
                  </div>
                </a>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} ── Bottom-position promo (spans full width below columns) ── {%- endcomment -%}
        {%- if promo_block != blank and promo_position == 'bottom' -%}
          {%- render promo_block -%}
        {%- endif -%}

      </div>
    </div>

  {%- endif -%}

</li>

{% schema %}
{
  "name": "Mega menu",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Top-level URL",
      "info": "Optional. Falls back to the first link in the selected menu."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Mega menu",
      "info": "Top-level links become columns. Their children become rows or sub-headings."
    },
    {
      "type": "checkbox",
      "id": "show_products",
      "label": "Show 'Trending Now' product rail",
      "default": true,
      "info": "Pulls up to 3 products from the collection linked by the first menu item."
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Icon name",
      "info": "Optional. Rendered via snippets/menu-icon.liquid."
    }
  ],
  "blocks": [
    {
      "type": "mega-menu-promo"
    }
  ],
  "presets": [
    {
      "name": "Mega menu"
    }
  ]
}
{% endschema %}