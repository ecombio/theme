{% comment %}
  ECOMBIO Header — Single Link Block
  File: blocks/single.liquid
{% endcomment %}

<li class="menu-bar__item" {{ block.shopify_attributes }}>
  <a href="{{ block.settings.link | default: '#' }}" class="menu-bar__link">
    {%- if block.settings.icon != blank -%}
      <span class="menu-bar__icon">{%- render 'menu-icon', icon: block.settings.icon -%}</span>
    {%- endif -%}
    {{ block.settings.label | default: 'Link' }}
  </a>
</li>

{% schema %}
{
  "name": "Link",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "link",
      "label": "URL"
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Icon name",
      "info": "Optional. Rendered via snippets/menu-icon.liquid."
    }
  ]
}
{% endschema %}