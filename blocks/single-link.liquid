{% comment %}
  ============================================================
  BLOCK: single-link.liquid
  ============================================================
  A reusable single navigation link block.
  This file is the single source of truth for this block type.
{% endcomment %}

{# === OUTPUT === #}
<li class="menu-bar__item" {{ block.shopify_attributes }}>
  {% render 'menu-item', 
      type: 'link',
      title: block.settings.label,
      url: block.settings.link,
      icon_type: block.settings.icon %}
</li>

{# === SCHEMA (Settings) === #}
{% schema %}
{
  "name": "Single Link",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Link"
    },
    {
      "type": "url",
      "id": "link",
      "label": "URL"
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Icon name",
      "info": "Optional. Uses snippets/menu-icon.liquid"
    }
  ]
}
{% endschema %}